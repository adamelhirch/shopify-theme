{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign display_limit = section.settings.reviews_limit | plus: 0
  assign jdgm_reviews_count = shop.metafields.judgeme.all_reviews_count | default: section.blocks.size
  assign jdgm_reviews_rating = shop.metafields.judgeme.all_reviews_rating | default: 5
  assign has_judgeme_data = false
  assign featured_rating = 5
  assign featured_source_label = 'Avis verifie'
  assign featured_quote = blank
  assign featured_author = blank
  assign featured_date = blank
  assign featured_product = blank
  assign featured_product_link = blank
  assign featured_product_object = blank
  assign featured_product_handle = blank
  assign featured_product_media = blank
  assign featured_product_url = blank

  if section.blocks.size > 0
    assign featured_block = section.blocks.first
    assign featured_rating = featured_block.settings.rating | default: 5
    assign featured_quote = featured_block.settings.quote | default: blank
    assign featured_author = featured_block.settings.author | default: blank
    assign featured_date = featured_block.settings.location | default: blank
    assign featured_product = featured_block.settings.meta | default: blank
    assign featured_product_link = featured_block.settings.product_link | default: blank

    if featured_block.settings.product != blank
      assign featured_product_object = all_products[featured_block.settings.product]
    elsif featured_product_link != blank
      assign featured_product_href = featured_product_link | append: ''

      if featured_product_href contains '/products/'
        assign featured_product_handle = featured_product_href | split: '/products/' | last | split: '?' | first | split: '#' | first
      elsif featured_product_href contains 'shopify://products/'
        assign featured_product_handle = featured_product_href | split: 'shopify://products/' | last
      endif

      if featured_product_handle != blank
        assign featured_product_object = all_products[featured_product_handle]
      endif
    endif

    if featured_product_object != blank
      assign featured_product_media = featured_product_object.featured_media.preview_image | default: featured_product_object.featured_image
      assign featured_product_url = featured_product_object.url

      if featured_product == blank
        assign featured_product = featured_product_object.title
      endif
    else
      assign featured_product_url = featured_product_link
    endif
  endif

  if shop.metafields.judgeme.featured_carousel != blank or shop.metafields.judgeme.all_reviews_count != blank
    assign has_judgeme_data = true
  endif
-%}

<section
  class="section-{{ section.id }}-padding vd-testimonials color-{{ section.settings.color_scheme }}"
  data-vd-testimonials-section
  data-vd-testimonials-limit="{{ section.settings.reviews_limit }}"
>
  <div class="page-width vd-testimonials__featured-shell" data-vd-testimonials-featured-shell>
    <article class="vd-testimonials__featured" data-vd-testimonials-featured>
      <div class="vd-testimonials__featured-topline">
        {% render 'vd-review-verified-badge', label: featured_source_label %}
        <div class="vd-testimonials__featured-stars-wrap">
          <span class="vd-testimonials__featured-source" data-vd-testimonials-featured-source>{{ featured_source_label }}</span>
          <div class="vd-testimonials__featured-stars" data-vd-testimonials-featured-stars aria-hidden="true">
            {% for i in (1..5) %}
              <span class="{% if i <= featured_rating %}is-active{% endif %}">&#9733;</span>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="vd-testimonials__featured-main">
        <div class="vd-testimonials__featured-copy">
          <blockquote class="vd-testimonials__featured-quote" data-vd-testimonials-featured-quote>{{ featured_quote }}</blockquote>

          <div class="vd-testimonials__featured-footer">
            <div class="vd-testimonials__featured-product-wrap" data-vd-testimonials-featured-product-wrap {% if featured_product == blank %}hidden{% endif %}>
              <a
                {% if featured_product_url != blank %}
                  href="{{ featured_product_url }}"
                {% elsif featured_product_link != blank %}
                  href="{{ featured_product_link }}"
                {% else %}
                  href="#"
                {% endif %}
                class="vd-testimonials__featured-product-link"
                data-vd-testimonials-featured-product
              >{{ featured_product }}</a>
            </div>

            <div class="vd-testimonials__featured-meta">
              <strong data-vd-testimonials-featured-author>{{ featured_author }}</strong>
              <span data-vd-testimonials-featured-date>{{ featured_date }}</span>
            </div>

            {% if section.settings.button_label != blank %}
              <a
                href="{{ section.settings.button_link | default: '#' }}"
                class="vd-arrow-cta vd-testimonials__cta"
                data-vd-testimonials-cta
                {% if section.settings.button_link != blank %}
                  data-vd-testimonials-static-link="true"
                {% endif %}
              >
                <span class="vd-arrow-cta__label">{{ section.settings.button_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>

        <div
          class="vd-testimonials__featured-media-panel"
          data-vd-testimonials-featured-media-panel
          {% if featured_product_media == blank %}hidden{% endif %}
        >
          <div class="vd-testimonials__featured-media-card">
            <a
              class="vd-testimonials__featured-media-link"
              data-vd-testimonials-featured-media-link
              {% if featured_product_url != blank %}
                href="{{ featured_product_url }}"
              {% elsif featured_product_link != blank %}
                href="{{ featured_product_link }}"
              {% endif %}
            >
              {% if featured_product_media != blank %}
                {{
                  featured_product_media
                  | image_url: width: 1600
                  | image_tag:
                    class: 'vd-testimonials__featured-image',
                    data-vd-testimonials-featured-image: '',
                    widths: '480, 720, 960, 1280, 1600',
                    sizes: '(min-width: 990px) 28vw, 92vw',
                    loading: 'lazy',
                    alt: featured_product_media.alt | default: featured_product | escape
                }}
              {% endif %}
            </a>

            <div class="vd-testimonials__featured-media-caption">
              {% render 'vd-review-verified-badge', label: 'Verifie', compact: true %}
              <span class="vd-testimonials__featured-media-product" data-vd-testimonials-featured-media-product>{{ featured_product }}</span>
            </div>
          </div>
        </div>
      </div>
    </article>
  </div>

  <div class="page-width vd-testimonials__stage" data-vd-testimonials-stage>
    <div class="vd-testimonials__viewport" data-vd-testimonials-viewport>
      <ul class="vd-testimonials__cards" data-vd-testimonials-cards role="list">
        {% for block in section.blocks limit: display_limit %}
          {% assign rating = block.settings.rating | default: 5 %}
          {%- liquid
            assign testimonial_product = blank
            assign testimonial_product_handle = blank
            assign testimonial_product_url = block.settings.product_link
            assign testimonial_product_media = blank
            assign testimonial_product_label = block.settings.meta
            assign testimonial_product_alt = block.settings.meta

            if block.settings.product != blank
              assign testimonial_product = all_products[block.settings.product]
            elsif block.settings.product_link != blank
              assign testimonial_product_href = block.settings.product_link | append: ''

              if testimonial_product_href contains '/products/'
                assign testimonial_product_handle = testimonial_product_href | split: '/products/' | last | split: '?' | first | split: '#' | first
              elsif testimonial_product_href contains 'shopify://products/'
                assign testimonial_product_handle = testimonial_product_href | split: 'shopify://products/' | last
              endif

              if testimonial_product_handle != blank
                assign testimonial_product = all_products[testimonial_product_handle]
              endif
            endif

            if testimonial_product != blank
              assign testimonial_product_url = testimonial_product.url
              assign testimonial_product_media = testimonial_product.featured_media.preview_image | default: testimonial_product.featured_image
              assign testimonial_product_label = testimonial_product.title | default: testimonial_product_label
              assign testimonial_product_alt = testimonial_product_media.alt | default: testimonial_product.title
            endif
          -%}
          <li
            class="vd-testimonials__card"
            data-vd-testimonial-card
            role="listitem"
            {% if testimonial_product_url != blank %}
              data-vd-testimonial-link="{{ testimonial_product_url }}"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            <article
              class="vd-testimonials__card-shell"
              data-vd-testimonial-shell
              tabindex="0"
              data-vd-testimonial-rating="{{ rating }}"
              data-vd-testimonial-author="{{ block.settings.author | escape }}"
              data-vd-testimonial-date="{{ block.settings.location | escape }}"
              data-vd-testimonial-product="{{ testimonial_product_label | escape }}"
              data-vd-testimonial-quote="{{ block.settings.quote | strip_html | escape }}"
              data-vd-testimonial-source-label="Avis verifie"
              data-vd-testimonial-verified="true"
              {% if testimonial_product_url != blank %}
                data-vd-testimonial-product-url="{{ testimonial_product_url }}"
              {% endif %}
              {% if testimonial_product_media != blank %}
                data-vd-testimonial-image="{{ testimonial_product_media | image_url: width: 1600 }}"
                data-vd-testimonial-image-alt="{{ testimonial_product_alt | escape }}"
              {% endif %}
            >
              <div class="vd-testimonials__card-media-wrap">
                {% if testimonial_product_media != blank %}
                  <a class="vd-testimonials__card-media-link" href="{{ testimonial_product_url | default: '#' }}">
                    {{
                      testimonial_product_media
                      | image_url: width: 900
                      | image_tag:
                        class: 'vd-testimonials__card-image',
                        widths: '320, 480, 640, 900',
                        sizes: '(min-width: 990px) 22vw, 92vw',
                        loading: 'lazy',
                        alt: testimonial_product_alt | escape
                    }}
                  </a>
                {% else %}
                  <div class="vd-testimonials__card-media-fallback" aria-hidden="true">
                    <span>{{ testimonial_product_label | default: block.settings.author | slice: 0 }}</span>
                  </div>
                {% endif %}
              </div>

              <div class="vd-testimonials__card-body">
                <div class="vd-testimonials__card-topline">
                  {% render 'vd-review-verified-badge', label: 'Verifie', compact: true %}
                  <div class="vd-testimonials__stars" aria-hidden="true">
                    {% for i in (1..5) %}
                      <span class="{% if i <= rating %}is-active{% endif %}">&#9733;</span>
                    {% endfor %}
                  </div>
                </div>

                {% if testimonial_product_label != blank %}
                  <div class="vd-testimonials__card-top">
                    {% if testimonial_product_url != blank %}
                      <a href="{{ testimonial_product_url }}" class="vd-testimonials__product-link">
                        {{ testimonial_product_label }}
                      </a>
                    {% else %}
                      <span class="vd-testimonials__product-link">{{ testimonial_product_label }}</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.quote != blank %}
                  <blockquote class="vd-testimonials__quote" data-vd-testimonial-quote>{{ block.settings.quote }}</blockquote>
                {% endif %}

                <div class="vd-testimonials__meta">
                  {% if block.settings.author != blank %}
                    <strong>{{ block.settings.author }}</strong>
                  {% endif %}

                  {% if block.settings.location != blank %}
                    <span>{{ block.settings.location }}</span>
                  {% endif %}
                </div>
              </div>
            </article>
          </li>
        {% endfor %}
      </ul>

      <div class="vd-testimonials__judge-source" data-vd-testimonials-judge-source aria-hidden="true">
        {% if shop.metafields.judgeme.featured_carousel != blank %}
          {{ shop.metafields.judgeme.featured_carousel }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Testimonials",
  "tag": "section",
  "class": "section section-vd-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Avis clients"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Avis clients verifies"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Quelques retours clients sur les produits les plus commandes, avec un rendu plus sobre et plus precis.</p>"
    },
    {
      "type": "select",
      "id": "reviews_limit",
      "label": "Nombre d'avis",
      "default": "10",
      "options": [
        {
          "value": "8",
          "label": "8"
        },
        {
          "value": "10",
          "label": "10"
        },
        {
          "value": "12",
          "label": "12"
        }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libelle bouton",
      "default": "Voir tous les avis"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Apercu avis",
      "limit": 12,
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Note",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Citation",
          "default": "\"Une longueur, une souplesse et une profondeur rares. On sent tout de suite que la selection est serieuse.\""
        },
        {
          "type": "text",
          "id": "author",
          "label": "Auteur",
          "default": "Jean-Marc L."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Date ou contexte",
          "default": "Chef patissier, Lyon"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Nom produit",
          "default": "Bourbon Gourmet"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Produit associe"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Lien produit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "\"Les gousses sont charnues, souples, brillantes. Meme avant l'infusion, on voit la difference.\"",
            "author": "Elise B.",
            "location": "Passionnee de gastronomie",
            "meta": "Gousses noires"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "\"Le produit suit le discours. C'est net, precis, sans promesse en trop.\"",
            "author": "Thomas V.",
            "location": "Collectionneur d'epices",
            "meta": "Extrait premium"
          }
        }
      ]
    }
  ]
}
{% endschema %}
