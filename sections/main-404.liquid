        url: {{ pages['wiki-sels-melanges'].url | default: '/pages/wiki-sels-melanges' | json }},
        label: 'Sels & mélanges'
      }
    };

    var currentPath = window.location.pathname;
    var redirect = redirects[currentPath];
    if (!redirect) return;

    var copy = document.querySelector('[data-vd-404-copy]');
    var primaryLink = document.querySelector('[data-vd-404-primary]');
    var primaryLabel = document.querySelector('[data-vd-404-primary-label]');
    var target = new URL(redirect.url, window.location.origin);
    var previewThemeId = new URLSearchParams(window.location.search).get('preview_theme_id');

    if (previewThemeId && !target.searchParams.get('preview_theme_id')) {
      target.searchParams.set('preview_theme_id', previewThemeId);
    }

    if (copy) {
      copy.textContent =
        'Cette ancienne entree du wiki a ete regroupee. Vous etes redirige vers ' +
        redirect.label +
        ' pour retrouver un contenu utile et un maillage propre.';
    }

    if (primaryLink) {
      primaryLink.href = target.pathname + target.search + target.hash;
    }

    if (primaryLabel) {
      primaryLabel.textContent = 'Ouvrir ' + redirect.label;
    }

    window.location.replace(target.pathname + target.search + target.hash);
  })();
</script>
