{{ 'vd-savoir-faire-detail.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="vd-sf" aria-labelledby="VdSfTitle">
  {%- comment -%} ── Hero ── {%- endcomment -%}
  <header class="page-width vd-sf__hero">
    {%- if section.settings.heading != blank -%}
      <h1 id="VdSfTitle" class="vd-sf__title vd-sf-reveal">
        {{ section.settings.heading }}{%- if section.settings.heading_accent != blank -%} <span class="vd-sf__title-accent">{{ section.settings.heading_accent }}</span>{%- endif -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.lede != blank -%}
      <div class="vd-sf__lede rte vd-sf-reveal" style="--vd-sf-delay: 120ms;">{{ section.settings.lede }}</div>
    {%- endif -%}
  </header>

  {%- comment -%} ── Callout : Lots tracés ── {%- endcomment -%}
  {%- if section.settings.callout_title != blank or section.settings.callout_text != blank -%}
    <div class="page-width vd-sf__callout vd-sf-reveal">
      <div class="vd-sf__callout-inner">
        {%- if section.settings.callout_kicker != blank -%}
          <span class="vd-sf__callout-kicker">{{ section.settings.callout_kicker }}</span>
        {%- endif -%}
        {%- if section.settings.callout_title != blank -%}
          <h2 class="vd-sf__callout-title">{{ section.settings.callout_title }}</h2>
        {%- endif -%}
        {%- if section.settings.callout_text != blank -%}
          <p class="vd-sf__callout-text">{{ section.settings.callout_text }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Méthode (alternating rows) ── {%- endcomment -%}
  {%- assign has_steps = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'step' -%}{%- assign has_steps = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- if has_steps -%}
    {%- if section.settings.method_heading != blank -%}
      <header class="page-width vd-sf__chapter-head vd-sf-reveal">
        {%- if section.settings.method_kicker != blank -%}
          <span class="vd-sf__chapter-kicker">{{ section.settings.method_kicker }}</span>
        {%- endif -%}
        <h2 class="vd-sf__chapter-title">{{ section.settings.method_heading }}</h2>
      </header>
    {%- endif -%}

    {%- assign step_counter = 0 -%}
    <div class="vd-sf__chapters">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_counter = step_counter | plus: 1 -%}
          {%- assign num = block.settings.step_number | default: step_counter -%}
          {%- if num < 10 -%}{%- assign num = num | prepend: '0' -%}{%- endif -%}
          {%- assign is_reverse = forloop.index0 | modulo: 2 -%}

          <article
            class="vd-sf__row{% if is_reverse == 1 %} vd-sf__row--reverse{% endif %} vd-sf-reveal"
            {{ block.shopify_attributes }}
          >
            <div class="page-width vd-sf__row-inner">
              <figure class="vd-sf__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'vd-sf__img',
                      widths: '400, 600, 800, 1000, 1200',
                      sizes: '(min-width: 990px) 42vw, 90vw',
                      loading: 'lazy',
                      alt: block.settings.image.alt | default: block.settings.title
                  }}
                {%- else -%}
                  {%- assign placeholder_names = 'lifestyle-1,lifestyle-2,collection-1,collection-2,product-1,product-apparel-3' | split: ',' -%}
                  {%- assign placeholder_idx = forloop.index0 | modulo: placeholder_names.size -%}
                  {%- assign placeholder_name = placeholder_names[placeholder_idx] -%}
                  <div class="vd-sf__img vd-sf__img--placeholder" aria-hidden="true">
                    {{ placeholder_name | placeholder_svg_tag: 'vd-sf__img-svg' }}
                  </div>
                {%- endif -%}
                <span class="vd-sf__num" aria-hidden="true">{{ num }}</span>
              </figure>

              <div class="vd-sf__copy">
                <h3 class="vd-sf__h2">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <div class="vd-sf__text rte">{{ block.settings.description }}</div>
                {%- endif -%}
              </div>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Values strip (engagements) ── {%- endcomment -%}
  {%- assign has_values = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'value' -%}{%- assign has_values = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- if has_values or section.settings.values_heading != blank -%}
    <div class="vd-sf__values vd-sf-reveal">
      <div class="page-width vd-sf__values-inner">
        {%- if section.settings.values_kicker != blank or section.settings.values_heading != blank -%}
          <header class="vd-sf__values-head">
            {%- if section.settings.values_kicker != blank -%}
              <span class="vd-sf__values-kicker">{{ section.settings.values_kicker }}</span>
            {%- endif -%}
            {%- if section.settings.values_heading != blank -%}
              <h2 class="vd-sf__values-title">{{ section.settings.values_heading }}</h2>
            {%- endif -%}
          </header>
        {%- endif -%}
        {%- if has_values -%}
          <ul class="vd-sf__values-grid" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'value' -%}
                <li class="vd-sf__value" {{ block.shopify_attributes }}>
                  {%- if block.settings.kicker != blank -%}
                    <span class="vd-sf__value-kicker">{{ block.settings.kicker }}</span>
                  {%- endif -%}
                  <h3 class="vd-sf__value-title">{{ block.settings.title }}</h3>
                  {%- if block.settings.text != blank -%}
                    <p class="vd-sf__value-text">{{ block.settings.text }}</p>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── CTA final (optionnel) ── {%- endcomment -%}
  {%- if section.settings.cta_heading != blank or section.settings.cta_label != blank -%}
    <div class="vd-sf__cta vd-sf-reveal">
      <div class="page-width vd-sf__cta-inner">
        {%- if section.settings.cta_heading != blank -%}
          <h2 class="vd-sf__cta-title">{{ section.settings.cta_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <p class="vd-sf__cta-text">{{ section.settings.cta_text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="vd-sf__cta-btn">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.vd-sf-reveal').forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.vd-sf-reveal').forEach(function (el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "VD Savoir-faire détaillé",
  "tag": "section",
  "class": "section section-vd-sf",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Un savoir-faire artisanal, une chaîne courte," },
    { "type": "text", "id": "heading_accent", "label": "Accent (italique)", "default": "un goût vrai." },
    { "type": "richtext", "id": "lede", "label": "Texte court", "default": "<p>Sélection directe auprès de familles productrices, contrôle à l'arrivée, mise en pot propre en France. Simple, net, reproductible.</p>" },

    { "type": "header", "content": "Bloc info (callout)" },
    { "type": "text", "id": "callout_kicker", "label": "Sur-titre", "default": "Lots tracés" },
    { "type": "text", "id": "callout_title", "label": "Titre", "default": "Chaque lot a sa carte d'identité." },
    { "type": "text", "id": "callout_text", "label": "Texte", "default": "Origine, séchage, taux d'humidité : tout est consigné." },

    { "type": "header", "content": "Méthode (alternance rows)" },
    { "type": "text", "id": "method_kicker", "label": "Sur-titre", "default": "Notre méthode" },
    { "type": "text", "id": "method_heading", "label": "Titre", "default": "En 3 gestes." },

    { "type": "header", "content": "Engagements" },
    { "type": "text", "id": "values_kicker", "label": "Sur-titre", "default": "Engagements" },
    { "type": "text", "id": "values_heading", "label": "Titre", "default": "Simples & mesurables." },

    { "type": "header", "content": "Appel à l'action (optionnel)" },
    { "type": "text", "id": "cta_heading", "label": "Titre" },
    { "type": "textarea", "id": "cta_text", "label": "Texte" },
    { "type": "text", "id": "cta_label", "label": "Libellé bouton" },
    { "type": "url", "id": "cta_link", "label": "Lien bouton" },

    { "type": "header", "content": "Espacement" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Marge haute", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Marge basse", "default": 0 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Geste de méthode",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "step_number", "label": "Numéro (laisser vide pour auto)" },
        { "type": "text", "id": "title", "label": "Titre", "default": "RÉCOLTE & AFFINAGE" },
        { "type": "richtext", "id": "description", "label": "Texte", "default": "<p>Récoltes au bon stade puis séchage soigné (soleil/ombre), affinage patient.</p>" },
        { "type": "image_picker", "id": "image", "label": "Image (portrait)" }
      ]
    },
    {
      "type": "value",
      "name": "Engagement (pilier)",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "kicker", "label": "Sur-titre (catégorie)", "default": "Traçabilité" },
        { "type": "text", "id": "title", "label": "Titre court", "default": "Chaque lot se suit" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Origine, méthode, humidité — un QR interne pour tout retrouver." }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Savoir-faire détaillé",
      "blocks": [
        { "type": "step", "settings": { "step_number": "01", "title": "RÉCOLTE & AFFINAGE", "description": "<p>Récoltes au bon stade puis séchage soigné (soleil/ombre), affinage patient. Le temps fait le profil aromatique.</p>" } },
        { "type": "step", "settings": { "step_number": "02", "title": "TRI & CONTRÔLE", "description": "<p>Calibrage, examen visuel et organoleptique. Les lots irréguliers ne passent pas. La cohérence d'un lot à l'autre est notre exigence.</p>" } },
        { "type": "step", "settings": { "step_number": "03", "title": "MISE EN POT CLAIRE", "description": "<p>Conditionnement propre, étiquette lisible, lot et DLC. Rien à cacher : la matière et la méthode parlent d'elles-mêmes.</p>" } },
        { "type": "value", "settings": { "kicker": "Traçabilité", "title": "Chaque lot se suit", "text": "Origine, méthode, humidité — un QR interne pour tout retrouver." } },
        { "type": "value", "settings": { "kicker": "Qualité", "title": "Contrôles reproductibles", "text": "Même exigence à chaque réception : cohérence des profils et du taux d'humidité." } },
        { "type": "value", "settings": { "kicker": "Sobriété", "title": "Pas de surpromesse", "text": "On montre la matière et la méthode. Le reste, c'est dans l'assiette." } }
      ]
    }
  ]
}
{% endschema %}
