<section class="vd-section vd-section--tight">
  <div class="vd-coll-grid vd-reveal">
    {%- for block in section.blocks -%}
      {%- liquid
        assign coll = collections[block.settings.collection]
        assign image = block.settings.image
        if image == blank and coll != blank
          assign image = coll.image | default: coll.products.first.featured_image
        endif
      -%}
      <a href="{{ block.settings.link | default: coll.url | default: '#' }}" class="vd-coll-tile" {{ block.shopify_attributes }}>
        {%- if image != blank -%}
          <img src="{{ image | image_url: width: 800 }}" srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 1000 }} 1000w" sizes="(min-width: 1100px) 33vw, 100vw" alt="{{ block.settings.title | escape }}" loading="lazy" width="800" height="1000">
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1606312619070-d48b4c652a52?w=800&auto=format&fit=crop" alt="placeholder" loading="lazy" width="800" height="1000">
        {%- endif -%}
        <div class="vd-coll-tile__label">
          <div class="vd-coll-tile__title">{{ block.settings.title }}</div>
          <span class="vd-coll-tile__cta">{{ block.settings.cta | default: 'Découvrir' }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille collections",
  "tag": "section",
  "max_blocks": 9,
  "settings": [],
  "blocks": [
    {
      "type": "tile",
      "name": "Tuile collection",
      "settings": [
        { "type": "text", "id": "title", "label": "Titre", "default": "Découvrez nos vanilles" },
        { "type": "collection", "id": "collection", "label": "Collection (optionnelle)" },
        { "type": "image_picker", "id": "image", "label": "Image (sinon image collection)" },
        { "type": "url", "id": "link", "label": "Lien (sinon URL collection)" },
        { "type": "text", "id": "cta", "label": "Libellé CTA", "default": "Découvrir" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grille collections",
      "category": "Accueil",
      "blocks": [
        { "type": "tile", "settings": { "title": "Découvrez nos vanilles" } },
        { "type": "tile", "settings": { "title": "Découvrez nos épices" } },
        { "type": "tile", "settings": { "title": "Découvrez nos sels & poivres" } },
        { "type": "tile", "settings": { "title": "Découvrez nos coffrets" } },
        { "type": "tile", "settings": { "title": "Huiles essentielles" } },
        { "type": "tile", "settings": { "title": "Espace Pro" } }
      ]
    }
  ]
}
{% endschema %}
