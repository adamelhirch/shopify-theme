{{ 'customer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vd-customer-carnet.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account section-{{ section.id }}-padding">
  {%- assign latest_order = customer.orders.first -%}
  {%- assign favorites_metafield = customer.metafields.vd.recipe_favorites -%}
  {%- assign favorites_metafield_value = favorites_metafield.value | default: favorites_metafield -%}
  {%- assign history_metafield = customer.metafields.vd.recipe_history -%}
  {%- assign history_metafield_value = history_metafield.value | default: history_metafield -%}
  <div class="vd-customer-shell">
    <div class="vd-customer-shell__header">
      <div>
        <p class="vd-customer-shell__eyebrow">Espace client</p>
        <h1 class="customer__title">{{ 'customer.account.title' | t }}</h1>
        <p class="vd-customer-shell__lede">
          Une lecture plus directe pour suivre les commandes, les statuts et les adresses sans passer par des écrans neutres.
        </p>
      </div>
      <div class="vd-customer-shell__links">
        <a href="{{ routes.account_addresses_url }}" class="button button--secondary">
          {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
        </a>
        <a href="{{ routes.account_logout_url }}" class="vd-customer-shell__text-link">
          <span class="svg-wrapper">
            {{- 'icon-account.svg' | inline_asset_content -}}
          </span>
          {{ 'customer.log_out' | t }}
        </a>
      </div>
    </div>

    <div class="vd-customer-shell__metrics" role="list">
      <div class="vd-customer-shell__metric" role="listitem">
        <span class="vd-customer-shell__metric-label">Commandes</span>
        <strong>{{ customer.orders_count }}</strong>
      </div>
      <div class="vd-customer-shell__metric" role="listitem">
        <span class="vd-customer-shell__metric-label">Adresses</span>
        <strong>{{ customer.addresses_count }}</strong>
      </div>
      <div class="vd-customer-shell__metric" role="listitem">
        <span class="vd-customer-shell__metric-label">Dernière commande</span>
        <strong>{% if latest_order %}{{ latest_order.name }}{% else %}Aucune{% endif %}</strong>
      </div>
    </div>

    <div class="vd-customer-dashboard">
      <div
        class="vd-customer-card vd-customer-card--wide"
        data-vd-customer-carnet
        data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
        data-customer-id="{{ customer.id }}"
        data-customer-email="{{ customer.email | escape }}"
        data-customer-shelf-endpoint="{{ section.settings.customer_shelf_endpoint | escape }}"
      >
        <div class="vd-customer-card__head">
          <p class="vd-customer-card__kicker">Carnet recette</p>
          <h2>Vos recettes sauvegardées dans le compte Shopify</h2>
          <p>Le compte peut maintenant porter un vrai carnet persistant pour vos favoris et vos reprises de recettes.</p>
        </div>
        <div class="vd-customer-carnet__grid">
          <section class="vd-customer-carnet__panel" data-vd-customer-favorites-panel hidden>
            <div class="vd-customer-carnet__panel-head">
              <strong>Favoris</strong>
              <span data-vd-customer-favorites-count>0</span>
            </div>
            <div class="vd-customer-carnet__cards" data-vd-customer-favorites-track></div>
          </section>
          <section class="vd-customer-carnet__panel" data-vd-customer-history-panel hidden>
            <div class="vd-customer-carnet__panel-head">
              <strong>Reprendre</strong>
              <span data-vd-customer-history-count>0</span>
            </div>
            <div class="vd-customer-carnet__cards" data-vd-customer-history-track></div>
          </section>
        </div>
        <div class="vd-customer-carnet__empty" data-vd-customer-carnet-empty>
          Le carnet persistant est encore vide.
        </div>
        <script type="application/json" data-vd-customer-favorites>
          {{ favorites_metafield_value | json }}
        </script>
        <script type="application/json" data-vd-customer-history>
          {{ history_metafield_value | json }}
        </script>
      </div>

      <div class="vd-customer-card vd-customer-card--wide">
        <div class="vd-customer-card__head">
          <p class="vd-customer-card__kicker">{{ 'customer.orders.title' | t }}</p>
          <h2>Historique des commandes</h2>
        </div>

      {% paginate customer.orders by 20 %}
        {%- if customer.orders.size > 0 -%}
          <table role="table" class="order-history">
            <caption class="visually-hidden">
              {{ 'customer.orders.title' | t }}
            </caption>
            <thead role="rowgroup">
              <tr role="row">
                <th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
                <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
                <th id="ColumnPayment" scope="col" role="columnheader">{{ 'customer.orders.payment_status' | t }}</th>
                <th id="ColumnFulfillment" scope="col" role="columnheader">
                  {{ 'customer.orders.fulfillment_status' | t }}
                </th>
                <th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th>
              </tr>
            </thead>
            <tbody role="rowgroup">
              {%- for order in customer.orders -%}
                <tr role="row">
                  <td
                    id="RowOrder"
                    role="cell"
                    headers="ColumnOrder"
                    data-label="{{ 'customer.orders.order_number' | t }}"
                  >
                    <a
                      href="{{ order.customer_url }}"
                      aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                    >
                      {{ order.name }}
                    </a>
                  </td>
                  <td headers="RowOrder ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t }}">
                    {{ order.created_at | time_tag: format: 'date' }}
                  </td>
                  <td
                    headers="RowOrder ColumnPayment"
                    role="cell"
                    data-label="{{ 'customer.orders.payment_status' | t }}"
                  >
                    {{ order.financial_status_label }}
                  </td>
                  <td
                    headers="RowOrder ColumnFulfillment"
                    role="cell"
                    data-label="{{ 'customer.orders.fulfillment_status' | t }}"
                  >
                    {{ order.fulfillment_status_label }}
                  </td>
                  <td headers="RowOrder ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t }}">
                    {{ order.total_net_amount | money_with_currency }}
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- else -%}
          <p>{{ 'customer.orders.none' | t }}</p>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          {%- if paginate.parts.size > 0 -%}
            <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
              <ul role="list">
                {%- if paginate.previous -%}
                  <li>
                    <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  <li>
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                        {{- part.title -}}
                      </a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                          {{- part.title -}}
                        </span>
                      {%- else -%}
                        <span>{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </li>
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endif -%}
      {% endpaginate %}
      </div>

      <div class="vd-customer-card vd-customer-card--aside">
        <div class="vd-customer-card__head">
          <p class="vd-customer-card__kicker">{{ 'customer.account.details' | t }}</p>
          <h2>Adresse principale</h2>
          <p>La base utile pour relancer vite une commande ou vérifier une livraison.</p>
        </div>

        <div class="vd-customer-address">
          {{ customer.default_address | format_address }}
        </div>

        <a href="{{ routes.account_addresses_url }}" class="button button--secondary">
          {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
        </a>
      </div>
    </div>
  </div>
</div>

{%- style -%}
  .vd-customer-carnet__grid {
    display: grid;
    gap: 1.6rem;
    margin-top: 1.2rem;
  }

  .vd-customer-carnet__panel {
    padding: 1.6rem;
    border: 1px solid rgba(16, 16, 16, 0.08);
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.72);
  }

  .vd-customer-carnet__panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .vd-customer-carnet__cards {
    display: grid;
    gap: 1rem;
  }

  .vd-customer-carnet__card {
    display: grid;
    grid-template-columns: 11rem minmax(0, 1fr);
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    padding: 1rem;
    border-radius: 1.8rem;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(16, 16, 16, 0.08);
  }

  .vd-customer-carnet__media {
    min-height: 10rem;
    border-radius: 1.2rem;
    background:
      linear-gradient(145deg, rgba(211, 224, 203, 0.64), rgba(235, 226, 214, 0.72));
    background-size: cover;
    background-position: center;
    display: grid;
    place-items: center;
    color: rgba(17, 17, 17, 0.5);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .vd-customer-carnet__body {
    display: grid;
    align-content: center;
    gap: 0.5rem;
  }

  .vd-customer-carnet__body strong,
  .vd-customer-carnet__panel-head strong {
    color: rgb(17, 17, 17);
  }

  .vd-customer-carnet__body p,
  .vd-customer-carnet__empty {
    margin: 0;
    color: rgba(17, 17, 17, 0.68);
  }

  .vd-customer-carnet__meta {
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(17, 17, 17, 0.46);
  }

  .vd-customer-carnet__empty {
    margin-top: 1.2rem;
    padding: 1.2rem 1.4rem;
    border-radius: 1.6rem;
    background: rgba(255, 255, 255, 0.54);
    border: 1px dashed rgba(16, 16, 16, 0.1);
  }

  @media screen and (min-width: 990px) {
    .vd-customer-carnet__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "text",
      "id": "customer_shelf_endpoint",
      "label": "Endpoint carnet client",
      "default": "/apps/recipes-studio/shelf",
      "info": "App proxy Shopify ou endpoint public pour synchroniser favoris et historique."
    }
  ]
}
{% endschema %}
