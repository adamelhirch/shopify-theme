{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign footer_primary_link = section.settings.primary_link | default: '/collections/all'
  assign footer_house_url = routes.root_url
  assign footer_wiki_url = '/blogs/le-wiki'
  assign footer_recipes_url = '/pages/recettes'
  assign footer_savoir_faire_url = '/pages/savoir-faire'
  assign footer_contact_url = '/pages/contact'
  assign footer_faq_url = '/pages/faq'
  assign footer_vanille_url = '/collections/vanille-bourbon'
  assign footer_epices_url = '/collections/epices-madagascar'
  assign footer_poivres_url = '/collections/poivre-baies'
  assign footer_shipping_url = '/policies/shipping-policy'
  if shop.shipping_policy != blank
    assign footer_shipping_url = shop.shipping_policy.url
  endif
  assign footer_refund_url = '/policies/refund-policy'
  if shop.refund_policy != blank
    assign footer_refund_url = shop.refund_policy.url
  endif
  assign footer_legal_url = '/pages/mentions-legales'
  if pages['mentions-legales'] != blank
    assign footer_legal_url = pages['mentions-legales'].url
  endif
  assign footer_terms_url = '/policies/terms-of-service'
  if shop.terms_of_service != blank
    assign footer_terms_url = shop.terms_of_service.url
  endif
  assign footer_help_url = '/pages/contact'
  assign footer_video_url = ''
  if section.settings.background_video != blank
    for source in section.settings.background_video.sources
      if source.mime_type == 'video/mp4'
        assign footer_video_url = source.url
        break
      endif
    endfor
  endif
  assign footer_image = section.settings.background_image
-%}

<footer
  class="footer footer--scene footer--millia color-{{ section.settings.color_scheme }} gradient"
  data-vd-footer-scene
>
  <div class="vd-footer-millia">
    <section class="vd-footer-millia__hero">
      <div class="vd-footer-millia__hero-media" aria-hidden="true">
        {%- if footer_video_url != blank -%}
          <video autoplay muted loop playsinline preload="metadata" poster="{{ 'vd-hero-origin-poster.jpg' | asset_url }}">
            <source src="{{ footer_video_url }}" type="video/mp4">
          </video>
        {%- elsif footer_image != blank -%}
          {{
            footer_image
            | image_url: width: 2400
            | image_tag:
              class: 'vd-footer-millia__hero-image',
              widths: '720, 960, 1280, 1600, 2200, 2400',
              sizes: '100vw',
              loading: 'lazy',
              alt: ''
          }}
        {%- else -%}
          <img src="{{ 'vd-hero-origin-poster.jpg' | asset_url }}" alt="" class="vd-footer-millia__hero-image" loading="lazy">
        {%- endif -%}
      </div>
      <div class="vd-footer-millia__hero-overlay" aria-hidden="true"></div>
      <div class="vd-footer-millia__hero-shell">
        <div class="vd-footer-millia__hero-copy">
          <p class="vd-footer-millia__eyebrow" data-vd-footer-item>
            {{ section.settings.newsletter_kicker | default: 'Journal de la maison' }}
          </p>
          <h2 class="vd-footer-millia__hero-title" data-vd-footer-item>
            {{ section.settings.newsletter_heading_shell | default: 'Une correspondance rare.' }}
          </h2>
          <div class="vd-footer-millia__hero-text rte" data-vd-footer-item>
            {{ section.settings.newsletter_text }}
          </div>
          {%- if section.settings.newsletter_enable -%}
            <div class="vd-footer-millia__hero-form" data-vd-footer-item>
              {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form vd-form vd-form--newsletter' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="vd-footer-millia__newsletter-line">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="vd-footer-millia__newsletter-input"
                    value="{{ form.email }}"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="ContactFooter-error"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="ContactFooter-success"
                    {% endif %}
                    placeholder="E-mail"
                    required
                  >
                  <button
                    type="submit"
                    class="vd-footer-millia__newsletter-submit"
                    name="commit"
                    aria-label="{{ 'newsletter.button_label' | t }}"
                  >
                    S'inscrire
                  </button>
                </div>
                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="ContactFooter-error">
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    autofocus
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-success.svg' | inline_asset_content -}}
                    </span>
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </section>

    <section class="vd-footer-millia__base">
      <div class="vd-footer-millia__crumb" data-vd-footer-item>
        <a href="{{ routes.root_url }}">Accueil</a>
      </div>
      <div class="vd-footer-millia__grid">
        <nav class="vd-footer-millia__column" aria-label="E-shop" data-vd-footer-item>
          <h3>E-Shop</h3>
          <ul role="list">
            <li><a href="{{ footer_primary_link }}">Le catalogue</a></li>
            <li><a href="{{ footer_vanille_url }}">Vanille Bourbon</a></li>
            <li><a href="{{ footer_epices_url }}">Epices</a></li>
            <li><a href="{{ footer_poivres_url }}">Poivres & baies</a></li>
          </ul>
        </nav>

        <nav class="vd-footer-millia__column" aria-label="La marque" data-vd-footer-item>
          <h3>La Marque</h3>
          <ul role="list">
            <li><a href="{{ footer_wiki_url }}">Le Wiki</a></li>
            <li><a href="{{ footer_recipes_url }}">Recettes</a></li>
            <li><a href="{{ footer_savoir_faire_url }}">Savoir-faire</a></li>
            <li><a href="{{ footer_contact_url }}">Contact</a></li>
          </ul>
        </nav>

        <div class="vd-footer-millia__mark" data-vd-footer-item>
          <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
            {%- if settings.logo != blank -%}
              {%- assign footer_logo_alt = settings.logo.alt | default: shop.name | escape -%}
              {%- assign footer_logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
              {{
                settings.logo
                | image_url: width: 320
                | image_tag:
                  class: 'vd-footer-millia__logo',
                  widths: '120, 160, 220, 320',
                  width: settings.logo_width,
                  height: footer_logo_height,
                  alt: footer_logo_alt,
                  loading: 'lazy'
              }}
            {%- else -%}
              <img src="{{ 'vanille-desire-logo.png' | asset_url }}" alt="{{ shop.name }}" class="vd-footer-millia__logo" loading="lazy">
            {%- endif -%}
          </a>
        </div>

        <nav class="vd-footer-millia__column" aria-label="Aide" data-vd-footer-item>
          <h3>Aide</h3>
          <ul role="list">
            <li><a href="{{ footer_faq_url }}">FAQ</a></li>
            <li><a href="{{ footer_contact_url }}">Contact</a></li>
            <li><a href="{{ footer_shipping_url }}">Expédition</a></li>
            <li><a href="{{ footer_refund_url }}">Retours</a></li>
          </ul>
        </nav>

        <nav class="vd-footer-millia__column" aria-label="Social media" data-vd-footer-item>
          <h3>Social Media</h3>
          <ul role="list">
            {%- if settings.social_instagram_link != blank -%}
              <li><a href="{{ settings.social_instagram_link }}">Instagram</a></li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li><a href="{{ settings.social_tiktok_link }}">Tiktok</a></li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li><a href="{{ settings.social_youtube_link }}">Youtube</a></li>
            {%- elsif settings.social_facebook_link != blank -%}
              <li><a href="{{ settings.social_facebook_link }}">Facebook</a></li>
            {%- endif -%}
          </ul>
        </nav>
      </div>

      <div class="vd-footer-millia__bottom" data-vd-footer-item>
        <div class="vd-footer-millia__policies">
          <a href="{{ footer_legal_url }}">Mentions légales</a>
          <a href="{{ footer_terms_url }}">Conditions générales de vente</a>
        </div>
        <div class="vd-footer-millia__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} - all rights reserved
        </div>
      </div>
    </section>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Width",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            {
              "value": "",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Scene"
    },
    {
      "type": "text",
      "id": "scene_eyebrow",
      "label": "Sur-titre",
      "default": "Maison"
    },
    {
      "type": "inline_richtext",
      "id": "scene_heading",
      "label": "Titre principal",
      "default": "Vanille, épices, poivres et recettes dans une même maison."
    },
    {
      "type": "richtext",
      "id": "scene_text",
      "label": "Texte principal",
      "default": "<p>Vanille Désiré relie sourcing à Madagascar, produits de caractère, idées recettes et conseils utiles dans une lecture plus éditoriale, plus fluide et plus premium.</p>"
    },
    {
      "type": "text",
      "id": "primary_link_label",
      "label": "CTA principal",
      "default": "Voir le catalogue"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien CTA principal"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "CTA secondaire",
      "default": "Nous contacter"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien CTA secondaire"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "text",
      "id": "newsletter_kicker",
      "label": "Sur-titre newsletter",
      "default": "Journal de la maison"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading_shell",
      "label": "Titre newsletter",
      "default": "Une correspondance plus rare, pas un bruit de plus."
    },
    {
      "type": "richtext",
      "id": "newsletter_text",
      "label": "Texte newsletter",
      "default": "<p>Nouveaux lots, éditions limitées, recettes et matières à suivre avec un rythme plus juste.</p>"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_kicker",
      "label": "Sur-titre contact",
      "default": "Contact"
    },
    {
      "type": "inline_richtext",
      "id": "contact_heading",
      "label": "Titre contact",
      "default": "Questions, commandes spéciales, collaborations."
    },
    {
      "type": "richtext",
      "id": "contact_text",
      "label": "Texte contact",
      "default": "<p>Un point direct avec la maison pour les demandes sur mesure, cadeaux, sourcing et échanges plus éditoriaux.</p>"
    },
    {
      "type": "text",
      "id": "contact_link_label",
      "label": "Libellé lien contact",
      "default": "Page contact"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Lien contact"
    },
    {
      "type": "header",
      "content": "Repères"
    },
    {
      "type": "text",
      "id": "signal_1_label",
      "label": "Repère 1 label",
      "default": "Origine"
    },
    {
      "type": "text",
      "id": "signal_1_value",
      "label": "Repère 1 valeur",
      "default": "Direct Madagascar"
    },
    {
      "type": "text",
      "id": "signal_2_label",
      "label": "Repère 2 label",
      "default": "Maison"
    },
    {
      "type": "text",
      "id": "signal_2_value",
      "label": "Repère 2 valeur",
      "default": "Vanille, épices, poivres"
    },
    {
      "type": "text",
      "id": "signal_3_label",
      "label": "Repère 3 label",
      "default": "Service"
    },
    {
      "type": "text",
      "id": "signal_3_value",
      "label": "Repère 3 valeur",
      "default": "Expédition soignée"
    },
    {
      "type": "header",
      "content": "Fond"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond"
    },
    {
