{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign footer_primary_link = section.settings.primary_link | default: '/collections/all'
  assign footer_house_url = routes.root_url
  assign footer_shipping_url = '/policies/shipping-policy'
  if shop.shipping_policy != blank
    assign footer_shipping_url = shop.shipping_policy.url
  endif
  assign footer_help_url = '/pages/contact'
-%}

<footer
  class="footer footer--scene color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  data-vd-footer-scene
>
  <div class="vd-footer-stage">
    <div class="vd-footer-stage__shell">
      <div class="vd-footer-bento">
        <article class="bento-item vd-footer-bento__brand" data-vd-footer-panel>
          <p class="vd-footer-stage__label">Maison</p>
          <h2 class="vd-footer-stage__title">Vanille, épices, poivres et recettes dans une même maison.</h2>
          <p class="vd-footer-stage__text">Sourcing direct à Madagascar.</p>
        </article>

        <nav class="bento-item vd-footer-bento__explore" aria-label="Explorer" data-vd-footer-panel>
          <p class="vd-footer-stage__label">Explorer</p>
          <ul class="vd-footer-stage__nav-list list-unstyled" role="list">
            <li><a href="{{ footer_primary_link }}">Le Catalogue</a></li>
            <li><a href="{{ footer_house_url }}">La Maison</a></li>
            <li><a href="{{ footer_shipping_url }}">Expéditions</a></li>
            <li><a href="{{ footer_help_url }}">Aide</a></li>
          </ul>
        </nav>

        <aside class="bento-item vd-footer-bento__journal" data-vd-footer-panel>
          <p class="vd-footer-stage__label">Journal</p>
          <p class="vd-footer-stage__journal-text">Une correspondance rare.</p>
          <div class="vd-footer-stage__newsletter-shell">
            {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form vd-form vd-form--newsletter' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="vd-footer-stage__newsletter-line">
                <div class="field vd-form__field vd-form__field--line">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="field__input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="ContactFooter-error"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="ContactFooter-success"
                    {% endif %}
                    placeholder="E-mail"
                    required
                  >
                  <button
                    type="submit"
                    class="newsletter-form__button field__button vd-form__submit vd-form__submit--line"
                    name="commit"
                    id="Subscribe"
                    aria-label="{{ 'newsletter.button_label' | t }}"
                  >
                    <span class="vd-arrow-cta__icon" aria-hidden="true">→</span>
                  </button>
                </div>
                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="ContactFooter-error">
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}
              </div>
              {%- if form.posted_successfully? -%}
                <h3
                  class="newsletter-form__message newsletter-form__message--success form__message"
                  id="ContactFooter-success"
                  tabindex="-1"
                  autofocus
                >
                  <span class="svg-wrapper">
                    {{- 'icon-success.svg' | inline_asset_content -}}
                  </span>
                  {{- 'newsletter.success' | t }}
                </h3>
              {%- endif -%}
            {%- endform -%}
          </div>
        </aside>
      </div>
    </div>
  </div>
</footer>

