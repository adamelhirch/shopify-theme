{% if page.handle == 'recettes' %}
  {{ 'vd-recipes-hub.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'vd-recipes-hub.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign encoded_return_to = request.path | url_encode
  assign login_target = routes.account_login_url | append: '?return_to=' | append: encoded_return_to
  assign register_target = routes.account_register_url | append: '?return_to=' | append: encoded_return_to
-%}

{% if page.handle == 'recettes' %}
  <section
    class="section-{{ section.id }}-padding vd-recipes-hub color-{{ section.settings.color_scheme }}"
    data-vd-recipes-hub
    data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
    data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
    data-login-url="{{ login_target }}"
    data-register-url="{{ register_target }}"
  >
    <div class="vd-recipes-hub__media" aria-hidden="true">
      {% if section.settings.recipes_background_video != blank %}
        {{
          section.settings.recipes_background_video
          | video_tag:
            class: 'vd-recipes-hub__video',
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            playsinline: true,
            preload: 'metadata',
            image_size: '2000x'
        }}
      {% elsif section.settings.recipes_video_url != blank %}
        <video class="vd-recipes-hub__video" autoplay loop muted playsinline preload="metadata">
          <source src="{{ section.settings.recipes_video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.recipes_background_image != blank %}
        {{
          section.settings.recipes_background_image
          | image_url: width: 2400
          | image_tag:
            class: 'vd-recipes-hub__poster',
            widths: '750, 1200, 1600, 2000, 2400',
            sizes: '100vw',
            loading: 'eager'
        }}
      {% endif %}
    </div>
    <div class="vd-recipes-hub__veil"></div>
    <div class="vd-recipes-hub__glow"></div>

    <div class="page-width">
      <div class="vd-recipes-hub__hero">
        <div class="vd-recipes-hub__copy">
          <span class="vd-recipes-hub__eyebrow">{{ section.settings.recipes_eyebrow | default: 'Carnet de recettes' }}</span>
          <h1 class="vd-recipes-hub__title">{{ section.settings.recipes_heading | default: page.title }}</h1>
          <div class="vd-recipes-hub__text rte">
            {{ section.settings.recipes_intro | default: page.content }}
          </div>

          <div class="vd-recipes-hub__search-shell">
            <label class="vd-recipes-hub__search" for="VDRecipesSearch-{{ section.id }}">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                <path
                  d="M10.5 4a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm9 15.5-4.1-4.1"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
              <input
                id="VDRecipesSearch-{{ section.id }}"
                type="search"
                placeholder="{{ section.settings.search_placeholder | default: 'Rechercher une recette, un ingredient ou un accord' }}"
                autocomplete="off"
                data-vd-recipes-search-input
              >
              <button type="button" class="vd-recipes-hub__clear" data-vd-recipes-search-clear hidden>
                Effacer
              </button>
            </label>
            <p class="vd-recipes-hub__search-note">
              Recherche instantanee dans les recettes maison et les publications validees.
            </p>
          </div>
        </div>

        <aside class="vd-recipes-hub__hero-card">
          <span class="vd-recipes-hub__panel-label">Bibliotheque vivante</span>
          <h2>Une navigation rapide, une lecture nette, une mise a jour souveraine.</h2>
          <p>
            Chaque fiche est issue du registre recette Vanille Desire. Les contenus invites peuvent rejoindre le hub
            apres validation editoriale.
          </p>

          <div class="vd-recipes-hub__metrics" role="list">
            <div class="vd-recipes-hub__metric" role="listitem">
              <span class="vd-recipes-hub__metric-label">Total</span>
              <strong data-vd-recipes-total>0</strong>
            </div>
            <div class="vd-recipes-hub__metric" role="listitem">
              <span class="vd-recipes-hub__metric-label">Acces libre</span>
              <strong data-vd-recipes-free>0</strong>
            </div>
            <div class="vd-recipes-hub__metric" role="listitem">
              <span class="vd-recipes-hub__metric-label">Compte client</span>
              <strong data-vd-recipes-member>0</strong>
            </div>
          </div>
        </aside>
      </div>

      <div class="vd-recipes-hub__toolbar" aria-label="Filtres recettes">
        <div class="vd-recipes-hub__toolbar-head">
          <span class="vd-recipes-hub__toolbar-count" data-vd-recipes-count>0 resultat</span>
          <span class="vd-recipes-hub__toolbar-count">Registre mis a jour depuis la base recette</span>
        </div>

        <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par acces">
          <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-access data-value="all">Tout voir</button>
          <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-access data-value="free">Acces libre</button>
          <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-access data-value="member">Compte client</button>
        </div>

        <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par difficulte">
          <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-difficulty data-value="all">Toutes</button>
          <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="facile">Facile</button>
          <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="intermediaire">Intermediaire</button>
          <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="signature">Signature</button>
        </div>
      </div>

      <div class="vd-recipes-hub__grid" data-vd-recipes-grid></div>

      <div class="vd-recipes-hub__empty" data-vd-recipes-empty hidden>
        Aucun resultat pour cette recherche.
      </div>

      <div class="vd-recipes-hub__viewer" data-vd-recipes-viewer hidden>
        <div class="vd-recipes-hub__viewer-backdrop" data-vd-recipes-viewer-close></div>
        <div class="vd-recipes-hub__viewer-panel" data-vd-recipes-viewer-panel>
          <button type="button" class="vd-recipes-hub__viewer-close" data-vd-recipes-viewer-close aria-label="Fermer la recette">
            Fermer
          </button>
          <div data-vd-recipes-viewer-content></div>
        </div>
      </div>

      <div class="vd-recipes-hub__publication">
        <article class="vd-recipes-hub__publication-item">
          <span class="vd-recipes-hub__publication-label">Publication</span>
          <h2>Recettes maison et signatures invitees.</h2>
          <p>Le hub accepte les contributions externes, mais rien n'entre en ligne sans relecture ni validation.</p>
        </article>
        <article class="vd-recipes-hub__publication-item">
          <span class="vd-recipes-hub__publication-label">Experience</span>
          <h2>Lecture libre ou mode compte client.</h2>
          <p>Les recettes premium ouvrent une navigation immersive, memorisee et pensee pour cuisiner sans friction.</p>
        </article>
      </div>
    </div>
  </section>
{% else %}
  <section class="section-{{ section.id }}-padding vd-page-flow color-{{ section.settings.color_scheme }}">
    <div class="page-width rte">
      <h1>{{ page.title }}</h1>
      {{ page.content }}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "VD Page Flow",
  "tag": "section",
  "class": "section section-vd-page-flow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Recettes"
    },
    {
      "type": "text",
      "id": "recipes_eyebrow",
      "label": "Sur-titre recettes",
      "default": "Carnet de recettes"
    },
    {
      "type": "textarea",
      "id": "recipes_heading",
      "label": "Titre recettes",
      "default": "Recettes & accords"
    },
    {
      "type": "richtext",
      "id": "recipes_intro",
      "label": "Introduction recettes",
      "default": "<p>Explorez les recettes Vanille Desire, recherchez un ingredient ou un style de cuisine, puis entrez dans une lecture plus immersive sur les fiches detail.</p>"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Placeholder recherche",
      "default": "Rechercher une recette, un ingredient ou un accord"
    },
    {
      "type": "text",
      "id": "recipes_video_url",
      "label": "URL video MP4 de fond recettes"
    },
    {
      "type": "video",
      "id": "recipes_background_video",
      "label": "Video Shopify de fond recettes"
    },
    {
      "type": "image_picker",
      "id": "recipes_background_image",
      "label": "Image de fond recettes"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "recipe_card",
      "name": "Carte recette",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Page Flow"
    }
  ]
}
{% endschema %}
