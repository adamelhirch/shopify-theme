{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign is_about_page = false
  assign is_recipes_page = false

  if page.handle == 'qui-sommes-nous'
    assign is_about_page = true
  endif

  if page.handle == 'recettes'
    assign is_recipes_page = true
  endif

  assign recipe_handles = 'caviar-vanille-bourbon-madagascar-20g,extrait-vanille-bourbon-madagascar-20ml,vanille-bourbon-madagascar-3-gousses' | split: ','
-%}

{% if is_about_page or is_recipes_page %}
  <section class="section-{{ section.id }}-padding vd-page-flow color-{{ section.settings.color_scheme }}">
    <div class="page-width">
      {% if is_about_page %}
        <div class="vd-page-flow__hero">
          <div class="vd-page-flow__hero-copy">
            <span class="vd-section-kicker">Maison</span>
            <h1 class="vd-page-flow__title">{{ page.title }}</h1>
            <div class="vd-page-flow__text">
              <p>
                Trois generations, une meme exigence: garder la vanille et les epices de Madagascar dans une relation
                directe, lisible et digne de la matiere.
              </p>
            </div>

            <div class="vd-page-flow__metrics" role="list">
              <div class="vd-page-flow__metric" role="listitem">
                <span>Origine</span>
                <strong>Madagascar</strong>
              </div>
              <div class="vd-page-flow__metric" role="listitem">
                <span>Lecture</span>
                <strong>Circuit direct</strong>
              </div>
              <div class="vd-page-flow__metric" role="listitem">
                <span>Promesse</span>
                <strong>Qualite suivie</strong>
              </div>
            </div>

            <div class="vd-page-flow__actions">
              <a class="vd-arrow-cta" href="/collections/vanille-bourbon">
                <span class="vd-arrow-cta__label">Voir la collection</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
              <a class="vd-arrow-cta" href="/pages/contact">
                <span class="vd-arrow-cta__label">Parler avec nous</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="vd-page-flow__hero-card">
            <span class="vd-page-flow__card-kicker">Pourquoi nous suivre</span>
            <h2>Une maison qui veut montrer le produit avant le folklore.</h2>
            <p>
              Nous ne cherchons pas a empiler des promesses marketing. Le site doit donner une lecture claire de
              l'origine, du geste et de l'usage final.
            </p>
          </div>
        </div>

        <div class="vd-page-flow__pillars" role="list">
          <article class="vd-page-flow__pillar" role="listitem">
            <span>01</span>
            <h2>Selection terrain</h2>
            <p>Chaque lot est choisi pour sa longueur, sa souplesse, son parfum et sa regularite.</p>
          </article>
          <article class="vd-page-flow__pillar" role="listitem">
            <span>02</span>
            <h2>Transmission familiale</h2>
            <p>Le savoir-faire n'est pas raconte comme une legende, mais comme une suite de gestes concrets.</p>
          </article>
          <article class="vd-page-flow__pillar" role="listitem">
            <span>03</span>
            <h2>Usage contemporain</h2>
            <p>On parle autant aux chefs, aux passionnes de patisserie qu'aux achats pros exigeants.</p>
          </article>
        </div>

        {% if page.content != blank %}
          <div class="vd-page-flow__prose rte">
            {{ page.content }}
          </div>
        {% endif %}
      {% endif %}

      {% if is_recipes_page %}
        <div class="vd-page-flow__hero">
          <div class="vd-page-flow__hero-copy">
            <span class="vd-section-kicker">Cuisine & usages</span>
            <h1 class="vd-page-flow__title">{{ page.title }}</h1>
            <div class="vd-page-flow__text">
              <p>
                Cette page doit devenir une porte d'entree simple: quoi utiliser, pour quel resultat, avec quel niveau
                d'intensite.
              </p>
            </div>
            <div class="vd-page-flow__actions">
              <a class="vd-arrow-cta" href="/collections/vanille-bourbon">
                <span class="vd-arrow-cta__label">Commencer par la vanille</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
              <a class="vd-arrow-cta" href="/blogs/le-wiki">
                <span class="vd-arrow-cta__label">Lire le Wiki</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="vd-page-flow__hero-card">
            <span class="vd-page-flow__card-kicker">Mode d'emploi</span>
            <h2>Des recettes courtes, visuelles et directement shoppables.</h2>
            <p>
              Vous ajouterez ensuite les videos 4K et les recettes finales, mais la structure est deja en place pour
              rendre la page exploitable.
            </p>
          </div>
        </div>

        <div class="vd-page-flow__recipe-grid" role="list">
          <article class="vd-page-flow__recipe-card" role="listitem">
            <span>Desserts</span>
            <h2>Creme, ganache, entremets, glace</h2>
            <p>Focus sur l'infusion lente, la rondeur et la profondeur aromatique.</p>
          </article>
          <article class="vd-page-flow__recipe-card" role="listitem">
            <span>Boissons</span>
            <h2>Rhum arrange, latte, sirops maison</h2>
            <p>Des formats pratiques pour travailler vite sans sacrifier l'intensite.</p>
          </article>
          <article class="vd-page-flow__recipe-card" role="listitem">
            <span>Accords sales</span>
            <h2>Poissons, sauces beurre, legumes rotis</h2>
            <p>Une lecture plus mature de la vanille, loin du seul usage sucre.</p>
          </article>
        </div>

        <div class="vd-page-flow__products">
          <div class="vd-page-flow__products-head">
            <span class="vd-section-kicker">Commencer avec</span>
            <h2>Trois formats simples pour entrer dans l'univers.</h2>
          </div>

          <div class="vd-page-flow__product-grid" role="list">
            {% for product_handle in recipe_handles %}
              {% assign product = all_products[product_handle] %}
              {% if product != blank %}
                {%- liquid
                  assign card_image = product.featured_media.preview_image | default: product.featured_image
                  assign card_subtitle = product.metafields.descriptors.subtitle.value | default: product.vendor
                -%}
                <a class="vd-page-flow__product-card" href="{{ product.url }}" role="listitem">
                  <div class="vd-page-flow__product-media">
                    {% if card_image != blank %}
                      {{
                        card_image
                        | image_url: width: 1200
                        | image_tag:
                          class: 'vd-page-flow__product-image',
                          widths: '360, 540, 720, 960, 1200',
                          sizes: '(min-width: 990px) 24vw, 92vw',
                          loading: 'lazy',
                          alt: card_image.alt | default: product.title | escape
                      }}
                    {% endif %}
                  </div>
                  <div class="vd-page-flow__product-body">
                    <span>{{ card_subtitle }}</span>
                    <h3>{{ product.title }}</h3>
                    <strong>{{ product.price | money_without_trailing_zeros }}</strong>
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if page.content != blank %}
          <div class="vd-page-flow__prose rte">
            {{ page.content }}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "VD Page Flow",
  "tag": "section",
  "class": "section section-vd-page-flow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "VD Page Flow"
    }
  ]
}
{% endschema %}
