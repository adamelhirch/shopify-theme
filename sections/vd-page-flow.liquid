                      {% if block.settings.kicker != blank %}
                        <span class="vd-wiki-page__category-kicker">{{ block.settings.kicker }}</span>
                      {% endif %}
                      <h3 class="vd-wiki-page__category-title">{{ block.settings.title }}</h3>
                      {% if block.settings.text != blank %}
                        <p class="vd-wiki-page__category-text">{{ block.settings.text }}</p>
                      {% endif %}
                      {% if block.settings.link_label != blank %}
