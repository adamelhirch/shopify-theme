{%- liquid
  assign recipe_metafield = page.metafields.vd.recipe_slug
  assign recipe_metafield_value = recipe_metafield.value | default: recipe_metafield
  assign recipe_handles_source = section.settings.recipe_page_handles | default: 'beignet-banane,recettes-accords'
  assign recipe_handles_normalized = recipe_handles_source | downcase | replace: ' ', ''
  assign recipe_handle_token = ',' | append: page.handle | append: ','
  assign recipe_handles_csv = ',' | append: recipe_handles_normalized | append: ','
  assign is_recipe_page = false
  assign is_catalog_page = false
  assign is_wiki_page = false
  assign is_wiki_detail_page = false
  if recipe_metafield_value != blank or recipe_handles_csv contains recipe_handle_token
    assign is_recipe_page = true
  endif
  if page.handle == 'catalogue'
    assign is_catalog_page = true
  endif
  if page.handle == 'wiki'
    assign is_wiki_page = true
  elsif page.handle contains 'wiki-' or page.handle == 'vanille-pompona'
    assign is_wiki_detail_page = true
  endif
-%}

{% if page.handle == 'recettes' or is_recipe_page %}
  {{ 'vd-recipes-hub.css' | asset_url | stylesheet_tag }}
  {{ 'vd-recipe-signature.css' | asset_url | stylesheet_tag }}
  {% if page.handle == 'recettes' %}
    <script src="{{ 'vd-recipes-hub.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  <script src="{{ 'vd-recipe-signature.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% if is_wiki_page %}
  {{ 'vd-wiki-page.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'vd-preview-links.js' | asset_url }}" defer="defer"></script>
{% elsif is_wiki_detail_page %}
  {{ 'vd-wiki-detail.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'vd-preview-links.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign encoded_return_to = request.path | url_encode
  assign login_joiner = '?'
  assign register_joiner = '?'
  if routes.account_login_url contains '?'
    assign login_joiner = '&'
  endif
  if routes.account_register_url contains '?'
    assign register_joiner = '&'
  endif
  assign login_target = routes.account_login_url | append: login_joiner | append: 'return_to=' | append: encoded_return_to
  assign register_target = routes.account_register_url | append: register_joiner | append: 'return_to=' | append: encoded_return_to
-%}

{% if page.handle == 'recettes' %}
  <section
    class="section-{{ section.id }}-padding vd-recipes-hub color-{{ section.settings.color_scheme }}"
    data-vd-recipes-hub
    data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
    data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
    data-customer-shelf-endpoint="{{ section.settings.customer_shelf_endpoint | escape }}"
    data-login-url="{{ login_target }}"
    data-register-url="{{ register_target }}"
  >
    <div class="vd-recipes-hub__media" aria-hidden="true">
      {% if section.settings.recipes_background_video != blank %}
        {{
          section.settings.recipes_background_video
          | video_tag:
            class: 'vd-recipes-hub__video',
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            playsinline: true,
            preload: 'metadata',
            image_size: '2000x'
        }}
      {% elsif section.settings.recipes_video_url != blank %}
        <video class="vd-recipes-hub__video" autoplay loop muted playsinline preload="metadata">
          <source src="{{ section.settings.recipes_video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.recipes_background_image != blank %}
        {{
          section.settings.recipes_background_image
          | image_url: width: 2400
          | image_tag:
            class: 'vd-recipes-hub__poster',
            widths: '750, 1200, 1600, 2000, 2400',
            sizes: '100vw',
            loading: 'eager'
        }}
      {% endif %}
    </div>
    <div class="vd-recipes-hub__veil"></div>
    <div class="vd-recipes-hub__glow"></div>

    <div class="page-width">
      <div data-vd-recipes-screen="hub">
        <div class="vd-recipes-hub__hero">
          <div class="vd-recipes-hub__copy">
            <span class="vd-recipes-hub__eyebrow">{{ section.settings.recipes_eyebrow | default: 'Carnet de recettes' }}</span>
            <h1 class="vd-recipes-hub__title">{{ section.settings.recipes_heading | default: page.title }}</h1>
            <div class="vd-recipes-hub__text rte">
              {{ section.settings.recipes_intro | default: page.content }}
            </div>

            <div class="vd-recipes-hub__search-shell">
              <label class="vd-recipes-hub__search" for="VDRecipesSearch-{{ section.id }}">
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M10.5 4a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm9 15.5-4.1-4.1"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                </svg>
                <input
                  id="VDRecipesSearch-{{ section.id }}"
                  type="search"
                  placeholder="{{ section.settings.search_placeholder | default: 'Rechercher une recette, un ingrédient ou un accord' }}"
                  autocomplete="off"
                  data-vd-recipes-search-input
                >
                <button type="button" class="vd-recipes-hub__clear" data-vd-recipes-search-clear hidden>
                  Effacer
                </button>
              </label>
              <p class="vd-recipes-hub__search-note">
                Trouvez une idée selon le temps, l’envie ou les produits que vous avez sous la main.
              </p>
            </div>
          </div>

          <aside class="vd-recipes-hub__hero-card">
            <span class="vd-recipes-hub__panel-label">À cuisiner</span>
            <h2>Des recettes claires, gourmandes et faciles à refaire.</h2>
            <p>
              Desserts, goûters, idées salées et accords autour de la vanille pour cuisiner au quotidien ou recevoir.
            </p>

            <div class="vd-recipes-hub__metrics" role="list">
              <div class="vd-recipes-hub__metric" role="listitem">
                <span class="vd-recipes-hub__metric-label">Total</span>
                <strong data-vd-recipes-total>0</strong>
              </div>
              <div class="vd-recipes-hub__metric" role="listitem">
                <span class="vd-recipes-hub__metric-label">Accès libre</span>
                <strong data-vd-recipes-free>0</strong>
              </div>
              <div class="vd-recipes-hub__metric" role="listitem">
                <span class="vd-recipes-hub__metric-label">Compte client</span>
                <strong data-vd-recipes-member>0</strong>
              </div>
            </div>
          </aside>
        </div>

        <div class="vd-recipes-hub__toolbar" aria-label="Filtres recettes">
          <div class="vd-recipes-hub__toolbar-head">
            <span class="vd-recipes-hub__toolbar-count" data-vd-recipes-count>0 résultat</span>
            <span class="vd-recipes-hub__toolbar-count">Filtrez selon le moment, le niveau et les produits que vous aimez cuisiner.</span>
          </div>

          <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par accès">
            <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-access data-value="all">Tout voir</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-access data-value="free">Accès libre</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-access data-value="member">Compte client</button>
          </div>

          <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par difficulté">
            <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-difficulty data-value="all">Toutes</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="facile">Facile</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="intermediaire">Intermédiaire</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="signature">Signature</button>
          </div>

          <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par temps">
            <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-time data-value="all">Tous les temps</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-time data-value="quick">Moins de 30 min</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-time data-value="medium">30 à 60 min</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-time data-value="long">Plus de 60 min</button>
          </div>

          <div class="vd-recipes-hub__filters vd-recipes-hub__filters--collections" role="toolbar" aria-label="Filtrer par univers" data-vd-recipes-collection-filters></div>

          <div class="vd-recipes-hub__discover" aria-label="Affiner la recherche">
            <label class="vd-recipes-hub__discover-field">
              <span>Ingrédient</span>
              <select data-vd-recipes-ingredient>
                <option value="all">Tous les ingrédients</option>
              </select>
            </label>
            <label class="vd-recipes-hub__discover-field">
              <span>Produit</span>
              <select data-vd-recipes-product>
                <option value="all">Tous les produits</option>
              </select>
            </label>
            <label class="vd-recipes-hub__discover-field">
              <span>Trier</span>
              <select data-vd-recipes-sort>
                <option value="recommended">À commencer</option>
                <option value="quick">Les plus rapides</option>
                <option value="easy">Les plus faciles</option>
                <option value="name">Par nom</option>
              </select>
            </label>
            <button type="button" class="vd-recipes-hub__discover-reset" data-vd-recipes-reset>
              Réinitialiser les filtres
            </button>
          </div>
          <div class="vd-recipes-hub__active-filters" data-vd-recipes-active-filters hidden></div>
        </div>

        <div class="vd-recipes-hub__rails" data-vd-recipes-rails hidden>
          <section class="vd-recipes-hub__rail" data-vd-recipes-history hidden>
            <div class="vd-recipes-hub__rail-head">
              <div>
                <span class="vd-recipes-hub__panel-label">Session</span>
                <h2>Reprendre une recette déjà ouverte.</h2>
              </div>
            </div>
            <div class="vd-recipes-hub__rail-track" data-vd-recipes-history-track></div>
          </section>

          <section class="vd-recipes-hub__rail" data-vd-recipes-favorites hidden>
            <div class="vd-recipes-hub__rail-head">
              <div>
                <span class="vd-recipes-hub__panel-label">Carnet</span>
                <h2>Vos recettes favorites pour revenir plus vite.</h2>
              </div>
            </div>
            <div class="vd-recipes-hub__rail-track" data-vd-recipes-favorites-track></div>
          </section>
        </div>

        <section class="vd-recipes-hub__collections" data-vd-recipes-collections></section>

        <div class="vd-recipes-hub__grid" data-vd-recipes-grid></div>

        <div class="vd-recipes-hub__empty" data-vd-recipes-empty hidden>
          Aucun résultat pour cette recherche.
        </div>

        <div class="vd-recipes-hub__publication">
          <article class="vd-recipes-hub__publication-item">
            <span class="vd-recipes-hub__publication-label">Univers</span>
            <h2>Desserts, goûters et cuisine salée.</h2>
            <p>Retrouvez des recettes du quotidien, des formats à partager et des idées pour travailler la vanille autrement.</p>
          </article>
          <article class="vd-recipes-hub__publication-item">
            <span class="vd-recipes-hub__publication-label">Accès</span>
            <h2>À ouvrir tout de suite ou avec votre compte.</h2>
            <p>Certaines recettes sont libres d’accès, d’autres débloquent le pas-à-pas complet après connexion.</p>
          </article>
        </div>
      </div>

      <div data-vd-recipes-screen="detail" hidden>
        <section
          class="vd-recipe-signature color-{{ section.settings.color_scheme }}"
          data-vd-recipe
          data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
          data-recipe-slug=""
          data-page-handle="{{ page.handle }}"
          data-require-customer-access="true"
          data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
          data-customer-id="{{ customer.id }}"
          data-customer-email="{{ customer.email | escape }}"
          data-customer-shelf-endpoint="{{ section.settings.customer_shelf_endpoint | escape }}"
          data-login-url="{{ login_target }}"
          data-register-url="{{ register_target }}"
        >
          <div class="page-width vd-recipe-signature__back-shell">
            <div class="vd-recipe-signature__back-wrap">
              <a href="{{ page.url | default: request.path }}" class="vd-recipe-signature__back-link">Retour aux recettes</a>
            </div>
          </div>
          <div class="vd-recipe-signature__media" data-vd-recipe-media aria-hidden="true"></div>
          <div class="vd-recipe-signature__veil"></div>
          <div class="vd-recipe-signature__glow"></div>
          <div class="page-width">
            <div class="vd-recipe-signature__shell" data-vd-recipe-shell>
              <div class="vd-recipe-signature__loading">
                <span class="vd-recipe-signature__loading-label">Chargement</span>
                <h1>Préparation de la recette...</h1>
              </div>
            </div>
          </div>
          <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>
          <script type="application/json" data-vd-recipe-editor-media>
            [
              {%- assign media_delimiter = '' -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'recipe_media' -%}
                  {{ media_delimiter }}
                  {%- assign block_video_url = '' -%}
                  {%- if block.settings.video != blank -%}
                    {%- for source in block.settings.video.sources -%}
                      {%- if source.mime_type == 'video/mp4' -%}
                        {%- assign block_video_url = source.url -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  {
                    "recipe_slug": {{ block.settings.recipe_slug | strip | json }},
                    "placement": {{ block.settings.placement | json }},
                    "step_number": {{ block.settings.step_number | json }},
                    "image_url": {{ block.settings.image | image_url: width: 1800 | json }},
                    "image_alt": {{ block.settings.image.alt | default: block.settings.caption | json }},
                    "video_url": {{ block.settings.video_url | default: block_video_url | json }},
                    "caption": {{ block.settings.caption | json }}
                  }{%- assign media_delimiter = ',' -%}
                {%- endif -%}
              {%- endfor -%}
            ]
          </script>
          <script type="application/ld+json" data-vd-recipe-schema></script>
        </section>
      </div>

    </div>
  </section>
{% elsif is_recipe_page %}
  <section class="section-{{ section.id }}-padding vd-recipes-hub color-{{ section.settings.color_scheme }}">
    <section
      class="vd-recipe-signature color-{{ section.settings.color_scheme }}"
      data-vd-recipe
      data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
      data-recipe-slug="{{ recipe_metafield_value | default: page.handle }}"
      data-page-handle="{{ page.handle }}"
      data-require-customer-access="true"
      data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
      data-login-url="{{ login_target }}"
      data-register-url="{{ register_target }}"
    >
      <div class="page-width vd-recipe-signature__back-shell">
        <div class="vd-recipe-signature__back-wrap">
          <a href="/pages/recettes" class="vd-recipe-signature__back-link" data-vd-preview-link>Retour aux recettes</a>
        </div>
      </div>
      <div class="vd-recipe-signature__media" data-vd-recipe-media aria-hidden="true"></div>
      <div class="vd-recipe-signature__veil"></div>
      <div class="vd-recipe-signature__glow"></div>
      <div class="page-width">
        <div class="vd-recipe-signature__shell" data-vd-recipe-shell>
          <div class="vd-recipe-signature__loading">
            <span class="vd-recipe-signature__loading-label">Chargement</span>
            <h1>Préparation de la recette...</h1>
          </div>
        </div>
      </div>
      <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>
      <script type="application/json" data-vd-recipe-editor-media>
        [
          {%- assign media_delimiter = '' -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'recipe_media' -%}
              {{ media_delimiter }}
              {%- assign block_video_url = '' -%}
              {%- if block.settings.video != blank -%}
                {%- for source in block.settings.video.sources -%}
                  {%- if source.mime_type == 'video/mp4' -%}
                    {%- assign block_video_url = source.url -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {
                "recipe_slug": {{ block.settings.recipe_slug | strip | json }},
                "placement": {{ block.settings.placement | json }},
                "step_number": {{ block.settings.step_number | json }},
                "image_url": {{ block.settings.image | image_url: width: 1800 | json }},
                "image_alt": {{ block.settings.image.alt | default: block.settings.caption | json }},
                "video_url": {{ block.settings.video_url | default: block_video_url | json }},
                "caption": {{ block.settings.caption | json }}
              }{%- assign media_delimiter = ',' -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      </script>
      <script type="application/ld+json" data-vd-recipe-schema></script>
    </section>
  </section>
{% elsif is_catalog_page %}
  {%- liquid
    assign catalogue_handles = section.settings.catalogue_handles | default: 'vanille-bourbon,epices-madagascar,poivre-baies,sels,huiles-madagascar'
    assign catalogue_handles_array = catalogue_handles | split: ','
    assign all_products_collection = collections['all']
    assign hero_collection_primary = collections['vanille-bourbon']
    assign hero_collection_secondary = collections['epices-madagascar']
    assign hero_collection_tertiary = collections['poivre-baies']
    assign hero_image_primary = hero_collection_primary.image
    assign hero_image_secondary = hero_collection_secondary.image
    assign hero_image_tertiary = hero_collection_tertiary.image
    assign catalogue_background_video_url = ''
    assign catalogue_backdrop_image = section.settings.catalogue_background_image
    assign has_catalogue_backdrop = false

    if section.settings.catalogue_background_video != blank
      for source in section.settings.catalogue_background_video.sources
        if source.mime_type == 'video/mp4'
          assign catalogue_background_video_url = source.url
          break
        endif
      endfor
    endif

    if hero_image_primary == blank and hero_collection_primary.products.first != blank
      assign hero_image_primary = hero_collection_primary.products.first.featured_media.preview_image | default: hero_collection_primary.products.first.featured_image
    endif
    if hero_image_secondary == blank and hero_collection_secondary.products.first != blank
      assign hero_image_secondary = hero_collection_secondary.products.first.featured_media.preview_image | default: hero_collection_secondary.products.first.featured_image
    endif
    if hero_image_tertiary == blank and hero_collection_tertiary.products.first != blank
      assign hero_image_tertiary = hero_collection_tertiary.products.first.featured_media.preview_image | default: hero_collection_tertiary.products.first.featured_image
    endif

    if catalogue_backdrop_image == blank
      assign catalogue_backdrop_image = hero_image_primary
    endif

    if catalogue_backdrop_image != blank or catalogue_background_video_url != blank
      assign has_catalogue_backdrop = true
    endif
  -%}
  <section class="section-{{ section.id }}-padding vd-catalogue vd-catalogue--page-flow{% if has_catalogue_backdrop %} vd-catalogue--with-backdrop{% endif %} color-{{ section.settings.color_scheme }}">
    {% if has_catalogue_backdrop %}
      <div class="vd-catalogue__backdrop" aria-hidden="true">
        {% if catalogue_background_video_url != blank %}
          <video
            class="vd-catalogue__backdrop-media"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="{{ catalogue_background_video_url }}" type="video/mp4">
          </video>
        {% elsif catalogue_backdrop_image != blank %}
          {{
            catalogue_backdrop_image
            | image_url: width: 2200
            | image_tag:
              class: 'vd-catalogue__backdrop-media',
              widths: '720, 960, 1280, 1600, 2200',
              sizes: '100vw',
              loading: 'eager',
              alt: ''
          }}
        {% endif %}
      </div>
    {% endif %}
    <div class="page-width">
      <div class="vd-catalogue__hero vd-catalogue__hero--immersive">
        <div class="vd-catalogue__hero-copy">
          <span class="vd-section-kicker">{{ section.settings.catalogue_eyebrow | default: 'Catalogue' }}</span>
          <h1 class="vd-catalogue__title">{{ section.settings.catalogue_heading | default: 'Explorer la maison par matière, intensité et usage.' }}</h1>
          <div class="vd-catalogue__text rte">
            {{ section.settings.catalogue_text | default: '<p>Vanille Bourbon, épices, poivres, assemblages, huiles et formats cadeau : une lecture claire pour trouver le bon produit, le bon format et le bon usage.</p>' }}
          </div>
          <div class="vd-catalogue__actions">
            <a href="{{ routes.all_products_collection_url }}" class="vd-arrow-cta">
              <span class="vd-arrow-cta__label">{{ section.settings.catalogue_primary_link_label | default: 'Voir tous les produits' }}</span>
              <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
              </svg>
            </a>
            <a href="/pages/recettes" class="vd-arrow-cta">
              <span class="vd-arrow-cta__label">{{ section.settings.catalogue_secondary_link_label | default: 'Entrer par les recettes' }}</span>
              <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="vd-catalogue__stage">
          <div class="vd-catalogue__stage-glow"></div>
          <div class="vd-catalogue__mosaic">
            {% if hero_image_primary != blank %}
              <a href="{{ routes.all_products_collection_url }}" class="vd-catalogue__mosaic-tile vd-catalogue__mosaic-tile--1">
                {{
                  hero_image_primary
                  | image_url: width: 1600
                  | image_tag:
                    class: 'vd-catalogue__mosaic-image',
                    widths: '480, 720, 960, 1280, 1600',
                    sizes: '(min-width: 990px) 52vw, 100vw',
                    loading: 'eager',
                    alt: all_products_collection.title | default: hero_collection_primary.title | escape
                }}
                <span class="vd-catalogue__tile-copy">
                  <span>{{ section.settings.catalogue_primary_link_label | default: 'Voir tous les produits' }}</span>
                  <strong>{{ all_products_collection.all_products_count }} références</strong>
                </span>
              </a>
            {% endif %}
            {% if hero_image_secondary != blank %}
              <a href="{{ hero_collection_secondary.url }}" class="vd-catalogue__mosaic-tile vd-catalogue__mosaic-tile--2">
                {{
                  hero_image_secondary
                  | image_url: width: 960
                  | image_tag:
                    class: 'vd-catalogue__mosaic-image',
                    widths: '320, 480, 720, 960',
                    sizes: '(min-width: 990px) 18vw, 50vw',
                    loading: 'lazy',
                    alt: hero_collection_secondary.title | escape
                }}
                <span class="vd-catalogue__tile-copy">
                  <span>Collection</span>
                  <strong>{{ hero_collection_secondary.title }}</strong>
                </span>
              </a>
            {% endif %}
            {% if hero_image_tertiary != blank %}
              <a href="{{ hero_collection_tertiary.url }}" class="vd-catalogue__mosaic-tile vd-catalogue__mosaic-tile--3">
                {{
                  hero_image_tertiary
                  | image_url: width: 960
                  | image_tag:
                    class: 'vd-catalogue__mosaic-image',
                    widths: '320, 480, 720, 960',
                    sizes: '(min-width: 990px) 22vw, 50vw',
                    loading: 'lazy',
                    alt: hero_collection_tertiary.title | escape
                }}
                <span class="vd-catalogue__tile-copy">
                  <span>Collection</span>
                  <strong>{{ hero_collection_tertiary.title }}</strong>
                </span>
              </a>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="vd-catalogue__grid" role="list">
        {% if all_products_collection != blank %}
          <article class="vd-catalogue__card vd-catalogue__card--all" role="listitem">
            <a href="{{ routes.all_products_collection_url }}" class="vd-catalogue__card-link">
              {% if hero_image_primary != blank %}
                <div class="vd-catalogue__card-media">
                  {{
                    hero_image_primary
                    | image_url: width: 1200
                    | image_tag:
                      class: 'vd-catalogue__card-image',
                      widths: '360, 540, 720, 960, 1200',
                      sizes: '(min-width: 990px) 30vw, 92vw',
                      loading: 'lazy',
                      alt: all_products_collection.title | escape
                  }}
                </div>
              {% endif %}
              <div class="vd-catalogue__card-head">
                <span>Vue d’ensemble</span>
                <strong>{{ all_products_collection.all_products_count }} refs</strong>
              </div>
              <h2>Voir tout le catalogue</h2>
              <div class="vd-catalogue__card-text rte">
                <p>Retrouver l’ensemble de la maison pour comparer rapidement les formats, les intensités, les cadeaux et les usages quotidiens.</p>
              </div>
              <span class="vd-arrow-cta">
                <span class="vd-arrow-cta__label">Parcourir tous les produits</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </span>
            </a>
          </article>
        {% endif %}
        {% for handle in catalogue_handles_array %}
          {%- liquid
            assign entry_collection = collections[handle]
            if entry_collection == blank
              continue
            endif

            assign entry_image = entry_collection.image
            if entry_image == blank and entry_collection.products.first != blank
              assign entry_image = entry_collection.products.first.featured_media.preview_image | default: entry_collection.products.first.featured_image
            endif

            assign entry_kicker = 'Collection'
            assign entry_title = entry_collection.title
            assign entry_text = entry_collection.description | strip_html | truncatewords: 28
            assign entry_link_label = 'Explorer'

            if handle == 'vanille-bourbon'
              assign entry_kicker = 'Signature'
              assign entry_text = 'Gousses, extraits, caviar et formats cadeaux: le cœur de la maison, pensé pour la pâtisserie, l’infusion et les gestes de précision.'
              assign entry_link_label = 'Entrer dans la vanille'
            elsif handle == 'epices-madagascar'
              assign entry_kicker = 'Accords'
              assign entry_text = 'Cannelle, combava, curry, poivres et épices de Madagascar pour prolonger la cuisine de la maison avec plus de relief.'
              assign entry_link_label = 'Explorer les épices'
            elsif handle == 'poivre-baies'
              assign entry_kicker = 'Sélection'
              assign entry_text = 'Poivres, baies rares et signatures plus franches pour la table, les sauces et les finitions qui demandent du caractère.'
              assign entry_link_label = 'Voir les poivres & baies'
            elsif handle == 'sels' or handle == 'sels-aromatises'
              assign entry_kicker = 'Assemblages'
              assign entry_text = 'Des sels parfumés pensés pour assaisonner, finir un plat ou créer des accords plus immédiats.'
              assign entry_link_label = 'Découvrir les assemblages'
            elsif handle == 'huiles-madagascar' or handle == 'huiles-essentielles'
              assign entry_kicker = 'Usage'
              assign entry_text = 'Huiles essentielles et huiles naturelles avec une lecture plus simple par famille, usage externe et dilution.'
              assign entry_link_label = 'Voir les huiles'
            endif
          -%}
          <article class="vd-catalogue__card" role="listitem">
            <a href="{{ entry_collection.url }}" class="vd-catalogue__card-link">
              {% if entry_image != blank %}
                <div class="vd-catalogue__card-media">
                  {{
                    entry_image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'vd-catalogue__card-image',
                      widths: '360, 540, 720, 960, 1200',
                      sizes: '(min-width: 990px) 30vw, 92vw',
                      loading: 'lazy',
                      alt: entry_title | escape
                  }}
                </div>
              {% endif %}
              <div class="vd-catalogue__card-head">
                <span>{{ entry_kicker }}</span>
                <strong>{{ entry_collection.all_products_count }} refs</strong>
              </div>
              <h2>{{ entry_title }}</h2>
              <div class="vd-catalogue__card-text rte">
                <p>{{ entry_text }}</p>
              </div>
              <span class="vd-arrow-cta">
                <span class="vd-arrow-cta__label">{{ entry_link_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </span>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
{% elsif is_wiki_page %}
  {%- liquid
    assign wiki_stage_image = section.settings.wiki_hero_image
    assign wiki_stage_video = section.settings.wiki_hero_video
    assign wiki_stage_video_url = section.settings.wiki_hero_video_url
    assign wiki_primary_link = section.settings.wiki_primary_link | default: wiki_recipes_link
    assign wiki_secondary_link = section.settings.wiki_secondary_link | default: wiki_catalogue_link
    assign wiki_stage_asset = 'vd-wiki-cover.jpg'
    assign wiki_card_1_asset = 'vd-wiki-botanique.jpg'
    assign wiki_card_2_asset = 'vd-wiki-science.jpg'
    assign wiki_card_3_asset = 'vd-wiki-cover.jpg'

    assign wiki_catalogue_link = '/pages/catalogue'
    assign wiki_recipes_link = '/pages/recettes'
    assign wiki_feature_count = 0
    assign wiki_category_count = 0
    assign wiki_faq_count = 0

    for block in section.blocks
      case block.type
        when 'wiki_feature'
          assign wiki_feature_count = wiki_feature_count | plus: 1
        when 'wiki_category'
          assign wiki_category_count = wiki_category_count | plus: 1
        when 'wiki_faq'
          assign wiki_faq_count = wiki_faq_count | plus: 1
      endcase
    endfor
  -%}

  <section class="section-{{ section.id }}-padding vd-wiki-page color-{{ section.settings.color_scheme }}">
    <div class="page-width">
      <div class="vd-wiki-page__shell">
        <div class="vd-wiki-page__hero">
          <div class="vd-wiki-page__hero-copy">
            <span class="vd-section-kicker">{{ section.settings.wiki_eyebrow | default: 'Le Wiki' }}</span>
            <h1 class="vd-wiki-page__title">{{ section.settings.wiki_heading | default: 'Le grand Wiki de Vanille Désiré' }}</h1>
            <div class="vd-wiki-page__lede rte">
              {{ section.settings.wiki_text }}
            </div>

            <form class="vd-wiki-page__search" action="{{ routes.search_url }}" method="get" role="search" aria-label="Recherche dans le wiki">
              <input type="hidden" name="type" value="page">
              <label class="vd-wiki-page__search-field" for="VDWikiSearch-{{ section.id }}">
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                  <path d="M10.5 4a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm9 15.5-4.1-4.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <input id="VDWikiSearch-{{ section.id }}" type="search" name="q" placeholder="{{ section.settings.wiki_search_placeholder | escape }}" autocomplete="off">
              </label>
              <button class="vd-wiki-page__search-button" type="submit">Rechercher</button>
            </form>

            <div class="vd-wiki-page__hero-actions">
              <a href="{{ wiki_primary_link }}" class="vd-arrow-cta" data-vd-preview-link>
                <span class="vd-arrow-cta__label">{{ section.settings.wiki_primary_link_label | default: 'Voir les recettes' }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
              <a href="{{ wiki_secondary_link }}" class="vd-arrow-cta" data-vd-preview-link>
                <span class="vd-arrow-cta__label">{{ section.settings.wiki_secondary_link_label | default: 'Voir le catalogue' }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="vd-wiki-page__hero-stage">
            <div class="vd-wiki-page__hero-media">
              {% if wiki_stage_video != blank %}
                {{
                  wiki_stage_video
                  | video_tag:
                    class: 'vd-wiki-page__media-video',
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true,
                    preload: 'metadata',
                    image_size: '2000x'
                }}
              {% elsif wiki_stage_video_url != blank %}
                <video class="vd-wiki-page__media-video" autoplay loop muted playsinline preload="metadata">
                  <source src="{{ wiki_stage_video_url }}" type="video/mp4">
                </video>
              {% elsif wiki_stage_image != blank %}
                {{
                  wiki_stage_image
                  | image_url: width: 2200
                  | image_tag:
                    class: 'vd-wiki-page__media-image',
                    widths: '720, 960, 1280, 1600, 2000, 2200',
                    sizes: '(min-width: 990px) 44vw, 100vw',
                    loading: 'eager',
                    alt: 'Le grand Wiki de Vanille Désiré'
                }}
              {% else %}
                <img class="vd-wiki-page__media-image" src="{{ wiki_stage_asset | asset_url }}" alt="Le grand Wiki de Vanille Désiré" loading="eager" width="1201" height="800">
              {% endif %}
            </div>

            <div class="vd-wiki-page__hero-card vd-wiki-page__hero-card--summary">
              <span class="vd-wiki-page__eyebrow">{{ section.settings.wiki_summary_eyebrow | default: 'Depuis Madagascar' }}</span>
              <strong>{{ section.settings.wiki_summary_heading | default: 'Vanille Bourbon, épices rares et savoir-faire producteur.' }}</strong>
              <p>{{ section.settings.wiki_summary | default: 'Guides de conservation, usages, recettes et savoir-faire pour avancer avec des réponses claires.' }}</p>
            </div>
          </div>
        </div>

        <section class="vd-wiki-page__section" aria-labelledby="wiki-essentiel-{{ section.id }}">
          <div class="vd-wiki-page__section-head">
            <span class="vd-section-kicker">{{ section.settings.wiki_essentials_eyebrow | default: 'Vanille' }}</span>
            <h2 class="vd-wiki-page__section-title" id="wiki-essentiel-{{ section.id }}">{{ section.settings.wiki_essentials_heading | default: 'Vanille — l’essentiel' }}</h2>
            <div class="vd-wiki-page__section-text rte">
              {{ section.settings.wiki_essentials_text | default: '<p>Tout savoir sur la <strong>vanille Bourbon</strong> : reconnaître une gousse de qualité, la préparer, la conserver et l’utiliser selon vos recettes.</p>' }}
            </div>
          </div>

          <div class="vd-wiki-page__featured-grid" role="list">
            {% if wiki_feature_count > 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'wiki_feature' %}
                  {%- liquid
                    assign wiki_feature_asset = wiki_card_1_asset
                    if forloop.index == 2
                      assign wiki_feature_asset = wiki_card_2_asset
                    elsif forloop.index == 3
                      assign wiki_feature_asset = wiki_card_3_asset
                    endif
                  -%}
                  <article class="vd-wiki-page__feature" role="listitem" {{ block.shopify_attributes }}>
                    <div class="vd-wiki-page__feature-media">
                      {% if block.settings.image != blank %}
                        {{
                          block.settings.image
                          | image_url: width: 1600
                          | image_tag:
                            widths: '540, 720, 960, 1200, 1600',
                            sizes: '(min-width: 990px) 30vw, 100vw',
                            loading: 'lazy',
                            alt: block.settings.title | escape
                        }}
                      {% else %}
                        <img src="{{ wiki_feature_asset | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="1201" height="800">
                      {% endif %}
                    </div>
                    <div class="vd-wiki-page__feature-body">
                      {% if block.settings.kicker != blank %}
                        <span class="vd-wiki-page__category-kicker">{{ block.settings.kicker }}</span>
                      {% endif %}
                      <h3 class="vd-wiki-page__feature-title">{{ block.settings.title }}</h3>
                      {% if block.settings.text != blank %}
                        <div class="vd-wiki-page__feature-text rte">
                          <p>{{ block.settings.text }}</p>
                        </div>
                      {% endif %}
                      {% if block.settings.point_1 != blank or block.settings.point_2 != blank or block.settings.point_3 != blank %}
                        <ul class="vd-wiki-page__feature-list">
                          {% if block.settings.point_1 != blank %}<li>{{ block.settings.point_1 }}</li>{% endif %}
                          {% if block.settings.point_2 != blank %}<li>{{ block.settings.point_2 }}</li>{% endif %}
                          {% if block.settings.point_3 != blank %}<li>{{ block.settings.point_3 }}</li>{% endif %}
                        </ul>
                      {% endif %}
                      {% if block.settings.link != blank and block.settings.link_label != blank %}
                        <a href="{{ block.settings.link }}" class="vd-arrow-cta" data-vd-preview-link>
                          <span class="vd-arrow-cta__label">{{ block.settings.link_label }}</span>
                          <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                            <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                          </svg>
                        </a>
                      {% endif %}
                    </div>
                  </article>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
        </section>

        <section class="vd-wiki-page__section" aria-labelledby="wiki-categories-{{ section.id }}">
          <div class="vd-wiki-page__section-head">
            <span class="vd-section-kicker">{{ section.settings.wiki_categories_eyebrow | default: 'Catégories' }}</span>
            <h2 class="vd-wiki-page__section-title" id="wiki-categories-{{ section.id }}">{{ section.settings.wiki_categories_heading | default: 'Explorer toutes les catégories' }}</h2>
            <div class="vd-wiki-page__section-text rte">
              {{ section.settings.wiki_categories_text | default: '<p>Un sommaire visuel pour accéder rapidement aux sujets encyclopédiques du wiki.</p>' }}
            </div>
          </div>

          <div class="vd-wiki-page__category-grid">
            {% if wiki_category_count > 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'wiki_category' %}
                  <a href="{{ block.settings.link }}" class="vd-wiki-page__category" data-vd-preview-link {{ block.shopify_attributes }}>
                    {% if block.settings.kicker != blank %}
                      <span class="vd-wiki-page__category-kicker">{{ block.settings.kicker }}</span>
                    {% endif %}
                    <h3 class="vd-wiki-page__category-title">{{ block.settings.title }}</h3>
                    {% if block.settings.text != blank %}
                      <p class="vd-wiki-page__category-text">{{ block.settings.text }}</p>
                    {% endif %}
                    {% if block.settings.link_label != blank %}
                      <span class="vd-arrow-cta">
                        <span class="vd-arrow-cta__label">{{ block.settings.link_label }}</span>
                        <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                          <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                        </svg>
                      </span>
                    {% endif %}
                  </a>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
        </section>

        <div class="vd-wiki-page__cta">
          <section class="vd-wiki-page__cta-copy">
            <span class="vd-section-kicker">{{ section.settings.wiki_footer_eyebrow | default: 'Goûter la différence' }}</span>
            <h2 class="vd-wiki-page__cta-title">{{ section.settings.wiki_footer_heading | default: 'Prêt à goûter la différence ?' }}</h2>
            <div class="vd-wiki-page__cta-text rte">
              {{ section.settings.wiki_footer_text | default: '<p>Découvrez nos <strong>gousses de vanille Bourbon</strong>, nos <strong>épices rares</strong> et nos <strong>sels gourmets</strong> au prix direct producteur.</p>' }}
            </div>
            <a href="{{ section.settings.wiki_footer_primary_link | default: wiki_catalogue_link }}" class="vd-arrow-cta" data-vd-preview-link>
              <span class="vd-arrow-cta__label">{{ section.settings.wiki_footer_primary_link_label | default: 'Accéder à la boutique' }}</span>
              <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
              </svg>
            </a>
            {% if section.settings.wiki_footer_secondary_link_label != blank %}
              <a href="{{ section.settings.wiki_footer_secondary_link | default: wiki_recipes_link }}" class="vd-arrow-cta" data-vd-preview-link>
                <span class="vd-arrow-cta__label">{{ section.settings.wiki_footer_secondary_link_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {% endif %}
            <div class="vd-wiki-page__trust">{{ section.settings.wiki_footer_trust | default: 'Traçabilité totale · Qualité artisanale · Relation directe avec les producteurs de Madagascar' }}</div>
          </section>

          <section class="vd-wiki-page__faq" aria-labelledby="wiki-faq-{{ section.id }}">
            <h2 class="vd-wiki-page__faq-title" id="wiki-faq-{{ section.id }}">{{ section.settings.wiki_faq_title | default: 'FAQ — Vanille & épices' }}</h2>
            {% if wiki_faq_count > 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'wiki_faq' %}
                  <details class="vd-wiki-page__faq-item" {{ block.shopify_attributes }}>
                    <summary>{{ block.settings.question }}</summary>
                    <div class="vd-wiki-page__faq-answer"><p>{{ block.settings.answer }}</p></div>
                  </details>
                {% endif %}
              {% endfor %}
            {% endif %}
          </section>
        </div>
      </div>
    </div>
  </section>
{% elsif is_wiki_detail_page %}
