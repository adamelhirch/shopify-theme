      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "recipe_card",
      "name": "Carte recette",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "collection_label",
          "label": "Categorie",
          "default": "Dessert"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Beignets de banane a la vanille"
        },
        {
          "type": "textarea",
          "id": "summary",
          "label": "Resume",
          "default": "Une recette signature avec un angle clair, un temps lisible et une vraie utilite produit."
        },
        {
          "type": "select",
          "id": "access",
          "label": "Acces",
          "default": "member",
          "options": [
            {
              "value": "free",
              "label": "Gratuit"
            },
            {
              "value": "member",
              "label": "Mode membre"
            }
          ]
        },
        {
          "type": "text",
          "id": "difficulty",
          "label": "Difficulte",
          "default": "Facile"
        },
        {
          "type": "text",
          "id": "time",
          "label": "Temps",
          "default": "35 min"
        },
        {
          "type": "text",
          "id": "serves",
          "label": "Portions",
          "default": "10 portions"
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Mots-clés recherche",
          "default": "banane, dessert, vanille bourbon, friture"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
