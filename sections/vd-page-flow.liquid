      assign wiki_detail_collection_label = ''
      assign wiki_detail_media_video = ''
      assign wiki_detail_media_image = 'vd-wiki-cover.jpg'
      assign wiki_detail_media_poster = 'vd-wiki-cover.jpg'
      assign wiki_detail_media_alt = 'Vanille Bourbon et producteurs Vanille Désiré'
