        assign wiki_detail_summary = 'Souplesse, brillance, parfum, préparation et format: les bons repères pour choisir une vanille Bourbon cohérente avec votre usage.'
      when 'vanille-pompona', 'wiki-vanille-pompona'
        assign wiki_detail_summary = 'La Pompona sert ici de point de comparaison pour mieux lire les grandes familles de vanille, puis revenir vers la référence la plus cohérente à cuisiner.'
      when 'wiki-sels-melanges'
        assign wiki_detail_summary = 'Des sels et assemblages pensés pour la finition, l’assaisonnement et les accords rapides, avec des repères concrets de dosage, de texture et d’usage.'
      when 'wiki-poivres-baies-madagascar'
        assign wiki_detail_summary = 'Comparer les profils, la puissance et le bon moment d’ajout pour choisir un poivre ou une baie selon la cuisson, la finition et le plat.'
      when 'wiki-epices-madagascar'
        assign wiki_detail_summary = 'Une porte d’entrée claire pour comprendre les grandes familles d’épices de Madagascar, leurs usages culinaires et les meilleurs ponts vers recettes et produits.'
      when 'wiki-dosage-vanille'
        assign wiki_detail_summary = 'Crème, lait, pâte, sirop ou dessert: des repères simples pour doser la vanille sans saturer la recette ni sous-exploiter la gousse.'
      when 'wiki-recycler-gousse-vanille'
        assign wiki_detail_summary = 'Sucre vanillé, sirop, compote ou lait parfumé: comment prolonger proprement la vie d’une gousse déjà utilisée.'
      when 'wiki-combava-madagascar'
        assign wiki_detail_summary = 'Poisson, coco, légumes, desserts frais: comprendre comment doser le combava sans écraser l’assiette.'
      when 'wiki-poivre-quel-plat'
        assign wiki_detail_summary = 'Viande, poisson, légumes, chocolat ou fruits: choisir le bon poivre selon la cuisson, la puissance et la finition recherchée.'
      when 'wiki-sel-aromatise-quel-plat'
        assign wiki_detail_summary = 'Œufs, légumes, poissons, viandes ou desserts: trouver le bon sel aromatisé selon le moment d’ajout et l’intensité souhaitée.'
    endcase

    assign wiki_detail_show_secondary = false
    if wiki_detail_secondary_url != blank and wiki_detail_secondary_label != blank and wiki_detail_secondary_url != wiki_detail_primary_url
      assign wiki_detail_show_secondary = true
    endif

    assign wiki_detail_show_collection = false
    if wiki_detail_collection_url != blank
      if wiki_detail_collection_url != wiki_detail_primary_url and wiki_detail_collection_url != wiki_detail_secondary_url and wiki_detail_collection_label != blank
        assign wiki_detail_show_collection = true
      endif
    endif
  -%}

  <section class="section-{{ section.id }}-padding vd-wiki-detail color-{{ section.settings.color_scheme }}">
    <div class="vd-wiki-detail__stage">
      <div class="vd-wiki-detail__stage-media" aria-hidden="true" data-vd-wiki-stage>
        {% if wiki_detail_media_video != blank %}
          <video class="vd-wiki-detail__video" autoplay loop muted playsinline preload="metadata" poster="{{ wiki_detail_media_poster | asset_url }}">
            <source src="{{ wiki_detail_media_video | asset_url }}" type="video/mp4">
          </video>
        {% else %}
          <img class="vd-wiki-detail__poster" src="{{ wiki_detail_media_image | asset_url }}" alt="">
        {% endif %}
      </div>
      <div class="vd-wiki-detail__stage-veil"></div>
      <div class="vd-wiki-detail__stage-glow"></div>

      <div class="page-width vd-wiki-detail__stage-shell">
        <a href="/pages/wiki" class="vd-arrow-cta vd-wiki-detail__back" data-vd-preview-link>
          <span class="vd-arrow-cta__label">Retour au wiki</span>
          <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
            <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
          </svg>
        </a>

        <article class="vd-wiki-detail__shell vd-wiki-detail__shell--lite" data-vd-wiki-theme="{{ wiki_detail_chapter | handleize }}" data-vd-wiki-handle="{{ page.handle }}">
          <header class="vd-wiki-detail__hero vd-wiki-detail__hero--lite">
            <div class="vd-wiki-detail__hero-copy vd-wiki-detail__hero-copy--lite">
              <span class="vd-section-kicker">{{ wiki_detail_chapter }}</span>
              <h1 class="vd-wiki-detail__title" data-vd-wiki-title>{{ wiki_detail_title }}</h1>
              <div class="vd-wiki-detail__lede rte">
                <p>{{ wiki_detail_summary }}</p>
              </div>
              <div class="vd-wiki-detail__hero-links">
                <a href="{{ wiki_detail_primary_url }}" class="vd-arrow-cta" data-vd-preview-link>
                  <span class="vd-arrow-cta__label">{{ wiki_detail_primary_label }}</span>
                  <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                    <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                  </svg>
                </a>
                {% if wiki_detail_show_secondary %}
                  <a href="{{ wiki_detail_secondary_url }}" class="vd-arrow-cta" data-vd-preview-link>
                    <span class="vd-arrow-cta__label">{{ wiki_detail_secondary_label }}</span>
                    <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                      <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                    </svg>
                  </a>
                {% endif %}
                {% if wiki_detail_show_collection %}
                  <a href="{{ wiki_detail_collection_url }}" class="vd-arrow-cta" data-vd-preview-link>
                    <span class="vd-arrow-cta__label">{{ wiki_detail_collection_label }}</span>
                    <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                      <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                    </svg>
                  </a>
                {% endif %}
              </div>
            </div>
          </header>

          <script type="application/ld+json">
            {
              "@context": "https://schema.org",
              "@type": "Article",
              "headline": {{ wiki_detail_title | json }},
              "description": {{ wiki_detail_summary | strip_html | strip | json }},
              "articleSection": {{ wiki_detail_chapter | json }},
              "inLanguage": {{ request.locale.iso_code | default: 'fr' | json }},
              "mainEntityOfPage": {{ canonical_url | json }},
              "author": {
                "@type": "Organization",
                "name": "Vanille Désiré"
              },
              "publisher": {
                "@type": "Organization",
                "name": "Vanille Désiré"
              }
            }
          </script>

          {% if page.handle == 'wiki-faq-vanille-epices' %}
            <script type="application/ld+json">
              {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": [
                  {
                    "@type": "Question",
                    "name": "Comment reconnaître une bonne gousse de vanille ?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Une bonne gousse de vanille doit être souple, parfumée, bien préparée et adaptée à l’usage prévu, sans se limiter à sa longueur."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "Comment conserver la vanille et les épices ?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "La vanille et les épices se conservent à température ambiante, à l’abri de la lumière, de la chaleur et de l’humidité, dans un contenant propre et fermé."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "Quel produit choisir pour débuter ?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Pour la vanille, un petit lot de gousses bien préparées suffit pour débuter. Pour les épices, commencez par une sélection courte et lisible correspondant à vos usages."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "Les épices entières se conservent-elles mieux ?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Souvent oui : les formats entiers protègent mieux l’aromatique et permettent un dosage plus précis au dernier moment."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "Comment choisir entre wiki, recettes et catalogue ?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Le wiki sert à comprendre, les recettes à passer au geste, et le catalogue à acheter quand le besoin est clarifié."
                    }
                  }
                ]
              }
            </script>
          {% endif %}

          <div class="vd-wiki-detail__body">
            <div class="vd-wiki-detail__content-wrap vd-wiki-detail__content-wrap--lite">
              <div class="vd-wiki-detail__content rte">
                {{ wiki_detail_content }}
              </div>
            </div>
          </div>

          <footer class="vd-wiki-detail__footer vd-wiki-detail__footer--lite">
            <div class="vd-wiki-detail__footer-head">
              <span class="vd-wiki-detail__eyebrow">Poursuivre</span>
              <h2>Continuer dans le wiki</h2>
            </div>
            <div class="vd-wiki-detail__footer-links" aria-label="Navigation du chapitre">
              <a href="{{ wiki_detail_card_one_url }}" class="vd-wiki-detail__footer-link" data-vd-preview-link>
                <span>{{ wiki_detail_chapter }}</span>
                <strong>{{ wiki_detail_card_one_title }}</strong>
                <p>{{ wiki_detail_card_one_copy }}</p>
              </a>
              <a href="{{ wiki_detail_card_two_url }}" class="vd-wiki-detail__footer-link" data-vd-preview-link>
                <span>Explorer</span>
                <strong>{{ wiki_detail_card_two_title }}</strong>
                <p>{{ wiki_detail_card_two_copy }}</p>
              </a>
              <a href="{{ wiki_detail_card_three_url }}" class="vd-wiki-detail__footer-link" data-vd-preview-link>
                <span>Continuer</span>
                <strong>{{ wiki_detail_card_three_title }}</strong>
                <p>{{ wiki_detail_card_three_copy }}</p>
              </a>
            </div>
          </footer>
        </article>
      </div>
    </div>
  </section>
{% else %}
  <section class="section-{{ section.id }}-padding vd-page-flow color-{{ section.settings.color_scheme }}">
    <div class="page-width rte">
      <h1>{{ page.title }}</h1>
      {{ page.content }}
    </div>
  </section>
{% endif %}

