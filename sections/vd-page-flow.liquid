{%- liquid
  assign recipe_metafield = page.metafields.vd.recipe_slug
  assign recipe_metafield_value = recipe_metafield.value | default: recipe_metafield
  assign recipe_handles_source = section.settings.recipe_page_handles | default: 'beignet-banane,recettes-accords'
  assign recipe_handles_normalized = recipe_handles_source | downcase | replace: ' ', ''
  assign recipe_handle_token = ',' | append: page.handle | append: ','
  assign recipe_handles_csv = ',' | append: recipe_handles_normalized | append: ','
  assign is_recipe_page = false
  if recipe_metafield_value != blank or recipe_handles_csv contains recipe_handle_token
    assign is_recipe_page = true
  endif
-%}

{% if page.handle == 'recettes' or is_recipe_page %}
  {{ 'vd-recipes-hub.css' | asset_url | stylesheet_tag }}
  {{ 'vd-recipe-signature.css' | asset_url | stylesheet_tag }}
  {% if page.handle == 'recettes' %}
    <script src="{{ 'vd-recipes-hub.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  <script src="{{ 'vd-recipe-signature.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign encoded_return_to = request.path | url_encode
  assign login_joiner = '?'
  assign register_joiner = '?'
  if routes.account_login_url contains '?'
    assign login_joiner = '&'
  endif
  if routes.account_register_url contains '?'
    assign register_joiner = '&'
  endif
  assign login_target = routes.account_login_url | append: login_joiner | append: 'return_to=' | append: encoded_return_to
  assign register_target = routes.account_register_url | append: register_joiner | append: 'return_to=' | append: encoded_return_to
-%}

{% if page.handle == 'recettes' %}
  <section
    class="section-{{ section.id }}-padding vd-recipes-hub color-{{ section.settings.color_scheme }}"
    data-vd-recipes-hub
    data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
    data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
    data-login-url="{{ login_target }}"
    data-register-url="{{ register_target }}"
  >
    <div class="vd-recipes-hub__media" aria-hidden="true">
      {% if section.settings.recipes_background_video != blank %}
        {{
          section.settings.recipes_background_video
          | video_tag:
            class: 'vd-recipes-hub__video',
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            playsinline: true,
            preload: 'metadata',
            image_size: '2000x'
        }}
      {% elsif section.settings.recipes_video_url != blank %}
        <video class="vd-recipes-hub__video" autoplay loop muted playsinline preload="metadata">
          <source src="{{ section.settings.recipes_video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.recipes_background_image != blank %}
        {{
          section.settings.recipes_background_image
          | image_url: width: 2400
          | image_tag:
            class: 'vd-recipes-hub__poster',
            widths: '750, 1200, 1600, 2000, 2400',
            sizes: '100vw',
            loading: 'eager'
        }}
      {% endif %}
    </div>
    <div class="vd-recipes-hub__veil"></div>
    <div class="vd-recipes-hub__glow"></div>

    <div class="page-width">
      <div data-vd-recipes-screen="hub">
        <div class="vd-recipes-hub__hero">
          <div class="vd-recipes-hub__copy">
            <span class="vd-recipes-hub__eyebrow">{{ section.settings.recipes_eyebrow | default: 'Carnet de recettes' }}</span>
            <h1 class="vd-recipes-hub__title">{{ section.settings.recipes_heading | default: page.title }}</h1>
            <div class="vd-recipes-hub__text rte">
              {{ section.settings.recipes_intro | default: page.content }}
            </div>

            <div class="vd-recipes-hub__search-shell">
              <label class="vd-recipes-hub__search" for="VDRecipesSearch-{{ section.id }}">
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M10.5 4a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm9 15.5-4.1-4.1"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                </svg>
                <input
                  id="VDRecipesSearch-{{ section.id }}"
                  type="search"
                  placeholder="{{ section.settings.search_placeholder | default: 'Rechercher une recette, un ingredient ou un accord' }}"
                  autocomplete="off"
                  data-vd-recipes-search-input
                >
                <button type="button" class="vd-recipes-hub__clear" data-vd-recipes-search-clear hidden>
                  Effacer
                </button>
              </label>
              <p class="vd-recipes-hub__search-note">
                Recherche instantanée dans les recettes maison et les publications validées.
              </p>
            </div>
          </div>

          <aside class="vd-recipes-hub__hero-card">
            <span class="vd-recipes-hub__panel-label">Bibliothèque vivante</span>
            <h2>Une navigation rapide, une lecture nette, une mise à jour souveraine.</h2>
            <p>
              Chaque fiche est issue du registre recette Vanille Désiré. Les contenus invités peuvent rejoindre le hub
              après validation éditoriale.
            </p>

            <div class="vd-recipes-hub__metrics" role="list">
              <div class="vd-recipes-hub__metric" role="listitem">
                <span class="vd-recipes-hub__metric-label">Total</span>
                <strong data-vd-recipes-total>0</strong>
              </div>
              <div class="vd-recipes-hub__metric" role="listitem">
                <span class="vd-recipes-hub__metric-label">Accès libre</span>
                <strong data-vd-recipes-free>0</strong>
              </div>
              <div class="vd-recipes-hub__metric" role="listitem">
                <span class="vd-recipes-hub__metric-label">Compte client</span>
                <strong data-vd-recipes-member>0</strong>
              </div>
            </div>
          </aside>
        </div>

        <div class="vd-recipes-hub__toolbar" aria-label="Filtres recettes">
          <div class="vd-recipes-hub__toolbar-head">
            <span class="vd-recipes-hub__toolbar-count" data-vd-recipes-count>0 résultat</span>
            <span class="vd-recipes-hub__toolbar-count">Registre mis à jour depuis la base recette</span>
          </div>

          <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par accès">
            <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-access data-value="all">Tout voir</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-access data-value="free">Accès libre</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-access data-value="member">Compte client</button>
          </div>

          <div class="vd-recipes-hub__filters" role="toolbar" aria-label="Filtrer par difficulté">
            <button type="button" class="vd-recipes-hub__filter is-active" data-vd-recipes-difficulty data-value="all">Toutes</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="facile">Facile</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="intermediaire">Intermédiaire</button>
            <button type="button" class="vd-recipes-hub__filter" data-vd-recipes-difficulty data-value="signature">Signature</button>
          </div>

          <div class="vd-recipes-hub__filters vd-recipes-hub__filters--collections" role="toolbar" aria-label="Filtrer par univers" data-vd-recipes-collection-filters></div>
        </div>

        <div class="vd-recipes-hub__rails" data-vd-recipes-rails hidden>
          <section class="vd-recipes-hub__rail" data-vd-recipes-history hidden>
            <div class="vd-recipes-hub__rail-head">
              <div>
                <span class="vd-recipes-hub__panel-label">Session</span>
                <h2>Reprendre une recette déjà ouverte.</h2>
              </div>
            </div>
            <div class="vd-recipes-hub__rail-track" data-vd-recipes-history-track></div>
          </section>

          <section class="vd-recipes-hub__rail" data-vd-recipes-favorites hidden>
            <div class="vd-recipes-hub__rail-head">
              <div>
                <span class="vd-recipes-hub__panel-label">Carnet</span>
                <h2>Vos recettes favorites pour revenir plus vite.</h2>
              </div>
            </div>
            <div class="vd-recipes-hub__rail-track" data-vd-recipes-favorites-track></div>
          </section>
        </div>

        <section class="vd-recipes-hub__collections" data-vd-recipes-collections></section>

        <div class="vd-recipes-hub__grid" data-vd-recipes-grid></div>

        <div class="vd-recipes-hub__empty" data-vd-recipes-empty hidden>
          Aucun résultat pour cette recherche.
        </div>

        <div class="vd-recipes-hub__publication">
          <article class="vd-recipes-hub__publication-item">
            <span class="vd-recipes-hub__publication-label">Publication</span>
            <h2>Recettes maison et signatures invitées.</h2>
            <p>Le hub accepte les contributions externes, mais rien n’entre en ligne sans relecture ni validation.</p>
          </article>
          <article class="vd-recipes-hub__publication-item">
            <span class="vd-recipes-hub__publication-label">Expérience</span>
            <h2>Lecture libre ou mode compte client.</h2>
            <p>Les recettes premium ouvrent une navigation immersive, mémorisée et pensée pour cuisiner sans friction.</p>
          </article>
        </div>
      </div>

      <div data-vd-recipes-screen="detail" hidden>
        <section
          class="vd-recipe-signature color-{{ section.settings.color_scheme }}"
          data-vd-recipe
          data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
          data-recipe-slug=""
          data-page-handle="{{ page.handle }}"
          data-require-customer-access="true"
          data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
          data-login-url="{{ login_target }}"
          data-register-url="{{ register_target }}"
        >
          <div class="page-width vd-recipe-signature__back-shell">
            <div class="vd-recipe-signature__back-wrap">
              <a href="{{ page.url | default: request.path }}" class="vd-recipe-signature__back-link">Retour aux recettes</a>
            </div>
          </div>
          <div class="vd-recipe-signature__media" data-vd-recipe-media aria-hidden="true"></div>
          <div class="vd-recipe-signature__veil"></div>
          <div class="vd-recipe-signature__glow"></div>
          <div class="page-width">
            <div class="vd-recipe-signature__shell" data-vd-recipe-shell>
              <div class="vd-recipe-signature__loading">
                <span class="vd-recipe-signature__loading-label">Chargement</span>
                <h1>Préparation de la recette...</h1>
              </div>
            </div>
          </div>
          <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>
          <script type="application/json" data-vd-recipe-editor-media>
            [
              {%- assign media_delimiter = '' -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'recipe_media' -%}
                  {{ media_delimiter }}
                  {%- assign block_video_url = '' -%}
                  {%- if block.settings.video != blank -%}
                    {%- for source in block.settings.video.sources -%}
                      {%- if source.mime_type == 'video/mp4' -%}
                        {%- assign block_video_url = source.url -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  {
                    "recipe_slug": {{ block.settings.recipe_slug | strip | json }},
                    "placement": {{ block.settings.placement | json }},
                    "step_number": {{ block.settings.step_number | json }},
                    "image_url": {{ block.settings.image | image_url: width: 1800 | json }},
                    "image_alt": {{ block.settings.image.alt | default: block.settings.caption | json }},
                    "video_url": {{ block.settings.video_url | default: block_video_url | json }},
                    "caption": {{ block.settings.caption | json }}
                  }{%- assign media_delimiter = ',' -%}
                {%- endif -%}
              {%- endfor -%}
            ]
          </script>
          <script type="application/ld+json" data-vd-recipe-schema></script>
        </section>
      </div>

    </div>
  </section>
{% elsif is_recipe_page %}
  <section class="section-{{ section.id }}-padding vd-recipes-hub color-{{ section.settings.color_scheme }}">
    <section
      class="vd-recipe-signature color-{{ section.settings.color_scheme }}"
      data-vd-recipe
      data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
      data-recipe-slug="{{ recipe_metafield_value | default: page.handle }}"
      data-page-handle="{{ page.handle }}"
      data-require-customer-access="true"
      data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
      data-login-url="{{ login_target }}"
      data-register-url="{{ register_target }}"
    >
      <div class="page-width vd-recipe-signature__back-shell">
        <div class="vd-recipe-signature__back-wrap">
          <a href="/pages/recettes" class="vd-recipe-signature__back-link" data-vd-preview-link>Retour aux recettes</a>
        </div>
      </div>
      <div class="vd-recipe-signature__media" data-vd-recipe-media aria-hidden="true"></div>
      <div class="vd-recipe-signature__veil"></div>
      <div class="vd-recipe-signature__glow"></div>
      <div class="page-width">
        <div class="vd-recipe-signature__shell" data-vd-recipe-shell>
          <div class="vd-recipe-signature__loading">
            <span class="vd-recipe-signature__loading-label">Chargement</span>
            <h1>Préparation de la recette...</h1>
          </div>
        </div>
      </div>
      <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>
      <script type="application/json" data-vd-recipe-editor-media>
        [
          {%- assign media_delimiter = '' -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'recipe_media' -%}
              {{ media_delimiter }}
              {%- assign block_video_url = '' -%}
              {%- if block.settings.video != blank -%}
                {%- for source in block.settings.video.sources -%}
                  {%- if source.mime_type == 'video/mp4' -%}
                    {%- assign block_video_url = source.url -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {
                "recipe_slug": {{ block.settings.recipe_slug | strip | json }},
                "placement": {{ block.settings.placement | json }},
                "step_number": {{ block.settings.step_number | json }},
                "image_url": {{ block.settings.image | image_url: width: 1800 | json }},
                "image_alt": {{ block.settings.image.alt | default: block.settings.caption | json }},
                "video_url": {{ block.settings.video_url | default: block_video_url | json }},
                "caption": {{ block.settings.caption | json }}
              }{%- assign media_delimiter = ',' -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      </script>
      <script type="application/ld+json" data-vd-recipe-schema></script>
    </section>
  </section>
{% else %}
  <section class="section-{{ section.id }}-padding vd-page-flow color-{{ section.settings.color_scheme }}">
    <div class="page-width rte">
      <h1>{{ page.title }}</h1>
      {{ page.content }}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "VD Page Flow",
  "tag": "section",
  "class": "section section-vd-page-flow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Recettes"
    },
    {
      "type": "text",
      "id": "recipes_eyebrow",
      "label": "Sur-titre recettes",
      "default": "Carnet de recettes"
    },
    {
      "type": "textarea",
      "id": "recipes_heading",
      "label": "Titre recettes",
      "default": "Recettes & accords"
    },
    {
      "type": "richtext",
      "id": "recipes_intro",
      "label": "Introduction recettes",
      "default": "<p>Explorez les recettes Vanille Desire, recherchez un ingredient ou un style de cuisine, puis entrez dans une lecture plus immersive sur les fiches detail.</p>"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Placeholder recherche",
      "default": "Rechercher une recette, un ingredient ou un accord"
    },
    {
      "type": "text",
      "id": "recipe_page_handles",
      "label": "Handles pages recette dediees",
      "default": "beignet-banane,recettes-accords",
      "info": "Toute page Shopify vide dont le handle apparait ici affichera automatiquement la fiche recette correspondante."
    },
    {
      "type": "text",
      "id": "recipes_video_url",
      "label": "URL video MP4 de fond recettes"
    },
    {
      "type": "video",
      "id": "recipes_background_video",
      "label": "Video Shopify de fond recettes"
    },
    {
      "type": "image_picker",
      "id": "recipes_background_image",
      "label": "Image de fond recettes"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "recipe_card",
      "name": "Carte recette",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre"
        }
      ]
    },
    {
      "type": "recipe_media",
      "name": "Media recette",
      "settings": [
        {
          "type": "text",
          "id": "recipe_slug",
          "label": "Slug recette",
          "info": "Exemple : beignet-banane"
        },
        {
          "type": "select",
          "id": "placement",
          "label": "Placement",
          "default": "gallery",
          "options": [
            { "value": "hero", "label": "Hero / fond principal" },
            { "value": "gallery", "label": "Galerie recette" },
            { "value": "step", "label": "Étape" }
          ]
        },
        {
          "type": "range",
          "id": "step_number",
          "min": 1,
          "max": 12,
          "step": 1,
          "label": "Numero d'etape",
          "default": 1
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video Shopify"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "URL video MP4 externe",
          "info": "Utilisee si aucune video Shopify n'est selectionnee"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Legende"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Page Flow"
    }
  ]
}
{% endschema %}
