{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign is_about_page = false
  assign is_recipes_page = false
  assign is_catalog_page = false
  assign is_generic_page = false
  assign page_kicker = 'Editorial'
  assign page_intro = 'Une base de page plus dense pour eviter les pages nues et garder une vraie tenue de marque.'
  assign metric_1_label = 'Lecture'
  assign metric_1_value = 'Claire'
  assign metric_2_label = 'Ton'
  assign metric_2_value = 'Sobre'
  assign metric_3_label = 'Suite'
  assign metric_3_value = 'Catalogue'
  assign primary_link = '/collections/all'
  assign primary_label = 'Voir le catalogue'
  assign secondary_link = '/pages/contact'
  assign secondary_label = 'Nous contacter'

  if page.handle == 'qui-sommes-nous'
    assign is_about_page = true
  endif

  if page.handle == 'recettes'
    assign is_recipes_page = true
  endif

  if page.handle == 'catalogue'
    assign is_catalog_page = true
  endif

  unless is_about_page or is_recipes_page or is_catalog_page
    assign is_generic_page = true
  endunless

  if page.handle contains 'faq'
    assign page_kicker = 'Questions frequentes'
    assign page_intro = 'Une page qui doit lever les doutes utiles, rassurer vite et rediriger vers les bons contenus ou produits.'
    assign metric_1_label = 'Sujet'
    assign metric_1_value = 'Reponses nettes'
    assign metric_2_label = 'Angle'
    assign metric_2_value = 'Produit + service'
    assign metric_3_label = 'Suite'
    assign metric_3_value = 'Contact'
    assign primary_label = 'Voir les produits'
  elsif page.handle contains 'wiki' or page.handle contains 'savoir' or page.handle contains 'glossaire'
    assign page_kicker = 'Le Wiki'
    assign page_intro = 'Une base editoriale plus severe et plus lisible, faite pour accueillir ensuite vos videos, details matiere et comparatifs.'
    assign metric_1_label = 'Angle'
    assign metric_1_value = 'Pedagogique'
    assign metric_2_label = 'But'
    assign metric_2_value = 'Orienter'
    assign metric_3_label = 'Suite'
    assign metric_3_value = 'Produits'
    assign primary_link = '/pages/recettes'
    assign primary_label = 'Voir les recettes'
  elsif page.handle contains 'contact'
    assign page_kicker = 'Contact'
    assign page_intro = 'Un point de contact premium pour les demandes boutique, professionnelles ou de sourcing.'
    assign metric_1_label = 'Canal'
    assign metric_1_value = 'Direct'
    assign metric_2_label = 'Usage'
    assign metric_2_value = 'Conseil + pro'
    assign metric_3_label = 'Suite'
    assign metric_3_value = 'Accompagnement'
  elsif page.handle contains 'huile'
    assign page_kicker = 'Usage & precautions'
    assign page_intro = 'Une page qui doit rester claire, responsable et premium, sans laisser l information utile se perdre dans le decor.'
    assign metric_1_label = 'Focus'
    assign metric_1_value = 'Usage externe'
    assign metric_2_label = 'Ton'
    assign metric_2_value = 'Responsable'
    assign metric_3_label = 'Suite'
    assign metric_3_value = 'Collection'
    assign primary_link = '/collections/huiles-essentielles'
    assign primary_label = 'Voir les huiles'
  endif

  assign recipe_handles = 'caviar-vanille-bourbon-madagascar-20g,extrait-vanille-bourbon-madagascar-20ml,vanille-bourbon-madagascar-3-gousses' | split: ','
  assign catalogue_collection_handles = 'vanille-bourbon,epices-madagascar,sels-aromatises,huiles-essentielles,poivre-baies,all' | split: ','
-%}

{% if is_about_page or is_recipes_page or is_catalog_page or is_generic_page %}
  <section class="section-{{ section.id }}-padding vd-page-flow color-{{ section.settings.color_scheme }}">
    <div class="page-width">
      {% if is_about_page %}
        <div class="vd-page-flow__hero">
          <div class="vd-page-flow__hero-copy">
            <span class="vd-section-kicker">Maison</span>
            <h1 class="vd-page-flow__title">{{ page.title }}</h1>
            <div class="vd-page-flow__text">
              <p>
                Trois generations, une meme exigence: garder la vanille et les epices de Madagascar dans une relation
                directe, lisible et digne de la matiere.
              </p>
            </div>

            <div class="vd-page-flow__metrics" role="list">
              <div class="vd-page-flow__metric" role="listitem">
                <span>Origine</span>
                <strong>Madagascar</strong>
              </div>
              <div class="vd-page-flow__metric" role="listitem">
                <span>Lecture</span>
                <strong>Circuit direct</strong>
              </div>
              <div class="vd-page-flow__metric" role="listitem">
                <span>Promesse</span>
                <strong>Qualite suivie</strong>
              </div>
            </div>

            <div class="vd-page-flow__actions">
              <a class="vd-arrow-cta" href="/collections/vanille-bourbon">
                <span class="vd-arrow-cta__label">Voir la collection</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
              <a class="vd-arrow-cta" href="/pages/contact">
                <span class="vd-arrow-cta__label">Parler avec nous</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="vd-page-flow__hero-card">
            <span class="vd-page-flow__card-kicker">Pourquoi nous suivre</span>
            <h2>Une maison qui veut montrer le produit avant le folklore.</h2>
            <p>
              Nous ne cherchons pas a empiler des promesses marketing. Le site doit donner une lecture claire de
              l'origine, du geste et de l'usage final.
            </p>
          </div>
        </div>

        <div class="vd-page-flow__pillars" role="list">
          <article class="vd-page-flow__pillar" role="listitem">
            <span>01</span>
            <h2>Selection terrain</h2>
            <p>Chaque lot est choisi pour sa longueur, sa souplesse, son parfum et sa regularite.</p>
          </article>
          <article class="vd-page-flow__pillar" role="listitem">
            <span>02</span>
            <h2>Transmission familiale</h2>
            <p>Le savoir-faire n'est pas raconte comme une legende, mais comme une suite de gestes concrets.</p>
          </article>
          <article class="vd-page-flow__pillar" role="listitem">
            <span>03</span>
            <h2>Usage contemporain</h2>
            <p>On parle autant aux chefs, aux passionnes de patisserie qu'aux achats pros exigeants.</p>
          </article>
        </div>

        {% if page.content != blank %}
          <div class="vd-page-flow__prose rte">
            {{ page.content }}
          </div>
        {% endif %}
      {% endif %}

      {% if is_recipes_page %}
        <div class="vd-page-flow__hero">
          <div class="vd-page-flow__hero-copy">
            <span class="vd-section-kicker">Cuisine & usages</span>
            <h1 class="vd-page-flow__title">{{ page.title }}</h1>
            <div class="vd-page-flow__text">
              <p>
                Cette page doit devenir une porte d'entree simple: quoi utiliser, pour quel resultat, avec quel niveau
                d'intensite.
              </p>
            </div>
            <div class="vd-page-flow__actions">
              <a class="vd-arrow-cta" href="/collections/vanille-bourbon">
                <span class="vd-arrow-cta__label">Commencer par la vanille</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
              <a class="vd-arrow-cta" href="/blogs/le-wiki">
                <span class="vd-arrow-cta__label">Lire le Wiki</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="vd-page-flow__hero-card">
            <span class="vd-page-flow__card-kicker">Mode d'emploi</span>
            <h2>Des recettes courtes, visuelles et directement shoppables.</h2>
            <p>
              Vous ajouterez ensuite les videos 4K et les recettes finales, mais la structure est deja en place pour
              rendre la page exploitable.
            </p>
          </div>
        </div>

        <div class="vd-page-flow__recipe-grid" role="list">
          <article class="vd-page-flow__recipe-card" role="listitem">
            <span>Desserts</span>
            <h2>Creme, ganache, entremets, glace</h2>
            <p>Focus sur l'infusion lente, la rondeur et la profondeur aromatique.</p>
          </article>
          <article class="vd-page-flow__recipe-card" role="listitem">
            <span>Boissons</span>
            <h2>Rhum arrange, latte, sirops maison</h2>
            <p>Des formats pratiques pour travailler vite sans sacrifier l'intensite.</p>
          </article>
          <article class="vd-page-flow__recipe-card" role="listitem">
            <span>Accords sales</span>
            <h2>Poissons, sauces beurre, legumes rotis</h2>
            <p>Une lecture plus mature de la vanille, loin du seul usage sucre.</p>
          </article>
        </div>

        <div class="vd-page-flow__products">
          <div class="vd-page-flow__products-head">
            <span class="vd-section-kicker">Commencer avec</span>
            <h2>Trois formats simples pour entrer dans l'univers.</h2>
          </div>

          <div class="vd-page-flow__product-grid" role="list">
            {% for product_handle in recipe_handles %}
              {% assign product = all_products[product_handle] %}
              {% if product != blank %}
                {%- liquid
                  assign card_image = product.featured_media.preview_image | default: product.featured_image
                  assign card_subtitle = product.metafields.descriptors.subtitle.value | default: product.vendor
                -%}
                <a class="vd-page-flow__product-card" href="{{ product.url }}" role="listitem">
                  <div class="vd-page-flow__product-media">
                    {% if card_image != blank %}
                      {{
                        card_image
                        | image_url: width: 1200
                        | image_tag:
                          class: 'vd-page-flow__product-image',
                          widths: '360, 540, 720, 960, 1200',
                          sizes: '(min-width: 990px) 24vw, 92vw',
                          loading: 'lazy',
                          alt: card_image.alt | default: product.title | escape
                      }}
                    {% endif %}
                  </div>
                  <div class="vd-page-flow__product-body">
                    <span>{{ card_subtitle }}</span>
                    <h3>{{ product.title }}</h3>
                    <strong>{{ product.price | money_without_trailing_zeros }}</strong>
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if page.content != blank %}
          <div class="vd-page-flow__prose rte">
            {{ page.content }}
          </div>
        {% endif %}
      {% endif %}

      {% if is_catalog_page %}
        <div class="vd-catalogue vd-catalogue--page-flow">
          <div class="vd-catalogue__hero">
            <div class="vd-catalogue__hero-copy">
              <span class="vd-section-kicker">Catalogue</span>
              <h1 class="vd-catalogue__title">{{ page.title }}</h1>
              <div class="vd-catalogue__text">
                <p>
                  Une entree claire pour explorer la maison par univers, usages et niveau de gamme, avec une lecture
                  nette des formats, de la matiere et des suites logiques.
                </p>
              </div>

              <div class="vd-catalogue__actions">
                <a class="vd-arrow-cta" href="/collections/all">
                  <span class="vd-arrow-cta__label">Voir tous les produits</span>
                  <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                    <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                  </svg>
                </a>
                <a class="vd-arrow-cta" href="/pages/recettes">
                  <span class="vd-arrow-cta__label">Voir les recettes</span>
                  <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                    <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                  </svg>
                </a>
              </div>
            </div>

            <div class="vd-catalogue__hero-panel">
              <div class="vd-catalogue__quicklinks">
                <a href="/collections/vanille-bourbon" class="vd-catalogue__quicklink">
                  <span>Signature</span>
                  <strong>Commencer par la vanille Bourbon</strong>
                </a>
                <a href="/collections/all?filter.v.availability=1" class="vd-catalogue__quicklink">
                  <span>Selection</span>
                  <strong>Voir les produits disponibles</strong>
                </a>
                <a href="/pages/contact" class="vd-catalogue__quicklink">
                  <span>Conseil</span>
                  <strong>Nous orienter selon un usage</strong>
                </a>
              </div>

              <div class="vd-catalogue__metric-list" role="list">
                <div class="vd-catalogue__metric" role="listitem">
                  <span>Navigation</span>
                  <strong>Par univers et besoin</strong>
                </div>
                <div class="vd-catalogue__metric" role="listitem">
                  <span>Promesse</span>
                  <strong>Moins de bruit, plus de repere</strong>
                </div>
                <div class="vd-catalogue__metric" role="listitem">
                  <span>Suite</span>
                  <strong>Produits, recettes, contact</strong>
                </div>
              </div>
            </div>
          </div>

          <div class="vd-catalogue__grid" role="list">
            {% for collection_handle in catalogue_collection_handles %}
              {% assign featured_collection = collections[collection_handle] %}
              {% if featured_collection != blank %}
                {%- liquid
                  assign collection_title = featured_collection.title
                  assign collection_label = 'Explorer la collection'
                  assign collection_copy = featured_collection.description | strip_html | truncatewords: 24
                  assign collection_kicker = 'Collection'

                  case featured_collection.handle
                    when 'vanille-bourbon'
                      assign collection_kicker = 'Signature'
                      assign collection_label = 'Entrer dans la vanille'
                    when 'epices-madagascar'
                      assign collection_kicker = 'Accords'
                      assign collection_label = 'Explorer les epices'
                    when 'sels-aromatises'
                      assign collection_kicker = 'Assemblages'
                      assign collection_label = 'Voir les sels'
                    when 'huiles-essentielles'
                      assign collection_kicker = 'Usage'
                      assign collection_label = 'Voir les huiles'
                    when 'poivre-baies'
                      assign collection_kicker = 'Selection'
                      assign collection_label = 'Voir les poivres et baies'
                    when 'all'
                      assign collection_kicker = "Vue d'ensemble"
                      assign collection_label = 'Parcourir tout le catalogue'
                  endcase

                  if collection_copy == blank
                    assign collection_copy = 'Un univers pense pour aider a choisir vite, comprendre le bon usage et retrouver une lecture premium du catalogue.'
                  endif
                -%}

                <article class="vd-catalogue__card" role="listitem">
                  {% if featured_collection.featured_image != blank %}
                    <div class="vd-catalogue__card-media">
                      {{
                        featured_collection.featured_image
                        | image_url: width: 1200
                        | image_tag:
                          class: 'vd-catalogue__card-image',
                          widths: '360, 540, 720, 960, 1200',
                          sizes: '(min-width: 990px) 32vw, 92vw',
                          loading: 'lazy',
                          alt: collection_title | escape
                      }}
                    </div>
                  {% endif %}

                  <div class="vd-catalogue__card-head">
                    <span>{{ collection_kicker }}</span>
                    <strong>{{ featured_collection.all_products_count }} refs</strong>
                  </div>

                  <h2>{{ collection_title }}</h2>
                  <div class="vd-catalogue__card-text rte">
                    <p>{{ collection_copy }}</p>
                  </div>

                  <a href="{{ featured_collection.url }}" class="vd-arrow-cta">
                    <span class="vd-arrow-cta__label">{{ collection_label }}</span>
                    <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                      <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                    </svg>
                  </a>
                </article>
              {% endif %}
            {% endfor %}
          </div>

          <div class="vd-page-flow__pillars vd-catalogue__pillars" role="list">
            <article class="vd-page-flow__pillar" role="listitem">
              <span>01</span>
              <h2>Choisir par usage</h2>
              <p>Chaque entree doit aider a distinguer infusion, patisserie, cadeau, assaisonnement ou usage quotidien.</p>
            </article>
            <article class="vd-page-flow__pillar" role="listitem">
              <span>02</span>
              <h2>Relier les contenus utiles</h2>
              <p>Le catalogue doit renvoyer vers les recettes, le wiki et le contact au bon moment, sans parasiter l'achat.</p>
            </article>
            <article class="vd-page-flow__pillar" role="listitem">
              <span>03</span>
              <h2>Monter en gamme sans folklore</h2>
              <p>La tenue premium passe par la clarte, la selection et la matiere, pas par des artifices de template.</p>
            </article>
          </div>
        </div>
      {% endif %}

      {% if is_generic_page %}
        <div class="vd-page-flow__hero">
          <div class="vd-page-flow__hero-copy">
            <span class="vd-section-kicker">{{ page_kicker }}</span>
            <h1 class="vd-page-flow__title">{{ page.title }}</h1>
            <div class="vd-page-flow__text">
              <p>{{ page_intro }}</p>
            </div>

            <div class="vd-page-flow__metrics" role="list">
              <div class="vd-page-flow__metric" role="listitem">
                <span>{{ metric_1_label }}</span>
                <strong>{{ metric_1_value }}</strong>
              </div>
              <div class="vd-page-flow__metric" role="listitem">
                <span>{{ metric_2_label }}</span>
                <strong>{{ metric_2_value }}</strong>
              </div>
              <div class="vd-page-flow__metric" role="listitem">
                <span>{{ metric_3_label }}</span>
                <strong>{{ metric_3_value }}</strong>
              </div>
            </div>

            <div class="vd-page-flow__actions">
              <a class="vd-arrow-cta" href="{{ primary_link }}">
                <span class="vd-arrow-cta__label">{{ primary_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
              <a class="vd-arrow-cta" href="{{ secondary_link }}">
                <span class="vd-arrow-cta__label">{{ secondary_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            </div>
          </div>

          <div class="vd-page-flow__hero-card">
            <span class="vd-page-flow__card-kicker">Base de page</span>
            <h2>Une structure propre avant les futurs assets.</h2>
            <p>
              Cette page recupere une vraie presence visuelle, des points d entree nets et une lecture plus haut de
              gamme, meme avant l ajout des videos et contenus definitifs.
            </p>
          </div>
        </div>

        <div class="vd-page-flow__pillars" role="list">
          <article class="vd-page-flow__pillar" role="listitem">
            <span>01</span>
            <h2>Cadre immediat</h2>
            <p>Un titre, un angle et des metriques lisibles pour ne plus laisser une page partir dans le vide.</p>
          </article>
          <article class="vd-page-flow__pillar" role="listitem">
            <span>02</span>
            <h2>Parcours plus logique</h2>
            <p>Chaque page doit pouvoir renvoyer soit vers le catalogue, soit vers le wiki, soit vers le contact.</p>
          </article>
          <article class="vd-page-flow__pillar" role="listitem">
            <span>03</span>
            <h2>Direction plus luxe</h2>
            <p>Moins d effets parasites, plus de contraste, une lecture plus dure et plus stable visuellement.</p>
          </article>
        </div>

        {% if page.content != blank %}
          <div class="vd-page-flow__prose rte">
            {{ page.content }}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "VD Page Flow",
  "tag": "section",
  "class": "section section-vd-page-flow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "VD Page Flow"
    }
  ]
}
{% endschema %}
