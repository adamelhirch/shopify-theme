        assign wiki_detail_meta_badge_three = 'Qualité'
      when 'wiki-dosage-vanille'
        assign wiki_detail_meta_label = 'Guide de dosage'
        assign wiki_detail_meta_badge_one = 'Vanille'
        assign wiki_detail_meta_badge_two = 'Dosage'
        assign wiki_detail_meta_badge_three = 'Cuisine'
      when 'wiki-recycler-gousse-vanille'
        assign wiki_detail_meta_label = 'Seconde vie'
        assign wiki_detail_meta_badge_one = 'Vanille'
        assign wiki_detail_meta_badge_two = 'Recycler'
        assign wiki_detail_meta_badge_three = 'Cuisine'
      when 'wiki-poivre-quel-plat', 'wiki-sel-aromatise-quel-plat'
        assign wiki_detail_meta_label = 'Guide d’accords'
      when 'wiki-recettes'
        assign wiki_detail_meta_label = 'Accords & usages'
        assign wiki_detail_meta_badge_one = 'Recettes'
        assign wiki_detail_meta_badge_two = 'Accords'
      when 'wiki-glossaire-epices'
        assign wiki_detail_meta_label = 'Glossaire'
        assign wiki_detail_meta_badge_one = 'Vocabulaire'
        assign wiki_detail_meta_badge_two = 'Repères'
      when 'wiki-faq-vanille-epices'
        assign wiki_detail_meta_label = 'Questions fréquentes'
        assign wiki_detail_meta_badge_one = 'FAQ'
        assign wiki_detail_meta_badge_two = 'Réponses'
      when 'wiki-savoir-faire-producteurs'
        assign wiki_detail_meta_label = 'Filière & savoir-faire'
        assign wiki_detail_meta_badge_one = 'Producteurs'
        assign wiki_detail_meta_badge_two = 'Traçabilité'
      when 'wiki-bienfaits-sante'
        assign wiki_detail_meta_label = 'Repères d’usage'
        assign wiki_detail_meta_badge_one = 'Épices'
        assign wiki_detail_meta_badge_two = 'Usages'
    endcase

    assign wiki_detail_show_secondary = false
    if wiki_detail_secondary_url != blank and wiki_detail_secondary_label != blank and wiki_detail_secondary_url != wiki_detail_primary_url
      assign wiki_detail_show_secondary = true
    endif

    assign wiki_detail_show_collection = false
    if wiki_detail_collection_url != blank
      if wiki_detail_collection_url != wiki_detail_primary_url and wiki_detail_collection_url != wiki_detail_secondary_url and wiki_detail_collection_label != blank
        assign wiki_detail_show_collection = true
      endif
    endif

    assign wiki_detail_meta_date_source = page.published_at | default: 'now'
    assign wiki_detail_meta_day = wiki_detail_meta_date_source | date: '%-d'
    assign wiki_detail_meta_year = wiki_detail_meta_date_source | date: '%Y'
    assign wiki_detail_meta_month_number = wiki_detail_meta_date_source | date: '%-m'
    case wiki_detail_meta_month_number
      when '1'
        assign wiki_detail_meta_month = 'janvier'
      when '2'
        assign wiki_detail_meta_month = 'février'
      when '3'
        assign wiki_detail_meta_month = 'mars'
      when '4'
        assign wiki_detail_meta_month = 'avril'
      when '5'
        assign wiki_detail_meta_month = 'mai'
      when '6'
        assign wiki_detail_meta_month = 'juin'
      when '7'
        assign wiki_detail_meta_month = 'juillet'
      when '8'
        assign wiki_detail_meta_month = 'août'
      when '9'
        assign wiki_detail_meta_month = 'septembre'
      when '10'
        assign wiki_detail_meta_month = 'octobre'
      when '11'
        assign wiki_detail_meta_month = 'novembre'
      when '12'
        assign wiki_detail_meta_month = 'décembre'
    endcase
    assign wiki_detail_meta_date = wiki_detail_meta_day | append: ' ' | append: wiki_detail_meta_month | append: ' ' | append: wiki_detail_meta_year
  -%}
