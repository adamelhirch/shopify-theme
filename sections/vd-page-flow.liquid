            <a href="#wiki-categories-{{ section.id }}">Explorer</a>
            <a href="#wiki-faq-{{ section.id }}">FAQ</a>
          </nav>

          <section class="vd-wiki-page__section" aria-labelledby="wiki-essentiel-{{ section.id }}">
            <div class="vd-wiki-page__section-head">
              <span class="vd-section-kicker">{{ section.settings.wiki_essentials_eyebrow | default: 'Vanille' }}</span>
              <h2 class="vd-wiki-page__section-title" id="wiki-essentiel-{{ section.id }}">{{ section.settings.wiki_essentials_heading | default: 'Vanille — l’essentiel' }}</h2>
              <div class="vd-wiki-page__section-text rte">
                {{ section.settings.wiki_essentials_text | default: '<p>Tout savoir sur la <strong>vanille Bourbon</strong> : reconnaître une gousse de qualité, la préparer, la conserver et l’utiliser selon vos recettes.</p>' }}
              </div>
            </div>

            <div class="vd-wiki-page__featured-grid" role="list">
              {% if wiki_feature_count > 0 %}
                {% for block in section.blocks %}
                  {% if block.type == 'wiki_feature' %}
                    {%- liquid
                      assign wiki_feature_asset = wiki_card_1_asset
                      if forloop.index == 2
                        assign wiki_feature_asset = wiki_card_2_asset
                      elsif forloop.index == 3
                        assign wiki_feature_asset = wiki_card_3_asset
                      endif
                    -%}
                    <article class="vd-wiki-page__feature" role="listitem" {{ block.shopify_attributes }}>
                      <div class="vd-wiki-page__feature-media">
                        {% if block.settings.image != blank %}
                          {{
                            block.settings.image
                            | image_url: width: 1600
                            | image_tag:
                              widths: '540, 720, 960, 1200, 1600',
                              sizes: '(min-width: 990px) 24vw, 100vw',
                              loading: 'lazy',
                              alt: block.settings.title | escape
                          }}
                        {% else %}
                          <img src="{{ wiki_feature_asset | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="1201" height="800">
                        {% endif %}
                      </div>
                      <div class="vd-wiki-page__feature-body">
                        {% if block.settings.kicker != blank %}
                          <span class="vd-wiki-page__category-kicker">{{ block.settings.kicker }}</span>
                        {% endif %}
                        <h3 class="vd-wiki-page__feature-title">{{ block.settings.title }}</h3>
                        {% if block.settings.text != blank %}
                          <div class="vd-wiki-page__feature-text rte">
                            <p>{{ block.settings.text }}</p>
                          </div>
                        {% endif %}
                        {% if block.settings.point_1 != blank or block.settings.point_2 != blank or block.settings.point_3 != blank %}
                          <ul class="vd-wiki-page__feature-list">
                            {% if block.settings.point_1 != blank %}<li>{{ block.settings.point_1 }}</li>{% endif %}
                            {% if block.settings.point_2 != blank %}<li>{{ block.settings.point_2 }}</li>{% endif %}
                            {% if block.settings.point_3 != blank %}<li>{{ block.settings.point_3 }}</li>{% endif %}
                          </ul>
                        {% endif %}
                        {% if block.settings.link != blank and block.settings.link_label != blank %}
                          <a href="{{ block.settings.link }}" class="vd-arrow-cta" data-vd-preview-link>
                            <span class="vd-arrow-cta__label">{{ block.settings.link_label }}</span>
                            <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                              <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                            </svg>
                          </a>
                        {% endif %}
                      </div>
                    </article>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>
          </section>

          <section class="vd-wiki-page__section" aria-labelledby="wiki-categories-{{ section.id }}">
            <div class="vd-wiki-page__section-head">
