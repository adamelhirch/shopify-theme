{%- liquid
  assign autoplay_seconds = section.settings.autoplay_seconds | default: 6
  assign overlay_alpha = section.settings.overlay_opacity | default: 40
  assign overlay_alpha_fraction = overlay_alpha | divided_by: 100.0
-%}

<section
  class="vd-ss"
  data-vd-slideshow
  data-autoplay="{{ autoplay_seconds }}"
  style="--vd-ss-overlay: rgba(30, 17, 10, {{ overlay_alpha_fraction }});"
>
  <div class="vd-ss__track" role="region" aria-label="Diaporama" aria-roledescription="carousel">
    {%- for block in section.blocks -%}
      <div
        class="vd-ss__slide{% if forloop.first %} is-active{% endif %}"
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} sur {{ section.blocks.size }}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        <div class="vd-ss__bg">
          {%- liquid
            if forloop.first
              assign img_loading = 'eager'
              assign img_priority = 'high'
            else
              assign img_loading = 'lazy'
              assign img_priority = 'auto'
            endif
            assign img_alt = block.settings.title | default: '' | escape
          -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 2400 | image_tag: widths: '600,900,1200,1600,2000,2400', sizes: '100vw', loading: img_loading, fetchpriority: img_priority, alt: img_alt, class: 'vd-ss__bg-img' }}
          {%- else -%}
            {%- liquid
              # Placeholders dédiés au slideshow home, distincts du
              # wiki-teaser, du hub wiki et des images de collection.
              # 0 → Slide "Livraison 48h"
              # 1 → Slide "Vanille Bourbon"
              # +  fallbacks génériques pour les slides additionnels
              assign placeholders = 'photo-1607344645866-009c320b63e0|photo-1488477181946-6428a0291777|photo-1547592180-85f173990554|photo-1599058945522-28d584b6f0ff' | split: '|'
              assign ph_idx = forloop.index0
              if ph_idx >= placeholders.size
                assign ph_idx = placeholders.size | minus: 1
              endif
              assign ph = placeholders[ph_idx]
            -%}
            <img
              src="https://images.unsplash.com/{{ ph }}?w=2400&auto=format&fit=crop"
              alt=""
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="2400"
              height="1200"
              class="vd-ss__bg-img"
            >
          {%- endif -%}
          <div class="vd-ss__overlay" aria-hidden="true"></div>
        </div>

        <div class="vd-ss__content">
          {%- if block.settings.eyebrow != blank -%}
            <div class="vd-ss__eyebrow">{{ block.settings.eyebrow }}</div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h2 class="vd-ss__title">{{ block.settings.title }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="vd-ss__text">{{ block.settings.text }}</p>
          {%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <a href="{{ block.settings.cta_link | default: '#' }}" class="vd-ss__cta vd-btn-outline-animated">
              <span class="vd-btn-outline-animated__label">{{ block.settings.cta_label }}</span>
            </a>
          {%- endif -%}
        </div>

        {%- if block.settings.legal != blank -%}
          <div class="vd-ss__legal">{{ block.settings.legal }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="vd-ss__controls">
      <div class="vd-ss__markers" role="tablist" aria-label="Sélectionner un slide">
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="vd-ss__marker{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Aller au slide {{ forloop.index }}"
            data-slide-target="{{ forloop.index0 }}"
          >
            <span class="vd-ss__marker-fill" aria-hidden="true"></span>
          </button>
        {%- endfor -%}
      </div>
      <button
        type="button"
        class="vd-ss__autoplay-btn"
        aria-label="Activer/désactiver la lecture automatique"
        aria-pressed="true"
        data-vd-autoplay-toggle
      >
        <svg class="vd-ss__autoplay-icon vd-ss__autoplay-icon--pause" aria-hidden="true" focusable="false" width="9" viewBox="0 0 9 11" fill="none">
          <path stroke="currentColor" stroke-linecap="square" stroke-linejoin="round" stroke-width="2" d="M1.5 1.5v8M7.5 1.5v8"/>
        </svg>
        <svg class="vd-ss__autoplay-icon vd-ss__autoplay-icon--play" aria-hidden="true" focusable="false" width="10" viewBox="0 0 10 12" fill="none">
          <path fill="currentColor" stroke="currentColor" stroke-width="1.5" d="M1 9.938V1.5l7.031 4.219L1 9.937Z"/>
        </svg>
      </button>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Slideshow plein écran",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "autoplay_seconds",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6,
      "unit": "s",
      "label": "Durée par slide (autoplay)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "%",
      "label": "Opacité du voile sombre sur l'image"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image de fond" },
        { "type": "text", "id": "eyebrow", "label": "Sur-titre (badge)" },
        { "type": "text", "id": "title", "label": "Titre" },
        { "type": "textarea", "id": "text", "label": "Texte" },
        { "type": "text", "id": "cta_label", "label": "Bouton — libellé" },
        { "type": "url", "id": "cta_link", "label": "Bouton — lien" },
        { "type": "text", "id": "legal", "label": "Mention en bas à gauche" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow plein écran",
      "category": "Accueil",
      "blocks": [
        { "type": "slide", "settings": { "eyebrow": "Maintenant disponible", "title": "Livraison en 48h", "text": "Commandez avant 14h, expédié le jour-même.", "cta_label": "Commander maintenant" } },
        { "type": "slide", "settings": { "eyebrow": "La sélection du moment", "title": "Récolte 2026", "text": "Les nouvelles gousses Bourbon enfin disponibles.", "cta_label": "Découvrir" } }
      ]
    }
  ]
}
{% endschema %}
