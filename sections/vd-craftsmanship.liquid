<div class="vd-savoir color-{{ section.settings.color_scheme }}" data-vd-savoir>
  {%- comment -%} ── Header asymetrique ── {%- endcomment -%}
  <div class="page-width vd-savoir__header">
    <div class="vd-savoir__header-grid">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="vd-section-kicker">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="vd-savoir__title">
            {{ section.settings.heading }}
            {% if section.settings.heading_accent != blank %}
              <span class="vd-savoir__title-accent">{{ section.settings.heading_accent }}</span>
            {% endif %}
          </h2>
        {% endif %}
      </div>

      {% if section.settings.text != blank %}
        <div class="vd-savoir__lede rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="vd-savoir__line" data-vd-savoir-line></div>
  </div>

  {%- comment -%} ── Steps grid ── {%- endcomment -%}
  <div class="page-width vd-savoir__steps">
    {% for block in section.blocks %}
      <div
        class="vd-savoir__step{% if forloop.index == 2 or forloop.index == 4 %} vd-savoir__step--offset{% endif %}"
        data-vd-savoir-step
        {{ block.shopify_attributes }}
      >
        {%- liquid
          assign step_fallbacks = 'savoir-recolte.jpg,savoir-echaudage.jpg,savoir-sechage.jpg,savoir-affinage.jpg' | split: ','
          assign step_fallback = step_fallbacks[forloop.index0]
        -%}
        <div class="vd-savoir__step-preview" aria-hidden="true">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 600
              | image_tag:
                class: 'vd-savoir__step-preview-img',
                widths: '300, 400, 600',
                sizes: '280px',
                loading: 'lazy',
                alt: ''
            }}
          {% elsif step_fallback %}
            <img
              class="vd-savoir__step-preview-img"
              src="{{ step_fallback | asset_url }}"
              alt=""
              loading="lazy"
              width="600"
              height="800"
            >
          {% endif %}
        </div>

        <span class="vd-savoir__number" aria-hidden="true">{{ block.settings.step_label | default: forloop.index | prepend: '0' }}</span>
        <h3 class="vd-savoir__step-title">{{ block.settings.title }}</h3>

        {% if block.settings.text != blank %}
          <div class="vd-savoir__step-text rte">{{ block.settings.text }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {%- comment -%} ── Marquee ── {%- endcomment -%}
  <div class="vd-savoir__marquee" aria-hidden="true">
    <div class="vd-savoir__marquee-track">
      {% for i in (1..3) %}
        <span class="vd-savoir__marquee-word">Recolte</span>
        <span class="vd-savoir__marquee-sep">&</span>
        <span class="vd-savoir__marquee-word">Echaudage</span>
        <span class="vd-savoir__marquee-sep">&</span>
        <span class="vd-savoir__marquee-word">Etuvage</span>
        <span class="vd-savoir__marquee-sep">&</span>
        <span class="vd-savoir__marquee-word">Sechage</span>
        <span class="vd-savoir__marquee-sep">&</span>
        <span class="vd-savoir__marquee-word">Affinage</span>
        <span class="vd-savoir__marquee-sep">&</span>
        <span class="vd-savoir__marquee-word">Selection</span>
        <span class="vd-savoir__marquee-sep">&</span>
        <span class="vd-savoir__marquee-word">Conditionnement</span>
        <span class="vd-savoir__marquee-sep">&</span>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VD Savoir-faire",
  "tag": "section",
  "class": "section section-vd-craftsmanship",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Heritage"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "De la liane"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent titre (italique)",
      "default": "a votre cuisine"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Un processus de 2 ans, guide par la patience et l'exigence, pour reveler toute la richesse aromatique de chaque gousse.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libelle bouton",
      "default": "Notre histoire"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "story_panel",
      "name": "Etape",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Numero",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Recolte"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>Cueillette manuelle des gousses a maturite optimale.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optionnel)"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (optionnel)"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Citation (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Savoir-faire",
      "blocks": [
        {
          "type": "story_panel",
          "settings": {
            "step_label": "01",
            "title": "Recolte",
            "text": "<p>Cueillette manuelle des gousses a maturite optimale, entre juin et septembre, dans la region SAVA.</p>"
          }
        },
        {
          "type": "story_panel",
          "settings": {
            "step_label": "02",
            "title": "Echaudage",
            "text": "<p>Les gousses sont plongees dans l'eau chaude pour initier la transformation enzymatique.</p>"
          }
        },
        {
          "type": "story_panel",
          "settings": {
            "step_label": "03",
            "title": "Sechage lent",
            "text": "<p>Alternance de soleil et d'ombre pendant plusieurs semaines. La patience faconne chaque gousse.</p>"
          }
        },
        {
          "type": "story_panel",
          "settings": {
            "step_label": "04",
            "title": "Affinage",
            "text": "<p>24 mois en malles de bois. C'est ici que naissent les 300+ composes aromatiques.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
