{%- comment -%}
  Wiki teaser — clone du `vd-yc-slideshow` (`.vd-ss` + `data-vd-slideshow`)
  pour bénéficier de la même mécanique : transition curtain, autoplay,
  markers de progression, play/pause, swipe. Chaque slide pointe vers
  un article du wiki.
{%- endcomment -%}

{%- liquid
  assign autoplay_seconds = section.settings.autoplay_seconds | default: 6
  assign overlay_alpha = section.settings.overlay_opacity | default: 45
  assign overlay_alpha_fraction = overlay_alpha | divided_by: 100.0
-%}

<section
  class="vd-ss"
  data-vd-slideshow
  data-autoplay="{{ autoplay_seconds }}"
  style="--vd-ss-overlay: rgba(30, 17, 10, {{ overlay_alpha_fraction }});"
>
  <div class="vd-ss__track" role="region" aria-label="Wiki Vanille Désiré" aria-roledescription="carousel">
    {%- for block in section.blocks -%}
      <div
        class="vd-ss__slide{% if forloop.first %} is-active{% endif %}"
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} sur {{ section.blocks.size }}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        <div class="vd-ss__bg">
          {%- liquid
            if forloop.first
              assign img_loading = 'eager'
              assign img_priority = 'high'
            else
              assign img_loading = 'lazy'
              assign img_priority = 'auto'
            endif
            assign img_alt = block.settings.title | default: '' | escape
          -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 2400 | image_tag: widths: '600,900,1200,1600,2000,2400', sizes: '100vw', loading: img_loading, fetchpriority: img_priority, alt: img_alt, class: 'vd-ss__bg-img' }}
          {%- else -%}
            {%- liquid
              # Placeholders Unsplash sélectionnés et vérifiés (HTTP 200) par
              # étape du parcours de la vanille. L'admin peut override en
              # uploadant une image dans le bloc depuis l'éditeur Shopify.
              # 0 → Plantation     : liane sur tuteur bois
              # 1 → Pollinisation  : fleur blanche close-up
              # 2 → Récolte        : main tenant la plante
              # 3 → Échaudage      : gousse de vanille
              # 4 → Affinage       : faisceau de gousses sur planche bois
              # +  fallback générique (épices)
              assign placeholders = 'photo-1752006477826-3dd029cdf5c1|photo-1689862319562-45022bedab06|photo-1617122776253-1ef0005b8646|photo-1592788174877-3f99727fd23d|photo-1682482198446-4cbf92f85a4b|photo-1716816211590-c15a328a5ff0' | split: '|'
              assign ph_idx = forloop.index0
              if ph_idx >= placeholders.size
                assign ph_idx = placeholders.size | minus: 1
              endif
              assign ph = placeholders[ph_idx]
            -%}
            <img
              src="https://images.unsplash.com/{{ ph }}?w=2400&auto=format&fit=crop"
              alt=""
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="2400"
              height="1200"
              class="vd-ss__bg-img"
            >
          {%- endif -%}
          <div class="vd-ss__overlay" aria-hidden="true"></div>
        </div>

        <div class="vd-ss__content">
          {%- if block.settings.eyebrow != blank -%}
            <div class="vd-ss__eyebrow">{{ block.settings.eyebrow }}</div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h2 class="vd-ss__title">{{ block.settings.title }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="vd-ss__text">{{ block.settings.text }}</p>
          {%- endif -%}
          {%- if block.settings.cta_link != blank -%}
            <a href="{{ block.settings.cta_link }}" class="vd-ss__cta vd-btn-outline-animated">
              <span class="vd-btn-outline-animated__label">{{ block.settings.cta_label | default: "Lire l'article" }}</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="vd-ss__controls">
      <div class="vd-ss__markers" role="tablist" aria-label="Sélectionner un article">
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="vd-ss__marker{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Aller à l'article {{ forloop.index }}"
            data-slide-target="{{ forloop.index0 }}"
          >
            <span class="vd-ss__marker-fill" aria-hidden="true"></span>
          </button>
        {%- endfor -%}
      </div>
      <button
        type="button"
        class="vd-ss__autoplay-btn"
        aria-label="Activer/désactiver la lecture automatique"
        aria-pressed="true"
        data-vd-autoplay-toggle
      >
        <svg class="vd-ss__autoplay-icon vd-ss__autoplay-icon--pause" aria-hidden="true" focusable="false" width="9" viewBox="0 0 9 11" fill="none">
          <path stroke="currentColor" stroke-linecap="square" stroke-linejoin="round" stroke-width="2" d="M1.5 1.5v8M7.5 1.5v8"/>
        </svg>
        <svg class="vd-ss__autoplay-icon vd-ss__autoplay-icon--play" aria-hidden="true" focusable="false" width="10" viewBox="0 0 10 12" fill="none">
          <path fill="currentColor" stroke="currentColor" stroke-width="1.5" d="M1 9.938V1.5l7.031 4.219L1 9.937Z"/>
        </svg>
      </button>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Étapes — wiki",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "range",
      "id": "autoplay_seconds",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6,
      "unit": "s",
      "label": "Durée par article (autoplay)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 45,
      "unit": "%",
      "label": "Opacité du voile sombre sur l'image"
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Étape",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image de fond" },
        { "type": "text", "id": "eyebrow", "label": "Sur-titre (Ex: Étape 1)" },
        { "type": "text", "id": "title", "label": "Titre de l'étape" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "cta_label", "label": "Bouton — libellé (laisser vide sauf sur la dernière étape)" },
        { "type": "url", "id": "cta_link", "label": "Lien (typiquement vers le wiki sur la dernière étape)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Étapes — wiki",
      "category": "Accueil",
      "blocks": [
        { "type": "article", "settings": { "eyebrow": "Étape 1", "title": "Plantation de la liane", "text": "Sur les terres malgaches, la liane de vanille est plantée à l'ombre légère des tuteurs naturels et grandit pendant 3 à 4 ans avant la première floraison." } },
        { "type": "article", "settings": { "eyebrow": "Étape 2", "title": "Pollinisation à la main", "text": "Chaque fleur n'est ouverte que quelques heures et doit être pollinisée manuellement, geste précis transmis de génération en génération." } },
        { "type": "article", "settings": { "eyebrow": "Étape 3", "title": "Récolte à maturité", "text": "9 mois plus tard, les gousses encore vertes sont récoltées une à une, au bon stade, pour préserver tout le potentiel aromatique." } },
        { "type": "article", "settings": { "eyebrow": "Étape 4", "title": "Échaudage & étuvage", "text": "Les gousses sont plongées dans l'eau chaude puis enveloppées : c'est le déclic qui amorce le développement de la vanilline." } },
        { "type": "article", "settings": { "eyebrow": "Étape 5", "title": "Affinage en malle", "text": "Plusieurs mois en malles cloturées, dans l'obscurité : les gousses se patinent, s'huilent et concentrent leur arôme.", "cta_label": "En savoir plus", "cta_link": "/pages/wiki" } }
      ]
    }
  ]
}
{% endschema %}
