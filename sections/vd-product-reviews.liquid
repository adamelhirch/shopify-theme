{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign product_reviews = blank
  assign use_json_reviews = false
  assign reviews_count = 0
  assign review_limit = section.settings.reviews_limit | plus: 0
  assign reviews_total = 0
  assign average_rating = blank
  assign featured_review = blank
  assign has_reviews = false
  assign review_count_label = blank

  if product != blank and product.metafields.custom.vd_reviews.value != blank
    assign product_reviews = product.metafields.custom.vd_reviews.value
    assign reviews_count = product_reviews.count | default: product_reviews.size | default: 0
  elsif product != blank and product.metafields.custom.vd_reviews_json.value != blank
    assign product_reviews = product.metafields.custom.vd_reviews_json.value
    assign reviews_count = product_reviews.size | default: 0
    assign use_json_reviews = true
  endif

  if reviews_count > 0
    assign has_reviews = true
    assign featured_review = product_reviews.first

    if product.metafields.custom.vd_rating_average.value != blank
      assign average_rating = product.metafields.custom.vd_rating_average.value | plus: 0
    else
      for review in product_reviews
        if use_json_reviews
          assign review_rating = review.rating | default: 5 | plus: 0
        else
          assign review_rating = review.rating.value | default: 5 | plus: 0
        endif
        assign reviews_total = reviews_total | plus: review_rating
      endfor

      if reviews_count > 0
        assign average_rating = reviews_total | times: 1.0 | divided_by: reviews_count
      endif
    endif
  endif

  if product.metafields.custom.vd_rating_count.value != blank
    assign review_count_label = product.metafields.custom.vd_rating_count.value
  elsif product.metafields.custom.vd_rating_count != blank
    assign review_count_label = product.metafields.custom.vd_rating_count
  else
    assign review_count_label = reviews_count
  endif
-%}

<section class="section-{{ section.id }}-padding vd-product-reviews color-{{ section.settings.color_scheme }}">
  <div class="page-width vd-product-reviews__shell">
    <div class="vd-product-reviews__head">
      <div class="vd-product-reviews__intro">
        {% if section.settings.eyebrow != blank %}
          <span class="vd-section-kicker">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="vd-product-reviews__title">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>

      <div class="vd-product-reviews__summary">
        {% if section.settings.text != blank %}
          <div class="vd-product-reviews__text rte">{{ section.settings.text }}</div>
        {% endif %}

        <div class="vd-product-reviews__score">
          {% if has_reviews %}
            <strong>{{ average_rating | default: 5 | round: 1 }}/5</strong>
            <span>{{ review_count_label }} avis relies a ce produit</span>
          {% else %}
            <strong>0 avis</strong>
            <span>{{ section.settings.empty_label }}</span>
          {% endif %}
        </div>
      </div>
    </div>

    {% if has_reviews %}
      {%- liquid
        assign featured_is_verified = false

        if use_json_reviews
          assign featured_rating = featured_review.rating | default: 5 | round
          assign featured_quote = featured_review.quote | default: blank
          assign featured_author = featured_review.author | default: 'Client'
          assign featured_context = featured_review.context | default: blank
          assign featured_source = featured_review.source | default: blank

          if featured_review.review_date != blank
            assign featured_context = featured_review.review_date | date: '%d/%m/%Y'
          endif

          if featured_review.verified == true or featured_review.verified == 'true'
            assign featured_is_verified = true
          endif
        else
          assign featured_rating = featured_review.rating.value | default: 5 | round
          assign featured_quote = featured_review.quote.value | default: blank
          assign featured_author = featured_review.author.value | default: 'Client'
          assign featured_context = featured_review.context.value | default: blank
          assign featured_source = featured_review.source.value | default: blank

          if featured_review.review_date.value != blank
            assign featured_context = featured_review.review_date.value | date: '%d/%m/%Y'
          endif

          if featured_review.verified.value == true
            assign featured_is_verified = true
          endif
        endif

        if featured_source == blank
          assign featured_source = 'Avis client'
        endif
      -%}

      <div class="vd-product-reviews__layout">
        <article class="vd-product-reviews__featured">
          <div class="vd-product-reviews__featured-topline">
            <div class="vd-product-reviews__source-row">
              <span class="vd-product-reviews__source">{{ featured_source }}</span>
              {% if featured_is_verified %}
                {% render 'vd-review-verified-badge', class: 'vd-review-verified-badge' %}
              {% endif %}
            </div>
            {% render 'vd-review-stars', rating: featured_rating, class: 'vd-product-reviews__stars' %}
          </div>

          {% if featured_quote != blank %}
            <blockquote class="vd-product-reviews__featured-quote">{{ featured_quote }}</blockquote>
          {% endif %}

          <div class="vd-product-reviews__featured-meta">
            <strong>{{ featured_author }}</strong>
            {% if featured_context != blank %}
              <span>{{ featured_context }}</span>
            {% endif %}
          </div>
        </article>

        <div class="vd-product-reviews__list" role="list">
          {% for review in product_reviews limit: review_limit offset: 1 %}
            {%- liquid
              assign review_is_verified = false

              if use_json_reviews
                assign review_rating = review.rating | default: 5 | round
                assign review_quote = review.quote | default: blank
                assign review_author = review.author | default: 'Client'
                assign review_context = review.context | default: blank
                assign review_source = review.source | default: blank

                if review.review_date != blank
                  assign review_context = review.review_date | date: '%d/%m/%Y'
                endif

                if review.verified == true or review.verified == 'true'
                  assign review_is_verified = true
                endif
              else
                assign review_rating = review.rating.value | default: 5 | round
                assign review_quote = review.quote.value | default: blank
                assign review_author = review.author.value | default: 'Client'
                assign review_context = review.context.value | default: blank
                assign review_source = review.source.value | default: blank

                if review.review_date.value != blank
                  assign review_context = review.review_date.value | date: '%d/%m/%Y'
                endif

                if review.verified.value == true
                  assign review_is_verified = true
                endif
              endif

              if review_source == blank
                assign review_source = 'Avis client'
              endif
            -%}

            <article class="vd-product-reviews__card" role="listitem">
              <div class="vd-product-reviews__card-topline">
                <div class="vd-product-reviews__source-row">
                  <span class="vd-product-reviews__source">{{ review_source }}</span>
                  {% if review_is_verified %}
                    {% render 'vd-review-verified-badge', class: 'vd-review-verified-badge' %}
                  {% endif %}
                </div>
                {% render 'vd-review-stars', rating: review_rating, class: 'vd-product-reviews__stars' %}
              </div>

              {% if review_quote != blank %}
                <blockquote class="vd-product-reviews__quote">{{ review_quote }}</blockquote>
              {% endif %}

              <div class="vd-product-reviews__meta">
                <strong>{{ review_author }}</strong>
                {% if review_context != blank %}
                  <span>{{ review_context }}</span>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="vd-product-reviews__empty">
        <p>{{ section.settings.empty_text }}</p>
      </div>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="vd-product-reviews__footer">
        <a href="{{ section.settings.button_link }}" class="vd-arrow-cta">
          <span class="vd-arrow-cta__label">{{ section.settings.button_label }}</span>
          <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
            <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
          </svg>
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "VD Product Reviews",
  "tag": "section",
  "class": "section section-vd-product-reviews",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Avis produit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Les retours relies directement a cette fiche."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Une lecture plus simple et plus franche: uniquement les avis relies au produit courant, sans widget externe.</p>"
    },
    {
      "type": "text",
      "id": "empty_label",
      "label": "Label sans avis",
      "default": "Les premiers retours arriveront ici"
    },
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Texte sans avis",
      "default": "Aucun avis n'est encore relie a ce produit. La section est deja prete pour lire les prochains retours custom."
    },
    {
      "type": "select",
      "id": "reviews_limit",
      "label": "Nombre d'avis affiches",
      "default": "5",
      "options": [
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libelle bouton"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "VD Product Reviews"
    }
  ]
}
{% endschema %}
