{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign story_catalogue_page = pages['catalogue']
  assign story_contact_page = pages['contact']
  assign story_recipes_page = pages['recettes']
  assign story_wiki_page = pages['wiki']
  assign story_vanille_page = pages['wiki-vanille-bien-choisir']
  assign render_story_grid = true
  assign story_catalogue_url = story_catalogue_page.url | default: routes.all_products_collection_url
  assign story_contact_url = story_contact_page.url | default: '/pages/contact'
  assign story_recipes_url = story_recipes_page.url | default: '/pages/recettes'
  assign story_wiki_url = story_wiki_page.url | default: '/pages/wiki'
  assign story_vanille_url = story_vanille_page.url | default: '/pages/wiki-vanille-bien-choisir'

  if request.page_type == 'collection'
    assign render_story_grid = false

    if collection.handle == 'vanille-bourbon' or collection.handle == 'epices-madagascar' or collection.handle == 'poivre-baies'
      assign render_story_grid = true
    endif
  endif
-%}
{%- assign story_intro_text = section.settings.text | replace: '/pages/wiki-vanille-bien-choisir', story_vanille_url | replace: '/pages/recettes', story_recipes_url | replace: '/pages/catalogue', story_catalogue_url | replace: '/pages/contact', story_contact_url | replace: '/pages/wiki', story_wiki_url -%}

{% if render_story_grid %}
  <section class="section-{{ section.id }}-padding vd-story color-{{ section.settings.color_scheme }}">
    <div class="page-width">
      <div class="vd-story__head">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if story_intro_text != blank %}
          <div class="rte">{{ story_intro_text }}</div>
        {% endif %}
      </div>

      <div class="vd-story__grid">
        {% for block in section.blocks %}
          {%- liquid
            assign story_background_video_url = ''
            assign story_background_image = block.settings.background_image
            assign story_media_index = forloop.index0
            assign story_block_text = block.settings.text

            if block.settings.background_video != blank
              for source in block.settings.background_video.sources
                if source.mime_type == 'video/mp4'
                  assign story_background_video_url = source.url
                  break
                endif
              endfor
            endif

            if story_background_image == blank and product != blank and product.media[story_media_index] != blank
              assign story_background_image = product.media[story_media_index].preview_image | default: product.media[story_media_index]
            endif

            if story_background_image == blank and product != blank and product.featured_media != blank
              assign story_background_image = product.featured_media.preview_image | default: product.featured_image
            endif

          -%}
          {%- assign story_block_text = story_block_text | replace: '/pages/wiki-vanille-bien-choisir', story_vanille_url | replace: '/pages/recettes', story_recipes_url | replace: '/pages/catalogue', story_catalogue_url | replace: '/pages/contact', story_contact_url | replace: '/pages/wiki', story_wiki_url -%}
          <article class="vd-story-card vd-story-card--{{ forloop.index }}{% if story_background_video_url != blank or story_background_image != blank %} vd-story-card--immersive{% endif %}" {{ block.shopify_attributes }}>
            {% if story_background_video_url != blank or story_background_image != blank %}
              <div class="vd-story-card__media" aria-hidden="true">
                {% if story_background_video_url != blank %}
                  <video
                    class="vd-story-card__video"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="none"
                    data-vd-deferred-video
                    data-video-src="{{ story_background_video_url }}"
                  >
                    <source data-src="{{ story_background_video_url }}" type="video/mp4">
                  </video>
                {% elsif story_background_image != blank %}
                  {{
                    story_background_image
                    | image_url: width: 1600
                    | image_tag:
                      class: 'vd-story-card__image',
                      widths: '480, 720, 960, 1280, 1600',
                      sizes: '(min-width: 990px) 33vw, 100vw',
                      loading: 'lazy',
                      alt: ''
                  }}
                {% endif %}
              </div>
              <div class="vd-story-card__veil" aria-hidden="true"></div>
            {% endif %}
            <span class="vd-story-card__index">{{ forloop.index }}</span>
            {% if block.settings.title != blank %}
              <h3 class="vd-story-card__title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if story_block_text != blank %}
              <div class="rte">{{ story_block_text }}</div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "VD Story Grid",
  "tag": "section",
  "class": "section section-vd-story-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Une boutique pensée comme un objet de dégustation."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Le thème met en avant une promesse simple : peu d’éléments, beaucoup d’air, et une matière noble qui parle d’elle-même.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pilier",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Origine maîtrisée"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>Une lecture claire des provenances, des usages et du niveau d’intensité attendu.</p>"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Image ou GIF de fond"
        },
        {
          "type": "video",
          "id": "background_video",
          "label": "Vidéo Shopify de fond"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Story Grid",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Origine maîtrisée",
            "text": "<p>Chaque lot peut être raconté en quelques mots, sans surcharge, avec une hiérarchie d’information nette.</p>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Design silencieux",
            "text": "<p>Anthracite profond, contrastes mesurés et surfaces satinées pour laisser le produit dominer.</p>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Conversion premium",
            "text": "<p>Des appels à l’action francs, des cartes généreuses et une expérience qui reste fluide sur mobile.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
