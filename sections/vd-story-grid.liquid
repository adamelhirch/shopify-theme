{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-padding vd-story color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="vd-story__head">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="vd-story__grid">
      {% for block in section.blocks %}
        <article class="vd-story-card" {{ block.shopify_attributes }}>
          <span class="vd-story-card__index">{{ forloop.index }}</span>
          {% if block.settings.title != blank %}
            <h3 class="vd-story-card__title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="rte">{{ block.settings.text }}</div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Story Grid",
  "tag": "section",
  "class": "section section-vd-story-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Une boutique pensée comme un objet de dégustation."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Le thème met en avant une promesse simple : peu d’éléments, beaucoup d’air, et une matière noble qui parle d’elle-même.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pilier",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Origine maîtrisée"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>Une lecture claire des provenances, des usages et du niveau d’intensité attendu.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Story Grid",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Origine maîtrisée",
            "text": "<p>Chaque lot peut être raconté en quelques mots, sans surcharge, avec une hiérarchie d’information nette.</p>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Design silencieux",
            "text": "<p>Anthracite profond, contrastes mesurés et surfaces satinées pour laisser le produit dominer.</p>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Conversion premium",
            "text": "<p>Des appels à l’action francs, des cartes généreuses et une expérience qui reste fluide sur mobile.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
