{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign featured_collection = section.settings.collection
  assign products_limit = section.settings.products_to_show
  assign has_configured_blocks = false

  for block in section.blocks
    if block.settings.product != blank
      assign has_configured_blocks = true
      break
    endif
  endfor
-%}

<div
  class="section-{{ section.id }}-padding vd-feature-gallery color-{{ section.settings.color_scheme }}"
  data-vd-feature-gallery
>
  <div class="page-width vd-feature-gallery__intro-wrap">
    <div class="vd-feature-gallery__intro">
      <div>
        {% if section.settings.heading != blank %}
          <h2 class="vd-feature-gallery__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>

      {% if section.settings.button_label != blank and featured_collection != blank and featured_collection.url != blank %}
        <div class="vd-feature-gallery__cta-wrap">
          <a href="{{ featured_collection.url }}" class="vd-arrow-cta vd-feature-gallery__cta">
            <span class="vd-arrow-cta__label">{{ section.settings.button_label }}</span>
            <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
              <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
            </svg>
          </a>
        </div>
      {% endif %}
    </div>
  </div>

  {% if has_configured_blocks or featured_collection != blank and featured_collection.products_count > 0 %}
    <div class="vd-feature-gallery__viewport" data-vd-feature-gallery-wrapper>
      <div class="vd-feature-gallery__strip" data-vd-feature-gallery-strip>
        {% if has_configured_blocks %}
          {% for block in section.blocks %}
            {%- liquid
              assign card_product = block.settings.product
              assign media_source = block.settings.media_source
              assign custom_image = block.settings.custom_image
              assign custom_video = block.settings.custom_video
              assign media_fit = block.settings.media_fit | default: 'contain'
              assign media_padding = '2rem'

              if media_fit == 'cover'
                assign media_padding = '0rem'
              endif

              assign card_eyebrow = block.settings.eyebrow
              if card_eyebrow == blank
                capture card_eyebrow
                  render 'vd-product-meta-label', product: card_product, prefer: 'vendor', fallback: section.settings.eyebrow
                endcapture
                assign card_eyebrow = card_eyebrow | strip
              endif

            -%}
            {% if card_product != blank %}
              <article
                class="vd-feature-card"
                data-vd-feature-card
                style="--vd-feature-media-fit: {{ media_fit }}; --vd-feature-media-padding: {{ media_padding }};"
                {{ block.shopify_attributes }}
              >
                <a href="{{ card_product.url }}" class="vd-feature-card__link">
                  <div class="vd-feature-card__media">
                    <div class="vd-feature-card__media-inner">
                      {% if media_source == 'shopify_video' and custom_video != blank %}
                        {{
                          custom_video
                          | video_tag:
                            class: 'vd-feature-card__video',
                            autoplay: true,
                            loop: true,
                            muted: true,
                            controls: false,
                            playsinline: true,
                            image_size: '1200x'
                        }}
                      {% elsif media_source == 'custom_image' and custom_image != blank %}
                      {{
                        custom_image
                        | image_url: width: 1400
                          | image_tag:
                            class: 'vd-feature-card__image',
                            widths: '540, 720, 960, 1200, 1400',
                            sizes: '(min-width: 990px) 22vw, 74vw',
                            loading: 'lazy',
                            alt: custom_image.alt | default: card_product.title | escape
                        }}
                      {% elsif card_product.featured_image != blank %}
                        {{
                          card_product.featured_image
                          | image_url: width: 1400
                          | image_tag:
                            class: 'vd-feature-card__image',
                            widths: '540, 720, 960, 1200, 1400',
                            sizes: '(min-width: 990px) 22vw, 74vw',
                            loading: 'lazy',
                            alt: card_product.featured_image.alt | default: card_product.title | escape
                        }}
                      {% else %}
                        {{ 'image' | placeholder_svg_tag: 'vd-feature-card__image placeholder-svg' }}
                      {% endif %}
                    </div>
                  </div>

                  <div class="vd-feature-card__body">
                    <div class="vd-feature-card__topline{% if card_eyebrow == blank %} is-price-only{% endif %}">
                      {% if card_eyebrow != blank %}
                        <span>{{ card_eyebrow }}</span>
                      {% endif %}
                      <strong>{{ card_product.price | money_without_trailing_zeros }}</strong>
                    </div>

                    <h3>{{ card_product.title }}</h3>
                  </div>
                </a>
              </article>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for product in featured_collection.products limit: products_limit %}
            <article
              class="vd-feature-card"
              data-vd-feature-card
              style="--vd-feature-media-fit: contain; --vd-feature-media-padding: 2rem;"
            >
              <a href="{{ product.url }}" class="vd-feature-card__link">
                {%- capture product_eyebrow -%}
                  {%- render 'vd-product-meta-label', product: product, prefer: 'vendor', fallback: section.settings.eyebrow -%}
                {%- endcapture -%}
                {%- assign product_eyebrow = product_eyebrow | strip -%}
                <div class="vd-feature-card__media">
                  <div class="vd-feature-card__media-inner">
                    {% if product.featured_image != blank %}
                      {{
                        product.featured_image
                        | image_url: width: 1400
                        | image_tag:
                          class: 'vd-feature-card__image',
                          widths: '540, 720, 960, 1200, 1400',
                          sizes: '(min-width: 990px) 22vw, 74vw',
                          loading: 'lazy',
                          alt: product.featured_image.alt | default: product.title | escape
                      }}
                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'vd-feature-card__image placeholder-svg' }}
                    {% endif %}
                  </div>
                </div>

                <div class="vd-feature-card__body">
                  <div class="vd-feature-card__topline{% if product_eyebrow == blank %} is-price-only{% endif %}">
                    {%- if product_eyebrow != blank -%}
                      <span>{{ product_eyebrow }}</span>
                    {%- endif -%}
                    <strong>{{ product.price | money_without_trailing_zeros }}</strong>
                  </div>

                  <h3>{{ product.title }}</h3>
                </div>
              </a>
            </article>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="page-width">
      <div class="vd-feature-gallery__empty">
        <p>Choisis une collection ou configure des blocks produits pour alimenter la galerie horizontale.</p>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "VD Featured Products",
  "tag": "section",
  "class": "section section-vd-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Nos produits en vedette"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Une galerie qui met la collection en mouvement."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection de secours"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 10,
      "step": 1,
      "label": "Nombre de produits",
      "default": 6
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libelle bouton",
      "default": "Tout découvrir"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "featured_item",
      "name": "Produit en vedette",
      "limit": 10,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Label court"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description courte"
        },
        {
          "type": "select",
          "id": "media_source",
          "label": "Source media",
          "default": "product_image",
          "options": [
            {
              "value": "product_image",
              "label": "Image produit"
            },
            {
              "value": "custom_image",
              "label": "Image perso / GIF uploadé"
            },
            {
              "value": "shopify_video",
              "label": "Video Shopify"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Image perso / GIF uploadé"
        },
        {
          "type": "video",
          "id": "custom_video",
          "label": "Video Shopify"
        },
        {
          "type": "select",
          "id": "media_fit",
          "label": "Ajustement media",
          "default": "contain",
          "options": [
            {
              "value": "contain",
              "label": "Contenir"
            },
            {
              "value": "cover",
              "label": "Recouvrir"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Featured Products"
    }
  ]
}
{% endschema %}
