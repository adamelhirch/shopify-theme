{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{{ 'vd-wiki-teaser-v2.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vd-wiki-teaser-v2.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign total_slides = section.blocks.size | plus: 1
  assign total_slides_label = total_slides
  if total_slides < 10
    assign total_slides_label = '0' | append: total_slides
  endif

  assign cover_link = section.settings.button_link
  if cover_link == blank and section.blocks.size > 0
    assign cover_link = section.blocks.first.settings.link
  endif

  assign cover_image = section.settings.cover_image
  if cover_image == blank and section.blocks.size > 0
    assign cover_image = section.blocks.first.settings.image
  endif

  assign cover_video = section.settings.cover_video
  if cover_video == blank and section.blocks.size > 0
    assign cover_video = section.blocks.first.settings.video
  endif

  assign cover_external_video_url = section.settings.cover_external_video_url
  if cover_external_video_url == blank and section.blocks.size > 0
    assign cover_external_video_url = section.blocks.first.settings.external_video_url
  endif
-%}

<section
  class="section-{{ section.id }}-padding vd-wiki vd-wiki-teaser color-{{ section.settings.color_scheme }}"
  data-vd-wiki-teaser
  data-section-id="{{ section.id }}"
  data-total-slides="{{ total_slides }}"
>
  <div class="page-width">
    <div class="vd-wiki-teaser__viewport" data-vd-wiki-viewport tabindex="0" aria-label="Teaser immersif du Wiki de Désiré">
      <article
        class="vd-wiki-teaser__slide is-cover"
        data-vd-wiki-slide
        data-slide-index="0"
        aria-hidden="false"
      >
        <div class="vd-wiki-teaser__outer" data-vd-wiki-outer>
          <div class="vd-wiki-teaser__inner" data-vd-wiki-inner>
            {% if cover_link != blank %}
              <a
                class="vd-wiki-teaser__panel-link"
                href="{{ cover_link }}"
                aria-label="{{ section.settings.heading | default: 'Le Wiki de Désiré' | escape }}"
              >
            {% else %}
              <div class="vd-wiki-teaser__panel-link is-disabled">
            {% endif %}
              <div class="vd-wiki-teaser__media" data-vd-wiki-media>
                {% if cover_video != blank %}
                  {{
                    cover_video
                    | video_tag:
                      class: 'vd-wiki-teaser__video',
                      autoplay: true,
                      loop: true,
                      muted: true,
                      controls: false,
                      playsinline: true,
                      preload: 'metadata',
                      image_size: '2200x'
                  }}
                {% elsif cover_external_video_url != blank %}
                  <video
                    class="vd-wiki-teaser__video"
                    autoplay
                    loop
                    muted
                    playsinline
                    preload="metadata"
                    {% if cover_image != blank %}
                      poster="{{ cover_image | image_url: width: 2200 }}"
                    {% endif %}
                  >
                    <source src="{{ cover_external_video_url }}" type="video/mp4">
                  </video>
                {% elsif cover_image != blank %}
                  {{
                    cover_image
                    | image_url: width: 2200
                    | image_tag:
                      class: 'vd-wiki-teaser__image',
                      widths: '750, 1100, 1500, 1900, 2200',
                      sizes: '100vw',
                      loading: 'eager',
                      alt: section.settings.heading | default: 'Le Wiki de Désiré' | escape
                  }}
                {% else %}
                  <div class="vd-wiki-teaser__fallback-media vd-wiki-teaser__fallback-media--cover" aria-hidden="true"></div>
                {% endif %}
              </div>

              <div class="vd-wiki-teaser__overlay"></div>

              <div class="vd-wiki-teaser__copy is-cover">
                {% if section.settings.heading != blank %}
                  <div class="vd-wiki-teaser__title-shell is-cover">
                    <h2 class="vd-wiki-teaser__panel-title vd-wiki-teaser__panel-title--cover" data-vd-wiki-title>
                      {{ section.settings.heading }}
                    </h2>
                  </div>
                {% endif %}
              </div>
            {% if cover_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        </div>
      </article>

      {% for block in section.blocks %}
        {%- liquid
          assign fallback_tone = 'botanique'
          case forloop.index
            when 2
              assign fallback_tone = 'science'
            when 3
              assign fallback_tone = 'terroirs'
            when 4
              assign fallback_tone = 'techniques'
            when 5
              assign fallback_tone = 'atelier'
          endcase

          assign nav_index = block.settings.number | strip
          if nav_index == blank
            assign nav_index = forloop.index
          endif
          assign nav_index = nav_index | append: ''
          if nav_index.size == 1
            assign nav_index = '0' | append: nav_index
          endif
        -%}
        <article
          class="vd-wiki-teaser__slide"
          data-vd-wiki-slide
          data-slide-index="{{ forloop.index }}"
          aria-hidden="true"
          {{ block.shopify_attributes }}
        >
          <div class="vd-wiki-teaser__outer" data-vd-wiki-outer>
            <div class="vd-wiki-teaser__inner" data-vd-wiki-inner>
              {% if block.settings.link != blank %}
                <a
                  class="vd-wiki-teaser__panel-link"
                  href="{{ block.settings.link }}"
                  aria-label="{{ block.settings.title | default: section.settings.heading | escape }}"
                >
              {% else %}
                <div class="vd-wiki-teaser__panel-link is-disabled">
              {% endif %}
                <div class="vd-wiki-teaser__media" data-vd-wiki-media>
                  {% if block.settings.video != blank %}
                    {{
                      block.settings.video
                      | video_tag:
                        class: 'vd-wiki-teaser__video',
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        preload: 'metadata',
                        image_size: '2200x'
                    }}
                  {% elsif block.settings.external_video_url != blank %}
                    <video
                      class="vd-wiki-teaser__video"
                      autoplay
                      loop
                      muted
                      playsinline
                      preload="metadata"
                      {% if block.settings.image != blank %}
                        poster="{{ block.settings.image | image_url: width: 2200 }}"
                      {% endif %}
                    >
                      <source src="{{ block.settings.external_video_url }}" type="video/mp4">
                    </video>
                  {% elsif block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 2200
                      | image_tag:
                        class: 'vd-wiki-teaser__image',
                        widths: '750, 1100, 1500, 1900, 2200',
                        sizes: '100vw',
                        loading: 'lazy',
                        alt: block.settings.image.alt | default: block.settings.title | escape
                    }}
                  {% else %}
                    <div
                      class="vd-wiki-teaser__fallback-media vd-wiki-teaser__fallback-media--{{ fallback_tone }}"
                      aria-hidden="true"
                    ></div>
                  {% endif %}
                </div>

                <div class="vd-wiki-teaser__overlay"></div>

                <div class="vd-wiki-teaser__copy">
                  {% if block.settings.title != blank %}
                    <div class="vd-wiki-teaser__title-shell">
                      <h3 class="vd-wiki-teaser__panel-title" data-vd-wiki-title>{{ block.settings.title }}</h3>
                    </div>
                  {% endif %}
                </div>
              {% if block.settings.link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}

      <div class="vd-wiki-teaser__hud" aria-hidden="false">
        {% if section.settings.button_label != blank and cover_link != blank %}
          <a class="vd-arrow-cta vd-wiki-teaser__cta-link" href="{{ cover_link }}" data-vd-wiki-cta>
            <span class="vd-arrow-cta__label">{{ section.settings.button_label }}</span>
            <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
              <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
            </svg>
          </a>
        {% endif %}

        <div class="vd-wiki-teaser__rail" data-vd-wiki-rail>
          <button
            class="vd-wiki-teaser__nav-button is-active"
            type="button"
            data-vd-wiki-nav="0"
            aria-pressed="true"
            aria-label="{{ section.settings.heading | default: 'Le Wiki de Désiré' | escape }}"
          >
            <span class="vd-wiki-teaser__nav-pill" aria-hidden="true"></span>
            <span class="vd-wiki-teaser__sr">{{ section.settings.heading | default: 'Le Wiki de Désiré' }}</span>
          </button>

          {% for block in section.blocks %}
            {%- liquid
              assign nav_index = block.settings.number | strip
              if nav_index == blank
                assign nav_index = forloop.index
              endif
              assign nav_index = nav_index | append: ''
              if nav_index.size == 1
                assign nav_index = '0' | append: nav_index
              endif
            -%}
            <button
              class="vd-wiki-teaser__nav-button"
              type="button"
              data-vd-wiki-nav="{{ forloop.index }}"
              aria-pressed="false"
              aria-label="{{ nav_index }} {{ block.settings.title | default: section.settings.heading | escape }}"
            >
              <span class="vd-wiki-teaser__nav-pill" aria-hidden="true"></span>
              <span class="vd-wiki-teaser__sr">{{ block.settings.title }}</span>
            </button>
          {% endfor %}
        </div>

        <span class="vd-wiki-teaser__counter" data-vd-wiki-counter>01 / {{ total_slides_label }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Wiki Teaser",
  "tag": "section",
  "class": "section section-vd-wiki-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Le Wiki de Désiré"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Un teaser éditorial pensé pour donner envie d'entrer dans le Wiki.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libellé bouton",
      "default": "Explorer le Wiki"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Image couverture"
    },
    {
      "type": "video",
      "id": "cover_video",
      "label": "Vidéo couverture"
    },
    {
      "type": "url",
      "id": "cover_external_video_url",
      "label": "URL vidéo MP4 couverture"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "article_card",
      "name": "Slide wiki",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Numero",
          "default": "01"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Categorie",
          "default": "Botanique"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "L'Orchidee Planifolia"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Resume",
          "default": "Comprendre la liane, la pollinisation et le temps long qui precede l'arome."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Vidéo"
        },
        {
          "type": "url",
          "id": "external_video_url",
          "label": "URL vidéo MP4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Wiki Teaser",
      "blocks": [
        {
          "type": "article_card"
        },
        {
          "type": "article_card",
          "settings": {
            "number": "02",
            "category": "Science",
            "title": "La Vanilline Naturelle",
            "text": "Faire la difference entre concentration aromatique, extraction et faux raccourcis."
          }
        },
        {
          "type": "article_card",
          "settings": {
            "number": "03",
            "category": "Terroirs",
            "title": "Terroirs & Crus",
            "text": "Lire les nuances entre regions, affinage, humidite et texture des gousses."
          }
        }
      ]
    }
  ]
}
{% endschema %}
