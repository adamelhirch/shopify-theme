{{ 'vd-wiki-teaser.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vd-wiki-teaser.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign slide_count = section.blocks.size
  if slide_count < 1
    assign slide_count = 1
  endif
-%}

<section
  class="section-{{ section.id }}-padding vd-wiki-teaser color-{{ section.settings.color_scheme }}"
  data-vd-wiki-teaser
  data-vd-wiki-count="{{ slide_count }}"
  style="--vd-wiki-slide-count: {{ slide_count }};"
>
  <svg class="vd-wiki-teaser__fx" aria-hidden="true" focusable="false" width="0" height="0">
    <defs>
      <filter id="vd-wiki-motion-blur-{{ section.id }}" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="0 0" data-vd-wiki-blur-node />
      </filter>
    </defs>
  </svg>

  <div class="vd-wiki-teaser__backdrop" aria-hidden="true">
    <div class="vd-wiki-teaser__backdrop-blur" style="filter: url('#vd-wiki-motion-blur-{{ section.id }}');">
      {% for block in section.blocks limit: 3 %}
        {%- liquid
          assign fallback_asset = 'vd-wiki-botanique.jpg'
          assign fallback_width = 1350
          assign fallback_height = 1800

          if forloop.index == 2
            assign fallback_asset = 'vd-wiki-terroirs.jpg'
            assign fallback_width = 1800
            assign fallback_height = 1350
          elsif forloop.index == 3
            assign fallback_asset = 'vd-wiki-science.jpg'
            assign fallback_width = 1800
            assign fallback_height = 1350
          endif
        -%}

        <figure
          class="vd-wiki-teaser__backdrop-layer{% if forloop.first %} is-active{% endif %}"
          data-vd-wiki-backdrop-layer
          data-vd-wiki-layer="{{ forloop.index0 }}"
        >
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 2400
              | image_tag:
                class: 'vd-wiki-teaser__backdrop-image',
                widths: '900, 1200, 1600, 2000, 2400',
                sizes: '100vw',
                loading: 'eager',
                alt: block.settings.image.alt | default: block.settings.title | escape
            }}
          {% else %}
            <img
              class="vd-wiki-teaser__backdrop-image"
              src="{{ fallback_asset | asset_url }}"
              alt=""
              loading="eager"
              width="{{ fallback_width }}"
              height="{{ fallback_height }}"
            >
          {% endif %}
        </figure>
      {% endfor %}
    </div>

    <div class="vd-wiki-teaser__backdrop-shade"></div>
    <div class="vd-wiki-teaser__backdrop-noise"></div>
  </div>

  <div class="vd-wiki-teaser__cursor" data-vd-wiki-cursor aria-hidden="true">
    <span data-vd-wiki-cursor-text>Explorer</span>
  </div>

  <div class="page-width">
    <div class="vd-wiki-teaser__shell">
      <header class="vd-wiki-teaser__masthead">
        <div class="vd-wiki-teaser__masthead-copy">
          {% if section.settings.eyebrow != blank %}
            <span class="vd-wiki-teaser__eyebrow">{{ section.settings.eyebrow }}</span>
          {% endif %}

          {% if section.settings.heading != blank %}
            <p class="vd-wiki-teaser__heading">{{ section.settings.heading }}</p>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="vd-wiki-teaser__lede rte">{{ section.settings.text }}</div>
          {% endif %}
        </div>
      </header>

      <div class="vd-wiki-teaser__viewport" data-vd-wiki-viewport tabindex="0">
        <div class="vd-wiki-teaser__track" data-vd-wiki-track role="list">
          {% for block in section.blocks %}
            {%- liquid
              assign chapter_key = 'botanique'
              assign fallback_asset = 'vd-wiki-botanique.jpg'
              assign fallback_secondary = 'vd-wiki-terroirs.jpg'
              assign fallback_tertiary = 'vd-wiki-science.jpg'
              assign fallback_width = 1350
              assign fallback_height = 1800
              assign chapter_cursor = 'Explorer'

              if forloop.index == 2
                assign chapter_key = 'terroirs'
                assign fallback_asset = 'vd-wiki-terroirs.jpg'
                assign fallback_secondary = 'vd-wiki-botanique.jpg'
                assign fallback_tertiary = 'vd-wiki-science.jpg'
                assign fallback_width = 1800
                assign fallback_height = 1350
                assign chapter_cursor = 'Decouvrir'
              elsif forloop.index == 3
                assign chapter_key = 'techniques'
                assign fallback_asset = 'vd-wiki-science.jpg'
                assign fallback_secondary = 'vd-wiki-botanique.jpg'
                assign fallback_tertiary = 'vd-wiki-terroirs.jpg'
                assign fallback_width = 1800
                assign fallback_height = 1350
                assign chapter_cursor = 'Observer'
              endif

              assign slide_link_label = block.settings.link_label
              if slide_link_label == blank
                assign slide_link_label = 'Explorer le chapitre'
              endif
            -%}

            <article
              class="vd-wiki-teaser__slide vd-wiki-teaser__slide--{{ chapter_key }}{% if forloop.first %} is-active{% endif %}"
              data-vd-wiki-slide
              data-vd-wiki-index="{{ forloop.index0 }}"
              data-vd-wiki-cursor="{{ chapter_cursor }}"
              aria-label="{{ forloop.index }} / {{ slide_count }}"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <div class="vd-wiki-teaser__panel">
                <div class="vd-wiki-teaser__copy">
                  <div class="vd-wiki-teaser__meta" data-vd-wiki-meta>
                    {% if block.settings.number != blank %}
                      <span>{{ block.settings.number }}</span>
                    {% endif %}
                    {% if block.settings.category != blank %}
                      <span>{{ block.settings.category }}</span>
                    {% endif %}
                  </div>

                  {% if block.settings.title != blank %}
                    <h2 class="vd-wiki-teaser__panel-title" data-vd-wiki-title>{{ block.settings.title }}</h2>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="vd-wiki-teaser__body rte" data-vd-wiki-body>{{ block.settings.text }}</div>
                  {% endif %}

                  <div class="vd-wiki-teaser__detail-list" data-vd-wiki-body>
                    {% if block.settings.detail_one != blank %}
                      <span class="vd-wiki-teaser__detail-pill">{{ block.settings.detail_one }}</span>
                    {% endif %}
                    {% if block.settings.detail_two != blank %}
                      <span class="vd-wiki-teaser__detail-pill">{{ block.settings.detail_two }}</span>
                    {% endif %}
                    {% if block.settings.detail_three != blank %}
                      <span class="vd-wiki-teaser__detail-pill">{{ block.settings.detail_three }}</span>
                    {% endif %}
                  </div>

                  {% if block.settings.link != blank %}
                    <div class="vd-wiki-teaser__actions" data-vd-wiki-body>
                      <a
                        class="vd-inline-link"
                        href="{{ block.settings.link }}"
                        data-vd-wiki-cursor-label="Entrer"
                      >
                        {{ slide_link_label }}
                      </a>
                    </div>
                  {% endif %}
                </div>

                <div class="vd-wiki-teaser__stage" data-vd-wiki-stage>
                  {% case forloop.index %}
                    {% when 1 %}
                      <div class="vd-wiki-teaser__stage-shell vd-wiki-teaser__stage-shell--botanique" data-vd-wiki-stage-main>
                        <div class="vd-wiki-teaser__macro-frame">
                          {% if block.settings.image != blank %}
                            {{
                              block.settings.image
                              | image_url: width: 2200
                              | image_tag:
                                class: 'vd-wiki-teaser__macro-image',
                                widths: '800, 1200, 1600, 2000, 2200',
                                sizes: '(min-width: 990px) 54vw, 100vw',
                                loading: 'lazy',
                                alt: block.settings.image.alt | default: block.settings.title | escape
                            }}
                          {% else %}
                            <img
                              class="vd-wiki-teaser__macro-image"
                              src="{{ fallback_asset | asset_url }}"
                              alt="{{ block.settings.title | escape }}"
                              loading="lazy"
                              width="{{ fallback_width }}"
                              height="{{ fallback_height }}"
                            >
                          {% endif %}
                          <div class="vd-wiki-teaser__film-grain"></div>
                        </div>

                        <div class="vd-wiki-teaser__orchid-bloom" aria-hidden="true">
                          <span class="vd-wiki-teaser__bloom-ring vd-wiki-teaser__bloom-ring--1" data-vd-wiki-bloom></span>
                          <span class="vd-wiki-teaser__bloom-ring vd-wiki-teaser__bloom-ring--2" data-vd-wiki-bloom></span>
                          <span class="vd-wiki-teaser__bloom-ring vd-wiki-teaser__bloom-ring--3" data-vd-wiki-bloom></span>
                        </div>

                        <div class="vd-wiki-teaser__specimen-card" data-vd-wiki-body>
                          <span>Vanilla planifolia</span>
                          <p>Floraison breve. Pollinisation manuelle. Aromatique patiente.</p>
                        </div>
                      </div>
                    {% when 2 %}
                      <div class="vd-wiki-teaser__stage-shell vd-wiki-teaser__stage-shell--terroirs" data-vd-wiki-stage-main>
                        <div class="vd-wiki-teaser__map-frame">
                          <svg
                            class="vd-wiki-teaser__map"
                            viewBox="0 0 1200 820"
                            role="img"
                            aria-label="Carte stylisee des terroirs de vanille"
                          >
                            <g class="vd-wiki-teaser__map-grid" aria-hidden="true">
                              <path d="M150 162H1050"></path>
                              <path d="M150 286H1050"></path>
                              <path d="M150 410H1050"></path>
                              <path d="M150 534H1050"></path>
                              <path d="M150 658H1050"></path>
                              <path d="M245 112V710"></path>
                              <path d="M430 112V710"></path>
                              <path d="M615 112V710"></path>
                              <path d="M800 112V710"></path>
                              <path d="M985 112V710"></path>
                            </g>

                            <g class="vd-wiki-teaser__map-world" aria-hidden="true">
                              <path d="M222 332c76-52 150-72 222-60 70 11 116 48 132 103 15 50-17 96-86 123-82 31-174 37-245 14-53-17-101-54-116-92-15-37-7-66 19-88 20-16 44-16 74 0z"></path>
                              <path d="M488 217c69-44 155-55 232-30 61 21 96 62 89 104-6 36-40 70-95 95-51 22-110 32-156 26-42-6-74-28-81-58-10-38 5-84 11-97z"></path>
                              <path d="M707 262c78-34 173-42 267-24 118 24 198 92 198 170 0 80-75 144-190 164-121 22-261 1-332-49-49-35-71-87-58-139 16-59 48-94 115-122z"></path>
                              <path d="M820 572c44-30 106-39 152-20 35 15 54 45 51 79-5 44-40 77-100 95-62 18-123 11-159-18-44-36-31-97 31-136z"></path>
                              <path d="M120 488c27-18 66-23 96-12 25 8 40 26 40 46 0 24-18 46-49 59-38 15-78 15-106-1-26-15-30-43-10-64 7-8 17-19 29-28z"></path>
                              <path d="M1024 627c34-12 68-5 82 18 13 20 6 47-18 66-25 18-63 25-91 16-25-7-41-28-38-51 2-22 24-39 65-49z"></path>
                            </g>

                            <g class="vd-wiki-teaser__map-labels" aria-hidden="true">
                              <circle cx="232" cy="515" r="5.5"></circle>
                              <circle cx="974" cy="658" r="5.5"></circle>
                              <circle cx="838" cy="501" r="5.5"></circle>
                            </g>

                            <path
                              class="vd-wiki-teaser__madagascar-outline"
                              data-vd-wiki-map-draw
                              d="M855 470c10-8 28-12 43-9 15 3 27 12 31 24 4 13 0 30-12 48-13 20-18 39-16 59 2 20-3 36-16 48-13 13-31 17-46 11-16-7-25-22-25-42 0-20 4-35 12-47 8-12 12-31 10-56-2-21 4-31 19-36z"
                            ></path>
                            <circle class="vd-wiki-teaser__sava-core" data-vd-wiki-sava-core cx="873" cy="497" r="5.5"></circle>
                            <circle class="vd-wiki-teaser__sava-halo" data-vd-wiki-sava-halo cx="873" cy="497" r="15"></circle>
                          </svg>

                          <div class="vd-wiki-teaser__map-caption">
                            <span>Radar de luxe</span>
                            <p>Madagascar s'ecrit en or fin. Le reste demeure presque fantome.</p>
                          </div>

                          <button
                            class="vd-wiki-teaser__sava-trigger"
                            type="button"
                            data-vd-wiki-region-button="sava"
                            data-vd-wiki-cursor-label="Decouvrir"
                            style="--sava-x: 72.7%; --sava-y: 55.8%;"
                          >
                            <span class="vd-wiki-teaser__sava-dot"></span>
                            <span class="vd-wiki-teaser__sava-label">SAVA</span>
                          </button>

                          <div class="vd-wiki-teaser__glass-orb is-active" data-vd-wiki-region-card="sava">
                            <span>Nord-Est malgache</span>
                            <strong>Humidite elevee, altitude douce, air sale.</strong>
                            <ul>
                              <li>Humidite : forte et reguliere</li>
                              <li>Altitude : 200 a 600 m</li>
                              <li>Lecture : bourbon sombre, ample, pulpeux</li>
                            </ul>
                          </div>
                        </div>
                      </div>
                    {% else %}
                      <div class="vd-wiki-teaser__stage-shell vd-wiki-teaser__stage-shell--techniques" data-vd-wiki-stage-main>
                        <div class="vd-wiki-teaser__cinema-grid">
                          <div class="vd-wiki-teaser__cinema-frame vd-wiki-teaser__cinema-frame--hero">
                            <img
                              class="vd-wiki-teaser__cinema-image"
                              src="{{ fallback_asset | asset_url }}"
                              alt="{{ block.settings.title | escape }}"
                              loading="lazy"
                              width="1800"
                              height="1350"
                            >
                            <div class="vd-wiki-teaser__film-grain"></div>
                          </div>

                          <div class="vd-wiki-teaser__cinema-frame vd-wiki-teaser__cinema-frame--detail">
                            <img
                              class="vd-wiki-teaser__cinema-image"
                              src="{{ fallback_secondary | asset_url }}"
                              alt=""
                              loading="lazy"
                              width="1350"
                              height="1800"
                            >
                            <div class="vd-wiki-teaser__film-grain"></div>
                          </div>

                          <div class="vd-wiki-teaser__cinema-frame vd-wiki-teaser__cinema-frame--climate">
                            <img
                              class="vd-wiki-teaser__cinema-image"
                              src="{{ fallback_tertiary | asset_url }}"
                              alt=""
                              loading="lazy"
                              width="1800"
                              height="1350"
                            >
                            <div class="vd-wiki-teaser__film-grain"></div>
                          </div>
                        </div>

                        <div class="vd-wiki-teaser__cinema-note" data-vd-wiki-body>
                          Pas de video moyenne. Juste le temps, le grain, et le geste.
                        </div>
                      </div>
                  {% endcase %}
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      </div>

      <div class="vd-wiki-teaser__hud">
        {% if section.settings.button_label != blank %}
          <a
            {% if section.settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="vd-arrow-cta vd-wiki-teaser__cta-link{% if section.settings.button_link == blank %} is-disabled{% endif %}"
            data-vd-wiki-cursor-label="Explorer"
          >
            <span class="vd-arrow-cta__label">{{ section.settings.button_label }}</span>
            <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
              <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
            </svg>
          </a>
        {% endif %}

        <div class="vd-wiki-teaser__rail" role="tablist" aria-label="Navigation du wiki">
          {% for block in section.blocks %}
            <button
              class="vd-wiki-teaser__nav-button{% if forloop.first %} is-active{% endif %}"
              type="button"
              data-vd-wiki-nav="{{ forloop.index0 }}"
              data-vd-wiki-cursor-label="Aller"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <span class="vd-wiki-teaser__nav-pill"></span>
              <span class="vd-wiki-teaser__sr">
                {{ block.settings.category | default: block.settings.title | default: 'Chapitre' }}
              </span>
            </button>
          {% endfor %}
        </div>

        <div class="vd-wiki-teaser__counter" data-vd-wiki-counter>
          {% if slide_count < 10 %}0{% endif %}1 / {% if slide_count < 10 %}0{% endif %}{{ slide_count }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Wiki Grid",
  "tag": "section",
  "class": "section section-vd-wiki-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Le Wiki"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Un codex digital pour la matiere, les terroirs et le geste."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Trois chapitres plein ecran. Plus d'espace, plus de rythme, plus de credibilite editoriale.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libelle bouton",
      "default": "Explorer le wiki"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 6,
      "unit": "px",
      "label": "Marge haute",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 6,
      "unit": "px",
      "label": "Marge basse",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "wiki_chapter",
      "name": "Chapitre wiki",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Numero",
          "default": "01"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Categorie",
          "default": "Botanique"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Botanique"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>Une lecture plus ample de la fleur, du temps de maturation et du geste initial.</p>"
        },
        {
          "type": "text",
          "id": "detail_one",
          "label": "Detail 1",
          "default": "Matiere"
        },
        {
          "type": "text",
          "id": "detail_two",
          "label": "Detail 2",
          "default": "Temps long"
        },
        {
          "type": "text",
          "id": "detail_three",
          "label": "Detail 3",
          "default": "Precision"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Libelle lien",
          "default": "Explorer"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image principale"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Wiki Grid",
      "blocks": [
        {
          "type": "wiki_chapter",
          "settings": {
            "number": "01",
            "category": "Botanique",
            "title": "Botanique",
            "text": "<p>La fleur n'apparait qu'un instant. Tout commence dans une matiere encore verte, avant meme le parfum.</p>",
            "detail_one": "Vanilla planifolia",
            "detail_two": "Pollinisation manuelle",
            "detail_three": "Floraison eclair"
          }
        },
        {
          "type": "wiki_chapter",
          "settings": {
            "number": "02",
            "category": "Terroirs & Crus",
            "title": "Terroirs",
            "text": "<p>Une geographie sobre, presque nocturne, ou l'origine apparait comme un trait d'or.</p>",
            "detail_one": "SAVA",
            "detail_two": "Humidite elevee",
            "detail_three": "Altitude douce"
          }
        },
        {
          "type": "wiki_chapter",
          "settings": {
            "number": "03",
            "category": "Techniques",
            "title": "Le Geste",
            "text": "<p>Pas de discours long. Le tri, la tension des mains, le temps de sechage, la repetition juste.</p>",
            "detail_one": "Tri manuel",
            "detail_two": "Sechage lent",
            "detail_three": "Affinage precis"
          }
        }
      ]
    }
  ]
}
{% endschema %}
