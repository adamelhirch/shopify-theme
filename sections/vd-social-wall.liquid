{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-padding vd-social-wall color-{{ section.settings.color_scheme }}">
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <clipPath id="vd-squircle-{{ section.id }}" clipPathUnits="objectBoundingBox">
        <path d="M 0,0.5 C 0,0 0,0 0.5,0 S 1,0 1,0.5 1,1 0.5,1 0,1 0,0.5"></path>
      </clipPath>
    </defs>
  </svg>

  <div class="page-width">
    <div class="vd-social-wall__head">
      {% if section.settings.heading != blank %}
        <h2 class="vd-social-wall__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="vd-social-wall__text rte">{{ section.settings.text }}</div>
      {% endif %}
      <div class="vd-social-wall__links">
        {% for block in section.blocks %}
          {% if block.settings.link != blank %}
            {%- liquid
              assign platform_handle = block.settings.platform | downcase
            -%}
            <a href="{{ block.settings.link }}" class="vd-social-wall__pill" {{ block.shopify_attributes }}>
              <span
                class="vd-social-wall__pill-icon vd-social-wall__pill-icon--{{ platform_handle | handleize }}"
                style="clip-path: url(#vd-squircle-{{ section.id }});"
              >
                <span class="svg-wrapper">
                  {% case platform_handle %}
                    {% when 'instagram' %}
                      {{ 'icon-instagram.svg' | inline_asset_content }}
                    {% when 'tiktok' %}
                      {{ 'icon-tiktok.svg' | inline_asset_content }}
                    {% when 'facebook' %}
                      {{ 'icon-facebook.svg' | inline_asset_content }}
                    {% when 'youtube' %}
                      {{ 'icon-youtube.svg' | inline_asset_content }}
                    {% else %}
                      {{ 'icon-instagram.svg' | inline_asset_content }}
                  {% endcase %}
                </span>
              </span>
              <span class="vd-social-wall__pill-label">{{ block.settings.platform }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="vd-social-wall__grid" role="list">
      {% for block in section.blocks %}
        <a
          class="vd-social-card"
          {% if block.settings.link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ block.settings.link }}"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                class: 'vd-social-card__image',
                widths: '360, 540, 720, 960, 1200',
                sizes: '(min-width: 990px) 24vw, 46vw',
                loading: 'lazy'
            }}
          {% else %}
            <div class="vd-social-card__placeholder"></div>
          {% endif %}

          <div class="vd-social-card__overlay"></div>

          <div class="vd-social-card__content">
            {% if block.settings.platform != blank %}
              <span class="vd-social-card__platform">{{ block.settings.platform }}</span>
            {% endif %}
            {% if block.settings.caption != blank %}
              <p>{{ block.settings.caption }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Social Wall",
  "tag": "section",
  "class": "section section-vd-social-wall",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Suivez-nous sur nos reseaux"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Recettes, gestes, coulisses et arrivages : la marque doit continuer de respirer hors de la fiche produit.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "social_card",
      "name": "Carte reseau",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "platform",
          "label": "Plateforme",
          "default": "Instagram"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Legende",
          "default": "Voir les coulisses"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Social Wall",
      "blocks": [
        {
          "type": "social_card"
        },
        {
          "type": "social_card"
        },
        {
          "type": "social_card"
        },
        {
          "type": "social_card"
        }
      ]
    }
  ]
}
{% endschema %}
