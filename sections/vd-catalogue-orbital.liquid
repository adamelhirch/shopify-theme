<div class="vd-catalogue color-{{ section.settings.color_scheme }}">
  <div class="page-width vd-catalogue__inner">
    <div class="vd-catalogue__header">
      {% if section.settings.eyebrow != blank %}
        <span class="vd-section-kicker">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="vd-catalogue__title">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="vd-catalogue__lede rte">{{ section.settings.text }}</div>
      {% endif %}

      {% if section.settings.primary_link_label != blank %}
        <div class="vd-catalogue__footer">
          <a href="{{ section.settings.primary_link | default: '#' }}" class="vd-arrow-cta">
            <span class="vd-arrow-cta__label">{{ section.settings.primary_link_label }}</span>
          </a>
        </div>
      {% endif %}
    </div>

    <div class="vd-catalogue__grid">
      {% for block in section.blocks %}
        {%- liquid
          assign col = block.settings.collection
          assign col_image = col.featured_image
        -%}

        <a
          href="{{ col.url | default: '#' }}"
          class="vd-catalogue__card"
          {{ block.shopify_attributes }}
        >
          <div class="vd-catalogue__card-media">
            {% if col_image != blank %}
              {{
                col_image
                | image_url: width: 1200
                | image_tag:
                  class: 'vd-catalogue__card-img',
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 990px) 30vw, 90vw',
                  loading: 'lazy',
                  alt: block.settings.title | escape
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'vd-catalogue__card-img placeholder-svg' }}
            {% endif %}
          </div>

          <div class="vd-catalogue__card-content">
            {% if block.settings.kicker != blank %}
              <span class="vd-catalogue__card-kicker">{{ block.settings.kicker }}</span>
            {% endif %}

            <h2 class="vd-catalogue__card-name">{{ block.settings.title }}</h2>

            {% if block.settings.text != blank %}
              <div class="vd-catalogue__card-text rte">{{ block.settings.text }}</div>
            {% endif %}

            {% if col != blank %}
              <span class="vd-catalogue__card-count">{{ col.all_products_count }} produits</span>
            {% endif %}

            <span class="vd-catalogue__card-cta">
              {{ block.settings.link_label | default: 'Explorer' }}
            </span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VD Catalogue",
  "tag": "section",
  "class": "section section-vd-catalogue-orbital",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Catalogue"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Explorer la maison"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>La vanille comme coeur de maison, les epices pour prolonger les accords, puis des selections pensees pour offrir ou decouvrir.</p>"
    },
    {
      "type": "text",
      "id": "primary_link_label",
      "label": "Libelle bouton",
      "default": "Voir tous les produits"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien bouton"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Libelle bouton 2"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien bouton 2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "Collection",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Sur-titre",
          "default": "Signature"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Vanille Bourbon"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Libelle lien",
          "default": "Explorer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Catalogue"
    }
  ]
}
{% endschema %}
