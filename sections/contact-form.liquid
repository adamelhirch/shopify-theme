{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .vd-contact-form__notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
    margin: 0 0 1.8rem;
  }

  .vd-contact-form__note {
    padding: 1.35rem 1.4rem;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 1.8rem;
    background: rgba(var(--color-background), 0.7);
    backdrop-filter: blur(12px);
  }

  .vd-contact-form__note span {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.62;
  }

  .vd-contact-form__note p {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.7;
  }

  .vd-contact-form__reasons {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin: 0 0 2rem;
  }

  .vd-contact-form__reason {
    padding: 1.35rem 1.4rem;
    border-radius: 1.8rem;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    background: rgba(var(--color-background), 0.68);
  }

  .vd-contact-form__reason-label {
    display: block;
    margin-bottom: 0.65rem;
    font-size: 1rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.58;
  }

  .vd-contact-form__reason h3 {
    margin: 0 0 0.65rem;
    font-size: 1.8rem;
    line-height: 1.3;
  }

  .vd-contact-form__reason p {
    margin: 0;
    font-size: 1.3rem;
    line-height: 1.65;
    opacity: 0.82;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 989px) {
    .vd-contact-form__reasons {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .vd-contact-form__notes {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

{%- liquid
  assign vd_contact_media = section.settings.feature_image
  assign vd_contact_media_url = 'vd-wiki-cover.jpg' | asset_url

  if vd_contact_media != blank
    assign vd_contact_media_url = vd_contact_media | image_url: width: 2000
  endif

  assign contact_form_class = 'contact vd-contact-form'
  if settings.animations_reveal_on_scroll
    assign contact_form_class = contact_form_class | append: ' scroll-trigger animate--slide-in'
  endif

  assign contact_reason_count = 0
  for block in section.blocks
    if block.type == 'contact_reason'
      assign contact_reason_count = contact_reason_count | plus: 1
    endif
  endfor
-%}

<section class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="vd-contact-page">
    <div class="vd-contact-page__layout">
      <div class="vd-contact-page__media" style="--vd-contact-media: url('{{ vd_contact_media_url }}');">
        <h1 class="visually-hidden">
          {% if page.title != blank %}
            {{ page.title }}
          {% else %}
            {{ 'templates.contact.form.title' | t }}
          {% endif %}
        </h1>
      </div>

      <div class="vd-contact-page__panel">
        {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
          <div class="vd-contact-form__intro">
            <h2 class="vd-contact-form__title">
              {{ section.settings.heading | default: 'Contactez-nous' }}
            </h2>
            <p class="vd-contact-form__lede">
              {{ section.settings.lede | default: 'Question produit, demande pro, partenariat ou commande : écrivez-nous via le formulaire ci-dessous. Réponse sous 24 h ouvrées.' }}
            </p>
          </div>

          {% if section.settings.response_note != blank or section.settings.support_note != blank %}
            <div class="vd-contact-form__notes" aria-label="Repères de contact">
              {% if section.settings.response_note != blank %}
                <article class="vd-contact-form__note">
                  <span>{{ section.settings.response_label | default: 'Réponse' }}</span>
                  <p>{{ section.settings.response_note }}</p>
                </article>
              {% endif %}
              {% if section.settings.support_note != blank %}
                <article class="vd-contact-form__note">
                  <span>{{ section.settings.support_label | default: 'Accompagnement' }}</span>
                  <p>{{ section.settings.support_note }}</p>
                </article>
              {% endif %}
            </div>
          {% endif %}

          {% if contact_reason_count > 0 %}
            <div class="vd-contact-form__reasons" role="list" aria-label="{{ section.settings.reasons_heading | default: 'Motifs de contact' }}">
              {% for block in section.blocks %}
                {% if block.type == 'contact_reason' %}
                  <article class="vd-contact-form__reason" role="listitem" {{ block.shopify_attributes }}>
                    {% if block.settings.label != blank %}
                      <span class="vd-contact-form__reason-label">{{ block.settings.label }}</span>
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <h3>{{ block.settings.title }}</h3>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <p>{{ block.settings.text }}</p>
                    {% endif %}
                  </article>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          {%- if form.posted_successfully? -%}
            <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
              {{- 'icon-success.svg' | inline_asset_content -}}
              {{ 'templates.contact.form.post_success' | t }}
            </h2>
          {%- elsif form.errors -%}
            <div class="form__message">
              <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                {{- 'icon-error.svg' | inline_asset_content -}}
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
            </div>
            <ul class="form-status-list caption-large" role="list">
              <li>
                <a href="#ContactForm-email" class="link">
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}
                </a>
              </li>
            </ul>
          {%- endif -%}

          <div class="contact__fields vd-contact-form__grid">
            <div class="field vd-contact-form__field">
              <input
                class="field__input"
                autocomplete="name"
                type="text"
                id="ContactForm-name"
                name="contact[{{ 'templates.contact.form.name' | t }}]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="{{ 'templates.contact.form.name' | t }}"
              >
              <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
            </div>

            <div class="field field--with-error vd-contact-form__field">
              <input
                autocomplete="email"
                type="email"
                id="ContactForm-email"
                class="field__input"
                name="contact[email]"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-email-error"
                {% endif %}
                placeholder="{{ 'templates.contact.form.email' | t }}"
              >
              <label class="field__label" for="ContactForm-email">
                {{- 'templates.contact.form.email' | t }}
                <span aria-hidden="true">*</span>
              </label>
              {%- if form.errors contains 'email' -%}
                <small class="contact__field-error" id="ContactForm-email-error">
                  <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                  <span class="form__message">
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </span>
                </small>
              {%- endif -%}
            </div>
          </div>

          <div class="field vd-contact-form__field">
            <input
              type="tel"
              id="ContactForm-phone"
              class="field__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.phone' | t }}]"
              pattern="[0-9\\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="{{ 'templates.contact.form.phone' | t }}"
            >
            <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
          </div>

          <div class="field vd-contact-form__field">
            <textarea
              rows="12"
              id="ContactForm-body"
              class="text-area field__input"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{ 'templates.contact.form.comment' | t }}"
            >{{- form.body -}}</textarea>
            <label class="form__label field__label" for="ContactForm-body">
              {{- 'templates.contact.form.comment' | t -}}
            </label>
          </div>

          <div class="contact__button vd-contact-form__button-wrap">
            <button type="submit" class="button vd-contact-form__button">
              {{ 'templates.contact.form.send' | t }}
            </button>
          </div>

          {%- if settings.social_instagram_link != blank
            or settings.social_facebook_link != blank
            or settings.social_tiktok_link != blank
            or settings.social_youtube_link != blank
            or settings.social_twitter_link != blank
            or settings.social_pinterest_link != blank
            or settings.social_snapchat_link != blank
            or settings.social_tumblr_link != blank
            or settings.social_vimeo_link != blank
          -%}
            <div class="vd-contact-form__social-wrap">
              {%- render 'social-icons', class: 'vd-contact-form__social' -%}
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Image"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "Contactez-nous"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Texte court",
      "default": "Question produit, demande pro, partenariat ou commande : écrivez-nous via le formulaire ci-dessous. Réponse sous 24 h ouvrées."
    },
    {
      "type": "text",
      "id": "response_label",
      "label": "Libellé note 1",
      "default": "Réponse"
    },
    {
      "type": "textarea",
      "id": "response_note",
      "label": "Note 1",
      "default": "Réponse humaine sous 24 h ouvrées pour les demandes produit, sourcing, coffrets et besoins récurrents."
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Libellé note 2",
      "default": "Accompagnement"
    },
    {
      "type": "textarea",
      "id": "support_note",
      "label": "Note 2",
      "default": "Le formulaire convient aussi aux demandes professionnelles, cadeaux, partenariats ou besoins plus précis autour des usages."
    },
    {
      "type": "text",
      "id": "reasons_heading",
      "label": "Titre implicite des cartes",
      "default": "Motifs de contact"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "contact_reason",
      "name": "Motif de contact",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Sur-titre",
          "default": "Produit"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Conseil avant achat"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Comparer un format, comprendre un usage ou vérifier la bonne référence avant commande."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
