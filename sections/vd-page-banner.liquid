{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-padding vd-page-banner color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="vd-page-banner__shell">
      <div class="vd-page-banner__copy">
        {% if section.settings.eyebrow != blank %}
          <span class="vd-section-kicker">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="vd-page-banner__title">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="vd-page-banner__text rte">{{ section.settings.text }}</div>
        {% endif %}

        {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
          <div class="vd-page-banner__actions">
            {% if section.settings.primary_button_label != blank %}
              <a
                {% if section.settings.primary_button_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ section.settings.primary_button_link }}"
                {% endif %}
                class="vd-arrow-cta"
              >
                <span class="vd-arrow-cta__label">{{ section.settings.primary_button_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.secondary_button_label != blank %}
              <a
                {% if section.settings.secondary_button_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ section.settings.secondary_button_link }}"
                {% endif %}
                class="vd-arrow-cta"
              >
                <span class="vd-arrow-cta__label">{{ section.settings.secondary_button_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="vd-page-banner__metrics" role="list">
        {% if section.settings.metric_1_value != blank or section.settings.metric_1_label != blank %}
          <div class="vd-page-banner__metric" role="listitem">
            {% if section.settings.metric_1_label != blank %}
              <span>{{ section.settings.metric_1_label }}</span>
            {% endif %}
            {% if section.settings.metric_1_value != blank %}
              <strong>{{ section.settings.metric_1_value }}</strong>
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.metric_2_value != blank or section.settings.metric_2_label != blank %}
          <div class="vd-page-banner__metric" role="listitem">
            {% if section.settings.metric_2_label != blank %}
              <span>{{ section.settings.metric_2_label }}</span>
            {% endif %}
            {% if section.settings.metric_2_value != blank %}
              <strong>{{ section.settings.metric_2_value }}</strong>
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.metric_3_value != blank or section.settings.metric_3_label != blank %}
          <div class="vd-page-banner__metric" role="listitem">
            {% if section.settings.metric_3_label != blank %}
              <span>{{ section.settings.metric_3_label }}</span>
            {% endif %}
            {% if section.settings.metric_3_value != blank %}
              <strong>{{ section.settings.metric_3_value }}</strong>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Page Banner",
  "tag": "section",
  "class": "section section-vd-page-banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Editorial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Une page plus claire, plus dense, plus utile."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Une banniere de lecture pour donner un cadre clair des l'arrivee sur la page, avant les contenus plus detailes ou les grilles catalogue.</p>"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Bouton principal",
      "default": "Voir la collection"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Lien bouton principal"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Bouton secondaire",
      "default": "Nous contacter"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Lien bouton secondaire"
    },
    {
      "type": "text",
      "id": "metric_1_label",
      "label": "Libelle metrique 1",
      "default": "Lecture"
    },
    {
      "type": "text",
      "id": "metric_1_value",
      "label": "Valeur metrique 1",
      "default": "Claire"
    },
    {
      "type": "text",
      "id": "metric_2_label",
      "label": "Libelle metrique 2",
      "default": "Fond"
    },
    {
      "type": "text",
      "id": "metric_2_value",
      "label": "Valeur metrique 2",
      "default": "Anthracite"
    },
    {
      "type": "text",
      "id": "metric_3_label",
      "label": "Libelle metrique 3",
      "default": "Objectif"
    },
    {
      "type": "text",
      "id": "metric_3_value",
      "label": "Valeur metrique 3",
      "default": "Conversion"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "VD Page Banner"
    }
  ]
}
{% endschema %}
