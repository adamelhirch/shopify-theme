{%- liquid
  assign menu = linklists[section.settings.menu]
-%}

<footer class="vd-footer">
  <div class="vd-footer__top">
    <div class="vd-footer__col vd-footer__brand">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" height="56" loading="lazy">
      {%- elsif settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" height="56" loading="lazy">
      {%- endif -%}
      <p>{{ section.settings.brand_text }}</p>
      {%- if section.settings.show_social -%}
        <div class="vd-footer__socials">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/></svg></a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h2.7l.4-3H13V9c0-.9.3-1.5 1.5-1.5H16V5c-.5-.1-1.4-.2-2.4-.2-2.4 0-4 1.5-4 4.1V11H7v3h2.6v8H13z"/></svg></a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.3a4.7 4.7 0 0 1-3-1.1V15a5 5 0 1 1-5-5v2.7a2.4 2.4 0 1 0 2.4 2.4V2h2.6a4.7 4.7 0 0 0 3 4.3v0z"/></svg></a>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.6 7.2a2.4 2.4 0 0 0-1.7-1.7C18.5 5 12 5 12 5s-6.5 0-7.9.5A2.4 2.4 0 0 0 2.4 7.2 25 25 0 0 0 2 12a25 25 0 0 0 .4 4.8 2.4 2.4 0 0 0 1.7 1.7C5.5 19 12 19 12 19s6.5 0 7.9-.5a2.4 2.4 0 0 0 1.7-1.7A25 25 0 0 0 22 12a25 25 0 0 0-.4-4.8zM10 15V9l5 3-5 3z"/></svg></a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'menu' -%}
          {%- assign block_menu = linklists[block.settings.menu] -%}
          <div class="vd-footer__col" {{ block.shopify_attributes }}>
            <div class="vd-footer__heading">{{ block.settings.heading }}</div>
            <ul class="vd-footer__list">
              {%- for link in block_menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- when 'links' -%}
          <div class="vd-footer__col" {{ block.shopify_attributes }}>
            <div class="vd-footer__heading">{{ block.settings.heading }}</div>
            <ul class="vd-footer__list">
              {%- if block.settings.link_1_label != blank -%}<li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a></li>{%- endif -%}
              {%- if block.settings.link_2_label != blank -%}<li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a></li>{%- endif -%}
              {%- if block.settings.link_3_label != blank -%}<li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a></li>{%- endif -%}
              {%- if block.settings.link_4_label != blank -%}<li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_label }}</a></li>{%- endif -%}
              {%- if block.settings.link_5_label != blank -%}<li><a href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_label }}</a></li>{%- endif -%}
              {%- if block.settings.link_6_label != blank -%}<li><a href="{{ block.settings.link_6_url }}">{{ block.settings.link_6_label }}</a></li>{%- endif -%}
            </ul>
          </div>
        {%- when 'newsletter' -%}
          <div class="vd-footer__col" {{ block.shopify_attributes }}>
            <div class="vd-footer__heading">{{ block.settings.heading }}</div>
            <p style="font-size:var(--vd-fs-sm);color:var(--vd-text-soft);">{{ block.settings.text }}</p>
            {%- form 'customer', class: 'vd-field', id: 'NewsletterForm--footer' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input class="vd-input" type="email" name="contact[email]" placeholder="Votre email" required>
              <button type="submit">S'inscrire</button>
            {%- endform -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  <div class="vd-footer__bottom">
    <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} — Tous droits réservés</div>
    {%- if section.settings.show_payments -%}
      <div class="vd-footer__payments">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "aside",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (optionnel)"
    },
    {
      "type": "richtext",
      "id": "brand_text",
      "label": "Texte marque",
      "default": "<p>Vanille Désiré sélectionne des gousses, extraits et épices de Madagascar en lien direct avec les producteurs.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Afficher les réseaux sociaux",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Afficher les moyens de paiement",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu Shopify",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "À propos" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "links",
      "name": "Liens manuels",
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Aide" },
        { "type": "text", "id": "link_1_label", "label": "Lien 1 — libellé" },
        { "type": "url", "id": "link_1_url", "label": "Lien 1 — URL" },
        { "type": "text", "id": "link_2_label", "label": "Lien 2 — libellé" },
        { "type": "url", "id": "link_2_url", "label": "Lien 2 — URL" },
        { "type": "text", "id": "link_3_label", "label": "Lien 3 — libellé" },
        { "type": "url", "id": "link_3_url", "label": "Lien 3 — URL" },
        { "type": "text", "id": "link_4_label", "label": "Lien 4 — libellé" },
        { "type": "url", "id": "link_4_url", "label": "Lien 4 — URL" },
        { "type": "text", "id": "link_5_label", "label": "Lien 5 — libellé" },
        { "type": "url", "id": "link_5_url", "label": "Lien 5 — URL" },
        { "type": "text", "id": "link_6_label", "label": "Lien 6 — libellé" },
        { "type": "url", "id": "link_6_url", "label": "Lien 6 — URL" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Newsletter" },
        { "type": "text", "id": "text", "label": "Texte", "default": "Recevez nos nouveautés et conseils." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "category": "Footer",
      "blocks": [
        { "type": "links", "settings": { "heading": "À propos", "link_1_label": "Notre histoire", "link_2_label": "Nos producteurs", "link_3_label": "Espace Pro", "link_4_label": "Salons" } },
        { "type": "links", "settings": { "heading": "Aide", "link_1_label": "Livraison", "link_2_label": "Retours", "link_3_label": "CGV", "link_4_label": "Mentions légales", "link_5_label": "Confidentialité" } },
        { "type": "newsletter", "settings": { "heading": "Newsletter", "text": "Recevez nos actualités et nos nouveautés." } }
      ]
    }
  ]
}
{% endschema %}
