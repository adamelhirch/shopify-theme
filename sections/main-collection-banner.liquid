{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection_products_count = collection.all_products_count
  assign collection_products_label = 'produits'
  if collection_products_count == 1
    assign collection_products_label = 'produit'
  endif

  assign hero_eyebrow = section.settings.eyebrow
  if hero_eyebrow == blank
    assign hero_eyebrow = 'Collection'
  endif

  assign display_title = collection.title
  assign curation_note = 'Une lecture plus nette des formats, de la matière et des usages.'
  assign collection_description_plain = collection.description | strip_html | strip
  assign hero_detail = collection_products_count | append: ' ' | append: collection_products_label
  assign primary_visual = collection.image
  assign feature_product_primary = collection.products.first
  assign feature_product_secondary = collection.products[1]
  assign feature_product_tertiary = collection.products[2]
  assign collection_background_video_url = ''
  assign collection_backdrop_image = section.settings.background_image
  assign has_collection_backdrop = false

  if collection.handle == 'all'
    assign display_title = 'Tous les produits'
    assign hero_eyebrow = 'Maison'
    assign curation_note = "Comparer l’ensemble de la maison pour retrouver rapidement le bon format, le bon usage ou une idée cadeau."
    assign hero_detail = 'Sélection complète'
  elsif collection.handle == 'vanille-bourbon'
    assign curation_note = 'La matière signature: gousses, caviar, extraits et formats de cuisine ou de cadeau.'
    assign hero_detail = 'Gousses, extraits, caviar'
  elsif collection.handle == 'epices-madagascar'
    assign curation_note = 'Poivres, combava, cannelle et épices de cuisine pour retrouver vite le bon accord et le bon niveau d’intensité.'
    assign hero_detail = 'Accords, intensités, cuisines'
  elsif collection.handle == 'sels-aromatises'
    assign curation_note = "Des assemblages signatures pour la finition, l’assaisonnement et les accords plus contemporains."
    assign hero_detail = 'Assemblages aromatiques'
  elsif collection.handle == 'poivre-baies'
    assign curation_note = 'Poivres, baies rares et signatures franches pour la table, les sauces et les finitions qui demandent du caractère.'
    assign hero_detail = 'Poivres, baies, coffrets'
  elsif collection.handle == 'huiles-essentielles'
    assign curation_note = 'Une approche claire et responsable pour les usages externes, les précautions et la bonne orientation produit.'
    assign hero_detail = 'Usage externe et dilution'
  endif

  if primary_visual == blank and feature_product_primary != blank
    assign primary_visual = feature_product_primary.featured_media.preview_image | default: feature_product_primary.featured_image
  endif

  if collection_backdrop_image == blank
    assign collection_backdrop_image = primary_visual
  endif

  if section.settings.background_video != blank
    for source in section.settings.background_video.sources
      if source.mime_type == 'video/mp4'
        assign collection_background_video_url = source.url
        break
      endif
    endfor
  endif

  if collection_backdrop_image != blank or collection_background_video_url != blank
    assign has_collection_backdrop = true
  endif
-%}

{%- style -%}
  @media screen and (max-width: 749px) {
    .collection-hero--with-image .collection-hero__inner {
      padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
    }
  }
{%- endstyle -%}

<div class="collection-hero{% if section.settings.show_collection_image and collection.image %} collection-hero--with-image{% endif %}{% if has_collection_backdrop %} collection-hero--with-backdrop{% endif %} color-{{ section.settings.color_scheme }} gradient">
  {% if has_collection_backdrop %}
    <div class="collection-hero__backdrop" aria-hidden="true">
      {% if collection_background_video_url != blank %}
        <video class="collection-hero__backdrop-media" autoplay muted loop playsinline preload="metadata">
          <source src="{{ collection_background_video_url }}" type="video/mp4">
        </video>
      {% elsif collection_backdrop_image != blank %}
        {{
          collection_backdrop_image
          | image_url: width: 2200
          | image_tag:
            class: 'collection-hero__backdrop-media',
            widths: '720, 960, 1280, 1600, 2200',
            sizes: '100vw',
            loading: 'eager',
            alt: ''
        }}
      {% endif %}
    </div>
  {% endif %}
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__shell">
      <div class="collection-hero__text-wrapper">
        <span class="vd-section-kicker">{{ hero_eyebrow }}</span>
        <h1 class="collection-hero__title">
          <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
          {{- display_title | escape -}}
        </h1>

        <div class="collection-hero__details" role="list">
          <span class="collection-hero__detail" role="listitem">{{ collection_products_count }} {{ collection_products_label }}</span>
          <span class="collection-hero__detail" role="listitem">{{ hero_detail }}</span>
        </div>

        {%- if section.settings.show_collection_description and collection_description_plain != blank -%}
          <div class="collection-hero__description rte"><p>{{ collection_description_plain | truncatewords: 40 }}</p></div>
        {%- else -%}
          <div class="collection-hero__description rte"><p>{{ curation_note }}</p></div>
        {%- endif -%}

        {%- if section.settings.primary_link_label != blank or section.settings.secondary_link_label != blank -%}
          <div class="collection-hero__actions">
            {%- if section.settings.primary_link_label != blank and section.settings.primary_link != blank -%}
              <a href="{{ section.settings.primary_link }}" class="vd-arrow-cta">
                <span class="vd-arrow-cta__label">{{ section.settings.primary_link_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.secondary_link_label != blank and section.settings.secondary_link != blank -%}
              <a href="{{ section.settings.secondary_link }}" class="vd-arrow-cta">
                <span class="vd-arrow-cta__label">{{ section.settings.secondary_link_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="collection-hero__stage">
        <div class="collection-hero__stage-glow" aria-hidden="true"></div>
        {% if primary_visual != blank %}
          <div class="collection-hero__visual collection-hero__visual--main media gradient">
            <img
              srcset="
                {%- if primary_visual.width >= 360 -%}{{ primary_visual | image_url: width: 360 }} 360w,{%- endif -%}
                {%- if primary_visual.width >= 535 -%}{{ primary_visual | image_url: width: 535 }} 535w,{%- endif -%}
                {%- if primary_visual.width >= 750 -%}{{ primary_visual | image_url: width: 750 }} 750w,{%- endif -%}
                {%- if primary_visual.width >= 1070 -%}{{ primary_visual | image_url: width: 1070 }} 1070w,{%- endif -%}
                {%- if primary_visual.width >= 1500 -%}{{ primary_visual | image_url: width: 1500 }} 1500w,{%- endif -%}
                {{ primary_visual | image_url }} {{ primary_visual.width }}w
              "
              src="{{ primary_visual | image_url: width: 1070 }}"
              sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 120 | divided_by: 2 }}px, (min-width: 750px) calc(54vw - 10rem), calc(100vw - 4rem)"
              alt="{{ primary_visual.alt | default: display_title | escape }}"
              width="{{ primary_visual.width }}"
              height="{{ primary_visual.height }}"
            >
          </div>
        {% endif %}

        {% if feature_product_secondary != blank %}
          <a class="collection-hero__floating-card collection-hero__floating-card--top" href="{{ feature_product_secondary.url }}">
            {% assign floating_image_top = feature_product_secondary.featured_media.preview_image | default: feature_product_secondary.featured_image %}
            {% if floating_image_top != blank %}
              {{
                floating_image_top
                | image_url: width: 320
                | image_tag:
                  class: 'collection-hero__floating-image',
                  widths: '160, 240, 320',
                  sizes: '18rem',
                  loading: 'lazy',
                  alt: feature_product_secondary.title | escape
              }}
            {% endif %}
            <div class="collection-hero__floating-copy">
              <span>{{ feature_product_secondary.type | default: 'Selection' }}</span>
              <strong>{{ feature_product_secondary.title }}</strong>
            </div>
          </a>
        {% endif %}

        {% if feature_product_tertiary != blank %}
          <a class="collection-hero__floating-card collection-hero__floating-card--bottom" href="{{ feature_product_tertiary.url }}">
            {% assign floating_image_bottom = feature_product_tertiary.featured_media.preview_image | default: feature_product_tertiary.featured_image %}
            {% if floating_image_bottom != blank %}
              {{
                floating_image_bottom
                | image_url: width: 320
                | image_tag:
                  class: 'collection-hero__floating-image',
                  widths: '160, 240, 320',
                  sizes: '18rem',
                  loading: 'lazy',
                  alt: feature_product_tertiary.title | escape
              }}
            {% endif %}
            <div class="collection-hero__floating-copy">
              <span>{{ feature_product_tertiary.type | default: 'Signature' }}</span>
              <strong>{{ feature_product_tertiary.title }}</strong>
            </div>
          </a>
        {% endif %}

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Repères"
    },
    {
      "type": "text",
      "id": "metric_primary_label",
      "label": "Libellé repère 1",
      "default": "Selection"
    },
    {
      "type": "text",
      "id": "metric_primary_value",
      "label": "Valeur repère 1"
    },
    {
      "type": "text",
      "id": "metric_secondary_label",
      "label": "Libellé repère 2",
      "default": "Lecture"
    },
    {
      "type": "text",
      "id": "metric_secondary_value",
      "label": "Valeur repère 2",
      "default": "Formats, intensite, usages"
    },
    {
      "type": "text",
      "id": "metric_tertiary_label",
      "label": "Libellé repère 3",
      "default": "Suite"
    },
    {
      "type": "text",
      "id": "metric_tertiary_value",
      "label": "Valeur repère 3",
      "default": "Recettes, conseils, wiki"
    },
    {
      "type": "header",
      "content": "Liens"
    },
    {
      "type": "text",
      "id": "primary_link_label",
      "label": "Libellé lien principal",
      "default": "Voir les recettes"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien principal"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Libellé lien secondaire",
      "default": "Parler avec nous"
    },
    {
      "type": "header",
      "content": "Fond média"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Vidéo Shopify de fond"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien secondaire"
    }
  ]
}
{% endschema %}
