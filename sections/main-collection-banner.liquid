{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection_products_count = collection.all_products_count
  assign collection_products_label = 'produits'
  if collection_products_count == 1
    assign collection_products_label = 'produit'
  endif

  assign hero_eyebrow = section.settings.eyebrow
  if hero_eyebrow == blank
    assign hero_eyebrow = 'Collection'
  endif

  assign metric_primary_label = section.settings.metric_primary_label
  if metric_primary_label == blank
    assign metric_primary_label = 'Selection'
  endif

  assign metric_primary_value = section.settings.metric_primary_value
  if metric_primary_value == blank
    assign metric_primary_value = collection_products_count | append: ' ' | append: collection_products_label
  endif

  assign metric_secondary_label = section.settings.metric_secondary_label
  if metric_secondary_label == blank
    assign metric_secondary_label = 'Lecture'
  endif

  assign metric_secondary_value = section.settings.metric_secondary_value
  if metric_secondary_value == blank
    assign metric_secondary_value = 'Formats, intensite, usages'
  endif

  assign metric_tertiary_label = section.settings.metric_tertiary_label
  if metric_tertiary_label == blank
    assign metric_tertiary_label = 'Suite'
  endif

  assign metric_tertiary_value = section.settings.metric_tertiary_value
  if metric_tertiary_value == blank
    assign metric_tertiary_value = 'Recettes, conseils, wiki'
  endif
-%}

{%- style -%}
  @media screen and (max-width: 749px) {
    .collection-hero--with-image .collection-hero__inner {
      padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
    }
  }
{%- endstyle -%}

<div class="collection-hero{% if section.settings.show_collection_image and collection.image %} collection-hero--with-image{% endif %} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      <span class="vd-section-kicker">{{ hero_eyebrow }}</span>
      <h1 class="collection-hero__title">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        {{- collection.title | escape -}}
      </h1>

      {%- if section.settings.show_collection_description -%}
        <div class="collection-hero__description rte">{{ collection.description }}</div>
      {%- endif -%}

      <div class="collection-hero__metrics" role="list">
        <div class="collection-hero__metric" role="listitem">
          <span>{{ metric_primary_label }}</span>
          <strong>{{ metric_primary_value }}</strong>
        </div>
        <div class="collection-hero__metric" role="listitem">
          <span>{{ metric_secondary_label }}</span>
          <strong>{{ metric_secondary_value }}</strong>
        </div>
        <div class="collection-hero__metric" role="listitem">
          <span>{{ metric_tertiary_label }}</span>
          <strong>{{ metric_tertiary_value }}</strong>
        </div>
      </div>

      {%- if section.settings.primary_link_label != blank or section.settings.secondary_link_label != blank -%}
        <div class="collection-hero__actions">
          {%- if section.settings.primary_link_label != blank and section.settings.primary_link != blank -%}
            <a href="{{ section.settings.primary_link }}" class="vd-arrow-cta">
              <span class="vd-arrow-cta__label">{{ section.settings.primary_link_label }}</span>
              <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_link_label != blank and section.settings.secondary_link != blank -%}
            <a href="{{ section.settings.secondary_link }}" class="vd-arrow-cta">
              <span class="vd-arrow-cta__label">{{ section.settings.secondary_link_label }}</span>
              <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
              </svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container media gradient">
        <img
          srcset="
            {%- if collection.image.width >= 165 -%}{{ collection.image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if collection.image.width >= 535 -%}{{ collection.image | image_url: width: 535 }} 535w,{%- endif -%}
            {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
            {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ collection.image | image_url }} {{ collection.image.width }}w
          "
          src="{{ collection.image | image_url: width: 750 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)"
          alt="{{ collection.image.alt | escape }}"
          width="{{ collection.image.width }}"
          height="{{ collection.image.height }}"
        >
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Repères"
    },
    {
      "type": "text",
      "id": "metric_primary_label",
      "label": "Libellé repère 1",
      "default": "Selection"
    },
    {
      "type": "text",
      "id": "metric_primary_value",
      "label": "Valeur repère 1"
    },
    {
      "type": "text",
      "id": "metric_secondary_label",
      "label": "Libellé repère 2",
      "default": "Lecture"
    },
    {
      "type": "text",
      "id": "metric_secondary_value",
      "label": "Valeur repère 2",
      "default": "Formats, intensite, usages"
    },
    {
      "type": "text",
      "id": "metric_tertiary_label",
      "label": "Libellé repère 3",
      "default": "Suite"
    },
    {
      "type": "text",
      "id": "metric_tertiary_value",
      "label": "Valeur repère 3",
      "default": "Recettes, conseils, wiki"
    },
    {
      "type": "header",
      "content": "Liens"
    },
    {
      "type": "text",
      "id": "primary_link_label",
      "label": "Libellé lien principal",
      "default": "Voir les recettes"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien principal"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Libellé lien secondaire",
      "default": "Parler avec nous"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien secondaire"
    }
  ]
}
{% endschema %}
