{%- liquid
  assign supporting_collection = section.settings.supporting_collection
  assign featured_product = section.settings.featured_product

  if featured_product == blank and supporting_collection != blank
    assign featured_product = supporting_collection.products.first
  endif

  assign display_title = section.settings.heading
  if display_title == blank and featured_product != blank
    assign display_title = featured_product.title
  endif

  assign display_text = section.settings.text
  assign primary_link = section.settings.primary_button_link
  assign secondary_link = section.settings.secondary_button_link

  if primary_link == blank and featured_product != blank
    assign primary_link = featured_product.url
  endif

  if secondary_link == blank and supporting_collection != blank
    assign secondary_link = supporting_collection.url
  endif
-%}

<div class="vd-showcase color-{{ section.settings.color_scheme }}" data-vd-showcase>
  {% if featured_product != blank %}
    {%- liquid
      assign featured_image = featured_product.featured_media.preview_image | default: featured_product.featured_image
    -%}

    {%- comment -%} ── Featured product: hero card ── {%- endcomment -%}
    <div class="vd-showcase__hero">
      <div class="vd-showcase__hero-media">
        {% if featured_image != blank %}
          {{
            featured_image
            | image_url: width: 1600
            | image_tag:
              class: 'vd-showcase__img',
              widths: '540, 720, 960, 1200, 1600',
              sizes: '(min-width: 990px) 50vw, 100vw',
              loading: 'lazy',
              alt: featured_image.alt | default: featured_product.title | escape
          }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'vd-showcase__img placeholder-svg' }}
        {% endif %}
      </div>

      <div class="vd-showcase__hero-content">
        {% if section.settings.eyebrow != blank %}
          <span class="vd-showcase__kicker">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if display_title != blank %}
          <h2 class="vd-showcase__title">{{ display_title }}</h2>
        {% endif %}

        {% if display_text != blank %}
          <div class="vd-showcase__text rte">{{ display_text }}</div>
        {% endif %}

        <div class="vd-showcase__actions">
          {% if section.settings.primary_button_label != blank %}
            <a href="{{ primary_link | default: '#' }}" class="vd-showcase__cta">{{ section.settings.primary_button_label }}</a>
          {% endif %}
          {% if section.settings.secondary_button_label != blank %}
            <a href="{{ secondary_link | default: '#' }}" class="vd-showcase__cta vd-showcase__cta--ghost">{{ section.settings.secondary_button_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>

    {%- comment -%} ── Supporting products: 2x2 grid ── {%- endcomment -%}
    <div class="vd-showcase__grid">
      {%- liquid
        assign support_count = 0
      -%}

      {% for product in supporting_collection.products %}
        {% if product.id == featured_product.id %}
          {% continue %}
        {% endif %}
        {% if support_count >= 4 %}
          {% break %}
        {% endif %}

        {%- liquid
          assign support_count = support_count | plus: 1
          assign card_image = product.featured_media.preview_image | default: product.featured_image
        -%}

        <a href="{{ product.url }}" class="vd-showcase__card">
          <div class="vd-showcase__card-media">
            {% if card_image != blank %}
              {{
                card_image
                | image_url: width: 800
                | image_tag:
                  class: 'vd-showcase__img',
                  widths: '320, 480, 640, 800',
                  sizes: '(min-width: 990px) 22vw, 46vw',
                  loading: 'lazy',
                  alt: card_image.alt | default: product.title | escape
              }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'vd-showcase__img placeholder-svg' }}
            {% endif %}
          </div>

          <div class="vd-showcase__card-info">
            <h3 class="vd-showcase__card-name">{{ product.title }}</h3>
            <span class="vd-showcase__card-price">{{ product.price | money }}</span>
          </div>
        </a>
      {% endfor %}

    </div>

  {% else %}
    <div class="page-width">
      <div class="vd-showcase__empty">
        <p>Choisissez un produit vedette et une collection d'appui.</p>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "VD Vitrine Produits",
  "tag": "section",
  "class": "section section-vd-new-product-bento",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Nouveau produit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Un concentre aromatique dense, net et pret a l'emploi.</p>"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Produit vedette"
    },
    {
      "type": "collection",
      "id": "supporting_collection",
      "label": "Collection d'appui"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Bouton principal",
      "default": "J'en profite"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Lien bouton principal"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Bouton secondaire",
      "default": "Voir tous les produits"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Lien bouton secondaire"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    }
  ],
  "presets": [
    {
      "name": "VD Vitrine Produits"
    }
  ]
}
{% endschema %}
