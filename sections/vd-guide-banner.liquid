<div class="vd-guide-banner" data-vd-guide-banner>
  <div class="vd-guide-banner__media">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          class: 'vd-guide-banner__img',
          widths: '720, 960, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          loading: 'lazy',
          alt: section.settings.image.alt | default: section.settings.heading | escape
      }}
    {% else %}
      <img
        class="vd-guide-banner__img"
        src="{{ 'guide-banner-bg.jpg' | asset_url }}"
        alt="Plantation de vanille"
        loading="lazy"
        width="1600"
        height="900"
      >
    {% endif %}
  </div>

  <div class="vd-guide-banner__overlay"></div>

  <div class="vd-guide-banner__content">
    {% if section.settings.kicker != blank %}
      <span class="vd-guide-banner__kicker">{{ section.settings.kicker }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="vd-guide-banner__title">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="vd-guide-banner__text">{{ section.settings.text }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link | default: '#' }}" class="vd-guide-banner__cta">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "VD Guide Banner",
  "tag": "section",
  "class": "section section-vd-guide-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Sur-titre",
      "default": "Le Wiki"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Tout comprendre sur la vanille"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texte",
      "default": "Terroirs, botanique, gestes et techniques : un guide complet pour les curieux exigeants."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libelle bouton",
      "default": "Lire le guide"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    }
  ],
  "presets": [
    {
      "name": "VD Guide Banner"
    }
  ]
}
{% endschema %}
