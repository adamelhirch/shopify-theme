{%- if section.blocks.size > 0 -%}
  <div class="vd-announcement" role="region" aria-label="Annonces">
    <div class="vd-announcement__track">
      {%- for block in section.blocks -%}
        <div class="vd-announcement__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
          {%- else -%}
            {{ block.settings.text }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.blocks.size > 1 -%}
      <button type="button" class="vd-announcement__nav vd-announcement__nav--prev" aria-label="Précédent">‹</button>
      <button type="button" class="vd-announcement__nav vd-announcement__nav--next" aria-label="Suivant">›</button>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Annonce (bandeau)",
  "tag": "aside",
  "class": "shopify-section--announcement",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison offerte dès 59€"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Annonce (bandeau)",
      "category": "Header",
      "blocks": [
        { "type": "message", "settings": { "text": "🌿 Livraison offerte dès 59€ — France métropolitaine" } },
        { "type": "message", "settings": { "text": "Direct producteurs Madagascar" } },
        { "type": "message", "settings": { "text": "Récolte 2026 disponible" } }
      ]
    }
  ]
}
{% endschema %}
