{{ 'vd-product.css' | asset_url | stylesheet_tag }}
{{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign current_variant = product.selected_or_first_available_variant
-%}

<section class="vd-product color-{{ section.settings.color_scheme }}" data-vd-product>
  {%- comment -%} ── 01 · Hero shell : galerie + panneau achat ── {%- endcomment -%}
  <div class="page-width vd-product__shell">
    <div class="vd-product__gallery">
      {%- assign featured = current_variant.featured_media | default: product.featured_media -%}

      <figure class="vd-product__main" data-vd-product-main>
        {%- if featured != blank -%}
          {{
            featured
            | image_url: width: 1600
            | image_tag:
              class: 'vd-product__main-img',
              widths: '600, 900, 1200, 1600',
              sizes: '(min-width: 990px) 55vw, 100vw',
              loading: 'eager',
              fetchpriority: 'high',
              alt: featured.alt | default: product.title | escape
          }}
        {%- else -%}
          <div class="vd-product__main-img vd-product__main-img--placeholder" aria-hidden="true">
            {{ 'product-1' | placeholder_svg_tag: 'vd-product__placeholder-svg' }}
          </div>
        {%- endif -%}
      </figure>

      {%- if product.media.size > 1 -%}
        <ul class="vd-product__thumbs" role="list">
          {%- for media in product.media -%}
            <li>
              <button
                type="button"
                class="vd-product__thumb{% if forloop.first %} is-active{% endif %}"
                data-vd-thumb
                data-src="{{ media | image_url: width: 1600 }}"
                data-alt="{{ media.alt | default: product.title | escape }}"
                aria-label="Afficher l'image {{ forloop.index }}"
              >
                {{
                  media
                  | image_url: width: 240
                  | image_tag:
                    widths: '120, 200, 240',
                    sizes: '8rem',
                    loading: 'lazy',
                    alt: ''
                }}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <aside class="vd-product__panel">
      <div class="vd-product__panel-inner">
        {%- liquid
          assign kicker_parts = ''
          if product.vendor != blank
            assign kicker_parts = product.vendor | upcase
          endif
          if section.settings.kicker_extra != blank
            if kicker_parts != ''
              assign kicker_parts = kicker_parts | append: ' · ' | append: section.settings.kicker_extra
            else
              assign kicker_parts = section.settings.kicker_extra
            endif
          endif
        -%}

        {%- if kicker_parts != '' -%}
          <span class="vd-product__kicker">
            <span class="vd-product__kicker-dot" aria-hidden="true"></span>{{ kicker_parts }}
          </span>
        {%- endif -%}

        <h1 class="vd-product__title">{{ product.title | escape }}</h1>

        {%- if section.settings.subtitle != blank -%}
          <p class="vd-product__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <div class="vd-product__price" id="Price-{{ section.id }}">
          {%- render 'price', product: product, use_variant: true, show_badges: true -%}
        </div>

        {%- if product.has_only_default_variant == false -%}
          <div class="vd-product__options">
            {%- render 'product-variant-picker',
              product: product,
              block: section,
              product_form_id: product_form_id
            -%}
          </div>
        {%- endif -%}

        <div class="vd-product__qty-row">
          <label for="Quantity-{{ section.id }}" class="vd-product__qty-label">Quantité</label>
          <quantity-input class="vd-product__qty">
            <button class="vd-product__qty-btn" name="minus" type="button" aria-label="Diminuer la quantité">
              <span aria-hidden="true">−</span>
            </button>
            <input
              class="vd-product__qty-input"
              type="number"
              name="quantity"
              id="Quantity-{{ section.id }}"
              min="1"
              value="1"
              form="{{ product_form_id }}"
            >
            <button class="vd-product__qty-btn" name="plus" type="button" aria-label="Augmenter la quantité">
              <span aria-hidden="true">+</span>
            </button>
          </quantity-input>
        </div>

        <div class="vd-product__buy">
          {%- render 'buy-buttons',
            block: section,
            product: product,
            product_form_id: product_form_id,
            section_id: section.id,
            show_pickup_availability: false
          -%}
        </div>

        {%- if section.settings.reassurance_1 != blank or section.settings.reassurance_2 != blank or section.settings.reassurance_3 != blank -%}
          <ul class="vd-product__reassurance" role="list">
            {%- if section.settings.reassurance_1 != blank -%}
              <li><span class="vd-product__reassurance-dot" aria-hidden="true"></span>{{ section.settings.reassurance_1 }}</li>
            {%- endif -%}
            {%- if section.settings.reassurance_2 != blank -%}
              <li><span class="vd-product__reassurance-dot" aria-hidden="true"></span>{{ section.settings.reassurance_2 }}</li>
            {%- endif -%}
            {%- if section.settings.reassurance_3 != blank -%}
              <li><span class="vd-product__reassurance-dot" aria-hidden="true"></span>{{ section.settings.reassurance_3 }}</li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>
    </aside>
  </div>

  {%- comment -%} ── 02 · Description (intro courte centrée façon YC) ── {%- endcomment -%}
  {%- if product.description != blank -%}
    <div class="page-width vd-product__intro vd-product-reveal">
      <div class="vd-product__intro-body rte">{{ product.description }}</div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 03 · Strip détails produit (Format / Poids / Origine / Lot) ── {%- endcomment -%}
  {%- liquid
    assign has_details = false
    if section.settings.detail_1_label != blank or section.settings.detail_2_label != blank or section.settings.detail_3_label != blank or section.settings.detail_4_label != blank
      assign has_details = true
    endif
  -%}

  {%- if has_details -%}
    <div class="page-width vd-product__details vd-product-reveal">
      <ul class="vd-product__details-list" role="list">
        {%- for i in (1..4) -%}
          {%- assign label_key = 'detail_' | append: i | append: '_label' -%}
          {%- assign value_key = 'detail_' | append: i | append: '_value' -%}
          {%- assign label = section.settings[label_key] -%}
          {%- assign value = section.settings[value_key] -%}
          {%- if label != blank -%}
            <li class="vd-product__detail">
              <span class="vd-product__detail-label">{{ label }}</span>
              <span class="vd-product__detail-value">{{ value }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  {%- comment -%} ── 04 · Ingrédients ── {%- endcomment -%}
  {%- if section.settings.ingredients != blank -%}
    <div class="page-width vd-product__block vd-product-reveal">
      <div class="vd-product__block-row">
        <span class="vd-product__hanging-label">{{ section.settings.ingredients_label | default: 'Ingrédients' }}</span>
        <div class="vd-product__block-body rte">{{ section.settings.ingredients }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 05 · Allergènes ── {%- endcomment -%}
  {%- if section.settings.allergens_list != blank or section.settings.allergens_note != blank -%}
    <div class="page-width vd-product__block vd-product-reveal">
      <div class="vd-product__block-row">
        <span class="vd-product__hanging-label">{{ section.settings.allergens_label | default: 'Allergènes' }}</span>
        <div class="vd-product__block-body">
          {%- if section.settings.allergens_list != blank -%}
            <ul class="vd-product__allergens" role="list">
              {%- assign allergens = section.settings.allergens_list | split: ',' -%}
              {%- for a in allergens -%}
                <li>
                  <span class="vd-product__allergen-dot" aria-hidden="true"></span>
                  <span>{{ a | strip }}</span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- if section.settings.allergens_note != blank -%}
            <p class="vd-product__allergens-note">{{ section.settings.allergens_note }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 06 · Valeurs nutritionnelles ── {%- endcomment -%}
  {%- liquid
    assign has_nutri = false
    for i in (1..6)
      assign nl_key = 'nutri_' | append: i | append: '_label'
      assign nl_val = section.settings[nl_key]
      if nl_val != blank
        assign has_nutri = true
        break
      endif
    endfor
  -%}

  {%- if has_nutri -%}
    <div class="page-width vd-product__block vd-product-reveal">
      <div class="vd-product__block-row">
        <span class="vd-product__hanging-label">{{ section.settings.nutri_label | default: 'Valeurs nutritionnelles' }}</span>
        <div class="vd-product__block-body">
          {%- if section.settings.nutri_intro != blank -%}
            <p class="vd-product__nutri-intro">{{ section.settings.nutri_intro }}</p>
          {%- endif -%}
          <ul class="vd-product__nutri" role="list">
            {%- for i in (1..6) -%}
              {%- assign nl_key = 'nutri_' | append: i | append: '_label' -%}
              {%- assign nv_key = 'nutri_' | append: i | append: '_value' -%}
              {%- assign nl = section.settings[nl_key] -%}
              {%- assign nv = section.settings[nv_key] -%}
              {%- if nl != blank -%}
                <li class="vd-product__nutri-cell">
                  <span class="vd-product__nutri-value">{{ nv }}</span>
                  <span class="vd-product__nutri-label">{{ nl }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 07 · Conservation & Usage (2 colonnes) ── {%- endcomment -%}
  {%- if section.settings.conservation_text != blank or section.settings.usage_text != blank -%}
    <div class="page-width vd-product__info vd-product-reveal">
      <div class="vd-product__info-grid">
        {%- if section.settings.conservation_text != blank -%}
          <div class="vd-product__info-block">
            <span class="vd-product__hanging-label">Conservation</span>
            <div class="vd-product__info-text rte">{{ section.settings.conservation_text }}</div>
          </div>
        {%- endif -%}
        {%- if section.settings.usage_text != blank -%}
          <div class="vd-product__info-block">
            <span class="vd-product__hanging-label">Usage</span>
            <div class="vd-product__info-text rte">{{ section.settings.usage_text }}</div>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 08 · Livraison & retrait ── {%- endcomment -%}
  {%- if section.settings.delivery_text != blank -%}
    <div class="page-width vd-product__block vd-product-reveal">
      <div class="vd-product__block-row">
        <span class="vd-product__hanging-label">{{ section.settings.delivery_label | default: 'Livraison & retrait' }}</span>
        <div class="vd-product__block-body rte">{{ section.settings.delivery_text }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 09 · Pull-quote (signature éditoriale, optionnel) ── {%- endcomment -%}
  {%- if section.settings.quote != blank -%}
    <div class="page-width vd-product__quote vd-product-reveal">
      <blockquote>
        <p>{{ section.settings.quote }}</p>
        {%- if section.settings.quote_author != blank -%}
          <cite>— {{ section.settings.quote_author }}</cite>
        {%- endif -%}
      </blockquote>
    </div>
  {%- endif -%}

  {%- comment -%} ── 10 · Mini-renvoi savoir-faire ── {%- endcomment -%}
  {%- if section.settings.method_link_label != blank or section.settings.method_pillars != blank -%}
    <div class="page-width vd-product__method vd-product-reveal">
      <div class="vd-product__method-row">
        <div class="vd-product__method-head">
          {%- if section.settings.method_kicker != blank -%}
            <span class="vd-product__hanging-label">{{ section.settings.method_kicker }}</span>
          {%- endif -%}
          {%- if section.settings.method_heading != blank -%}
            <h2 class="vd-product__method-title">{{ section.settings.method_heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.method_pillars != blank -%}
          <ol class="vd-product__method-pillars" role="list">
            {%- assign pillars = section.settings.method_pillars | split: '|' -%}
            {%- for p in pillars -%}
              <li>
                <span class="vd-product__method-num" aria-hidden="true">0{{ forloop.index }}</span>
                <span class="vd-product__method-text">{{ p | strip }}</span>
              </li>
            {%- endfor -%}
          </ol>
        {%- endif -%}
        {%- if section.settings.method_link_label != blank -%}
          <a href="{{ section.settings.method_link | default: '#' }}" class="vd-product__inline-link">
            <span>{{ section.settings.method_link_label }}</span>
            <span class="vd-product__inline-link-arrow" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 11 · FAQ ── {%- endcomment -%}
  {%- assign has_faq = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq_item' -%}{%- assign has_faq = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}

  {%- if has_faq -%}
    <div class="page-width vd-product__faq vd-product-reveal">
      <div class="vd-product__faq-row">
        <span class="vd-product__hanging-label">{{ section.settings.faq_label | default: 'Questions fréquentes' }}</span>
        <div class="vd-product__faq-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq_item' -%}
              <details class="vd-product__faq-item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="vd-product__faq-icon" aria-hidden="true">+</span>
                </summary>
                <div class="vd-product__faq-answer rte">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var root = document.querySelector('[data-vd-product]');
    if (!root) return;

    var main = root.querySelector('[data-vd-product-main] img');
    var thumbs = root.querySelectorAll('[data-vd-thumb]');
    thumbs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!main) return;
        var src = btn.getAttribute('data-src');
        var alt = btn.getAttribute('data-alt') || '';
        if (src) {
          main.removeAttribute('srcset');
          main.removeAttribute('sizes');
          main.src = src;
          main.alt = alt;
        }
        thumbs.forEach(function (t) { t.classList.toggle('is-active', t === btn); });
      });
    });

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      root.querySelectorAll('.vd-product-reveal').forEach(function (el) { io.observe(el); });
    } else {
      root.querySelectorAll('.vd-product-reveal').forEach(function (el) { el.classList.add('is-visible'); });
    }
  })();
</script>

{% schema %}
{
  "name": "VD Produit",
  "tag": "section",
  "class": "section section-vd-product",
  "settings": [
    { "type": "header", "content": "Panneau achat" },
    { "type": "text", "id": "kicker_extra", "label": "Suffixe kicker (origine, certif…)", "default": "MADAGASCAR" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre court (sous le titre)" },
    { "type": "text", "id": "reassurance_1", "label": "Réassurance 1", "default": "Livraison offerte dès 30 €" },
    { "type": "text", "id": "reassurance_2", "label": "Réassurance 2", "default": "Sélection directe, sans intermédiaire" },
    { "type": "text", "id": "reassurance_3", "label": "Réassurance 3", "default": "Mise en pot propre en France" },

    { "type": "header", "content": "Détails produit (strip)" },
    { "type": "text", "id": "detail_1_label", "label": "Détail 1 — label", "default": "Format" },
    { "type": "text", "id": "detail_1_value", "label": "Détail 1 — valeur", "default": "Tube · 2 gousses" },
    { "type": "text", "id": "detail_2_label", "label": "Détail 2 — label", "default": "Poids net" },
    { "type": "text", "id": "detail_2_value", "label": "Détail 2 — valeur", "default": "8 g" },
    { "type": "text", "id": "detail_3_label", "label": "Détail 3 — label", "default": "Origine" },
    { "type": "text", "id": "detail_3_value", "label": "Détail 3 — valeur", "default": "SAVA, Madagascar" },
    { "type": "text", "id": "detail_4_label", "label": "Détail 4 — label" },
    { "type": "text", "id": "detail_4_value", "label": "Détail 4 — valeur" },

    { "type": "header", "content": "Ingrédients" },
    { "type": "text", "id": "ingredients_label", "label": "Label hanging", "default": "Ingrédients" },
    { "type": "richtext", "id": "ingredients", "label": "Liste des ingrédients", "default": "<p>Vanille Bourbon de Madagascar (<em>Vanilla planifolia</em>) — 100 %.</p>" },

    { "type": "header", "content": "Allergènes" },
    { "type": "text", "id": "allergens_label", "label": "Label hanging", "default": "Allergènes" },
    { "type": "text", "id": "allergens_list", "label": "Liste (séparée par virgules)", "default": "Aucun allergène à déclaration obligatoire" },
    { "type": "textarea", "id": "allergens_note", "label": "Note complémentaire", "default": "Conditionné dans un atelier qui manipule fruits à coque, soja, sésame et lait." },

    { "type": "header", "content": "Valeurs nutritionnelles" },
    { "type": "text", "id": "nutri_label", "label": "Label hanging", "default": "Valeurs nutritionnelles" },
    { "type": "text", "id": "nutri_intro", "label": "Texte d'intro (ex : pour 100 g)", "default": "Pour 100 g (à titre indicatif)" },
    { "type": "text", "id": "nutri_1_label", "label": "Cellule 1 — label", "default": "Énergie" },
    { "type": "text", "id": "nutri_1_value", "label": "Cellule 1 — valeur", "default": "288 kcal" },
    { "type": "text", "id": "nutri_2_label", "label": "Cellule 2 — label", "default": "Matières grasses" },
    { "type": "text", "id": "nutri_2_value", "label": "Cellule 2 — valeur", "default": "0,1 g" },
    { "type": "text", "id": "nutri_3_label", "label": "Cellule 3 — label", "default": "Glucides" },
    { "type": "text", "id": "nutri_3_value", "label": "Cellule 3 — valeur", "default": "12,7 g" },
    { "type": "text", "id": "nutri_4_label", "label": "Cellule 4 — label", "default": "Sucres" },
    { "type": "text", "id": "nutri_4_value", "label": "Cellule 4 — valeur", "default": "12,5 g" },
    { "type": "text", "id": "nutri_5_label", "label": "Cellule 5 — label", "default": "Protéines" },
    { "type": "text", "id": "nutri_5_value", "label": "Cellule 5 — valeur", "default": "0,1 g" },
    { "type": "text", "id": "nutri_6_label", "label": "Cellule 6 — label", "default": "Sel" },
    { "type": "text", "id": "nutri_6_value", "label": "Cellule 6 — valeur", "default": "0 g" },

    { "type": "header", "content": "Conservation & Usage" },
    { "type": "richtext", "id": "conservation_text", "label": "Conservation", "default": "<p>À l'abri de la chaleur et de la lumière, dans un récipient hermétique. Plusieurs années sans perte d'arôme.</p>" },
    { "type": "richtext", "id": "usage_text", "label": "Usage", "default": "<p>Idéal en pâtisserie, en infusion lente dans un liquide chaud, ou râpé à la râpe fine sur une préparation finie.</p>" },

    { "type": "header", "content": "Livraison & retrait" },
    { "type": "text", "id": "delivery_label", "label": "Label hanging", "default": "Livraison & retrait" },
    { "type": "richtext", "id": "delivery_text", "label": "Texte", "default": "<p>Expédition sous 48 h ouvrées depuis la France. Livraison Colissimo ou Mondial Relay. Offerte dès 30 € d'achat.</p>" },

    { "type": "header", "content": "Pull-quote (optionnel)" },
    { "type": "text", "id": "quote", "label": "Phrase éditoriale (italique)" },
    { "type": "text", "id": "quote_author", "label": "Auteur (optionnel)" },

    { "type": "header", "content": "Renvoi savoir-faire" },
    { "type": "text", "id": "method_kicker", "label": "Sur-titre", "default": "Notre méthode" },
    { "type": "text", "id": "method_heading", "label": "Titre", "default": "Le geste avant le rendement." },
    { "type": "text", "id": "method_pillars", "label": "Piliers (séparés par |)", "default": "Récolte au bon stade | Tri & contrôle à l'arrivée | Mise en pot claire en France" },
    { "type": "text", "id": "method_link_label", "label": "Lien — libellé", "default": "Lire le savoir-faire" },
    { "type": "url", "id": "method_link", "label": "Lien — URL" },

    { "type": "header", "content": "FAQ" },
    { "type": "text", "id": "faq_label", "label": "Label hanging", "default": "Questions fréquentes" },

    { "type": "header", "content": "Couleur" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Palette", "default": "scheme-3" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question / Réponse",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Combien de temps puis-je conserver une gousse ?" },
        { "type": "richtext", "id": "answer", "label": "Réponse", "default": "<p>Plusieurs années à l'abri de la lumière dans un récipient hermétique. Si elle se cristallise, c'est bon signe : le givre de vanilline est synonyme de qualité.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Produit",
