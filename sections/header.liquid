{{ 'vd-navbar.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-localization-form.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- style -%}
  .section-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  .vd-nav__bar {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .vd-nav__bar {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign header_tag = 'div'
  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
-%}

<{{ header_tag }}{% if header_tag == 'sticky-header' %} data-sticky-type="{{ section.settings.sticky_header_type }}"{% endif %} class="vd-nav header-wrapper color-{{ section.settings.color_scheme }}" data-vd-nav-host data-vd-header-wrapper>
  {%- if section.settings.promo_text != blank -%}
    <div class="vd-nav__promo">{{ section.settings.promo_text }}</div>
  {%- endif -%}

  <div class="vd-nav__bar">
    <div class="vd-nav__left">
      <button type="button" class="vd-nav__btn" aria-label="Ouvrir le menu" data-vd-nav-open aria-expanded="false" aria-controls="VDNavDrawer">
        <span class="vd-nav__burger"><span></span><span></span></span>
        <span>Menu</span>
      </button>

      <a href="{{ routes.search_url }}" class="vd-nav__kicker vd-nav__kicker--dim vd-nav__kicker--hide-sm">Rechercher</a>
    </div>

    {%- assign logo_alt = shop.name | escape -%}
    {%- if settings.logo != blank and settings.logo.alt != blank -%}
      {%- assign logo_alt = settings.logo.alt | escape -%}
    {%- endif -%}
    <a href="{{ routes.root_url }}" class="vd-nav__logo" aria-label="{{ logo_alt }}">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 600 | image_tag: widths: '240, 360, 480', alt: logo_alt, loading: 'eager', fetchpriority: 'high' }}
      {%- else -%}
        <img src="{{ 'vanille-desire-logo.png' | asset_url }}" alt="{{ logo_alt }}" loading="eager" width="320" height="126">
      {%- endif -%}
    </a>

    <div class="vd-nav__right">
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="vd-nav__kicker vd-nav__kicker--dim vd-nav__kicker--hide-sm" rel="nofollow">Compte</a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" id="cart-icon-bubble" class="vd-nav__btn vd-nav__cart" aria-label="Panier">
        <span class="vd-nav__cart-label">Panier</span>
        <span class="vd-nav__cart-icon" aria-hidden="true">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        <span class="vd-nav__cart-count cart-count-bubble" {% if cart.item_count == 0 %}hidden{% endif %}>
          <span aria-hidden="true">{{ cart.item_count }}</span>
          <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
        </span>
      </a>
    </div>
  </div>
</{{ header_tag }}>

{%- liquid
  assign menu_links = section.settings.menu.links
  assign feature_image = section.settings.feature_image
-%}

<div class="menu-drawer" hidden aria-hidden="true"></div>

<div class="vd-nav-portal" data-vd-nav>
  <div class="vd-nav__overlay" data-vd-nav-close aria-hidden="true"></div>

  <aside
    id="VDNavDrawer"
    class="vd-nav__drawer"
    aria-label="Menu principal"
    aria-hidden="true"
  >
    <div class="vd-nav__drawer-head">
      <a href="{{ routes.root_url }}" class="vd-nav__drawer-logo" aria-label="{{ logo_alt }}">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 400 | image_tag: widths: '180, 270, 360', alt: logo_alt, loading: 'lazy' }}
        {%- else -%}
          <img src="{{ 'vanille-desire-logo.png' | asset_url }}" alt="{{ logo_alt }}" loading="lazy" width="184" height="72">
        {%- endif -%}
      </a>
      <button type="button" class="vd-nav__close" aria-label="Fermer le menu" data-vd-nav-close>
        <span>Fermer</span>
        {{ 'vd-nav-close.svg' | inline_asset_content }}
      </button>
    </div>

    <div class="vd-nav__drawer-utility">
      <a href="{{ routes.search_url }}" class="vd-nav__drawer-util-link">Rechercher</a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="vd-nav__drawer-util-link" rel="nofollow">Compte</a>
      {%- endif -%}
    </div>

    {%- if menu_links != blank -%}
      <div class="vd-nav__drawer-body">
        <nav class="vd-nav__cats" aria-label="Catégories">
          {%- for link in menu_links -%}
            <button
              type="button"
              class="vd-nav__cat{% if forloop.first %} is-active{% endif %}"
              data-vd-nav-cat="{{ forloop.index0 }}"
            >
              {{ link.title | escape }}
              <span class="vd-nav__cat-arrow" aria-hidden="true">→</span>
            </button>
          {%- endfor -%}
        </nav>

        <div class="vd-nav__panels">
          {%- for link in menu_links -%}
            <div
              class="vd-nav__panel{% unless forloop.first %} is-hidden{% endunless %}"
              data-vd-nav-panel="{{ forloop.index0 }}"
              {% unless forloop.first %}hidden{% endunless %}
            >
              <div>
                <button type="button" class="vd-nav__panel-back" data-vd-nav-back aria-label="Retour aux catégories">
                  <span aria-hidden="true">←</span>
                  <span>Catégories</span>
                </button>
                <div class="vd-nav__panel-eyebrow">{{ link.title | escape }}</div>
                {%- if link.links != blank -%}
                  <ul class="vd-nav__panel-list">
                    {%- for child in link.links -%}
                      <li>
                        <a href="{{ child.url }}">
                          <div class="vd-nav__panel-title">{{ child.title | escape }}</div>
                          {%- if child.object.description != blank -%}
                            <div class="vd-nav__panel-desc">{{ child.object.description | strip_html | truncate: 80 }}</div>
                          {%- endif -%}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <ul class="vd-nav__panel-list">
                    <li>
                      <a href="{{ link.url }}">
                        <div class="vd-nav__panel-title">Voir {{ link.title | downcase | escape }}</div>
                      </a>
                    </li>
                  </ul>
                {%- endif -%}
              </div>

              {%- if section.settings.feature_heading != blank or feature_image != blank -%}
                <a href="{{ section.settings.feature_link | default: '#' }}" class="vd-nav__feature">
                  <div
                    class="vd-nav__feature-tile"
                    {% if feature_image != blank %}style="background-image: url('{{ feature_image | image_url: width: 800 }}');"{% endif %}
                  >
                    {%- if section.settings.feature_kicker != blank -%}
                      <div class="vd-nav__feature-kicker">{{ section.settings.feature_kicker }}</div>
                    {%- endif -%}
                    <div class="vd-nav__feature-body">
                      {%- if section.settings.feature_heading != blank -%}
                        <div class="vd-nav__feature-title">{{ section.settings.feature_heading }}</div>
                      {%- endif -%}
                      {%- if section.settings.feature_cta != blank -%}
                        <div class="vd-nav__feature-cta">{{ section.settings.feature_cta }}</div>
                      {%- endif -%}
                    </div>
                  </div>
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.foot_link_1_label != blank or section.settings.foot_link_2_label != blank or section.settings.foot_link_3_label != blank or section.settings.enable_country_selector -%}
      <div class="vd-nav__drawer-foot">
        {%- if section.settings.foot_link_1_label != blank -%}
          <a href="{{ section.settings.foot_link_1_url | default: '#' }}">{{ section.settings.foot_link_1_label }}</a>
        {%- endif -%}
        {%- if section.settings.foot_link_2_label != blank -%}
          <a href="{{ section.settings.foot_link_2_url | default: '#' }}">{{ section.settings.foot_link_2_label }}</a>
        {%- endif -%}
        {%- if section.settings.foot_link_3_label != blank -%}
          <a href="{{ section.settings.foot_link_3_url | default: '#' }}">{{ section.settings.foot_link_3_label }}</a>
        {%- endif -%}
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="vd-nav__drawer-foot-locale">
            {%- form 'localization', id: 'VDNavCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="VDNavCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'VDNavCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- else -%}
          <span class="vd-nav__drawer-foot-locale">
            {{- localization.country.iso_code | default: 'FR' }} · {{ cart.currency.iso_code | default: 'EUR' -}}
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </aside>
</div>

{%- if settings.cart_type == "notification" -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: 'drawer' -%}
{%- endif -%}

{% javascript %}
  class StickyHeader extends HTMLElement {
    connectedCallback() {
      this.header = document.querySelector('.section-header');
      if (!this.header) return;
      this.headerIsAlwaysSticky = ['always', 'reduce-logo-size'].includes(this.getAttribute('data-sticky-type'));
      this.headerBounds = {};
      this.setHeaderHeight();
      window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));
      if (this.headerIsAlwaysSticky) this.header.classList.add('shopify-section-header-sticky');
      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.onScrollHandler = this.onScroll.bind(this);
      window.addEventListener('scroll', this.onScrollHandler, { passive: true });
      this.createObserver();
    }
    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
    }
    disconnectedCallback() {
      window.removeEventListener('scroll', this.onScrollHandler);
    }
    createObserver() {
      const observer = new IntersectionObserver((entries, obs) => {
        this.headerBounds = entries[0].intersectionRect;
        obs.disconnect();
      });
      observer.observe(this.header);
    }
    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (!this.headerIsAlwaysSticky) this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header', 'shopify-section-header-sticky', 'animate');
        this.header.classList.remove('shopify-section-header-hidden');
      } else if (scrollTop <= this.headerBounds.top) {
        this.header.classList.remove('scrolled-past-header');
        if (!this.headerIsAlwaysSticky) this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
      }
      this.currentScrollTop = scrollTop;
    }
  }
  if (!customElements.get('sticky-header')) customElements.define('sticky-header', StickyHeader);

  document.addEventListener('DOMContentLoaded', () => {
    const host = document.querySelector('[data-vd-nav-host]');
    const portal = document.querySelector('[data-vd-nav]');
    if (!portal) return;

    const sectionHeader = document.querySelector('.section-header');
    const openBtn = host && host.querySelector('[data-vd-nav-open]');
    const closers = portal.querySelectorAll('[data-vd-nav-close]');
    const drawer = portal.querySelector('.vd-nav__drawer');
    const cats = Array.from(portal.querySelectorAll('.vd-nav__cat'));
    const panels = Array.from(portal.querySelectorAll('.vd-nav__panel'));
    const backBtns = portal.querySelectorAll('[data-vd-nav-back]');
    const mobileMq = window.matchMedia('(max-width: 989px)');

    const open = () => {
      portal.classList.add('is-open');
      if (host) host.classList.add('is-open');
      if (sectionHeader) sectionHeader.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
      if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
      if (drawer) drawer.setAttribute('aria-hidden', 'false');
    };
    const close = () => {
      portal.classList.remove('is-open', 'is-panel-view');
      if (host) host.classList.remove('is-open');
      if (sectionHeader) sectionHeader.classList.remove('menu-open');
      document.body.style.overflow = '';
      if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
      if (drawer) drawer.setAttribute('aria-hidden', 'true');
    };
    const backToCats = () => portal.classList.remove('is-panel-view');

    if (openBtn) openBtn.addEventListener('click', open);
    closers.forEach((el) => el.addEventListener('click', close));
    backBtns.forEach((el) => el.addEventListener('click', backToCats));

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape' || !portal.classList.contains('is-open')) return;
      if (mobileMq.matches && portal.classList.contains('is-panel-view')) backToCats();
      else close();
    });

    const activate = (idx) => {
      cats.forEach((c) => c.classList.toggle('is-active', String(c.dataset.vdNavCat) === String(idx)));
      panels.forEach((p) => {
        const match = String(p.dataset.vdNavPanel) === String(idx);
        p.classList.toggle('is-hidden', !match);
        if (match) p.removeAttribute('hidden'); else p.setAttribute('hidden', '');
      });
    };
    cats.forEach((c) => {
      c.addEventListener('mouseenter', () => { if (!mobileMq.matches) activate(c.dataset.vdNavCat); });
      c.addEventListener('focus', () => activate(c.dataset.vdNavCat));
      c.addEventListener('click', () => {
        activate(c.dataset.vdNavCat);
        if (mobileMq.matches) portal.classList.add('is-panel-view');
      });
    });
  });
{% endjavascript %}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}"logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},{% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "promo_text",
      "label": "Bandeau promo",
      "default": "Livraison offerte dès 30 € pour les nouveaux clients"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "t:sections.header.settings.sticky_header_type.options__1.label" },
        { "value": "on-scroll-up", "label": "t:sections.header.settings.sticky_header_type.options__2.label" },
        { "value": "always", "label": "t:sections.header.settings.sticky_header_type.options__3.label" }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Visuel du menu (tuile)"
    },
    {
      "type": "text",
      "id": "feature_kicker",
      "label": "Kicker",
      "default": "En ce moment"
    },
    {
      "type": "text",
      "id": "feature_heading",
      "label": "Titre",
      "default": "Coffret récolte 2025"
    },
    {
      "type": "text",
      "id": "feature_cta",
      "label": "Libellé CTA",
      "default": "Découvrir"
    },
    {
      "type": "url",
      "id": "feature_link",
      "label": "Lien"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Pied de menu"
    },
    {
      "type": "text",
      "id": "foot_link_1_label",
      "label": "Lien 1 — libellé",
      "default": "Nous contacter"
    },
    {
      "type": "url",
      "id": "foot_link_1_url",
      "label": "Lien 1 — URL"
    },
    {
      "type": "text",
      "id": "foot_link_2_label",
      "label": "Lien 2 — libellé",
      "default": "Suivre ma commande"
    },
    {
      "type": "url",
      "id": "foot_link_2_url",
      "label": "Lien 2 — URL"
    },
    {
      "type": "text",
      "id": "foot_link_3_label",
      "label": "Lien 3 — libellé",
      "default": "Professionnels"
    },
    {
      "type": "url",
      "id": "foot_link_3_url",
      "label": "Lien 3 — URL"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__utilities.content"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_country_selector.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.margin_bottom.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 20
    }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
