<section class="vd-delivery vd-reveal">
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="" loading="lazy" width="2000" height="1125">
  {%- else -%}
    <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=2000&auto=format&fit=crop" alt="" loading="lazy" width="2000" height="1125">
  {%- endif -%}
  <div class="vd-delivery__inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="vd-eyebrow" style="color:rgba(255,255,255,0.6);">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2 class="vd-delivery__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <p style="font-size:var(--vd-fs-md);color:rgba(255,255,255,0.85);">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="vd-btn vd-btn--light vd-delivery__cta">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bannière livraison",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image de fond" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Livraison" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Expédition en 48h" },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "Commandez avant 14h, expédié le jour-même. Livraison soignée pour préserver l'arôme." },
    { "type": "text", "id": "button_label", "label": "Bouton", "default": "Commander" },
    { "type": "url", "id": "button_link", "label": "Lien bouton" }
  ],
  "presets": [
    { "name": "Bannière livraison", "category": "Accueil" }
  ]
}
{% endschema %}
