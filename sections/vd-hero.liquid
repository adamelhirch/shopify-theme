{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign hero_video_url = ''
  assign hero_poster_image = section.settings.background_image
  assign hero_poster_url = ''
  assign has_metrics = false
  assign hero_title_text = section.settings.heading | strip
  assign hero_body_text = section.settings.text | strip_html | strip
  assign hero_semantic_title = hero_title_text
  assign hero_semantic_text = hero_body_text

  if hero_poster_image == blank and section.settings.background_video.preview_image != blank
    assign hero_poster_image = section.settings.background_video.preview_image
  endif

  if section.settings.background_video != blank
    for source in section.settings.background_video.sources
      if source.mime_type == 'video/mp4'
        assign hero_video_url = source.url
        break
      endif
    endfor
  elsif section.settings.external_video_url != blank
    assign hero_video_url = section.settings.external_video_url
  elsif section.settings.use_demo_video
    assign hero_video_url = 'vd-hero-origin.mp4' | asset_url
  endif

  if hero_poster_image != blank
    assign hero_poster_url = hero_poster_image | image_url: width: 1920
  elsif hero_video_url != blank and section.settings.use_demo_video
    assign hero_poster_url = 'vd-hero-origin-poster.jpg' | asset_url
  endif

  if section.settings.metric_1_value != blank and section.settings.metric_1_label != blank
    assign has_metrics = true
  endif

  if section.settings.metric_2_value != blank and section.settings.metric_2_label != blank
    assign has_metrics = true
  endif

  if section.settings.metric_3_value != blank and section.settings.metric_3_label != blank
    assign has_metrics = true
  endif

  if hero_semantic_title == blank
    assign hero_semantic_title = shop.name | append: ' | Vanille et epices de Madagascar'
  endif

  if hero_semantic_text == blank
    capture hero_semantic_text
      if section.settings.eyebrow != blank
        echo section.settings.eyebrow
        echo '. '
      endif
      echo 'Une selection premium de vanille et d epices de Madagascar, pensee pour la cuisine, le cadeau et les amateurs exigeants.'
    endcapture
    assign hero_semantic_text = hero_semantic_text | strip
  endif

  assign has_aside = false
  if section.blocks.size > 0 or has_metrics
    assign has_aside = true
  endif
-%}

<section
  class="section-{{ section.id }}-padding section-vd-hero color-{{ section.settings.color_scheme }}"
  aria-label="{{ hero_semantic_title | escape }}"
>
  <div class="vd-hero vd-hero--immersive">
    <div class="vd-hero__media{% if hero_video_url != blank %} vd-hero__media--deferred{% endif %}" aria-hidden="true">
      {% if hero_video_url != blank %}
        <video
          class="vd-hero__video"
          autoplay
          loop
          muted
          playsinline
          preload="none"
          data-vd-deferred-video
          data-video-src="{{ hero_video_url }}"
          data-vd-video-load="idle"
          data-vd-video-delay="2400"
          data-min-width="990"
          aria-hidden="true"
          {% if hero_poster_url != blank %}
            poster="{{ hero_poster_url }}"
          {% endif %}
        >
          <source data-src="{{ hero_video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.background_image != blank %}
        {{
          section.settings.background_image
          | image_url: width: 1920
          | image_tag:
            class: 'vd-hero__image',
            widths: '480, 720, 960, 1280, 1600, 1920',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            decoding: 'async',
            alt: ''
        }}
      {% else %}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'vd-hero__image placeholder-svg' }}
      {% endif %}
    </div>

    <div class="vd-hero__backdrop" style="--vd-hero-overlay-opacity: {{ section.settings.media_overlay_opacity | divided_by: 100.0 }};"></div>
    <div class="vd-hero__ambient"></div>

    <div class="page-width vd-hero__frame">
      <div class="vd-hero__inner{% unless has_aside %} vd-hero__inner--solo{% endunless %}">
        <div class="vd-hero__copy">
          {% if section.settings.heading == blank %}
            <h1 class="visually-hidden">{{ hero_semantic_title }}</h1>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h1 class="vd-hero__title">{{ section.settings.heading }}</h1>
          {% endif %}

          {% if section.settings.eyebrow != blank %}
            <span class="{% if section.settings.heading != blank %}vd-eyebrow{% else %}vd-hero__statement{% endif %}">
              {{ section.settings.eyebrow }}
            </span>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="vd-hero__text rte">{{ section.settings.text }}</div>
          {% elsif hero_semantic_text != blank %}
            <p class="visually-hidden">{{ hero_semantic_text }}</p>
          {% endif %}

          <div class="vd-hero__actions">
            {% if section.settings.button_label != blank %}
              <a
                {% if section.settings.button_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ section.settings.button_link }}"
                {% endif %}
                class="button button--primary"
              >
                {{ section.settings.button_label }}
              </a>
            {% endif %}

            {% if section.settings.secondary_button_label != blank %}
              <a
                {% if section.settings.secondary_button_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ section.settings.secondary_button_link }}"
                {% endif %}
                class="button button--secondary"
              >
                {{ section.settings.secondary_button_label }}
              </a>
            {% endif %}
          </div>

          {% if section.settings.show_scroll_indicator %}
            <button
              class="vd-hero__scroll"
              type="button"
              onclick="window.scrollTo({ top: window.innerHeight * 0.92, behavior: 'smooth' });"
            >
              <span>{{ section.settings.scroll_label }}</span>
            </button>
          {% endif %}
        </div>

        {% if has_aside %}
          <aside class="vd-hero__aside">
            {% if section.blocks.size > 0 %}
              {% for block in section.blocks %}
                <div class="vd-hero__card" {{ block.shopify_attributes }}>
                  {% if block.settings.title != blank %}
                    <h2 class="vd-hero__card-title">{{ block.settings.title }}</h2>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <div class="rte">{{ block.settings.text }}</div>
                  {% endif %}
                </div>
              {% endfor %}
            {% endif %}

            {% if has_metrics %}
              <div class="vd-hero__metrics">
                {% if section.settings.metric_1_value != blank and section.settings.metric_1_label != blank %}
                  <div class="vd-metric">
                    <strong>{{ section.settings.metric_1_value }}</strong>
                    <span>{{ section.settings.metric_1_label }}</span>
                  </div>
                {% endif %}
                {% if section.settings.metric_2_value != blank and section.settings.metric_2_label != blank %}
                  <div class="vd-metric">
                    <strong>{{ section.settings.metric_2_value }}</strong>
                    <span>{{ section.settings.metric_2_label }}</span>
                  </div>
                {% endif %}
                {% if section.settings.metric_3_value != blank and section.settings.metric_3_label != blank %}
                  <div class="vd-metric">
                    <strong>{{ section.settings.metric_3_value }}</strong>
                    <span>{{ section.settings.metric_3_label }}</span>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </aside>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Hero Premium",
  "tag": "section",
  "class": "section section-vd-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Vanille premium"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre",
      "default": "La vanille dans sa forme la plus désirable."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Vanille Désiré compose une expérience sensorielle rare autour de gousses sélectionnées, calibrées pour une cuisine exigeante et un art de vivre sobre, précis et élégant.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Afficher l'indicateur de scroll",
      "default": true
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Libelle indicateur de scroll",
      "default": "Glisser vers le bas"
    },
    {
      "type": "text",
      "id": "external_video_url",
      "label": "URL video MP4 externe",
      "info": "Utiliser une video hebergee hors fichiers Shopify"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Video de fond"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image ou GIF de fond"
    },
    {
      "type": "checkbox",
      "id": "use_demo_video",
      "label": "Utiliser la video de demo du theme",
      "default": true
    },
    {
      "type": "range",
      "id": "media_overlay_opacity",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Opacite de l'overlay",
      "default": 55
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Bouton principal",
      "default": "Découvrir la collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien principal"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Bouton secondaire",
      "default": "Notre philosophie"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Lien secondaire"
    },
    {
      "type": "text",
      "id": "metric_1_value",
      "label": "Valeur métrique 1",
      "default": "Gourmet"
    },
    {
      "type": "text",
      "id": "metric_1_label",
      "label": "Libellé métrique 1",
      "default": "Sélection"
    },
    {
      "type": "text",
      "id": "metric_2_value",
      "label": "Valeur métrique 2",
      "default": "Traçable"
    },
    {
      "type": "text",
      "id": "metric_2_label",
      "label": "Libellé métrique 2",
      "default": "Origine"
    },
    {
      "type": "text",
      "id": "metric_3_value",
      "label": "Valeur métrique 3",
      "default": "Intense"
    },
    {
      "type": "text",
      "id": "metric_3_label",
      "label": "Libellé métrique 3",
      "default": "Signature aromatique"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Carte éditoriale",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Sélection haute intensité"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>Des gousses choisies pour leur souplesse, leur brillance et leur profondeur aromatique.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Hero Premium",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Sélection haute intensité",
            "text": "<p>Des lots triés pour une texture charnue, des grains généreux et une longueur en bouche raffinée.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Pensé pour les amateurs exigeants",
            "text": "<p>Pâtisserie, infusion, rhum arrangé ou cuisine fine, la matière première reste au centre du geste.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
