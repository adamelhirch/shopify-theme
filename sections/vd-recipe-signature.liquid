{{ 'vd-recipe-signature.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vd-recipe-signature.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign featured_product = section.settings.featured_product
  assign related_collection = section.settings.related_collection
  assign primary_link = section.settings.primary_link
  assign secondary_link = section.settings.secondary_link

  if primary_link == blank and featured_product != blank
    assign primary_link = featured_product.url
  endif

  if secondary_link == blank and related_collection != blank
    assign secondary_link = related_collection.url
  endif
-%}

<section
  class="section-{{ section.id }}-padding vd-recipe-signature color-{{ section.settings.color_scheme }}"
  data-vd-recipe
  data-base-serves="{{ section.settings.base_serves }}"
  data-download-name="{{ section.settings.download_filename | handle | default: 'recette-vanille-desire' }}"
>
  <div class="page-width">
    <div class="vd-recipe-signature__layout">
      <div class="vd-recipe-signature__main">
        <header class="vd-recipe-signature__hero">
          <div>
            {% if section.settings.eyebrow != blank %}
              <span class="vd-recipe-signature__eyebrow">{{ section.settings.eyebrow }}</span>
            {% endif %}

            {% if section.settings.heading != blank %}
              <h1 class="vd-recipe-signature__heading" data-vd-recipe-title>{{ section.settings.heading }}</h1>
            {% endif %}

            {% if section.settings.intro != blank %}
              <div class="vd-recipe-signature__intro rte" data-vd-recipe-intro>{{ section.settings.intro }}</div>
            {% endif %}

            <div class="vd-recipe-signature__meta">
              <span class="vd-recipe-signature__meta-item">
                {{ section.settings.base_serves }} personnes
              </span>
              {% if section.settings.prep_time != blank %}
                <span class="vd-recipe-signature__meta-item">{{ section.settings.prep_time }}</span>
              {% endif %}
              {% if section.settings.cook_time != blank %}
                <span class="vd-recipe-signature__meta-item">{{ section.settings.cook_time }}</span>
              {% endif %}
              {% if section.settings.difficulty != blank %}
                <span class="vd-recipe-signature__meta-item">{{ section.settings.difficulty }}</span>
              {% endif %}
            </div>
          </div>

          <div class="vd-recipe-signature__controls">
            <div class="vd-recipe-signature__qty" aria-live="polite">
              <button type="button" data-vd-recipe-minus aria-label="Diminuer les portions">−</button>
              <label class="visually-hidden" for="VDRecipeServes-{{ section.id }}">Portions</label>
              <input
                id="VDRecipeServes-{{ section.id }}"
                type="number"
                min="1"
                inputmode="numeric"
                value="{{ section.settings.base_serves }}"
                data-vd-recipe-serves
              >
              <button type="button" data-vd-recipe-plus aria-label="Augmenter les portions">+</button>
            </div>

            <div class="vd-recipe-signature__button-row">
              <button type="button" class="vd-recipe-signature__ghost" data-vd-recipe-toggle>
                Tout cocher
              </button>

              <button type="button" class="vd-recipe-signature__ghost" data-vd-recipe-copy>
                Copier
              </button>

              <button type="button" class="vd-recipe-signature__download" data-vd-recipe-download aria-label="Télécharger la recette">
                <svg viewBox="0 0 384 512" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M169.4 470.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 370.8V64c0-17.7-14.3-32-32-32s-32 14.3-32 32v306.7L54.6 265.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160Z"></path>
                </svg>
                <span class="vd-recipe-signature__download-line" aria-hidden="true"></span>
                <span class="vd-recipe-signature__download-tooltip">Télécharger</span>
              </button>
            </div>
          </div>
        </header>

        <article class="vd-recipe-signature__panel">
          <div class="vd-recipe-signature__panel-head">
            <h2>Ingrédients</h2>
            <span>Pour <span data-vd-recipe-serves-slot>{{ section.settings.base_serves }}</span> personnes</span>
          </div>
          <div class="vd-recipe-signature__panel-body">
            <div class="vd-recipe-signature__list" role="list">
              {% for block in section.blocks %}
                {% if block.type != 'ingredient' %}
                  {% continue %}
                {% endif %}

                {%- liquid
                  assign quantity_value = block.settings.quantity | strip
                  assign quantity_number = quantity_value | replace: ',', '.' | plus: 0
                -%}

                <label class="vd-recipe-signature__check" role="listitem" data-vd-recipe-ingredient {{ block.shopify_attributes }}>
                  <input type="checkbox" data-vd-recipe-check>
                  <span class="vd-recipe-signature__check-ui" aria-hidden="true"></span>
                  <span class="vd-recipe-signature__check-copy">
                    <strong>
                      {% if quantity_value != blank %}
                        <span
                          {% if block.settings.scalable %}
                            data-vd-recipe-base-qty="{{ quantity_value }}"
                          {% endif %}
                        >
                          {{ quantity_value }}
                        </span>
                        {% if block.settings.unit != blank %} {{ block.settings.unit }}{% endif %}
                      {% endif %}
                      {% if block.settings.title != blank %}
                        {% if quantity_value != blank %} · {% endif %}{{ block.settings.title }}
                      {% endif %}
                    </strong>
                    {% if block.settings.note != blank %}
                      <p>{{ block.settings.note }}</p>
                    {% endif %}
                  </span>
                  {% if block.settings.badge != blank %}
                    <span class="vd-recipe-signature__check-note">{{ block.settings.badge }}</span>
                  {% endif %}
                </label>
              {% endfor %}
            </div>
          </div>
        </article>

        <article class="vd-recipe-signature__panel">
          <div class="vd-recipe-signature__panel-head">
            <h2>Préparation</h2>
            <span>Cocher au fil de la recette</span>
          </div>
          <div class="vd-recipe-signature__panel-body">
            <div class="vd-recipe-signature__steps" role="list">
              {% assign step_index = 0 %}
              {% for block in section.blocks %}
                {% if block.type != 'step' %}
                  {% continue %}
                {% endif %}
                {% assign step_index = step_index | plus: 1 %}

                <label class="vd-recipe-signature__check" role="listitem" data-vd-recipe-step {{ block.shopify_attributes }}>
                  <input type="checkbox" data-vd-recipe-check>
                  <span class="vd-recipe-signature__check-ui" aria-hidden="true"></span>
                  <span class="vd-recipe-signature__step-copy">
                    <strong>Étape {{ step_index }}</strong>
                    <p>{{ block.settings.text }}</p>
                  </span>
                </label>
              {% endfor %}
            </div>
          </div>
        </article>
      </div>

      <aside class="vd-recipe-signature__aside">
        <article class="vd-recipe-signature__aside-card">
          <span class="vd-recipe-signature__aside-kicker">Produits à utiliser</span>
          <h3>La recette reste connectée au catalogue.</h3>
          {% if section.settings.sidebar_text != blank %}
            <div class="rte">{{ section.settings.sidebar_text }}</div>
          {% endif %}
          <div class="vd-recipe-signature__aside-actions">
            {% if section.settings.primary_label != blank %}
              <a
                {% if primary_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ primary_link }}"
                {% endif %}
                class="vd-arrow-cta"
              >
                <span class="vd-arrow-cta__label">{{ section.settings.primary_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.secondary_label != blank %}
              <a
                {% if secondary_link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ secondary_link }}"
                {% endif %}
                class="vd-arrow-cta"
              >
                <span class="vd-arrow-cta__label">{{ section.settings.secondary_label }}</span>
                <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                  <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                </svg>
              </a>
            {% endif %}
          </div>
        </article>

        {% if section.settings.provenance != blank %}
          <article class="vd-recipe-signature__aside-card">
            <span class="vd-recipe-signature__aside-kicker">Origine</span>
            <h3>Madagascar, sans folklore inutile.</h3>
            <div class="rte">{{ section.settings.provenance }}</div>
          </article>
        {% endif %}

        {% assign tip_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type != 'tip' %}
            {% continue %}
          {% endif %}
          {% assign tip_count = tip_count | plus: 1 %}
        {% endfor %}

        {% if tip_count > 0 %}
          <article class="vd-recipe-signature__panel">
            <div class="vd-recipe-signature__panel-head">
              <h2>Astuces</h2>
              <span>Service & texture</span>
            </div>
            <div class="vd-recipe-signature__panel-body">
              <div class="vd-recipe-signature__tip-list">
                {% for block in section.blocks %}
                  {% if block.type != 'tip' %}
                    {% continue %}
                  {% endif %}
                  <details class="vd-recipe-signature__tip" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
                    <summary>{{ block.settings.title }}</summary>
                    <div class="vd-recipe-signature__tip-content">
                      {{ block.settings.text }}
                    </div>
                  </details>
                {% endfor %}
              </div>
            </div>
          </article>
        {% endif %}
      </aside>
    </div>
  </div>

  <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>
</section>

{% schema %}
{
  "name": "VD Recette Signature",
  "tag": "section",
  "class": "section section-vd-recipe-signature",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Recette signature"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Beignets de banane à la vanille"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Une base premium pour les recettes maison: lisible, actionnable et reliée aux bons produits.</p>"
    },
    {
      "type": "range",
      "id": "base_serves",
      "min": 1,
      "max": 24,
      "step": 1,
      "label": "Portions de base",
      "default": 8
    },
    {
      "type": "text",
      "id": "prep_time",
      "label": "Préparation",
      "default": "25 min"
    },
    {
      "type": "text",
      "id": "cook_time",
      "label": "Cuisson",
      "default": "10 min"
    },
    {
      "type": "text",
      "id": "difficulty",
      "label": "Difficulté",
      "default": "Facile"
    },
    {
      "type": "text",
      "id": "download_filename",
      "label": "Nom du fichier téléchargé",
      "default": "beignets-banane-vanille"
    },
    {
      "type": "richtext",
      "id": "sidebar_text",
      "label": "Texte colonne droite",
      "default": "<p>Chaque recette doit pouvoir renvoyer vers le bon produit, le bon format ou la bonne collection.</p>"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Produit principal"
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "Collection liée"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "CTA principal",
      "default": "Voir le produit"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien CTA principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "CTA secondaire",
      "default": "Voir la collection"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien CTA secondaire"
    },
    {
      "type": "richtext",
      "id": "provenance",
      "label": "Bloc provenance",
      "default": "<p>Recette travaillée avec des gousses de vanille Bourbon sourcées directement à Madagascar, dans une logique de goût et de traçabilité plutôt que de folklore.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingrédient",
      "settings": [
        {
          "type": "text",
          "id": "quantity",
          "label": "Quantité",
          "default": "2"
        },
        {
          "type": "text",
          "id": "unit",
          "label": "Unité",
          "default": "gousses"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nom",
          "default": "Vanille Bourbon"
        },
        {
          "type": "textarea",
          "id": "note",
          "label": "Note"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge latéral"
        },
        {
          "type": "checkbox",
          "id": "scalable",
          "label": "Ajuster avec les portions",
          "default": true
        }
      ]
    },
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Décrire ici une étape claire, utile et concise."
        }
      ]
    },
    {
      "type": "tip",
      "name": "Astuce",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Température"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Ajoute ici une astuce de cuisson, de texture ou de service."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Recette Signature"
    }
  ]
}
{% endschema %}
