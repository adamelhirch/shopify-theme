{{ 'vd-recipe-signature.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vd-recipe-signature.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign featured_product = section.settings.featured_product
  assign related_collection = section.settings.related_collection
  assign primary_link = section.settings.primary_link
  assign secondary_link = section.settings.secondary_link
  assign requires_auth = false
  assign step_total = 0
  assign ingredient_total = 0
  assign preview_ingredient_limit = 4
  assign preview_step_limit = 2
  assign encoded_return_to = request.path | url_encode
  assign login_target = routes.account_login_url | append: '?return_to=' | append: encoded_return_to
  assign register_target = routes.account_register_url | append: '?return_to=' | append: encoded_return_to

  if primary_link == blank and featured_product != blank
    assign primary_link = featured_product.url
  endif

  if secondary_link == blank and related_collection != blank
    assign secondary_link = related_collection.url
  endif

  if section.settings.require_customer_access and customer == blank
    assign requires_auth = true
  endif

  for block in section.blocks
    if block.type == 'ingredient'
      assign ingredient_total = ingredient_total | plus: 1
    elsif block.type == 'step'
      assign step_total = step_total | plus: 1
    endif
  endfor
-%}

<section
  class="section-{{ section.id }}-padding vd-recipe-signature color-{{ section.settings.color_scheme }}"
  data-vd-recipe
  data-base-serves="{{ section.settings.base_serves }}"
  data-download-name="{{ section.settings.download_filename | handle | default: 'recette-vanille-desire' }}"
  data-storage-key="vd-recipe-{{ page.handle | default: section.id }}"
  data-recipe-locked="{{ requires_auth }}"
>
  <div class="vd-recipe-signature__media" aria-hidden="true">
    {% if section.settings.hero_background_video != blank %}
      {{
        section.settings.hero_background_video
        | video_tag:
          class: 'vd-recipe-signature__video',
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          preload: 'metadata',
          image_size: '2000x'
      }}
    {% elsif section.settings.hero_video_url != blank %}
      <video class="vd-recipe-signature__video" autoplay loop muted playsinline preload="metadata">
        <source src="{{ section.settings.hero_video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.hero_background_image != blank %}
      {{
        section.settings.hero_background_image
        | image_url: width: 2400
        | image_tag:
          class: 'vd-recipe-signature__poster',
          widths: '750, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          loading: 'eager'
      }}
    {% endif %}
  </div>
  <div class="vd-recipe-signature__veil"></div>
  <div class="vd-recipe-signature__glow"></div>

  <div class="page-width">
    <div class="vd-recipe-signature__hero">
      <div class="vd-recipe-signature__hero-copy">
        {% if section.settings.eyebrow != blank %}
          <span class="vd-recipe-signature__eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="vd-recipe-signature__heading" data-vd-recipe-title>{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.intro != blank %}
          <div class="vd-recipe-signature__intro rte" data-vd-recipe-intro>{{ section.settings.intro }}</div>
        {% endif %}

        <div class="vd-recipe-signature__meta">
          <span class="vd-recipe-signature__meta-item">{{ section.settings.base_serves }} personnes</span>
          {% if section.settings.prep_time != blank %}
            <span class="vd-recipe-signature__meta-item">{{ section.settings.prep_time }}</span>
          {% endif %}
          {% if section.settings.cook_time != blank %}
            <span class="vd-recipe-signature__meta-item">{{ section.settings.cook_time }}</span>
          {% endif %}
          {% if section.settings.difficulty != blank %}
            <span class="vd-recipe-signature__meta-item">{{ section.settings.difficulty }}</span>
          {% endif %}
          <span class="vd-recipe-signature__meta-item">{{ ingredient_total }} ingredients</span>
          <span class="vd-recipe-signature__meta-item">{{ step_total }} etapes</span>
        </div>
      </div>

      <aside class="vd-recipe-signature__hero-aside">
        <span>{% if requires_auth %}Acces membre{% else %}Mode cuisson{% endif %}</span>
        <h2>
          {% if requires_auth %}
            Une recette visible, une execution premium reservee aux comptes clients.
          {% else %}
            Un compagnon de cuisine clair, memoriel et fait pour aller vite.
          {% endif %}
        </h2>
        <p>
          {% if requires_auth %}
            Le contenu reste bon pour le SEO et la decouverte, mais l'experience pas a pas, la progression et la
            sauvegarde demandent une connexion.
          {% else %}
            Portions dynamiques, progression sauvegardee, mode focus et gestes relies au bon produit au bon moment.
          {% endif %}
        </p>

        <div class="vd-recipe-signature__hero-actions">
          {% if requires_auth %}
            <a href="{{ login_target }}" class="button button--primary">Se connecter</a>
            <a href="{{ register_target }}" class="button button--secondary">Creer un compte</a>
          {% elsif primary_link != blank %}
            <a href="{{ primary_link }}" class="button button--primary">{{ section.settings.primary_label | default: 'Voir le produit' }}</a>
          {% endif %}
          {% if secondary_link != blank %}
            <a href="{{ secondary_link }}" class="button button--secondary">{{ section.settings.secondary_label | default: 'Voir la collection' }}</a>
          {% endif %}
        </div>
      </aside>
    </div>

    {% if requires_auth %}
      <div class="vd-recipe-signature__gate">
        <span class="vd-recipe-signature__gate-kicker">{{ section.settings.gate_eyebrow | default: 'Connexion requise' }}</span>
        <h2>{{ section.settings.gate_heading | default: 'Connectez-vous pour lancer le mode recette complet.' }}</h2>
        <div class="rte">
          {{ section.settings.gate_text | default: '<p>Le visiteur decouvre la promesse, comprend l usage et peut ensuite debloquer une lecture plus proche d une application: progression, memoire, focus et gestes pas a pas.</p>' }}
        </div>
        <div class="vd-recipe-signature__gate-signals" role="list">
          <span class="vd-recipe-signature__gate-signal" role="listitem">Progression sauvegardee</span>
          <span class="vd-recipe-signature__gate-signal" role="listitem">Mode focus pas a pas</span>
          <span class="vd-recipe-signature__gate-signal" role="listitem">Recette connectee au catalogue</span>
        </div>
        <div class="vd-recipe-signature__gate-actions">
          <a href="{{ login_target }}" class="button button--primary">Se connecter</a>
          <a href="{{ register_target }}" class="button button--secondary">Creer un compte</a>
        </div>
      </div>

      <div class="vd-recipe-signature__preview">
        <article class="vd-recipe-signature__preview-card">
          <span class="vd-recipe-signature__panel-kicker">Avant de se connecter</span>
          <h3>Apercu ingredients</h3>
          <div class="vd-recipe-signature__preview-copy">
            {% assign ingredient_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type != 'ingredient' %}
                {% continue %}
              {% endif %}
              {% assign ingredient_index = ingredient_index | plus: 1 %}
              {% if ingredient_index > preview_ingredient_limit %}
                {% break %}
              {% endif %}
              <p>
                {% if block.settings.quantity != blank %}{{ block.settings.quantity }} {{ block.settings.unit }} · {% endif %}
                {{ block.settings.title | default: block.settings.unit }}
              </p>
            {% endfor %}
          </div>
        </article>

        <article class="vd-recipe-signature__preview-card vd-recipe-signature__preview-card--locked">
          <span class="vd-recipe-signature__panel-kicker">Apercu etapes</span>
          <h3>Le mode cuisson detaille se debloque apres connexion.</h3>
          <div class="vd-recipe-signature__preview-copy">
            {% assign preview_step_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type != 'step' %}
                {% continue %}
              {% endif %}
              {% assign preview_step_index = preview_step_index | plus: 1 %}
              {% if preview_step_index > preview_step_limit %}
                {% break %}
              {% endif %}
              <p>Etape {{ preview_step_index }} · {{ block.settings.text }}</p>
            {% endfor %}
          </div>
        </article>
      </div>
    {% else %}
      <div class="vd-recipe-signature__utility">
        <div class="vd-recipe-signature__utility-top">
          <div class="vd-recipe-signature__progress">
            <div class="vd-recipe-signature__progress-head">
              <span class="vd-recipe-signature__progress-label">Progression</span>
              <span class="vd-recipe-signature__progress-text" data-vd-recipe-progress-text>0/{{ step_total }} etapes cochees</span>
            </div>
            <div class="vd-recipe-signature__progress-bar">
              <span class="vd-recipe-signature__progress-fill" data-vd-recipe-progress-fill></span>
            </div>
          </div>

          <div class="vd-recipe-signature__serves">
            <span class="vd-recipe-signature__progress-label">Portions</span>
            <div class="vd-recipe-signature__serves-control" aria-live="polite">
              <button type="button" data-vd-recipe-minus aria-label="Diminuer les portions">−</button>
              <label class="visually-hidden" for="VDRecipeServes-{{ section.id }}">Portions</label>
              <input
                id="VDRecipeServes-{{ section.id }}"
                type="number"
                min="1"
                inputmode="numeric"
                value="{{ section.settings.base_serves }}"
                data-vd-recipe-serves
              >
              <button type="button" data-vd-recipe-plus aria-label="Augmenter les portions">+</button>
            </div>
          </div>
        </div>

        <div class="vd-recipe-signature__utility-bottom">
          <div>
            <span class="vd-recipe-signature__progress-label">Etape active</span>
            <div class="vd-recipe-signature__progress-text" data-vd-recipe-active-step>Etape 1</div>
            <div class="vd-recipe-signature__progress-text" data-vd-recipe-active-meta>Suivre la recette a votre rythme</div>
          </div>

          <div class="vd-recipe-signature__utility-actions">
            <button type="button" class="vd-recipe-signature__utility-button" data-vd-recipe-focus>Mode focus</button>
            <button type="button" class="vd-recipe-signature__utility-button" data-vd-recipe-toggle>Tout cocher</button>
            <button type="button" class="vd-recipe-signature__copy-button" data-vd-recipe-copy>Copier</button>
            <button type="button" class="vd-recipe-signature__download" data-vd-recipe-download>Telecharger</button>
            <button type="button" class="vd-recipe-signature__utility-button" data-vd-recipe-reset>Reinitialiser</button>
          </div>
        </div>
      </div>

      <div class="vd-recipe-signature__layout">
        <div class="vd-recipe-signature__main">
          <article class="vd-recipe-signature__panel">
            <div class="vd-recipe-signature__panel-head">
              <div>
                <span class="vd-recipe-signature__panel-kicker">Ingredients</span>
                <h2>Tout est ajuste pour <span data-vd-recipe-serves-slot>{{ section.settings.base_serves }}</span> personnes.</h2>
              </div>
              <p>Cochez vos preparations au fur et a mesure pour garder une lecture propre.</p>
            </div>
            <div class="vd-recipe-signature__panel-body">
              <div class="vd-recipe-signature__ingredient-list">
                {% for block in section.blocks %}
                  {% if block.type != 'ingredient' %}
                    {% continue %}
                  {% endif %}

                  <label class="vd-recipe-signature__ingredient" data-vd-recipe-ingredient {{ block.shopify_attributes }}>
                    <input
                      type="checkbox"
                      data-vd-recipe-check
                      data-item-id="{{ block.id }}"
                      data-item-type="ingredient"
                    >
                    <span>
                      <strong>
                        {% if block.settings.quantity != blank %}
                          <span {% if block.settings.scalable %}data-vd-recipe-base-qty="{{ block.settings.quantity }}"{% endif %}>
                            {{ block.settings.quantity }}
                          </span>
                          {% if block.settings.unit != blank %} {{ block.settings.unit }}{% endif %}
                          {% if block.settings.title != blank %} · {% endif %}
                        {% endif %}
                        {{ block.settings.title }}
                      </strong>
                      {% if block.settings.note != blank %}
                        <p>{{ block.settings.note }}</p>
                      {% endif %}
                    </span>
                    {% if block.settings.badge != blank %}
                      <span class="vd-recipe-signature__ingredient-badge">{{ block.settings.badge }}</span>
                    {% endif %}
                  </label>
                {% endfor %}
              </div>
            </div>
          </article>

          <article class="vd-recipe-signature__panel">
            <div class="vd-recipe-signature__panel-head">
              <div>
                <span class="vd-recipe-signature__panel-kicker">Preparation</span>
                <h2>Une etape active, un geste net, puis on avance.</h2>
              </div>
              <div class="vd-recipe-signature__step-nav">
                <button type="button" data-vd-recipe-prev-step>Etape precedente</button>
                <button type="button" data-vd-recipe-next-step>Etape suivante</button>
              </div>
            </div>
            <div class="vd-recipe-signature__panel-body">
              <div class="vd-recipe-signature__step-stack">
                {% assign step_index = 0 %}
                {% for block in section.blocks %}
                  {% if block.type != 'step' %}
                    {% continue %}
                  {% endif %}
                  {% assign step_index = step_index | plus: 1 %}
                  <article class="vd-recipe-signature__step" data-vd-recipe-step-item {{ block.shopify_attributes }}>
                    <div class="vd-recipe-signature__step-top">
                      <div class="vd-recipe-signature__step-meta">
                        <span class="vd-recipe-signature__step-index">Etape {{ step_index }}</span>
                        {% if block.settings.duration != blank %}
                          <span class="vd-recipe-signature__step-chip" data-vd-recipe-step-duration>{{ block.settings.duration }}</span>
                        {% endif %}
                        {% if block.settings.highlight != blank %}
                          <span class="vd-recipe-signature__step-chip">{{ block.settings.highlight }}</span>
                        {% endif %}
                      </div>
                      <div class="vd-recipe-signature__step-nav">
                        <label class="vd-recipe-signature__step-check">
                          <input
                            type="checkbox"
                            data-vd-recipe-check
                            data-item-id="{{ block.id }}"
                            data-item-type="step"
                          >
                          Fait
                        </label>
                        <button type="button" class="vd-recipe-signature__step-select" data-vd-recipe-step-select data-step-index="{{ step_index | minus: 1 }}">
                          Mettre au centre
                        </button>
                      </div>
                    </div>

                    <div class="vd-recipe-signature__step-content">
                      <strong class="vd-recipe-signature__step-title" data-vd-recipe-step-title>
                        {{ block.settings.title | default: 'Etape ' | append: step_index }}
                      </strong>
                      <p>{{ block.settings.text }}</p>
                    </div>
                  </article>
                {% endfor %}
              </div>
            </div>
          </article>
        </div>

        <aside class="vd-recipe-signature__aside">
          {% if featured_product != blank %}
            {%- liquid
              assign product_image = featured_product.featured_media.preview_image | default: featured_product.featured_image
            -%}
            <article class="vd-recipe-signature__aside-card">
              <span class="vd-recipe-signature__panel-kicker">Produit a utiliser</span>
              <div class="vd-recipe-signature__product-card">
                <div class="vd-recipe-signature__product-media">
                  {% if product_image != blank %}
                    {{
                      product_image
                      | image_url: width: 960
                      | image_tag:
                        widths: '360, 540, 720, 960',
                        sizes: '(min-width: 990px) 28vw, 92vw',
                        loading: 'lazy',
                        alt: featured_product.title | escape
                    }}
                  {% endif %}
                </div>
                <div class="vd-recipe-signature__product-meta">
                  <h3>{{ featured_product.title }}</h3>
                  <strong>{{ featured_product.price | money_without_trailing_zeros }}</strong>
                  {% if section.settings.sidebar_text != blank %}
                    <div class="rte">{{ section.settings.sidebar_text }}</div>
                  {% endif %}
                </div>
              </div>
              <div class="vd-recipe-signature__aside-actions">
                {% if primary_link != blank %}
                  <a href="{{ primary_link }}" class="vd-arrow-cta">
                    <span class="vd-arrow-cta__label">{{ section.settings.primary_label | default: 'Voir le produit' }}</span>
                    <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                      <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                    </svg>
                  </a>
                {% endif %}
              </div>
            </article>
          {% endif %}

          {% if section.settings.provenance != blank %}
            <article class="vd-recipe-signature__aside-card">
              <span class="vd-recipe-signature__panel-kicker">Origine</span>
              <h3>Madagascar en fond, sans folklore parasite.</h3>
              <div class="rte">{{ section.settings.provenance }}</div>
              {% if secondary_link != blank %}
                <div class="vd-recipe-signature__aside-actions">
                  <a href="{{ secondary_link }}" class="vd-arrow-cta">
                    <span class="vd-arrow-cta__label">{{ section.settings.secondary_label | default: 'Voir la collection' }}</span>
                    <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                      <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
                    </svg>
                  </a>
                </div>
              {% endif %}
            </article>
          {% endif %}

          {% assign tip_count = 0 %}
          {% for block in section.blocks %}
            {% if block.type != 'tip' %}
              {% continue %}
            {% endif %}
            {% assign tip_count = tip_count | plus: 1 %}
          {% endfor %}

          {% if tip_count > 0 %}
            <article class="vd-recipe-signature__panel">
              <div class="vd-recipe-signature__panel-head">
                <div>
                  <span class="vd-recipe-signature__panel-kicker">Astuces</span>
                  <h2>Texture, temperature, service.</h2>
                </div>
                <p>Des rappels courts pour rester efficace en cuisine.</p>
              </div>
              <div class="vd-recipe-signature__panel-body">
                <div class="vd-recipe-signature__tip-list">
                  {% for block in section.blocks %}
                    {% if block.type != 'tip' %}
                      {% continue %}
                    {% endif %}
                    <details class="vd-recipe-signature__tip" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
                      <summary>{{ block.settings.title }}</summary>
                      <div class="vd-recipe-signature__tip-content">{{ block.settings.text }}</div>
                    </details>
                  {% endfor %}
                </div>
              </div>
            </article>
          {% endif %}
        </aside>
      </div>
    {% endif %}
  </div>

  <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Recipe",
      "name": {{ section.settings.heading | json }},
      "description": {{ section.settings.intro | strip_html | json }},
      "recipeYield": {{ section.settings.base_serves | append: ' portions' | json }},
      "recipeIngredient": [
        {%- assign ingredient_index_json = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type != 'ingredient' -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign ingredient_index_json = ingredient_index_json | plus: 1 -%}
          {{ block.settings.quantity | append: ' ' | append: block.settings.unit | append: ' ' | append: block.settings.title | strip | json }}{% unless ingredient_index_json == ingredient_total %},{% endunless %}
        {%- endfor -%}
      ],
      "recipeInstructions": [
        {%- assign instruction_index_json = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type != 'step' -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign instruction_index_json = instruction_index_json | plus: 1 -%}
          {
            "@type": "HowToStep",
            "name": {{ block.settings.title | default: 'Etape ' | append: instruction_index_json | json }},
            "text": {{ block.settings.text | json }}
          }{% unless instruction_index_json == step_total %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
</section>

{% schema %}
{
  "name": "VD Recette Signature",
  "tag": "section",
  "class": "section section-vd-recipe-signature",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Recette signature"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Beignets de banane a la vanille"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Une base premium pour les recettes maison: lisible, actionnable et reliee aux bons produits.</p>"
    },
    {
      "type": "range",
      "id": "base_serves",
      "min": 1,
      "max": 24,
      "step": 1,
      "label": "Portions de base",
      "default": 8
    },
    {
      "type": "text",
      "id": "prep_time",
      "label": "Preparation",
      "default": "25 min"
    },
    {
      "type": "text",
      "id": "cook_time",
      "label": "Cuisson",
      "default": "10 min"
    },
    {
      "type": "text",
      "id": "difficulty",
      "label": "Difficulte",
      "default": "Facile"
    },
    {
      "type": "text",
      "id": "download_filename",
      "label": "Nom du fichier telecharge",
      "default": "beignets-banane-vanille"
    },
    {
      "type": "text",
      "id": "hero_video_url",
      "label": "URL video MP4 hero"
    },
    {
      "type": "video",
      "id": "hero_background_video",
      "label": "Video Shopify hero"
    },
    {
      "type": "image_picker",
      "id": "hero_background_image",
      "label": "Image hero"
    },
    {
      "type": "checkbox",
      "id": "require_customer_access",
      "label": "Exiger une connexion client pour le mode recette",
      "default": true
    },
    {
      "type": "text",
      "id": "gate_eyebrow",
      "label": "Sur-titre gate",
      "default": "Connexion requise"
    },
    {
      "type": "text",
      "id": "gate_heading",
      "label": "Titre gate",
      "default": "Connectez-vous pour lancer le mode recette complet."
    },
    {
      "type": "richtext",
      "id": "gate_text",
      "label": "Texte gate",
      "default": "<p>Le visiteur decouvre la promesse, puis debloque une vraie experience de cuisine avec progression, memoire et mode focus.</p>"
    },
    {
      "type": "richtext",
      "id": "sidebar_text",
      "label": "Texte produit",
      "default": "<p>Chaque recette doit pouvoir renvoyer vers le bon produit, le bon format ou la bonne collection.</p>"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Produit principal"
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "Collection liee"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "CTA principal",
      "default": "Voir le produit"
    },
    {
