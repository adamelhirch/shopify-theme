{{ 'vd-recipe-signature.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vd-recipe-signature.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{%- liquid
  assign encoded_return_to = request.path | url_encode
  assign login_joiner = '?'
  assign register_joiner = '?'
  if routes.account_login_url contains '?'
    assign login_joiner = '&'
  endif
  if routes.account_register_url contains '?'
    assign register_joiner = '&'
  endif
  assign login_target = routes.account_login_url | append: login_joiner | append: 'return_to=' | append: encoded_return_to
  assign register_target = routes.account_register_url | append: register_joiner | append: 'return_to=' | append: encoded_return_to
-%}

<section
  class="section-{{ section.id }}-padding vd-recipe-signature color-{{ section.settings.color_scheme }}"
  data-vd-recipe
  data-registry-url="{{ 'vd-recipes-registry.json' | asset_url }}"
  data-recipe-slug="{{ section.settings.recipe_slug | default: page.handle }}"
  data-page-handle="{{ page.handle }}"
  data-require-customer-access="{{ section.settings.require_customer_access }}"
  data-customer-authenticated="{% if customer %}true{% else %}false{% endif %}"
  data-login-url="{{ login_target }}"
  data-register-url="{{ register_target }}"
>
  <div class="vd-recipe-signature__media" data-vd-recipe-media aria-hidden="true"></div>
  <div class="vd-recipe-signature__veil"></div>
  <div class="vd-recipe-signature__glow"></div>

  <div class="page-width">
    <div class="vd-recipe-signature__shell" data-vd-recipe-shell>
      <div class="vd-recipe-signature__loading">
        <span class="vd-recipe-signature__loading-label">Chargement</span>
        <h1>Preparation de la recette...</h1>
      </div>
    </div>
  </div>

  <div class="vd-recipe-signature__toast" data-vd-recipe-toast role="status" aria-live="polite"></div>
  <script type="application/json" data-vd-recipe-editor-media>
    [
      {%- assign media_delimiter = '' -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'recipe_media' -%}
          {{ media_delimiter }}
          {%- assign block_video_url = '' -%}
          {%- if block.settings.video != blank -%}
            {%- for source in block.settings.video.sources -%}
              {%- if source.mime_type == 'video/mp4' -%}
                {%- assign block_video_url = source.url -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {
            "recipe_slug": {{ block.settings.recipe_slug | strip | json }},
            "placement": {{ block.settings.placement | json }},
            "step_number": {{ block.settings.step_number | json }},
            "image_url": {{ block.settings.image | image_url: width: 1800 | json }},
            "image_alt": {{ block.settings.image.alt | default: block.settings.caption | json }},
            "video_url": {{ block.settings.video_url | default: block_video_url | json }},
            "caption": {{ block.settings.caption | json }}
          }{%- assign media_delimiter = ',' -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>
  <script type="application/ld+json" data-vd-recipe-schema></script>
</section>

{% schema %}
{
  "name": "VD Recette Signature",
  "tag": "section",
  "class": "section section-vd-recipe-signature",
  "settings": [
    {
      "type": "text",
      "id": "recipe_slug",
      "label": "Slug recette",
      "default": "beignet-banane"
    },
    {
      "type": "checkbox",
      "id": "require_customer_access",
      "label": "Exiger un compte client pour les recettes premium",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "recipe_media",
      "name": "Media recette",
      "settings": [
        {
          "type": "text",
          "id": "recipe_slug",
          "label": "Slug recette",
          "info": "Exemple : beignet-banane"
        },
        {
          "type": "select",
          "id": "placement",
          "label": "Placement",
          "default": "gallery",
          "options": [
            { "value": "hero", "label": "Hero / fond principal" },
            { "value": "gallery", "label": "Galerie recette" },
            { "value": "step", "label": "Etape" }
          ]
        },
        {
          "type": "range",
          "id": "step_number",
          "min": 1,
          "max": 12,
          "step": 1,
          "label": "Numero d'etape",
          "default": 1
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video Shopify"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "URL video MP4 externe",
          "info": "Utilisee si aucune video Shopify n'est selectionnee"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Legende"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Recette Signature"
    }
  ]
}
{% endschema %}
