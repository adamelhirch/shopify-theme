{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-padding vd-wiki-hub color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="vd-wiki-hub__hero">
      <div class="vd-wiki-hub__copy">
        {% if section.settings.eyebrow != blank %}
          <span class="vd-section-kicker">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="vd-wiki-hub__title">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="vd-wiki-hub__text rte">{{ section.settings.text }}</div>
        {% endif %}
      </div>

      <div class="vd-wiki-hub__summary">
        <span>{{ section.settings.summary_eyebrow | default: 'Point clé' }}</span>
        <p>{{ section.settings.summary }}</p>
        <div class="vd-wiki-hub__summary-links">
          <a href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}" class="vd-arrow-cta">
            <span class="vd-arrow-cta__label">{{ section.settings.primary_link_label | default: 'Voir les produits' }}</span>
            <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
              <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
            </svg>
          </a>
          <a href="{{ section.settings.secondary_link | default: '/pages/contact' }}" class="vd-arrow-cta">
            <span class="vd-arrow-cta__label">{{ section.settings.secondary_link_label | default: 'Nous contacter' }}</span>
            <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
              <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="vd-wiki-hub__grid" role="list">
      {% for block in section.blocks %}
        <article class="vd-wiki-hub__card{% if forloop.first %} vd-wiki-hub__card--feature{% endif %}" role="listitem" {{ block.shopify_attributes }}>
          <span>{{ block.settings.kicker }}</span>
          <h3>{{ block.settings.title }}</h3>
          <div class="vd-wiki-hub__card-text rte">{{ block.settings.text }}</div>

          {% if block.settings.link != blank and block.settings.link_label != blank %}
            <a href="{{ block.settings.link }}" class="vd-arrow-cta">
              <span class="vd-arrow-cta__label">{{ block.settings.link_label }}</span>
              <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
                <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
              </svg>
            </a>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    <div class="vd-wiki-hub__foot">
      <div class="vd-wiki-hub__foot-copy">
        <span class="vd-section-kicker">{{ section.settings.footer_eyebrow | default: 'Explorer la suite' }}</span>
        <h2>{{ section.settings.footer_heading | default: 'Retrouver les produits, les recettes et les bons points d’entrée.' }}</h2>
      </div>
      <div class="vd-wiki-hub__foot-links">
        <a href="{{ section.settings.footer_primary_link | default: '/pages/recettes' }}" class="vd-arrow-cta">
          <span class="vd-arrow-cta__label">{{ section.settings.footer_primary_link_label | default: 'Voir les recettes' }}</span>
          <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
            <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
          </svg>
        </a>
        <a href="{{ section.settings.footer_secondary_link | default: routes.all_products_collection_url }}" class="vd-arrow-cta">
          <span class="vd-arrow-cta__label">{{ section.settings.footer_secondary_link_label | default: 'Retour au catalogue' }}</span>
          <svg class="vd-arrow-cta__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 46 16">
            <path d="M8 0 6.545 1.455l5.506 5.506H-30v2.078h42.052l-5.507 5.506L8 16l8-8Z" transform="translate(30)"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VD Wiki Content",
  "tag": "section",
  "class": "section section-vd-wiki-content",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre",
      "default": "Le Wiki"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Une lecture éditoriale claire, utile et crédible."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Un angle clair, quelques repères utiles et des passerelles nettes vers les produits, les recettes ou les contenus liés.</p>"
    },
    {
      "type": "textarea",
      "id": "summary",
      "label": "Resume lateral",
      "default": "Un angle clair, des usages concrets et des passerelles nettes vers la collection, les recettes ou un conseil plus direct."
    },
    {
      "type": "text",
      "id": "summary_eyebrow",
      "label": "Sur-titre resume",
      "default": "Point clé"
    },
    {
      "type": "text",
      "id": "primary_link_label",
      "label": "Libelle lien principal",
      "default": "Voir les produits"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien principal"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Libelle lien secondaire",
      "default": "Nous contacter"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien secondaire"
    },
    {
      "type": "text",
      "id": "footer_eyebrow",
      "label": "Sur-titre bas de page",
      "default": "Explorer la suite"
    },
    {
      "type": "text",
      "id": "footer_heading",
      "label": "Titre bas de page",
      "default": "Retrouver les produits, les recettes et les bons points d’entrée."
    },
    {
      "type": "text",
      "id": "footer_primary_link_label",
      "label": "Libelle lien bas 1",
      "default": "Voir les recettes"
    },
    {
      "type": "url",
      "id": "footer_primary_link",
      "label": "Lien bas 1"
    },
    {
      "type": "text",
      "id": "footer_secondary_link_label",
      "label": "Libelle lien bas 2",
      "default": "Retour au catalogue"
    },
    {
      "type": "url",
      "id": "footer_secondary_link",
      "label": "Lien bas 2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Palette",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Bloc",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "Repère"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Un angle net"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>Un bloc court pour poser une idée forte, une preuve ou une passerelle vers un produit ou une autre page du wiki.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Libelle lien",
          "default": "Continuer"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VD Wiki Content",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
