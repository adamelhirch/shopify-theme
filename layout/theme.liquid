<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#ffffff">
    <link rel="canonical" href="{{ canonical_url }}">

    {% comment %}theme-check-disable RemoteAsset{% endcomment %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap"
    >
    {% comment %}theme-check-enable RemoteAsset{% endcomment %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {{ 'vd-geometria.css' | asset_url | stylesheet_tag }}
    {% comment %}theme-check-disable AssetPreload{% endcomment %}
    <link rel="preload" as="font" href="{{ 'Geometria-Regular.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Geometria-Medium.woff2' | asset_url }}" type="font/woff2" crossorigin>
    {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {{ 'vd-yc.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}

    <script>
      // Empty string forces same-origin (relative) fetches. With request.origin
      // the shop's canonical URL, dev preview fetches were cross-origin and
      // blocked by CORS (e.g. fetchCart in vd-yc.js).
      window.shopUrl = '';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };
      window.cartStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      };
      if (window.Shopify && window.Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    <script src="{{ 'vd-yc.js' | asset_url }}" defer="defer"></script>
  </head>

  <body>
    <a class="vd-skip" href="#MainContent" style="position:absolute;left:-9999px;">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    <div class="vd-drawer-bg" data-vd-drawer-close></div>

    {%- render 'vd-yc-cart-drawer' -%}
    {%- render 'vd-yc-search-drawer' -%}
    {%- render 'vd-yc-mobile-menu' -%}
    {%- render 'vd-yc-mega-drawer' -%}

    {% sections 'header-group' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </body>
</html>
