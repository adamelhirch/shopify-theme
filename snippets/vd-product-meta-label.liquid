{%- liquid
  assign preferred_mode = prefer | default: 'vendor'
  assign fallback_label = fallback | strip
  assign vendor_label = product.vendor | default: '' | strip
  assign type_label = product.type | default: '' | strip
  assign subtitle_label = product.metafields.descriptors.subtitle.value | default: '' | strip
  assign vendor_handle = vendor_label | handleize
  assign shop_handle = shop.name | default: '' | handleize
  assign generic_vendor_handles = 'ma-boutique,my-store,store,boutique,shop,catalog,catalogue,default-vendor' | split: ','
  assign vendor_is_generic = false

  if vendor_label == blank or vendor_handle == blank
    assign vendor_is_generic = true
  elsif vendor_handle == shop_handle
    assign vendor_is_generic = true
  elsif generic_vendor_handles contains vendor_handle
    assign vendor_is_generic = true
  endif

  assign resolved_label = blank

  case preferred_mode
    when 'type'
      if type_label != blank
        assign resolved_label = type_label
      elsif subtitle_label != blank
        assign resolved_label = subtitle_label
      elsif vendor_is_generic == false
        assign resolved_label = vendor_label
      endif
    else
      if vendor_is_generic == false
        assign resolved_label = vendor_label
      elsif type_label != blank
        assign resolved_label = type_label
      elsif fallback_label != blank
        assign resolved_label = fallback_label
      elsif subtitle_label != blank
        assign resolved_label = subtitle_label
      endif
  endcase

  echo resolved_label | escape
-%}
