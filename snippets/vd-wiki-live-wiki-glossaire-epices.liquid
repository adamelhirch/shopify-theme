  <!-- SCRIPTS : reveal + A–Z + recherche + tags + halo -->
  <script>
    // Reveal
    (function(){const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.18});
      document.querySelectorAll('.reveal').forEach(n=>io.observe(n));})();

    // Build A–Z
    (function(){
      const letters='ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
      const box=document.querySelector('.vdG-index');
      const btn=(ch)=>{const b=document.createElement('button');b.textContent=ch;b.setAttribute('data-letter',ch);b.setAttribute('aria-pressed','false');return b};
      letters.forEach(l=>box.appendChild(btn(l)));
    })();

    // Search / filter
    (function(){
      const cards=[...document.querySelectorAll('.sp-card')];
      const q=document.getElementById('q');
      const letters=[...document.querySelectorAll('.vdG-index button')];
      const tags=[...document.querySelectorAll('.tag')];
      let activeLetter=''; let activeTag='all';

      const apply=()=>{
        const term=(q.value||'').trim().toLowerCase();
        cards.forEach(c=>{
          const name=c.dataset.name.toLowerCase();
          const tags=c.dataset.tags||'';
          const letter=c.dataset.letter||'';
          const matchTerm=!term||name.includes(term);
          const matchLetter=!activeLetter||letter===activeLetter;
          const matchTag=activeTag==='all'||tags.includes(activeTag);
          c.style.display=(matchTerm&&matchLetter&&matchTag)?'':'none';
        });
      };

      q.addEventListener('input',apply);

      letters.forEach(b=>b.addEventListener('click',()=>{
        const on=b.getAttribute('aria-pressed')==='true';
        letters.forEach(x=>x.setAttribute('aria-pressed','false'));
        activeLetter= on ? '' : b.dataset.letter;
        if(!on) b.setAttribute('aria-pressed','true');
        apply();
      }));

      tags.forEach(t=>t.addEventListener('click',()=>{
        const tag=t.dataset.tag;
        tags.forEach(x=>x.setAttribute('aria-pressed', x===t ? 'true':'false'));
        activeTag=tag; apply();
      }));

      apply();
    })();

    // Hover halo
    window.vdHalo=function(e,el){
      const r=el.getBoundingClientRect();
      el.style.setProperty('--mx', ((e.clientX-r.left)/r.width*100).toFixed(1)+'%');
      el.style.setProperty('--my', ((e.clientY-r.top)/r.height*100).toFixed(1)+'%');
    }
  </script>
</section>
              
