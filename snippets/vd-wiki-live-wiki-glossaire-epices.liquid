<section class="vdG-root" aria-label="Wiki — Glossaire des épices">
  <style>
    .vdG-root{
      --ink:#171511;--sub:#3d3a34;--muted:#6c695f;--line:rgba(0,0,0,.08);
      --paper:#fff;--bg:#fbf6ee;--cream:#f6efe6;--accent:#FFB766;--accent2:#FFD09A;--leaf:#87a36a;
      --shadow:rgba(13,10,8,.10);--r:22px;--w:clamp(980px,92vw,1280px);
      --h1:clamp(44px,7vw,84px);--h2:clamp(26px,4.4vw,52px);--lead:clamp(18px,2.2vw,22px);
      color:var(--ink);background:linear-gradient(180deg,var(--paper),var(--bg) 50%,var(--cream));
      border-radius:34px;box-shadow:0 30px 80px var(--shadow);isolation:isolate;overflow:hidden}
    .vdG-root *{box-sizing:border-box}
    .vdG-container{max-width:var(--w);margin-inline:auto;padding-inline:clamp(16px,2.2vw,28px)}

    /* Nav / header */
    .vdG-nav{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.85);backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--line)}
    .vdG-nav .vdG-container{display:flex;align-items:center;justify-content:space-between;padding-block:10px}
    .vdG-brand{display:flex;align-items:center;gap:10px}
    .vdG-logo{width:26px;height:26px;border-radius:8px;background:conic-gradient(from 12deg,#ffd7a3,#fff 40%,#ffc17a);box-shadow:inset 0 0 0 1px var(--line)}
    .vdG-brand b{font-size:14px}
    .vdG-nav a{color:var(--ink);text-decoration:none;font-size:14px;padding:.5rem .7rem;border-radius:10px}
    .vdG-nav a:hover{background:rgba(0,0,0,.04)}

    .vdG-hero .vdG-container{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(16px,4vw,48px);align-items:end;padding-block:clamp(28px,7vw,88px)}
    .vdG-kicker{letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600;font-size:12px}
    .vdG-hero h1{font-size:var(--h1);line-height:1.06;letter-spacing:-.02em;margin:.2rem 0 1rem}
    .vdG-hero h1 .hl{background:linear-gradient(90deg,var(--accent),var(--accent2));padding:.06em .20em;border-radius:.35em;box-decoration-break:clone}
    .vdG-hero p{font-size:var(--lead);color:var(--sub);max-width:64ch}
    .vdG-cta{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .chip{display:inline-flex;align-items:center;gap:6px;padding:.45rem .7rem;border:1px solid var(--line);border-radius:999px;background:#fff;font-size:12px;text-decoration:none;color:var(--ink)}
    .chip:hover{background:linear-gradient(180deg,#fff,#ffe8c9)}
    .chip .ext{font-size:10px;opacity:.7}

    /* Layout : sidebar index + main */
    .vdG-wrap{display:grid;grid-template-columns:240px 1fr;gap:clamp(14px,2.4vw,22px);align-items:start}
    .vdG-side{position:sticky;top:72px;align-self:start}
    .vdG-search{border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 12px;display:flex;gap:8px;align-items:center}
    .vdG-search input{border:none;outline:none;flex:1;min-width:0}
    .vdG-index{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:10px}
    .vdG-index button{border:1px solid var(--line);border-radius:10px;background:#fff;padding:.45rem .4rem;font-size:12px;cursor:pointer}
    .vdG-index button[aria-pressed="true"]{background:linear-gradient(180deg,#fff,#ffe2bf);box-shadow:0 8px 20px var(--shadow)}
    .vdG-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
    .tag{border:1px solid var(--line);border-radius:999px;padding:.35rem .6rem;font-size:11px;background:#fff}
    .tag[aria-pressed="true"]{background:linear-gradient(180deg,#fff,#f7efe5)}

    /* Cards grid */
    .vdG-main{min-height:300px}
    .vdG-sec{padding-block:clamp(24px,5.6vw,70px)}
    .vdG-sec h2{font-size:var(--h2);margin:0 0 8px}
    .vdG-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(12px,2vw,18px)}
    .sp-card{position:relative;background:#fff;border:1px solid var(--line);border-radius:18px;padding:14px;box-shadow:0 14px 34px var(--shadow);transition:transform .25s ease, box-shadow .25s ease}
    .sp-card:hover{transform:translateY(-6px);box-shadow:0 26px 60px var(--shadow)}
    .sp-head{display:flex;align-items:center;justify-content:space-between;gap:8px}
    .sp-name{font-size:18px;margin:.2rem 0}
    .sp-badges{display:flex;gap:6px;flex-wrap:wrap}
    .badge{font-size:11px;border:1px solid var(--line);border-radius:8px;padding:.18rem .45rem;background:linear-gradient(180deg,#fff,#f7efe5);color:var(--muted)}
    .sp-notes{display:flex;gap:10px;flex-wrap:wrap;margin:.35rem 0;color:var(--sub);font-size:13px}
    .sp-row{display:flex;gap:8px;align-items:center}
    .dot{width:8px;height:8px;border-radius:50%;background:#000;opacity:.2}
    .label{font-size:12px;color:var(--muted)}
    .sp-ul{margin:.3rem 0 0 1rem;color:var(--sub);font-size:14px}
    .sp-cta{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
    .halo{position:absolute;inset:0;background:radial-gradient(120px 80px at var(--mx,60%) var(--my,40%), rgba(255,183,102,.18), transparent 60%);mix-blend-mode:multiply;opacity:0;transition:opacity .25s ease}
    .sp-card:hover .halo{opacity:1}

    /* Reveal */
    .reveal{opacity:0;transform:translateY(22px);transition:opacity .6s cubic-bezier(.2,.8,.2,1), transform .6s cubic-bezier(.2,.8,.2,1)}
    .reveal.in{opacity:1;transform:none}

    /* Responsive */
    @media (max-width:1080px){.vdG-wrap{grid-template-columns:1fr}}
    @media (max-width:980px){.vdG-grid{grid-template-columns:1fr}}
  </style>

