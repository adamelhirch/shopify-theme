{% comment %}
  Renders a standard dropdown style menu for the header.

  Usage:
  {% render 'header-dropdown-menu' %}
{% endcomment %}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      {%- if forloop.index <= 2 -%}
        <li>
          {%- if link.links != blank -%}
            {%- liquid
              assign has_simple_children = false
              assign feature_title = 'Voir tout'
              assign feature_image = blank

              if link.title contains 'Catalogue'
                assign feature_title = 'Explorer la boutique'
                assign feature_image = section.settings.catalogue_feature_image
              elsif link.title contains 'Wiki'
                assign feature_title = 'Parcourir nos guides'
                assign feature_image = section.settings.wiki_feature_image
              endif

              for childlink in link.links
                if childlink.links == blank
                  assign has_simple_children = true
                endif
              endfor
            -%}
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}" class="vd-header-primary-menu">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset vd-header-primary-menu__toggle"
                >
                  <span
                    {%- if link.child_active %}
                      class="header__active-menu-item"
                    {% endif %}
                  >
                    {{- link.title | escape -}}
                  </span>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>
                <div
                  id="HeaderMenu-MenuList-{{ forloop.index }}"
                  class="vd-header-primary-menu__panel header__submenu list-menu list-menu--disclosure caption-large motion-reduce"
                  tabindex="-1"
                >
                  <div class="vd-header-primary-menu__grid{% if link.levels == 1 %} vd-header-primary-menu__grid--simple{% endif %}">
                    <div class="vd-header-primary-menu__columns">
                      {%- if has_simple_children -%}
                        <div class="vd-header-primary-menu__column vd-header-primary-menu__column--simple">
                          <span class="vd-header-primary-menu__eyebrow">{{ link.title | escape }}</span>
                          <ul class="vd-header-primary-menu__list" role="list">
                            {%- for childlink in link.links -%}
                              {%- if childlink.links == blank -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                                    href="{{ childlink.url }}"
                                    class="vd-header-primary-menu__link link focus-inset{% if childlink.current %} list-menu__item--active{% endif %}"
                                    {% if childlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ childlink.title | escape }}
                                  </a>
                                </li>
                              {%- endif -%}
                            {%- endfor -%}
                          </ul>
                        </div>
                      {%- endif -%}

                      {%- for childlink in link.links -%}
                        {%- if childlink.links != blank -%}
                          <div class="vd-header-primary-menu__column">
                            <a
                              id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                              href="{{ childlink.url }}"
                              class="vd-header-primary-menu__heading link focus-inset{% if childlink.current %} list-menu__item--active{% endif %}"
                              {% if childlink.current %}
                                aria-current="page"
                              {% endif %}
                            >
                              {{ childlink.title | escape }}
                            </a>

                            <ul class="vd-header-primary-menu__list" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="vd-header-primary-menu__link link focus-inset{% if grandchildlink.current %} list-menu__item--active{% endif %}"
                                    {% if grandchildlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    <a
                      href="{{ link.url }}"
                      class="vd-header-primary-menu__feature link focus-inset{% if feature_image != blank %} vd-header-primary-menu__feature--media{% endif %}"
                      {% if feature_image != blank %}
                        style="--vd-header-feature-image: url('{{ feature_image | image_url: width: 1200 }}');"
                      {% endif %}
                      {% if link.current %}
                        aria-current="page"
                      {% endif %}
                    >
                      <span class="vd-header-primary-menu__feature-kicker">{{ link.title | escape }}</span>
                      <strong class="vd-header-primary-menu__feature-title">{{ feature_title }}</strong>
                      <span class="vd-header-primary-menu__feature-cta">Voir tout</span>
                    </a>
                  </div>
                </div>
              </details>
            </header-menu>
          {%- else -%}
            <a
              id="HeaderMenu-{{ link.handle }}"
              href="{{ link.url }}"
              class="header__menu-item list-menu__item link link--text focus-inset"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              <span
                {%- if link.current %}
                  class="header__active-menu-item"
                {% endif %}
              >
                {{- link.title | escape -}}
              </span>
            </a>
          {%- endif -%}
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</nav>
