{%- comment -%}
  Cart drawer (latéral droit). Seul accès au panier — la page /cart redirige.
  Pas de Shopify Plus → pas de saisie d'adresse pré-checkout, pas de toggle
  retrait/livraison. Le checkout natif Shopify gère tout le post-CTA.

  Free shipping threshold piloté par settings.shipping_threshold_cents.
  Default = 3000 (30 €) — offerte aux nouveaux clients.

  Détection "nouveau client" : si l'utilisateur est connecté ET a déjà commandé,
  on n'affiche plus le message free-ship (il a déjà bénéficié). Sinon (anonyme
  OU 0 commande), on montre le compteur 30€.
{%- endcomment -%}

{%- liquid
  assign threshold_cents = settings.shipping_threshold_cents | default: 3000
  assign subtotal_cents = cart.items_subtotal_price
  assign remaining = threshold_cents | minus: subtotal_cents

  # Cible : nouveaux clients (anonymes ou 0 commandes)
  assign is_new_customer = true
  if customer and customer.orders_count > 0
    assign is_new_customer = false
  endif

  if subtotal_cents <= 0
    assign progress_pct = 0
  else
    assign progress_pct = subtotal_cents | times: 100 | divided_by: threshold_cents
  endif
  if progress_pct > 100
    assign progress_pct = 100
  endif
  assign threshold_reached = false
  if remaining <= 0 and subtotal_cents > 0
    assign threshold_reached = true
  endif
-%}

<aside
  id="vd-cart-drawer"
  class="vd-drawer vd-drawer--right vd-cart-drawer"
  aria-hidden="true"
  aria-label="Panier"
  data-vd-cart-drawer
  data-threshold-cents="{{ threshold_cents }}"
>
  <header class="vd-cart-drawer__head">
    <button type="button" class="vd-cart-drawer__close" data-vd-drawer-close aria-label="Fermer le panier">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <path d="M3 3l8 8M11 3l-8 8"/>
      </svg>
    </button>
    <h2 class="vd-cart-drawer__title">
      <svg class="vd-cart-drawer__title-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <path d="M5 7.5h14l-1.2 11.3c-.1 1-1 1.7-2 1.7H8.2c-1 0-1.9-.7-2-1.7L5 7.5z"/>
        <path d="M9 7.5V6a3 3 0 0 1 6 0v1.5"/>
      </svg>
      <span>Panier (<span data-vd-cart-count>{{ cart.item_count }}</span>)</span>
    </h2>
    <span aria-hidden="true"></span>
  </header>

  <div class="vd-cart-drawer__shipping" data-vd-shipping{% unless is_new_customer %} hidden{% endunless %}>
    <p class="vd-cart-drawer__shipping-label" data-vd-shipping-label>
      {%- if cart.item_count == 0 -%}
        &nbsp;
      {%- elsif threshold_reached -%}
        Livraison offerte sur votre 1<sup>ère</sup> commande ✓
      {%- else -%}
        Plus que <strong>{{ remaining | money }}</strong> pour la livraison offerte sur votre 1<sup>ère</sup> commande.
      {%- endif -%}
    </p>
    <div class="vd-cart-drawer__shipping-bar" {% if cart.item_count == 0 %}hidden{% endif %}>
      <span class="vd-cart-drawer__shipping-fill" style="width:{{ progress_pct }}%" data-vd-shipping-fill></span>
    </div>
  </div>

  <div class="vd-cart-drawer__body" data-vd-cart-body>
    {%- if cart.item_count > 0 -%}
      {%- render 'vd-yc-cart-drawer-items' -%}
    {%- else -%}
      <div class="vd-cart-drawer__empty">
        <p class="vd-cart-drawer__empty-title">Votre panier est vide</p>
        <a href="{{ routes.collections_url }}" class="vd-cart-drawer__empty-cta" data-vd-drawer-close>Découvrir nos produits</a>
      </div>
    {%- endif -%}
  </div>

  <footer class="vd-cart-drawer__foot" data-vd-cart-foot {% if cart.item_count == 0 %}hidden{% endif %}>
    <label class="vd-cart-drawer__terms">
      <input type="checkbox" data-vd-cart-terms aria-describedby="vd-cart-terms-text">
      <span id="vd-cart-terms-text">
        En validant mon panier, j'accepte les
        <a href="/policies/terms-of-service" target="_blank" rel="noopener">conditions générales de vente</a>
        et les
        <a href="/policies/legal-notice" target="_blank" rel="noopener">conditions générales d'utilisation</a>
        du site Vanille Désiré.
      </span>
    </label>

    <div class="vd-cart-drawer__total">
      <span>Total</span>
      <span data-vd-cart-total>{{ cart.total_price | money }}</span>
    </div>

    <a
      href="{{ routes.cart_url }}/checkout"
      class="vd-cart-drawer__cta is-disabled"
      data-vd-cart-checkout
      aria-disabled="true"
    >Passer la commande</a>

    <p class="vd-cart-drawer__tax">Taxes incluses. Frais d'expédition calculés à l'étape de paiement.</p>
  </footer>
</aside>
