  <!-- ======= Styles (namespacés) ======= -->
  <style>
    .vdw-choose{
      --ink:#2B1C10;
      --bg:#FAF5EE;
      --paper:#F6EFE6;
      --cream:#F2E9DD;
      --accent:#D4A373; /* Orange Vanille Désiré */
      --olive:#6E7B59;
      --ring:rgba(0,0,0,.08);
      color:var(--ink); background:var(--bg);
      border-radius:20px; padding:clamp(20px,3vw,44px)
    }
    .vdw-choose *{box-sizing:border-box}
    .vdw-choose a{color:inherit;text-decoration:none}
    .vdw-choose .wrap{max-width:1200px;margin:0 auto}

    /* Hero */
    .vdw-choose .kicker{letter-spacing:.12em;text-transform:uppercase;font-size:.78rem;opacity:.8;margin-bottom:.35rem}
    .vdw-choose h1{font-size:clamp(1.9rem,4.2vw,3rem);line-height:1.08;margin:.1rem 0 .35rem}
    .vdw-choose .lead{font-size:clamp(1rem,1.2vw,1.125rem);max-width:80ch;opacity:.95;margin:0}

    /* Sommaire sticky */
    .vdw-choose .toc{
      position:sticky; top:84px; /* laisse le header/bandeau respirer */
      align-self:flex-start;
      background:#fff; border:1px solid var(--cream); border-radius:16px; padding:14px;
      box-shadow:0 6px 18px rgba(0,0,0,.04)
    }
    .vdw-choose .toc h2{font-size:1rem;margin:.1rem 0 .4rem}
    .vdw-choose .toc ul{list-style:none;margin:0;padding:0;display:grid;gap:.35rem}
    .vdw-choose .toc a{display:flex;gap:.5rem;align-items:center;padding:.45rem .6rem;border-radius:10px}
    .vdw-choose .toc a:hover{background:var(--paper)}
    .vdw-choose .toc .dot{width:8px;height:8px;border-radius:999px;background:var(--accent);opacity:.8}

    /* Désactive le sticky sur mobile pour éviter le chevauchement du bandeau */
    @media(max-width:767px){
      .vdw-choose .grid.cols-2{grid-template-columns:1fr!important}
      .vdw-choose .toc{position:static; top:auto; margin-bottom:10px}
    }

    /* Layout */
    .vdw-choose .grid{display:grid;gap:20px}
    @media(min-width:980px){.vdw-choose .grid.cols-2{grid-template-columns:280px 1fr}}

    /* Sections */
    .vdw-choose section.block{background:#fff;border:1px solid var(--cream);border-radius:18px;padding:18px;box-shadow:0 8px 24px rgba(0,0,0,.04)}
    .vdw-choose .block h2{font-size:clamp(1.25rem,2.3vw,1.6rem);margin:0 0 .5rem}
    .vdw-choose .intro{opacity:.95;margin:.2rem 0 .8rem;max-width:85ch}

    /* Chips / badges */
    .vdw-choose .chips{display:flex;flex-wrap:wrap;gap:.5rem;margin:.6rem 0}
    .vdw-choose .chip{display:inline-flex;align-items:center;gap:.45rem;background:#fff;border:1px solid var(--cream);
      border-radius:999px;font-size:.82rem;padding:.35rem .7rem;color:#6B5E4A}

    /* Cards critères */
    .vdw-choose .cards{display:grid;gap:12px}
    @media(min-width:720px){.vdw-choose .cards{grid-template-columns:repeat(3,1fr)}}
    .vdw-choose .card{background:linear-gradient(180deg,#fff 0%,#fff7ee 100%);border:1px solid var(--cream);border-radius:16px;padding:16px;
      box-shadow:0 6px 20px rgba(0,0,0,.04);transition:transform .3s ease, box-shadow .3s ease}
    .vdw-choose .card:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,0,0,.08)}
    .vdw-choose .card h3{margin:.1rem 0 .35rem;font-size:1.02rem}
    .vdw-choose .mini{font-size:.93rem;opacity:.95;margin:.2rem 0 0}

    /* Comparatif */
    .vdw-choose .compare{display:grid;gap:12px}
    @media(min-width:720px){.vdw-choose .compare{grid-template-columns:1fr 1fr}}
    .vdw-choose .panel{background:#fff;border:1px solid var(--cream);border-radius:16px;padding:16px}
    .vdw-choose .panel h3{margin:.1rem 0 .35rem;font-size:1.02rem}
    .vdw-choose .panel ul{margin:.3rem 0 0;padding-left:1.1rem}
    .vdw-choose .panel.good{border-color:var(--olive)}
    .vdw-choose .panel.warn{border-color:#C77D47}

    /* Accordéons */
    .vdw-choose details{background:#fff;border:1px solid var(--cream);border-radius:12px;padding:12px 14px;margin:10px 0}
    .vdw-choose summary{cursor:pointer;font-weight:600;list-style:none}
    .vdw-choose summary::-webkit-details-marker{display:none}
    .vdw-choose details[open]{border-color:var(--accent)}

    /* CTA */
    .vdw-choose .cta-row{display:flex;flex-wrap:wrap;gap:.6rem}
    .vdw-choose .btn{appearance:none;border:none;border-radius:999px;background:var(--accent);color:#20130C;
      padding:.85rem 1.1rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:.45rem}
    .vdw-choose .btn--ghost{background:#fff;border:1px solid var(--cream);font-weight:600;transition:all .25s ease}
    .vdw-choose .btn--ghost:hover{background:var(--cream);color:var(--ink)}

    /* Accessibilité focus */
    .vdw-choose a:focus-visible, .vdw-choose button:focus-visible{
      outline:2px solid var(--accent); outline-offset:2px; border-radius:10px
    }

    /* Reveal */
    .vdw-choose .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease, transform .6s ease}
    .vdw-choose .reveal.on{opacity:1;transform:none}

    @media(prefers-reduced-motion:reduce){
      .vdw-choose .reveal{opacity:1;transform:none}
      .vdw-choose .card{transition:none}
      .vdw-choose .card:hover{transform:none}
    }
  </style>

