        <!-- 3. UTILISER -->
        <section id="utiliser" class="block reveal anchor" aria-labelledby="utiliser-title">
          <h2 id="utiliser-title">Bien utiliser : diffusion &amp; application cutanée</h2>
          <div class="cards">
            <div class="panel good">
              <h3>À faire ✅</h3>
              <ul>
                <li>Diffuser <strong>10–15 min/heure</strong> dans une pièce ventilée.</li>
                <li>Sur la peau : dilution <strong>1–3 %</strong> adulte (peaux sensibles : 0,5–1 %).</li>
                <li>Test cutané 24 h au pli du coude avant première utilisation.</li>
                <li>Utiliser une <strong>huile végétale</strong> (ricin, coco, jojoba) comme support.</li>
              </ul>
            </div>
            <div class="panel warn">
              <h3>À éviter ❌</h3>
              <ul>
                <li>Ingestion sans avis d’un professionnel qualifié.</li>
                <li>Contact avec yeux/muqueuses, application pure (sauf HE très douces et cas spécifiques).</li>
                <li>Usage chez femme enceinte/allaitante et enfant sans conseil adapté.</li>
                <li>Exposition solaire immédiate après HE photosensibilisantes (pas le cas des huiles listées ici, mais prudence générale).</li>
              </ul>
            </div>
          </div>

          <!-- HowTo exemples (SEO) -->
          <div class="steps" itemscope itemtype="https://schema.org/HowTo" style="margin-top:12px">
            <meta itemprop="name" content="Mélange de diffusion relaxant Ylang Ylang">
            <article class="step" itemprop="step" itemscope itemtype="https://schema.org/HowToStep">
              <h3><span class="n">1</span> Préparer</h3>
              <p class="mini" itemprop="text">Ajouter 2 g Ylang Ylang + 3 g Orange douce dans un diffuseur à eau.</p>
            </article>
            <article class="step" itemprop="step" itemscope itemtype="https://schema.org/HowToStep">
              <h3><span class="n">2</span> Diffuser</h3>
              <p class="mini" itemprop="text">Lancer 10–15 min. Aérer légèrement la pièce.</p>
            </article>
            <article class="step" itemprop="step" itemscope itemtype="https://schema.org/HowToStep">
              <h3><span class="n">3</span> Pause</h3>
              <p class="mini" itemprop="text">Faire une pause d’au moins 45 min avant de relancer.</p>
            </article>
            <article class="step" itemprop="step" itemscope itemtype="https://schema.org/HowToStep">
              <h3><span class="n">4</span> Ajuster</h3>
              <p class="mini" itemprop="text">Adapter le nombre de gouttes à la taille de la pièce.</p>
            </article>
          </div>
        </section>

