            <div class="cards" style="margin-top:.4rem">
              <div class="card">
                <img src="https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile_essentielle_ravintsara_madagascar.png?v=1757254488" alt="Huile essentielle Ravintsara" style="width:100%;border-radius:12px;margin-bottom:.6rem" loading="lazy">
