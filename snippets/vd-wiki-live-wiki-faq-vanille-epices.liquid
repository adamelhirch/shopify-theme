  <!-- SCRIPTS : reveal + filtre + recherche + ancre + open/close -->
  <script>
    // Reveal
    (function(){const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.18});
      document.querySelectorAll('.reveal').forEach(n=>io.observe(n));})();

    // Helpers
    const $$=(sel,ctx=document)=>[...ctx.querySelectorAll(sel)];

    // Search + filter by category + highlight + hash open
    (function(){
      const q=document.getElementById('faq-q');
      const tags=$$('.tag');
      let activeCat='all';

      const clearMarks=(el)=>{el.innerHTML=el.innerHTML.replace(/<mark>|<\/mark>/g,'')};
      const hilite=(node,term)=>{
        if(!term) return;
        const rx=new RegExp('('+term.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');
        node.innerHTML=node.innerHTML.replace(rx,'<mark>$1</mark>');
      };

      function apply(){
        const term=(q.value||'').trim().toLowerCase();
        const faqs=$$('details.faq');
        faqs.forEach(d=>{
          const body=d.querySelector('.ans'); const sum=d.querySelector('summary');
          clearMarks(sum); clearMarks(body);
          const text=(d.innerText||'').toLowerCase();
          const inCat=(activeCat==='all'||d.dataset.cat===activeCat);
          const match=!term || text.includes(term);
          d.style.display=(inCat && match)?'':'none';
          if(term && match){ hilite(sum,term); hilite(body,term); d.open=true; }
          if(!term && !d.dataset.pin){ d.open=false; }
        });
      }

      q.addEventListener('input',apply);
      tags.forEach(t=>t.addEventListener('click',()=>{
        tags.forEach(x=>x.setAttribute('aria-pressed','false'));
        t.setAttribute('aria-pressed','true'); activeCat=t.dataset.cat; apply();
      }));
      apply();

      // anchor open on load & copylink
      const hash=decodeURIComponent(location.hash||'');
      if(hash){
        const el=document.querySelector(hash);
        if(el && el.tagName.toLowerCase()==='details'){ el.open=true; el.scrollIntoView({behavior:'smooth',block:'start'}); }
      }
      $$('.copylink').forEach(b=>b.addEventListener('click',()=>{
        const a=b.dataset.anchor; const url=location.origin+location.pathname+a;
        navigator.clipboard.writeText(url); b.textContent='✔'; setTimeout(()=>b.textContent='🔗',900);
        history.replaceState(null,'',a);
      }));
    })();

    // Open/close all + clear search
    (function(){
      const openAll=document.getElementById('openAll');
      const closeAll=document.getElementById('closeAll');
      const clearSearch=document.getElementById('clearSearch');
      const q=document.getElementById('faq-q');

      openAll.addEventListener('click',()=>$$('details.faq').forEach(d=>{ if(d.style.display!=='none') d.open=true; }));
      closeAll.addEventListener('click',()=>$$('details.faq').forEach(d=>d.open=false));
      clearSearch.addEventListener('click',()=>{ q.value=''; q.dispatchEvent(new Event('input')); });
    })();
  </script>
