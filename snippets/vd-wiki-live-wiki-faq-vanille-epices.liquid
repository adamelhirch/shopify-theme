<section class="vdF-root" aria-label="Wiki — Foire aux questions">
  <style>
    .vdF-root{
      --ink:#171511;--sub:#3d3a34;--muted:#6c695f;--line:rgba(0,0,0,.08);
      --paper:#fff;--bg:#fbf6ee;--cream:#f6efe6;--accent:#FFB766;--accent2:#FFD09A;--leaf:#87a36a;
      --shadow:rgba(13,10,8,.10);--r:24px;--w:clamp(980px,92vw,1280px);
      --h1:clamp(44px,7vw,86px);--h2:clamp(26px,4.4vw,52px);--lead:clamp(18px,2.2vw,22px);
      color:var(--ink);background:linear-gradient(180deg,var(--paper),var(--bg) 48%,var(--cream));
      border-radius:34px;box-shadow:0 30px 80px var(--shadow);isolation:isolate;overflow:hidden}
    .vdF-root *{box-sizing:border-box}
    .vdF-container{max-width:var(--w);margin-inline:auto;padding-inline:clamp(16px,2.2vw,28px)}

    /* NAV */
    .vdF-nav{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.85);backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--line)}
    .vdF-nav .vdF-container{display:flex;align-items:center;justify-content:space-between;padding-block:10px}
    .vdF-brand{display:flex;align-items:center;gap:10px}
    .vdF-logo{width:26px;height:26px;border-radius:8px;background:conic-gradient(from 12deg,#ffd7a3,#fff 40%,#ffc17a);box-shadow:inset 0 0 0 1px var(--line)}
    .vdF-brand b{font-size:14px}
    .vdF-nav a{color:var(--ink);text-decoration:none;font-size:14px;padding:.5rem .7rem;border-radius:10px}
    .vdF-nav a:hover{background:rgba(0,0,0,.04)}

    /* HERO */
    .vdF-hero .vdF-container{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(16px,4vw,48px);align-items:end;padding-block:clamp(28px,7vw,88px)}
    .vdF-kicker{letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600;font-size:12px}
    .vdF-hero h1{font-size:var(--h1);line-height:1.06;letter-spacing:-.02em;margin:.2rem 0 1rem}
    .vdF-hero h1 .hl{background:linear-gradient(90deg,var(--accent),var(--accent2));padding:.06em .20em;border-radius:.35em;box-decoration-break:clone}
    .vdF-hero p{font-size:var(--lead);color:var(--sub);max-width:64ch}
    .vdF-cta{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .chip{display:inline-flex;align-items:center;gap:6px;padding:.45rem .7rem;border:1px solid var(--line);border-radius:999px;background:#fff;font-size:12px;text-decoration:none;color:var(--ink)}
    .chip:hover{background:linear-gradient(180deg,#fff,#ffe8c9)}
    .chip .ext{font-size:10px;opacity:.7}

    /* WRAP layout */
    .vdF-wrap{display:grid;grid-template-columns:260px 1fr;gap:clamp(14px,2.4vw,22px);align-items:start}
    .vdF-side{position:sticky;top:76px;align-self:start}
    .vdF-search{border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 12px;display:flex;gap:8px;align-items:center}
    .vdF-search input{border:none;outline:none;flex:1;min-width:0}
    .vdF-filters{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
    .tag{border:1px solid var(--line);border-radius:999px;padding:.35rem .6rem;font-size:11px;background:#fff;cursor:pointer}
    .tag[aria-pressed="true"]{background:linear-gradient(180deg,#fff,#f7efe5)}
    .vdF-tools{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .toolbtn{border:1px solid var(--line);border-radius:10px;background:#fff;padding:.45rem .6rem;font-size:12px;cursor:pointer}

    /* FAQ groups */
    .vdF-sec{padding-block:clamp(24px,5.6vw,70px)}
    .vdF-sec h2{font-size:var(--h2);margin:0 0 10px}
    .vdF-note{color:var(--muted);font-size:13px;margin-top:-4px;margin-bottom:10px}
    .faq-grid{display:grid;grid-template-columns:1fr;gap:10px}
    details.faq{position:relative;border:1px solid var(--line);border-radius:16px;background:#fff;box-shadow:0 12px 30px var(--shadow);overflow:hidden}
    summary{list-style:none;cursor:pointer;padding:14px 46px 14px 14px;display:flex;gap:10px;align-items:center}
    summary::-webkit-details-marker{display:none}
    .q{font-weight:700}
    .badge{font-size:11px;border:1px solid var(--line);border-radius:8px;padding:.18rem .45rem;background:linear-gradient(180deg,#fff,#f7efe5);color:var(--muted)}
    .ans{padding:0 14px 14px;color:var(--sub);font-size:14px}
    .copylink{position:absolute;right:8px;top:8px;border:1px solid var(--line);border-radius:10px;background:#fff;font-size:12px;padding:.25rem .45rem;cursor:pointer}
    .bar{height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));opacity:.7}

    /* highlight */
    mark{background:#ffe2bf;padding:0 .15em;border-radius:4px}

    /* Reveal */
    .reveal{opacity:0;transform:translateY(22px);transition:opacity .55s cubic-bezier(.2,.8,.2,1), transform .55s cubic-bezier(.2,.8,.2,1)}
    .reveal.in{opacity:1;transform:none}

    @media (max-width:1080px){.vdF-wrap{grid-template-columns:1fr}}
  </style>

