    .vdw-keep-clean .visual-copy h2,
    .vdw-keep-clean .visual-copy h3,
    .vdw-keep-clean .visual-copy p {
      color: inherit;
      margin: 0;
    }

    .vdw-keep-clean .visual-kicker {
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0.78;
      font-weight: 700;
