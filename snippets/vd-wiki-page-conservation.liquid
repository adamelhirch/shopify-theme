<section class="vdw-keep-clean" aria-labelledby="vdw-keep-clean-title">
  <style>
    .vdw-keep-clean {
      --ink: #171511;
      --sub: #4d473e;
      --muted: #6f685d;
      --bg: #fbf6ee;
      --paper: #fffdf8;
      --line: rgba(23, 21, 17, 0.08);
      --accent: #d4a373;
      --accent-soft: rgba(212, 163, 115, 0.12);
      --good: #6e7b59;
      --warn: #b3633f;
      color: var(--ink);
      background: linear-gradient(180deg, #fffdf9 0%, var(--bg) 100%);
      border: 1px solid var(--line);
      border-radius: 28px;
      padding: clamp(20px, 3vw, 42px);
      box-shadow: 0 22px 54px rgba(23, 21, 17, 0.06);
    }

    .vdw-keep-clean * {
      box-sizing: border-box;
    }

    .vdw-keep-clean .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      margin-bottom: 0.8rem;
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .vdw-keep-clean .eyebrow::before {
      content: "";
      width: 28px;
      height: 1px;
      background: currentColor;
      opacity: 0.55;
    }

    .vdw-keep-clean h1,
    .vdw-keep-clean h2,
    .vdw-keep-clean h3 {
      color: var(--ink);
      letter-spacing: -0.02em;
    }

    .vdw-keep-clean h1 {
      margin: 0;
      font-size: clamp(2.1rem, 4.7vw, 3.6rem);
      line-height: 1.02;
      max-width: 13ch;
    }

    .vdw-keep-clean p,
    .vdw-keep-clean li {
      color: var(--sub);
      font-size: 1rem;
      line-height: 1.7;
    }

    .vdw-keep-clean .hero {
      display: grid;
      gap: 1.4rem;
      margin-bottom: 1.9rem;
    }

    .vdw-keep-clean .lead {
      max-width: 76ch;
      margin: 0;
      font-size: 1.06rem;
    }

    .vdw-keep-clean .summary-note {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 1.1rem 1.15rem;
    }

    .vdw-keep-clean .summary-note strong {
      display: block;
      margin-bottom: 0.45rem;
      color: var(--ink);
      font-size: 0.82rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .vdw-keep-clean .quick-grid,
    .vdw-keep-clean .cards,
    .vdw-keep-clean .mini-grid {
      display: grid;
      gap: 14px;
    }

    .vdw-keep-clean .quick-grid {
      margin: 1.35rem 0 2rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .vdw-keep-clean .cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .vdw-keep-clean .mini-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .vdw-keep-clean .card,
    .vdw-keep-clean .panel {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 1rem 1rem 1.05rem;
    }

    .vdw-keep-clean .visual-band {
      display: grid;
      gap: 14px;
      grid-template-columns: 1.25fr 0.95fr;
      margin: 1.4rem 0 0.6rem;
    }

    .vdw-keep-clean .visual-card {
      position: relative;
      overflow: hidden;
      min-height: 250px;
      border: 1px solid var(--line);
      border-radius: 24px;
      background: #201712;
      color: #f9f4ec;
    }

    .vdw-keep-clean .visual-card img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.42;
    }

    .vdw-keep-clean .visual-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(23, 21, 17, 0.12), rgba(23, 21, 17, 0.84));
