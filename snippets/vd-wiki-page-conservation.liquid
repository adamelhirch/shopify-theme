    .vdw-keep-clean .card h3,
    .vdw-keep-clean .panel h3 {
      margin: 0 0 0.45rem;
      font-size: 1.03rem;
    }

    .vdw-keep-clean .panel--good {
      border-color: rgba(110, 123, 89, 0.35);
      background: linear-gradient(180deg, rgba(110, 123, 89, 0.06), rgba(255, 255, 255, 0.95));
    }

    .vdw-keep-clean .panel--warn {
      border-color: rgba(179, 99, 63, 0.34);
      background: linear-gradient(180deg, rgba(179, 99, 63, 0.06), rgba(255, 255, 255, 0.95));
    }

    .vdw-keep-clean .panel ul {
      margin: 0;
      padding-left: 1.1rem;
    }

    .vdw-keep-clean .panel li + li {
      margin-top: 0.35rem;
    }

    .vdw-keep-clean .section {
      margin-top: 2rem;
    }

    .vdw-keep-clean .section h2 {
      margin: 0 0 0.6rem;
      font-size: clamp(1.45rem, 2.6vw, 2rem);
    }

    .vdw-keep-clean .steps {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .vdw-keep-clean .step {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 1rem;
    }

    .vdw-keep-clean .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      margin-bottom: 0.75rem;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--ink);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .vdw-keep-clean .step h3 {
      font-size: 1rem;
      margin: 0 0 0.35rem;
    }

    .vdw-keep-clean .table-shell {
      margin-top: 1rem;
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--paper);
    }

    .vdw-keep-clean table {
      width: 100%;
      border-collapse: collapse;
      min-width: 580px;
    }

    .vdw-keep-clean th,
    .vdw-keep-clean td {
      padding: 0.9rem 1rem;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    .vdw-keep-clean th {
      color: var(--ink);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .vdw-keep-clean tr:last-child td {
      border-bottom: 0;
    }

    .vdw-keep-clean details {
      margin-top: 0.85rem;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 0.95rem 1rem;
    }

    .vdw-keep-clean summary {
      cursor: pointer;
      list-style: none;
      font-weight: 700;
      color: var(--ink);
    }

    .vdw-keep-clean summary::-webkit-details-marker {
      display: none;
    }

    .vdw-keep-clean details[open] {
      border-color: rgba(212, 163, 115, 0.45);
    }

    .vdw-keep-clean details .details-body {
      margin-top: 0.85rem;
    }

    .vdw-keep-clean .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .vdw-keep-clean .cta {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      min-height: 48px;
      padding: 0.8rem 1.1rem;
      border-radius: 999px;
      font-weight: 700;
      text-decoration: none;
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .vdw-keep-clean .cta--primary {
      background: var(--accent);
      color: #23160f;
    }

    .vdw-keep-clean .cta--secondary {
      background: var(--paper);
      color: var(--ink);
      border: 1px solid var(--line);
    }

    .vdw-keep-clean .cta:hover {
      transform: translateY(-1px);
    }

    .vdw-keep-clean .footnote {
      margin-top: 1.2rem;
