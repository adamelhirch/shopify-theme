<section class="vdw-spices" aria-labelledby="vdw-spices-title">
  <style>
    .vdw-spices{
      --ink:#2B1C10;
      --bg:#FAF5EE;
      --paper:#F6EFE6;
      --cream:#F2E9DD;
      --accent:#D4A373; /* Orange Vanille Désiré */
      --olive:#6E7B59;
      --ring:rgba(0,0,0,.08);
      color:var(--ink); background:var(--bg);
      border-radius:20px; padding:clamp(20px,3vw,44px)
    }
    .vdw-spices *{box-sizing:border-box}
    .vdw-spices a{color:inherit;text-decoration:none}
    .vdw-spices .wrap{max-width:1200px;margin:0 auto}

    /* Header */
    .vdw-spices .kicker{letter-spacing:.12em;text-transform:uppercase;font-size:.78rem;opacity:.8;margin-bottom:.35rem}
    .vdw-spices h1{font-size:clamp(1.9rem,4.2vw,3rem);line-height:1.08;margin:.1rem 0 .35rem}
    .vdw-spices .lead{font-size:clamp(1rem,1.2vw,1.125rem);max-width:80ch;opacity:.95;margin:0}

    /* Layout + Sommaire */
    .vdw-spices .grid{display:grid;gap:20px}
    .vdw-spices .toc{
      background:#fff;border:1px solid var(--cream);border-radius:16px;padding:14px;box-shadow:0 6px 18px rgba(0,0,0,.04)
    }
    .vdw-spices .toc h2{font-size:1rem;margin:.1rem 0 .4rem}
    .vdw-spices .toc ul{list-style:none;margin:0;padding:0;display:grid;gap:.35rem}
    .vdw-spices .toc a{display:flex;gap:.5rem;align-items:center;padding:.45rem .6rem;border-radius:10px}
    .vdw-spices .toc a:hover{background:var(--paper)}
    .vdw-spices .toc .dot{width:8px;height:8px;border-radius:999px;background:var(--accent);opacity:.85}
    @media(min-width:980px){
      .vdw-spices .grid.cols-2{grid-template-columns:280px 1fr}
      .vdw-spices .toc{position:sticky; top:96px;}
    }

    /* Blocs & cartes */
    .vdw-spices section.block{background:#fff;border:1px solid var(--cream);border-radius:18px;padding:18px;box-shadow:0 8px 24px rgba(0,0,0,.04)}
    .vdw-spices .block h2{font-size:clamp(1.25rem,2.3vw,1.6rem);margin:0 0 .5rem}
    .vdw-spices .intro{opacity:.95;margin:.2rem 0 .8rem;max-width:85ch}

    .vdw-spices .cards{display:grid;gap:14px}
    @media(min-width:700px){.vdw-spices .cards{grid-template-columns:repeat(2,1fr)}}
    @media(min-width:1080px){.vdw-spices .cards{grid-template-columns:repeat(3,1fr)}}
    .vdw-spices .card{
      position:relative;overflow:hidden;
      background:linear-gradient(180deg,#fff 0%,#fff7ee 100%);
      border:1px solid var(--cream);border-radius:16px;
      box-shadow:0 6px 20px rgba(0,0,0,.04);
      transition:transform .3s ease, box-shadow .3s ease
    }
    .vdw-spices .card:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,0,0,.08)}
    .vdw-spices .pad{padding:16px}
    .vdw-spices .card h3{margin:.1rem 0 .35rem;font-size:1.02rem}
    .vdw-spices .mini{font-size:.93rem;opacity:.95;margin:.2rem 0 .2rem}

    /* Bouton orange */
    .vdw-spices .btn{
      display:inline-flex;align-items:center;gap:.4rem;
      background:var(--accent);color:#20130C;
      border:1px solid var(--cream);border-radius:999px;
      padding:.7rem 1rem;font-weight:700;cursor:pointer
    }
    .vdw-spices .btn:hover{filter:brightness(0.98)}

    /* Badge & images */
    .vdw-spices .tag{display:inline-flex;align-items:center;gap:.45rem;background:#fff;border:1px solid var(--cream);
      border-radius:999px;font-size:.78rem;padding:.28rem .6rem;color:#6B5E4A}
    /* .ph = bandeau image 132px (cover) */
    .vdw-spices .ph{width:100%;height:132px;object-fit:cover;border-bottom:1px solid var(--cream);background:#fff;display:block}

    /* Reveal */
    .vdw-spices .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease, transform .6s ease}
    .vdw-spices .reveal.on{opacity:1;transform:none}
    @media(prefers-reduced-motion:reduce){
      .vdw-spices .reveal{opacity:1;transform:none}
      .vdw-spices .card{transition:none}
      .vdw-spices .card:hover{transform:none}
    }
  </style>

  <div class="wrap">
