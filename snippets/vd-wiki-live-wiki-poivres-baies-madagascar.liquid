<section class="vdw-peppers" aria-labelledby="vdw-peppers-title">
  {%- liquid
    assign wiki_pepper_voats_product = all_products['poivre-sauvage-voatsiperifery-sachet-50g-madagascar']
    assign wiki_pepper_noir_product = all_products['poivre-noir-madagascar-sachet-50g']
    assign wiki_pepper_blanc_product = all_products['poivre-blanc-madagascar-sachet-50g']
    assign wiki_pepper_roses_product = all_products['baies-roses-madagascar-sachet-30g']
    assign wiki_pepper_mix_product = all_products['melange-4-epices-madagascar-sachet-50g']

    assign wiki_pepper_voats_image = wiki_pepper_voats_product.featured_media.preview_image | default: wiki_pepper_voats_product.featured_image
    assign wiki_pepper_noir_image = wiki_pepper_noir_product.featured_media.preview_image | default: wiki_pepper_noir_product.featured_image
    assign wiki_pepper_blanc_image = wiki_pepper_blanc_product.featured_media.preview_image | default: wiki_pepper_blanc_product.featured_image
    assign wiki_pepper_roses_image = wiki_pepper_roses_product.featured_media.preview_image | default: wiki_pepper_roses_product.featured_image
    assign wiki_pepper_mix_image = wiki_pepper_mix_product.featured_media.preview_image | default: wiki_pepper_mix_product.featured_image
  -%}
  <style>
    .vdw-peppers{
      --ink:#2B1C10; --bg:#FAF5EE; --paper:#F6EFE6; --cream:#F2E9DD;
      --accent:#D4A373; --olive:#6E7B59; --ring:rgba(0,0,0,.08);
      color:var(--ink); background:var(--bg);
      border-radius:20px; padding:clamp(20px,3vw,44px)
    }
    .vdw-peppers *{box-sizing:border-box}
    .vdw-peppers a{color:inherit;text-decoration:none}
    .vdw-peppers .wrap{max-width:1200px;margin:0 auto}

    /* Header */
    .vdw-peppers .kicker{letter-spacing:.12em;text-transform:uppercase;font-size:.78rem;opacity:.8;margin-bottom:.35rem}
    .vdw-peppers h1{font-size:clamp(1.9rem,4.2vw,3rem);line-height:1.08;margin:.1rem 0 .35rem}
    .vdw-peppers .lead{font-size:clamp(1rem,1.2vw,1.125rem);max-width:80ch;opacity:.95;margin:0}

    /* Layout + Sommaire */
    .vdw-peppers .grid{display:grid;gap:20px}
    .vdw-peppers .toc{
      background:#fff;border:1px solid var(--cream);border-radius:16px;padding:14px;box-shadow:0 6px 18px rgba(0,0,0,.04)
    }
    .vdw-peppers .toc h2{font-size:1rem;margin:.1rem 0 .4rem}
    .vdw-peppers .toc ul{list-style:none;margin:0;padding:0;display:grid;gap:.35rem}
    .vdw-peppers .toc a{display:flex;gap:.5rem;align-items:center;padding:.45rem .6rem;border-radius:10px}
    .vdw-peppers .toc a:hover{background:var(--paper)}
    .vdw-peppers .toc .dot{width:8px;height:8px;border-radius:999px;background:var(--accent);opacity:.85}
    @media(min-width:980px){
      .vdw-peppers .grid.cols-2{grid-template-columns:280px 1fr}
      .vdw-peppers .toc{position:sticky; top:96px;}
    }

    /* Blocs & cartes */
    .vdw-peppers section.block{background:#fff;border:1px solid var(--cream);border-radius:18px;padding:18px;box-shadow:0 8px 24px rgba(0,0,0,.04)}
    .vdw-peppers .block h2{font-size:clamp(1.25rem,2.3vw,1.6rem);margin:0 0 .5rem}
    .vdw-peppers .intro{opacity:.95;margin:.2rem 0 .8rem;max-width:85ch}

    .vdw-peppers .cards{display:grid;gap:14px}
    @media(min-width:700px){.vdw-peppers .cards{grid-template-columns:repeat(2,1fr)}}
    @media(min-width:1080px){.vdw-peppers .cards{grid-template-columns:repeat(3,1fr)}}
    .vdw-peppers .card{
      position:relative;overflow:hidden;
      background:linear-gradient(180deg,#fff 0%,#fff7ee 100%);
      border:1px solid var(--cream);border-radius:16px;
      box-shadow:0 6px 20px rgba(0,0,0,.04);
      transition:transform .3s ease, box-shadow .3s ease
    }
    .vdw-peppers .card:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,0,0,.08)}
    .vdw-peppers .pad{padding:16px}
    .vdw-peppers .card h3{margin:.1rem 0 .35rem;font-size:1.02rem}
    .vdw-peppers .mini{font-size:.93rem;opacity:.95;margin:.2rem 0 .2rem}

    /* Bouton orange */
    .vdw-peppers .btn{
      display:inline-flex;align-items:center;gap:.4rem;background:var(--accent);color:#20130C;
      border:1px solid var(--cream);border-radius:999px;padding:.7rem 1rem;font-weight:700;cursor:pointer
    }
    .vdw-peppers .btn:hover{filter:brightness(0.98)}

    /* Badge & images */
    .vdw-peppers .tag{display:inline-flex;align-items:center;gap:.45rem;background:#fff;border:1px solid var(--cream);
      border-radius:999px;font-size:.78rem;padding:.28rem .6rem;color:#6B5E4A}
    .vdw-peppers .ph{width:100%;height:132px;object-fit:cover;border-bottom:1px solid var(--cream);background:#fff;display:block}

    /* Reveal */
    .vdw-peppers .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease, transform .6s ease}
    .vdw-peppers .reveal.on{opacity:1;transform:none}
    @media(prefers-reduced-motion:reduce){
      .vdw-peppers .reveal{opacity:1;transform:none}
      .vdw-peppers .card{transition:none}
      .vdw-peppers .card:hover{transform:none}
    }
  </style>

  <div class="wrap">
    <p class="kicker">Wiki — Poivres &amp; Baies</p>
    <h1 id="vdw-peppers-title">Poivres &amp; baies de Madagascar</h1>
    <p class="lead">
      <strong>Poivre sauvage (voatsiperifery)</strong>, <strong>poivre noir</strong>, <strong>poivre blanc</strong>, <strong>baies roses</strong> et <strong>mélanges</strong>…  
      Pour chacun : le profil aromatique, le bon moment d’ajout et les accords de cuisine qui fonctionnent vraiment.
    </p>

    <div class="grid cols-2" style="margin-top:18px">
      <!-- Sommaire -->
      <nav class="toc reveal" aria-label="Sommaire">
        <h2>Sommaire</h2>
        <ul>
          <li><a href="#voatsiperifery"><span class="dot"></span> Poivre sauvage (voatsiperifery)</a></li>
          <li><a href="#poivre-noir"><span class="dot"></span> Poivre noir</a></li>
          <li><a href="#poivre-blanc"><span class="dot"></span> Poivre blanc</a></li>
          <li><a href="#baies-roses"><span class="dot"></span> Baies roses</a></li>
          <li><a href="#melange"><span class="dot"></span> Mélange poivres &amp; baies</a></li>
        </ul>
      </nav>

      <!-- Contenu -->
      <div class="content">
        <section class="block reveal" aria-labelledby="intro-title">
          <h2 id="intro-title">Madagascar, terroirs à poivre</h2>
          <p class="intro">Forêts primaires &amp; hautes terres volcaniques : des <strong>grains expressifs</strong> (boisé, agrumes, floral) et des filières familiales en <strong>direct producteur</strong> pour une qualité régulière.</p>
        </section>

        <!-- Poivre sauvage -->
        <section id="voatsiperifery" class="block reveal" aria-labelledby="voats-title">
          <div class="tag">Poivre</div>
          <h2 id="voats-title">Poivre sauvage de Madagascar (voatsiperifery)</h2>
          <p class="intro">Grains à queue, nez boisé &amp; floral, pointe citronnée — chaleur fine, grande longueur.</p>
          <div class="cards">
            <article class="card">
              {% if wiki_pepper_voats_image != blank %}
                {{ wiki_pepper_voats_image | image_url: width: 720 | image_tag: class: 'ph', loading: 'lazy', alt: 'Poivre sauvage (voatsiperifery) — Vanille Désiré', sizes: '(min-width: 1080px) 360px, (min-width: 700px) 50vw, 100vw' }}
              {% else %}
                <img class="ph" src="{{ 'vd-wiki-terroirs.jpg' | asset_url }}" alt="Poivre sauvage (voatsiperifery) — Vanille Désiré" width="1800" height="1350" loading="lazy">
              {% endif %}
              <div class="pad">
                <h3>Repères essentiels</h3>
                <p class="mini">Profil, usages, mouture/moulin, accords &amp; conservation.</p>
                <a class="btn" href="/pages/wiki-poivre-sauvage-voatsiperifery">Lire le guide</a>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Quand il donne le plus</h3>
                <p class="mini">En finition sur un dessert au chocolat, des fruits rôtis, une crème légère, un jus court ou une volaille servie à la minute.</p>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>À éviter</h3>
                <p class="mini">Le cuire longtemps, le moudre trop fin ou le doser comme un poivre noir classique. Il perd vite sa singularité dans une sauce lourde.</p>
              </div>
            </article>
          </div>
        </section>

        <!-- Poivre noir -->
        <section id="poivre-noir" class="block reveal" aria-labelledby="noir-title">
          <div class="tag">Poivre</div>
          <h2 id="noir-title">Poivre noir de Madagascar</h2>
          <p class="intro">Chaud, boisé, légèrement fumé — sauces, grillades, légumes rôtis &amp; desserts chocolatés.</p>
          <div class="cards">
            <article class="card">
              {% if wiki_pepper_noir_image != blank %}
                {{ wiki_pepper_noir_image | image_url: width: 720 | image_tag: class: 'ph', loading: 'lazy', alt: 'Poivre noir de Madagascar — Vanille Désiré', sizes: '(min-width: 1080px) 360px, (min-width: 700px) 50vw, 100vw' }}
              {% else %}
                <img class="ph" src="{{ 'vd-wiki-cover.jpg' | asset_url }}" alt="Poivre noir de Madagascar — Vanille Désiré" width="1800" height="1151" loading="lazy">
              {% endif %}
              <div class="pad">
                <h3>Repères essentiels</h3>
                <p class="mini">Terroir, séchage, mouture, idées &amp; dosages.</p>
                <a class="btn" href="/pages/wiki-poivre-noir-madagascar">Lire le guide</a>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Ses terrains les plus fiables</h3>
                <p class="mini">Viandes, légumes rôtis, sauces brunes, œufs, pommes de terre, chocolat noir et préparations où il faut une assise chaude et nette.</p>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Geste de départ</h3>
                <p class="mini">Commencez au moulin en fin de cuisson, puis renforcez seulement si la matière supporte davantage. Sur un jus ou une sauce, le noir se goûte vite.</p>
              </div>
            </article>
          </div>
        </section>

        <!-- Poivre blanc -->
        <section id="poivre-blanc" class="block reveal" aria-labelledby="blanc-title">
          <div class="tag">Poivre</div>
          <h2 id="blanc-title">Poivre blanc de Madagascar</h2>
          <p class="intro">Plus subtil &amp; musqué — poissons, fruits de mer, sauces crémées &amp; plats délicats.</p>
          <div class="cards">
            <article class="card">
              {% if wiki_pepper_blanc_image != blank %}
                {{ wiki_pepper_blanc_image | image_url: width: 720 | image_tag: class: 'ph', loading: 'lazy', alt: 'Poivre blanc de Madagascar — Vanille Désiré', sizes: '(min-width: 1080px) 360px, (min-width: 700px) 50vw, 100vw' }}
              {% else %}
                <img class="ph" src="{{ 'vd-wiki-science.jpg' | asset_url }}" alt="Poivre blanc de Madagascar — Vanille Désiré" width="1800" height="1350" loading="lazy">
              {% endif %}
              <div class="pad">
                <h3>Repères essentiels</h3>
                <p class="mini">Préparation (décortication), usages fins &amp; conservation.</p>
                <a class="btn" href="/pages/wiki-poivre-blanc-madagascar">Lire le guide</a>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Quand le choisir</h3>
                <p class="mini">Sur les poissons, les sauces claires, les légumes blancs, les crèmes salées et les assiettes où le poivre doit rester présent sans durcir la bouche.</p>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Le piège classique</h3>
                <p class="mini">Le croire plus faible que le noir et en mettre trop. Le blanc est plus discret visuellement, pas forcément plus léger en bouche.</p>
              </div>
            </article>
          </div>
        </section>

        <!-- Baies roses -->
        <section id="baies-roses" class="block reveal" aria-labelledby="roses-title">
          <div class="tag">Baie</div>
          <h2 id="roses-title">Baies roses de Madagascar</h2>
          <p class="intro">Douces, légèrement sucrées &amp; florales — poissons, fromages, desserts &amp; cocktails.</p>
          <div class="cards">
            <article class="card">
              {% if wiki_pepper_roses_image != blank %}
                {{ wiki_pepper_roses_image | image_url: width: 720 | image_tag: class: 'ph', loading: 'lazy', alt: 'Baies roses de Madagascar — Vanille Désiré', sizes: '(min-width: 1080px) 360px, (min-width: 700px) 50vw, 100vw' }}
              {% else %}
                <img class="ph" src="{{ 'vd-wiki-botanique.jpg' | asset_url }}" alt="Baies roses de Madagascar — Vanille Désiré" width="1350" height="1800" loading="lazy">
              {% endif %}
              <div class="pad">
                <h3>Repères essentiels</h3>
                <p class="mini">Récolte, tri, accords &amp; idées (sucré/salé).</p>
                <a class="btn" href="/pages/wiki-baies-roses-madagascar">Lire le guide</a>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Accords rapides</h3>
                <p class="mini">Fromage frais, poisson blanc, agrumes, mangue, fraise, chocolat blond et cocktails où l’on cherche une note florale plutôt qu’une vraie chaleur poivrée.</p>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Dosage</h3>
                <p class="mini">Écrasez-les légèrement au dernier moment et gardez la main légère. Leur intérêt tient à la fraîcheur et à la couleur, pas à la puissance.</p>
              </div>
            </article>
          </div>
        </section>

        <!-- Mélange poivres & baies -->
        <section id="melange" class="block reveal" aria-labelledby="mix-title">
          <div class="tag">Mélange</div>
          <h2 id="mix-title">Mélange poivre noir + sauvage + blanc &amp; baies roses</h2>
          <p class="intro">Équilibre force / fraîcheur / floral — parfait en moulin à table.</p>
          <div class="cards">
            <article class="card">
              {% if wiki_pepper_mix_image != blank %}
                {{ wiki_pepper_mix_image | image_url: width: 720 | image_tag: class: 'ph', loading: 'lazy', alt: 'Mélange poivres &amp; baies — Vanille Désiré', sizes: '(min-width: 1080px) 360px, (min-width: 700px) 50vw, 100vw' }}
              {% else %}
                <img class="ph" src="{{ 'vd-wiki-techniques.jpg' | asset_url }}" alt="Mélange poivres &amp; baies — Vanille Désiré" width="1374" height="1800" loading="lazy">
              {% endif %}
              <div class="pad">
                <h3>Guide du mélange</h3>
                <p class="mini">Composition, usages, idées de finitions &amp; marinades.</p>
                <a class="btn" href="/pages/wiki-melange-poivres-baies">Lire le guide</a>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Ce qu’il fait très bien</h3>
                <p class="mini">Il simplifie la table, les légumes rôtis, les viandes blanches, les œufs, les salades tièdes et les assiettes où l’on veut un moulin unique mais lisible.</p>
              </div>
            </article>
            <article class="card">
              <div class="pad">
                <h3>Quand rester sur un poivre seul</h3>
                <p class="mini">Sur un poisson délicat, une sauce très claire ou un dessert précis, un seul profil bien choisi garde souvent plus de netteté qu’un mélange.</p>
              </div>
            </article>
          </div>
        </section>

        <!-- Fin : retour wiki -->
        <section class="block reveal" style="margin-top:18px;text-align:center">
          <h2>Continuer l’exploration</h2>
          <p class="intro">Retrouvez toutes les catégories sur la page d’accueil du Wiki.</p>
          <a class="btn" href="/pages/wiki">← Retour au Wiki</a>
        </section>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded',function(){
      var els=document.querySelectorAll('.vdw-peppers .reveal');
      if('IntersectionObserver' in window){
        var io=new IntersectionObserver(function(entries){
          entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('on'); io.unobserve(e.target);} });
        },{threshold:.12});
        els.forEach(function(el){ io.observe(el); });
      } else { els.forEach(function(el){ el.classList.add('on'); }); }
    });
  </script>

  <!-- Fil d’Ariane JSON-LD -->
  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Wiki","item":"https://vanilledesire.com/pages/wiki"},
      {"@type":"ListItem","position":2,"name":"Poivres & Baies de Madagascar","item":"https://vanilledesire.com/pages/wiki-poivres-baies-madagascar"}
    ]
  }
  </script>
</section>
              
