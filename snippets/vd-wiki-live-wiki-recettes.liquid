<section class="vdR-root" aria-label="Wiki — Recettes &amp; bases">
  <style>
    .vdR-root{
      --ink:#171511;--sub:#3d3a34;--muted:#6c695f;--line:rgba(0,0,0,.08);
      --paper:#fff;--bg:#fbf6ee;--cream:#f6efe6;--accent:#FFB766;--accent2:#FFD09A;
      --shadow:rgba(13,10,8,.10);--r:22px;--w:clamp(980px,92vw,1280px);
      --h1:clamp(42px,7.2vw,84px);--h2:clamp(26px,4.4vw,54px);--lead:clamp(18px,2.2vw,22px);
      color:var(--ink);background:linear-gradient(180deg,var(--paper),var(--bg) 50%,var(--cream));
      border-radius:34px;box-shadow:0 30px 80px var(--shadow);isolation:isolate;overflow:hidden
    }
    .vdR-root *{box-sizing:border-box}
    .vdR-container{max-width:var(--w);margin-inline:auto;padding-inline:clamp(16px,2.2vw,28px)}

    .vdR-nav{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.85);
      backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--line)}
    .vdR-nav .vdR-container{display:flex;align-items:center;justify-content:space-between;padding-block:10px}
    .vdR-brand{display:flex;align-items:center;gap:10px}
    .vdR-logo{width:26px;height:26px;border-radius:8px;background:conic-gradient(from 12deg,#ffd7a3,#fff 40%,#ffc17a);box-shadow:inset 0 0 0 1px var(--line)}
    .vdR-brand b{font-size:14px}
    .vdR-nav a{color:var(--ink);text-decoration:none;font-size:14px;padding:.5rem .7rem;border-radius:10px}
    .vdR-nav a:hover{background:rgba(0,0,0,.04)}

    .vdR-hero .vdR-container{display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(16px,4vw,48px);align-items:end;padding-block:clamp(28px,7vw,90px)}
    .vdR-kicker{letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600;font-size:12px}
    .vdR-hero h1{font-size:var(--h1);line-height:1.08;letter-spacing:-.02em;margin:.2rem 0 1rem}
    .vdR-hero h1 .hl{background:linear-gradient(90deg,var(--accent),var(--accent2));padding:.06em .20em;border-radius:.35em;box-decoration-break:clone}
    .vdR-hero p{font-size:var(--lead);color:var(--sub);max-width:64ch}
    .vdR-art{min-height:320px;border:1px solid var(--line);border-radius:var(--r);background:linear-gradient(180deg,#fff,#fff7ec);box-shadow:0 16px 40px var(--shadow);position:relative;overflow:hidden}

    /* link chips */
    .vdR-cta{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .chip{display:inline-flex;align-items:center;gap:6px;padding:.45rem .7rem;border:1px solid var(--line);border-radius:999px;background:#fff;font-size:12px;text-decoration:none;color:var(--ink)}
    .chip:hover{background:linear-gradient(180deg,#fff,#ffe8c9)}
    .chip .ext{font-size:10px;opacity:.7}

    .vdR-filters{padding-block:clamp(12px,2.8vw,20px)}
    .vdR-pills{display:flex;gap:8px;flex-wrap:wrap}
    .vdR-pill{border:1px solid var(--line);background:#fff;border-radius:999px;padding:.5rem .9rem;font-size:13px;cursor:pointer}
    .vdR-pill[aria-pressed="true"]{background:linear-gradient(180deg,#fff,#ffe2bf);box-shadow:0 8px 20px var(--shadow)}

    .vdR-sec{padding-block:clamp(28px,6vw,74px)}
    .vdR-sec h2{font-size:var(--h2);margin:0 0 8px;line-height:1.06}
    .vdR-lead{color:var(--sub);margin:0 0 14px}

    .vdR-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(12px,2vw,18px)}
    .vdR-card{background:#fff;border:1px solid var(--line);border-radius:18px;padding:16px;box-shadow:0 14px 34px var(--shadow);transition:transform .25s ease, box-shadow .25s ease}
    .vdR-card:hover{transform:translateY(-6px);box-shadow:0 26px 60px var(--shadow)}
    .vdR-card .kicker{letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600;font-size:11px}
    .vdR-card h3{font-size:18px;margin:.35rem 0}
    .vdR-card p, .vdR-card li{color:var(--sub)}
    .vdR-card ul{margin:.35rem 0 0 1rem;padding:0}
    .vdR-card a{color:inherit;text-decoration:underline;text-decoration-color:rgba(0,0,0,.25);text-underline-offset:2px}

    .vdR-tools{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(12px,2vw,18px)}
    .vdR-tool{background:#fff;border:1px solid var(--line);border-radius:18px;padding:16px;box-shadow:0 12px 30px var(--shadow)}
    .vdR-tool label{font-size:13px;color:var(--muted)}
    .vdR-tool input{width:100%;padding:10px;border:1px solid var(--line);border-radius:10px;margin:.35rem 0}
    .vdR-out{font-size:14px;color:var(--ink);font-weight:600}

    .vdR-gloss{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(12px,2vw,18px)}
    .vdR-note{background:#fff;border:1px solid var(--line);border-radius:16px;padding:14px}

    .os-badge{display:inline-block;font-size:11px;padding:.25rem .5rem;border-radius:999px;border:1px solid var(--line);background:linear-gradient(180deg,#fff,#f7efe5);color:var(--muted);margin-left:6px}

    .attr{font-size:12px;color:var(--muted);margin-top:8px}

    .reveal{opacity:0;transform:translateY(22px);transition:opacity .6s cubic-bezier(.2,.8,.2,1), transform .6s cubic-bezier(.2,.8,.2,1)}
    .reveal.in{opacity:1;transform:none}

    @media (max-width:980px){
      .vdR-hero .vdR-container{grid-template-columns:1fr}
      .vdR-grid,.vdR-tools,.vdR-gloss{grid-template-columns:1fr}
    }
  </style>

