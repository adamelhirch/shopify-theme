  <!-- SCRIPTS -->
  <script>
    (function(){const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.18});document.querySelectorAll('.reveal').forEach(n=>io.observe(n));})();
    (function(){const pills=[...document.querySelectorAll('.vdR-pill')];const cards=[...document.querySelectorAll('[data-cat]')];
      const set=f=>{pills.forEach(p=>p.setAttribute('aria-pressed',p.dataset.filter===f||f==='all'&&p.dataset.filter==='all'?'true':'false'));
        cards.forEach(c=>c.style.display=(f==='all'||c.dataset.cat===f)?'':'none');};
      pills.forEach(p=>p.addEventListener('click',()=>set(p.dataset.filter)));set('all');})();
    (function(){const $=id=>document.getElementById(id);
      const sc=()=>{const t=+$('sc-in1').value||0,v=+$('sc-in2').value||0,q=+$('sc-in3').value||0;$('sc-out').textContent='Quantité ajustée : '+(t?Math.round(q*(v/t)):'—')+' g'};
      const pc=()=>{const T=+$('pc-in1').value||0,P=(+$('pc-in2').value||0)/100;$('pc-out').textContent='Résultat : '+(T?Math.round(T*P):'—')+' g'};
      const sx=()=>{const s=+$('sx-in1').value||0,e=+$('sx-in2').value||0;const b=(s/(s+e))*100;$('sx-out').textContent='≈ '+(isFinite(b)?Math.round(b):'—')+' % sucres (Brix simplifié)';};
      ['sc-in1','sc-in2','sc-in3'].forEach(id=>$(id).addEventListener('input',sc));sc();
      ['pc-in1','pc-in2'].forEach(id=>$(id).addEventListener('input',pc));pc();
      ['sx-in1','sx-in2'].forEach(id=>$(id).addEventListener('input',sx));sx();
    })();
  </script>
