  <!-- OUTILS -->
  <section id="outils" class="vdR-sec">
    <div class="vdR-container">
      <h2 class="reveal">Outils rapides</h2>
      <p class="vdR-lead reveal">Scaler, convertir, dimensionner. Résultats indicatifs — à ajuster selon texture et matériel.</p>

      <div class="vdR-tools">
        <div class="vdR-tool reveal">
          <div class="kicker">Calcul</div>
          <h3>Scaler de recette</h3>
          <label>Poids total actuel (g)</label>
          <input id="sc-in1" type="number" min="1" value="1000">
          <label>Poids total voulu (g)</label>
          <input id="sc-in2" type="number" min="1" value="1500">
          <label>Quantité d’un ingrédient (g)</label>
          <input id="sc-in3" type="number" min="0" value="200">
          <div class="vdR-out" id="sc-out">Quantité ajustée : 300 g</div>
        </div>

        <div class="vdR-tool reveal">
          <div class="kicker">Conversion</div>
          <h3>% ⇄ grammes</h3>
          <label>Poids total (g)</label>
          <input id="pc-in1" type="number" min="1" value="1000">
          <label>Pourcentage (%)</label>
          <input id="pc-in2" type="number" min="0" step="0.1" value="12">
          <div class="vdR-out" id="pc-out">Résultat : 120 g</div>
        </div>

        <div class="vdR-tool reveal">
          <div class="kicker">Repère</div>
          <h3>Sirop : eau + sucre</h3>
          <label>Sucre (g)</label>
          <input id="sx-in1" type="number" min="0" value="800">
          <label>Eau (g)</label>
          <input id="sx-in2" type="number" min="0" value="1000">
          <div class="vdR-out" id="sx-out">≈ 44 % sucres (Brix simplifié)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- GLOSSAIRE -->
  <section id="glossaire" class="vdR-sec">
    <div class="vdR-container">
      <h2 class="reveal">Glossaire technique (utile, pas verbeux)</h2>
      <div class="vdR-gloss">
        <div class="vdR-note reveal">
          <h3>Infusion contrôlée</h3>
          <p>Vanille : 80–85 °C, 30–45 min, couvert. Filtrage fin. Préserve la fraîcheur aromatique.</p>
        </div>
        <div class="vdR-note reveal">
          <h3>Maturation</h3>
          <p>Repos à froid 6–12 h (glaces, pâtes sucrées) pour texture et diffusion homogènes.</p>
        </div>
        <div class="vdR-note reveal">
          <h3>Assaisonnement au service</h3>
          <p>Moudre <a href="/pages/wiki-poivre-sauvage-voatsiperifery">poivre sauvage</a> et <a href="/pages/wiki-baies-roses-madagascar">baies roses</a> juste avant dressage.</p>
        </div>
        <div class="vdR-note reveal">
          <h3>Équilibre acide/gras/sucre</h3>
          <p>Combava pour la tension, vanille pour la rondeur, <a href="/pages/wiki-poivre-noir-madagascar">poivre noir</a> pour la structure.</p>
        </div>
