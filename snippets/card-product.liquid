{% comment %}
  Renders the unified Vanille Désiré product card.

  Faithful clone of the Yann Couvreur "info-outside / blends" product
  card: just figure + info, no CTA button, no quick-buy overlay.
  The whole card is one click target → product page.

  Accepts:
  - card_product:        {Object} Product Liquid object (optional)
  - lazy_load:           {Boolean} Image should be lazy loaded. Default: true (optional)
  - skip_styles:         {Boolean} Skip stylesheet includes when rendering many cards. Default: false (optional)
  - section_id:          {String}  ID of the parent section, for unique element ids
  - placeholder_image:   {String}  Placeholder svg name when no product
  - show_category:       {Boolean} Display product.type as an eyebrow above the title. Default: false (optional)

  The following parameters are accepted for backwards compatibility but
  are intentionally ignored (the card is visually unified across the theme):
  - media_aspect_ratio, image_shape, show_secondary_image (always on),
    show_vendor, show_rating, extend_height, quick_add, horizontal_class,
    horizontal_quick_add.

  Usage:
  {% render 'card-product', card_product: product, section_id: section.id %}
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-card-product-vd.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- liquid
  assign placeholder_image = placeholder_image | default: 'product-1'
-%}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign card_url = card_product.url
    assign primary_media = card_product.featured_media
    assign secondary_media = card_product.media[1]
    assign first_variant = card_product.selected_or_first_available_variant

    assign needs_options = false
    if card_product.has_only_default_variant == false
      assign needs_options = true
    endif
  -%}

  <article
    class="vd-card{% if card_product.available == false %} vd-card--sold-out{% endif %}"
    data-product-id="{{ card_product.id }}"
  >
    <div class="vd-card__figure">
      <a
        href="{{ card_url }}"
        class="vd-card__media"
        aria-label="{{ card_product.title | escape }}"
      >
        {%- if primary_media -%}
          <img
            class="vd-card__image vd-card__image--primary"
            srcset="
              {%- if primary_media.width >= 360 -%}{{ primary_media | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if primary_media.width >= 540 -%}{{ primary_media | image_url: width: 540 }} 540w,{%- endif -%}
              {%- if primary_media.width >= 720 -%}{{ primary_media | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if primary_media.width >= 960 -%}{{ primary_media | image_url: width: 960 }} 960w,{%- endif -%}
              {%- if primary_media.width >= 1200 -%}{{ primary_media | image_url: width: 1200 }} 1200w,{%- endif -%}
              {{ primary_media | image_url }} {{ primary_media.width }}w
            "
            src="{{ primary_media | image_url: width: 720 }}"
            sizes="(min-width: 990px) 30vw, (min-width: 750px) 45vw, 50vw"
            alt="{{ primary_media.alt | escape }}"
            width="{{ primary_media.width }}"
            height="{{ primary_media.height }}"
            {% unless lazy_load == false %}
              loading="lazy"
            {% endunless %}
          >
        {%- else -%}
          {{ placeholder_image | placeholder_svg_tag: 'vd-card__image vd-card__image--primary placeholder-svg' }}
        {%- endif -%}

        {%- if secondary_media -%}
          <img
            class="vd-card__image vd-card__image--secondary"
            srcset="
              {%- if secondary_media.width >= 360 -%}{{ secondary_media | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if secondary_media.width >= 540 -%}{{ secondary_media | image_url: width: 540 }} 540w,{%- endif -%}
              {%- if secondary_media.width >= 720 -%}{{ secondary_media | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if secondary_media.width >= 960 -%}{{ secondary_media | image_url: width: 960 }} 960w,{%- endif -%}
              {%- if secondary_media.width >= 1200 -%}{{ secondary_media | image_url: width: 1200 }} 1200w,{%- endif -%}
              {{ secondary_media | image_url }} {{ secondary_media.width }}w
            "
            src="{{ secondary_media | image_url: width: 720 }}"
            sizes="(min-width: 990px) 30vw, (min-width: 750px) 45vw, 50vw"
            alt=""
            width="{{ secondary_media.width }}"
            height="{{ secondary_media.height }}"
            loading="lazy"
          >
        {%- endif -%}
      </a>

      {%- if secondary_media -%}
        <div class="vd-card__dots" aria-hidden="true" data-vd-card-dots>
          <span class="vd-card__dot is-active"></span>
          <span class="vd-card__dot"></span>
        </div>
      {%- endif -%}

      {%- if card_product.available == false -%}
        <div class="vd-card__badge-list">
          <span class="vd-card__badge vd-card__badge--sold-out">
            {{- 'products.product.sold_out' | t -}}
          </span>
        </div>
      {%- else -%}
        <div class="vd-card__quick-buy">
          {%- if needs_options -%}
            <a href="{{ card_url }}" class="vd-card__cta">
              {{- 'products.product.choose_options' | t -}}
            </a>
          {%- else -%}
            {%- form 'product',
              card_product,
              class: 'vd-card__form',
              novalidate: 'novalidate',
              data-type: 'add-to-cart-form'
            -%}
              <input
                type="hidden"
                name="id"
                value="{{ first_variant.id }}"
                class="product-variant-id"
              >
              <button
                type="submit"
                name="add"
                class="vd-card__cta"
                aria-label="{{ 'products.product.add_to_cart' | t }} — {{ card_product.title | escape }}"
              >
                {{- 'products.product.add_to_cart' | t -}}
              </button>
            {%- endform -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="vd-card__info">
      {%- if show_category and card_product.type != blank -%}
        <span class="vd-card__category">{{ card_product.type | escape }}</span>
      {%- endif -%}

      <a href="{{ card_url }}" class="vd-card__title">
        {{- card_product.title | escape -}}
      </a>

      {%- comment -%}
        Étoiles + nombre d'avis si Judge.me / autre app review a écrit
        dans les metafields standards Shopify (`reviews.rating` +
        `reviews.rating_count`). Aucun rendu si le produit n'a pas d'avis.
      {%- endcomment -%}
      {%- if card_product.metafields.reviews.rating.value != blank -%}
        {%- liquid
          assign rating_obj = card_product.metafields.reviews.rating.value
          assign rating = rating_obj.rating | times: 1.0
          assign rating_max = rating_obj.scale_max | default: 5 | times: 1
          assign rating_count = card_product.metafields.reviews.rating_count.value | default: 0 | times: 1
          assign rating_filled = rating | floor
          assign rating_decimal = rating | minus: rating_filled
          assign rating_half_idx = rating_filled | plus: 1
          assign rating_has_half = false
          if rating_decimal >= 0.5
            assign rating_has_half = true
          endif
        -%}
        <span
          class="vd-card__rating"
          aria-label="Note moyenne {{ rating | round: 1 }} sur {{ rating_max }} étoiles, basée sur {{ rating_count }} avis"
        >
          <span class="vd-card__rating-stars" aria-hidden="true">
            {%- for i in (1..rating_max) -%}
              {%- if i <= rating_filled -%}
                <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 2l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              {%- elsif i == rating_half_idx and rating_has_half -%}
                <svg viewBox="0 0 24 24" width="12" height="12">
                  <defs><linearGradient id="vd-half-{{ card_product.id }}-{{ i }}"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="currentColor" stop-opacity="0"/></linearGradient></defs>
                  <path d="M12 2l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z" fill="url(#vd-half-{{ card_product.id }}-{{ i }})" stroke="currentColor" stroke-width="1.2"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><path d="M12 2l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </span>
          {%- if rating_count > 0 -%}
            <span class="vd-card__rating-count">({{ rating_count }})</span>
          {%- endif -%}
        </span>
      {%- endif -%}

      <span class="vd-card__price">
        {%- if card_product.price_varies -%}
          {{ 'products.product.price.from_price_html' | t: price: card_product.price_min | money }}
        {%- elsif card_product.compare_at_price > card_product.price -%}
          <s class="vd-card__price-compare">{{ card_product.compare_at_price | money }}</s>
          {{ card_product.price | money }}
        {%- else -%}
          {{ card_product.price | money }}
        {%- endif -%}
      </span>
    </div>
  </article>
{%- else -%}
  <article class="vd-card vd-card--placeholder">
    <div class="vd-card__figure">
      <div class="vd-card__media" aria-hidden="true">
        {{ placeholder_image | placeholder_svg_tag: 'vd-card__image vd-card__image--primary placeholder-svg' }}
      </div>
    </div>
    <div class="vd-card__info">
      <span class="vd-card__title">{{ 'onboarding.product_title' | t }}</span>
      <span class="vd-card__price">—</span>
    </div>
  </article>
{%- endif -%}
