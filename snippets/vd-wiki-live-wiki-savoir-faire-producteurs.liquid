<section class="vd2-root" aria-label="Wiki — Savoir‑faire &amp; Producteurs">
  <style>
    /* THEME */
    .vd2-root{--ink:#171511;--sub:#3d3a34;--muted:#6c695f;--line:rgba(0,0,0,.08);
      --paper:#fff;--bg:#fbf6ee;--cream:#f6efe6;--accent:#f9e3bf;--accent2:#ffe9cc;--leaf:#87a36a;
      --shadow:rgba(13,10,8,.10);--r:26px;--r-sm:16px;--w:clamp(980px,92vw,1280px);
      --h1:clamp(48px,8vw,104px);--h2:clamp(28px,4.8vw,58px);--lead:clamp(18px,2.2vw,22px);
      color:var(--ink);background:linear-gradient(180deg,var(--paper),var(--bg) 50%,var(--cream));
      border-radius:34px;box-shadow:0 30px 80px var(--shadow);isolation:isolate;overflow:hidden}
    .vd2-root *{box-sizing:border-box}
    .vd2-container{max-width:var(--w);margin-inline:auto;padding-inline:clamp(16px,2.2vw,28px)}

    /* NAV minimal */
    .vd2-nav{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.85);backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--line)}
    .vd2-nav .vd2-container{display:flex;align-items:center;justify-content:space-between;padding-block:10px}
    .vd2-brand{display:flex;align-items:center;gap:10px}
    .vd2-logo{width:26px;height:26px;border-radius:8px;background:conic-gradient(from 12deg,#ecd7b6,#fff 40%,#d8b88d);box-shadow:inset 0 0 0 1px var(--line)}
    .vd2-brand b{font-size:14px}
    .vd2-nav a{color:var(--ink);text-decoration:none;font-size:14px;padding:.5rem .7rem;border-radius:10px}
    .vd2-nav a:hover{background:rgba(0,0,0,.04)}

    /* HERO — cinématique */
    .vd2-hero{position:relative}
    .vd2-hero .vd2-container{display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(16px,4vw,48px);align-items:end;padding-block:clamp(28px,7vw,96px)}
    .vd2-kicker{letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600;font-size:12px}
    .vd2-hero h1{font-size:var(--h1);line-height:1;letter-spacing:-.02em;margin:.2rem 0 1rem;word-spacing:.04em}
    .vd2-hero h1 .hl{background:linear-gradient(90deg,var(--accent),var(--accent2));padding:.08em .22em;border-radius:.35em;box-decoration-break:clone}
    .vd2-hero p{font-size:var(--lead);color:var(--sub);max-width:60ch}

    /* Parallax card */
    .vd2-art{position:relative;min-height:360px;border-radius:var(--r);overflow:hidden;background:linear-gradient(180deg,#fff,#fff6e9);border:1px solid var(--line)}
    .vd2-bokeh{position:absolute;inset:-20%;pointer-events:none;filter:blur(6px);opacity:.9}
    .vd2-bokeh:before,.vd2-bokeh:after{content:"";position:absolute;border-radius:50%;inset:auto;box-shadow:0 0 160px 90px rgba(183,139,94,.25)}
    .vd2-bokeh:before{top:12%;left:16%}
    .vd2-bokeh:after{bottom:8%;right:12%}
    .vd2-float{position:absolute;bottom:10%;right:8%;width:clamp(220px,30vw,340px);background:#fff;border:1px solid var(--line);border-radius:18px;padding:14px;box-shadow:0 16px 40px var(--shadow);transform:translateZ(0)}
    .vd2-chip{width:56px;height:56px;border-radius:14px;background:linear-gradient(180deg,#fff,#f5ede3);border:1px solid var(--line)}
    .vd2-row{display:flex;align-items:center;gap:10px}
    .vd2-float h3{font-size:16px;margin:0}
    .vd2-float p{font-size:13px;color:var(--muted);margin:.2rem 0 0}

    /* SECTION — méthode (3 gestes) */
    .vd2-steps{padding-block:clamp(34px,7vw,90px)}
    .vd2-steps h2{font-size:var(--h2);line-height:1.06;margin:0 0 10px}
    .vd2-progress{height:3px;background:linear-gradient(90deg,#000,#000) no-repeat left/0% 100%,
      linear-gradient(90deg,transparent,transparent) left/100% 100%;border-radius:999px;margin:12px 0 22px;opacity:.25}
    .vd2-stepgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(12px,2vw,18px)}
    .vd2-step{background:#fff;border:1px solid var(--line);border-radius:18px;padding:16px;box-shadow:0 12px 30px var(--shadow);
      transform-style:preserve-3d;will-change:transform;transition:transform .25s ease, box-shadow .25s ease}
    .vd2-step:hover{transform:translateY(-6px) rotateX(3deg) rotateY(-3deg);box-shadow:0 26px 60px var(--shadow)}
    .vd2-step b{display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:12px;background:linear-gradient(180deg,#fff,#f7efe5);border:1px solid var(--line);box-shadow:0 8px 20px var(--shadow);font-weight:700}
    .vd2-step h3{font-size:18px;margin:.4rem 0}
    .vd2-step p{color:var(--sub);margin:.2rem 0}

    /* SECTION — engagements (3) */
    .vd2-values{padding-block:clamp(30px,6vw,80px);background:linear-gradient(180deg,var(--cream),#fff)}
    .vd2-valgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(12px,2vw,18px)}
    .vd2-tile{position:relative;border:1px solid var(--line);border-radius:20px;overflow:hidden;background:#fff}
    .vd2-mask{position:absolute;inset:0;background:radial-gradient(120px 80px at var(--mx,60%) var(--my,40%), rgba(0,0,0,.06), transparent 60%);mix-blend-mode:multiply;opacity:0;transition:opacity .25s ease}
    .vd2-tile:hover .vd2-mask{opacity:1}
    .vd2-tile .vd2-body{padding:18px}
    .vd2-tile h4{font-size:20px;margin:4px 0}
    .vd2-tile p{color:var(--sub)}

    /* FOOTER light */
    .vd2-footer{border-top:1px solid var(--line);background:#fff}
    .vd2-footer .vd2-container{display:flex;justify-content:space-between;align-items:center;gap:10px;padding-block:16px;font-size:13px;color:var(--muted)}

    /* Cursor magnétique */
    .vd2-cursor{position:fixed;inset:auto;top:0;left:0;width:24px;height:24px;border-radius:50%;border:1px solid rgba(0,0,0,.6);pointer-events:none;transform:translate(-50%,-50%);z-index:50;mix-blend-mode:multiply;opacity:.85}

    /* Reveal base */
    .reveal{opacity:0;transform:translateY(24px);transition:opacity .6s cubic-bezier(.2,.8,.2,1), transform .6s cubic-bezier(.2,.8,.2,1)}
    .reveal.in{opacity:1;transform:none}

    /* Responsive */
    @media (max-width:980px){
      .vd2-hero .vd2-container{grid-template-columns:1fr}
      .vd2-stepgrid,.vd2-valgrid{grid-template-columns:1fr}
    }
  </style>

  <!-- NAV -->
  <nav class="vd2-nav" aria-label="Navigation de section">
    <div class="vd2-container">
      <div class="vd2-brand"><span class="vd2-logo" aria-hidden="true"></span><b>Savoir‑faire &amp; Producteurs</b></div>
      <div class="vd2-links"><a href="#methode">Méthode</a><a href="#engagements">Engagements</a></div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="vd2-hero">
    <div class="vd2-container">
      <div>
        <div class="vd2-kicker">Traçabilité complète • Direct Madagascar</div>
        <h1 id="kinetic">
          Un <span class="hl">savoir‑faire</span> artisanal,<br>
          une chaîne <span class="hl">courte</span>,<br>
          un goût <span class="hl">vrai</span>.
        </h1>
        <p class="reveal">Sélection directe auprès de familles productrices, contrôle à l’arrivée, mise en pot propre en France. Simple, net, reproductible.</p>
      </div>
      <div class="vd2-art reveal" style="transition-delay:.08s">
        <div class="vd2-bokeh" aria-hidden="true"></div>
        <div class="vd2-float">
          <div class="vd2-row">
            <div class="vd2-chip" aria-hidden="true"></div>
            <div>
              <h3>Lots tracés</h3>
              <p>Origine, séchage, humidité : chaque lot a sa carte d’identité.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- MÉTHODE -->
  <section id="methode" class="vd2-steps">
    <div class="vd2-container">
      <h2 class="reveal">Notre méthode en 3 gestes</h2>
      <div class="vd2-progress" id="progress"></div>
      <div class="vd2-stepgrid">
        <article class="vd2-step reveal">
          <b>01</b>
          <h3>Récolte &amp; affinage</h3>
          <p>Récoltes au bon stade puis séchage soigné (soleil/ombre), affinage patient.</p>
        </article>
        <article class="vd2-step reveal" style="transition-delay:.04s">
          <b>02</b>
          <h3>Tri &amp; contrôle</h3>
          <p>Calibrage, examen visuel et organoleptique. Les lots irréguliers ne passent pas.</p>
        </article>
        <article class="vd2-step reveal" style="transition-delay:.08s">
          <b>03</b>
          <h3>Mise en pot claire</h3>
          <p>Conditionnement propre, étiquette lisible, lot/DLC. Rien à cacher.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ENGAGEMENTS -->
  <section id="engagements" class="vd2-values">
    <div class="vd2-container">
      <h2 class="reveal">Engagements simples &amp; mesurables</h2>
      <div class="vd2-valgrid">
        <div class="vd2-tile reveal">
          <div class="vd2-mask"></div>
          <div class="vd2-body">
            <div class="vd2-kicker">Traçabilité</div>
            <h4>Chaque lot se suit</h4>
            <p>Origine, méthode, humidité — un QR interne pour tout retrouver.</p>
          </div>
        </div>
        <div class="vd2-tile reveal" style="transition-delay:.04s">
          <div class="vd2-mask"></div>
          <div class="vd2-body">
            <div class="vd2-kicker">Qualité</div>
            <h4>Contrôles reproductibles</h4>
            <p>Même exigence à chaque réception : cohérence des profils et du taux d’humidité.</p>
          </div>
        </div>
        <div class="vd2-tile reveal" style="transition-delay:.08s">
          <div class="vd2-mask"></div>
          <div class="vd2-body">
            <div class="vd2-kicker">Sobriété</div>
            <h4>Pas de surpromesse</h4>
            <p>On montre la matière et la méthode. Le reste, c’est dans l’assiette.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="vd2-footer">
    <div class="vd2-container"><span>© Vanille Désiré — Direct Madagascar</span><span>Traçabilité • Qualité • Prix justes</span></div>
  </footer>

  <!-- SCRIPTS : cinétique, parallax, reveal, progress, cursor, tilt, mask -->
  <script>
    // 1) Typo cinétique (split letters + entrée ressort)
    (function kinetic(){
      const el = document.getElementById('kinetic');
      if(!el) return;
      const wrap = s=>`<span class="kword">${[...s].map((c,i)=>`<span class="kletter" style="--i:${i}">${c}</span>`).join('')}</span>`;
      el.innerHTML = el.innerHTML.replace(/<span class=\"hl\">(.*?)<\/span>/g,(m,g)=>`<span class="hl khl">${wrap(g)}</span>`);
      requestAnimationFrame(()=>{
        document.querySelectorAll('.kletter').forEach((l,idx)=>{
          l.animate([
            {transform:'translate3d(0,40px,0) rotate(6deg)',opacity:0},
            {transform:'translate3d(0,0,0) rotate(0)',opacity:1}
          ],{duration:700,delay:idx*18,easing:'cubic-bezier(.2,.8,.2,1)',fill:'forwards'});
        });
      });
    })();

    // 2) Parallax carte + bokeh
    (function parallax(){
      const art = document.querySelector('.vd2-art');
      if(!art) return;
      art.addEventListener('mousemove',e=>{
        const r = art.getBoundingClientRect();
        const x = (e.clientX - r.left)/r.width - .5;
        const y = (e.clientY - r.top)/r.height - .5;
        art.querySelector('.vd2-float').style.transform = `translateY(${y*-8}px) translateX(${x*8}px)`;
      });
    })();

    // 3) Reveal on view
    (function reveal(){
      const io = new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.18});
      document.querySelectorAll('.reveal').forEach(n=>io.observe(n));
    })();

    // 4) Scroll progress (méthode)
    (function progress(){
      const sec = document.getElementById('methode');
      const bar = document.getElementById('progress');
      if(!sec||!bar) return;
      const onScroll=()=>{
        const r = sec.getBoundingClientRect();
        const t = Math.min(1, Math.max(0, (window.innerHeight - r.top) / (r.height + window.innerHeight)));
        bar.style.backgroundSize = `${t*100}% 100% , 100% 100%`;
      };
      onScroll();
      window.addEventListener('scroll', onScroll, {passive:true});
    })();

    // 5) Cursor magnétique
    (function cursor(){
      const c = document.createElement('div'); c.className='vd2-cursor'; document.body.appendChild(c);
      let x=0,y=0,tx=0,ty=0; const lerp=(a,b,n)=>a+(b-a)*n;
      const loop=()=>{x=lerp(x,tx,.18); y=lerp(y,ty,.18); c.style.transform=`translate(${x-12}px,${y-12}px)`; requestAnimationFrame(loop)}; loop();
      window.addEventListener('pointermove',e=>{tx=e.clientX;ty=e.clientY});
      const magnets=[...document.querySelectorAll('a, .vd2-step, .vd2-tile, .vd2-float')];
      magnets.forEach(m=>{
        m.addEventListener('mouseenter',()=>{c.style.transform+= ' scale(1.8)'; c.style.background='rgba(0,0,0,.06)'});
        m.addEventListener('mouseleave',()=>{c.style.transform=c.style.transform.replace(' scale(1.8)',''); c.style.background='transparent'});
      });
    })();

    // 6) Tilt cards by pointer
    (function tilt(){
      const cards=[...document.querySelectorAll('.vd2-step')];
      const damp=20;
      cards.forEach(card=>{
        card.addEventListener('mousemove',e=>{
          const r=card.getBoundingClientRect();
          const rx=((e.clientY-r.top)/r.height-.5)*-damp;
          const ry=((e.clientX-r.left)/r.width-.5)*damp;
          card.style.transform=`translateY(-6px) rotateX(${rx}deg) rotateY(${ry}deg)`;
        });
        card.addEventListener('mouseleave',()=>{card.style.transform=''})
      })
    })();

    // 7) Dynamic light mask on value tiles (follows mouse)
    (function mask(){
      document.querySelectorAll('.vd2-tile').forEach(t=>{
        t.addEventListener('mousemove',e=>{
          const r=t.getBoundingClientRect();
          const mx=((e.clientX-r.left)/r.width*100).toFixed(1)+"%";
          const my=((e.clientY-r.top)/r.height*100).toFixed(1)+"%";
          t.style.setProperty('--mx',mx); t.style.setProperty('--my',my);
        });
      })
    })();
  </script>
</section>
              
