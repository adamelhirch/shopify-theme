{%- comment -%}
  VD Product Card — minimal, mobile-first
  Accepts: card_product, lazy_load
{%- endcomment -%}

{%- liquid
  assign card_image = card_product.featured_media.preview_image | default: card_product.featured_image
-%}

<a href="{{ card_product.url }}" class="vd-product-card">
  <div class="vd-product-card__media">
    {% if card_image != blank %}
      {{
        card_image
        | image_url: width: 800
        | image_tag:
          class: 'vd-product-card__img',
          widths: '300, 400, 600, 800',
          sizes: '(min-width: 990px) 24vw, 46vw',
          loading: lazy_load | default: true,
          alt: card_image.alt | default: card_product.title | escape
      }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'vd-product-card__img placeholder-svg' }}
    {% endif %}
  </div>

  <div class="vd-product-card__info">
    <h3 class="vd-product-card__name">{{ card_product.title }}</h3>
    <span class="vd-product-card__price">{{ card_product.price | money }}</span>
  </div>
</a>
