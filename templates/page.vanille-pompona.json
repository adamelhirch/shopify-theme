            "code": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Vanille Pompona : guide complet, arômes & usages | Vanille Désiré</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <!-- Force le mode clair (et permet une traduction propre en EN via vos outils) -->\n  <meta name=\"color-scheme\" content=\"light\">\n  <meta name=\"description\" content=\"Tout savoir sur la vanille Pompona (Vanilla pompona) : origine, botanique, très grosses gousses, profil aromatique musqué & fruité (coumarine), accords, recettes, conservation, comparatif avec Bourbon (planifolia) et Tahiti.\">\n  <meta name=\"theme-color\" content=\"#ffffff\">\n  <style>\n    /* =========================\n       VANILLE DÉSIRÉ — ARTICLE UI (v4)\n       Palette & variables (FORCÉ CLAIR)\n    ========================== */\n    :root{\n      --ink:#171511;--sub:#3d3a34;--muted:#6c695f;--line:rgba(0,0,0,.10);\n      --paper:#fff;--bg:#fbf6ee;--cream:#f6efe6;\n      --accent:#FFB766;--accent2:#FFD09A;--leaf:#87a36a;\n      --shadow:rgba(13,10,8,.10);\n      --w:clamp(960px,92vw,1200px);\n      --r:26px;--r-sm:16px;\n      --h1:clamp(40px,7vw,84px);\n      --h2:clamp(26px,4.6vw,48px);\n      --h3:clamp(18px,2.8vw,22px);\n      --lead:clamp(18px,2.2vw,22px);\n      --lh:1.7;\n      --navH:64px; /* hauteur approx. du bandeau desktop */\n      --safeTop: env(safe-area-inset-top, 0px);\n    }\n\n    /* Base */\n    *{box-sizing:border-box}\n    html{scroll-behavior:smooth;scroll-padding-top:calc(var(--navH) + var(--safeTop))}\n    body{\n      margin:0;color:var(--ink);background:linear-gradient(180deg,var(--paper),var(--bg) 50%,var(--cream));\n      font:16px/var(--lh) ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;\n      -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;\n    }\n    .vd-container{max-width:var(--w);margin-inline:auto;padding-inline:clamp(16px,2.4vw,28px)}\n    a{color:inheri