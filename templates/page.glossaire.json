ansition:transform .25s ease, box-shadow .25s ease}\n    .sp-card:hover{transform:translateY(-6px);box-shadow:0 26px 60px var(--shadow)}\n    .sp-head{display:flex;align-items:center;justify-content:space-between;gap:8px}\n    .sp-name{font-size:18px;margin:.2rem 0}\n    .sp-badges{display:flex;gap:6px;flex-wrap:wrap}\n    .badge{font-size:11px;border:1px solid var(--line);border-radius:8px;padding:.18rem .45rem;background:linear-gradient(180deg,#fff,#f7efe5);color:var(--muted)}\n    .sp-notes{display:flex;gap:10px;flex-wrap:wrap;margin:.35rem 0;color:var(--sub);font-size:13px}\n    .sp-row{display:flex;gap:8px;align-items:center}\n    .dot{width:8px;height:8px;border-radius:50%;background:#000;opacity:.2}\n    .label{font-size:12px;color:var(--muted)}\n    .sp-ul{margin:.3rem 0 0 1rem;color:var(--sub);font-size:14px}\n    .sp-cta{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    .halo{position:absolute;inset:0;background:radial-gradient(120px 80px at var(--mx,60%) var(--my,40%), rgba(255,183,102,.18), transparent 60%);mix-blend-mode:multiply;opacity:0;transition:opacity .25s ease}\n    .sp-card:hover .halo{opacity:1}\n\n    /* Reveal */\n    .reveal{opacity:0;transform:translateY(22px);transition:opacity .6s cubic-bezier(.2,.8,.2,1), transform .6s cubic-bezier(.2,.8,.2,1)}\n    .reveal.in{opacity:1;transform:none}\n\n    /* Responsive */\n    @media (max-width:1080px){.vdG-wrap{grid-template-columns:1fr}}\n    @media (max-width:980px){.vdG-grid{grid-template-columns:1fr}}\n  </style>\n\n  <!-- NAV -->\n  <nav class=\"vdG-nav\" aria-label=\"Navigation Glossaire\">\n    <div class=\"vdG-container\">\n      <div class=\"vdG-brand\"><span class=\"vdG-logo\" aria-hidden=\"true\"></span><b>Glossaire des épices</b></div>\n      <div class=\"vdG-links\">\n        <a href=\"/collections/all\">Catalogue</a>\n        <a href=\"/pages/wiki-bienfaits-usages\">Bienfaits & Usages</a>\n        <a href=\"/pages/wiki-savoir-faire-producteurs\">Savoir-faire</a>\n      </div>\n    </div>\n  </nav>\n\n  <!-- HERO -->\n  <header class=\"vdG-hero\">\n    <div class=\"vdG-container\">\n      <div>\n        <div class=\"vdG-kicker\">Notes • Usages • Dosages repères</div>\n        <h1>Un <span class=\"hl\">glossaire</span> clair pour identifier l’<span class=\"hl\">arôme</span> juste et le <span class=\"hl\">bon geste</span>.</h1>\n        <p>Chaque fiche synthétise : profil sensoriel, idées d’usages, dosage indicatif et accords. Liens directs vers nos pages wiki produits et les collections pour acheter.</p>\n        <div class=\"vdG-cta\">\n          <a class=\"chip\" href=\"/collections/epices-madagascar\">Voir toutes les épices</a>\n          <a class=\"chip\" href=\"/collections/poivres-baies-de-madagascar\">Poivres & baies</a>\n          <a class=\"chip\" href=\"/collections/vanille-bourbon\">Vanille Bourbon</a>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <!-- WRAP : sidebar + main -->\n  <div class=\"vdG-container vdG-wrap\">\n    <!-- Sidebar : search + A-Z + tags -->\n    <aside class=\"vdG-side\" aria-label=\"Filtrer le glossaire\">\n      <div class=\"vdG-search\">\n        <span aria-hidden=\"true\">🔎</span>\n        <input id=\"q\" type=\"search\" placeholder=\"Rechercher (ex : poivre, combava…)\" aria-label=\"Rechercher une épice\">\n      </div>\n      <div class=\"vdG-index\" role=\"tablist\" aria-label=\"Index alphabétique\">\n        <!-- letters will be injected -->\n      </div>\n      <div class=\"vdG-tags\" aria-label=\"Familles\">\n        <button class=\"tag\" data-tag=\"all\" aria-pressed=\"true\">Tout</button>\n        <button class=\"tag\" data-tag=\"Poivre\">Poivres</button>\n        <button class=\"tag\" data-tag=\"Épice\">Épices</button>\n        <button class=\"tag\" data-tag=\"Mélange\">Mélanges</button>\n        <button class=\"tag\" data-tag=\"Agrume\">Agrumes</button>\n      </div>\n    </aside>\n\n    <!-- Main -->\n    <main class=\"vdG-main\">\n      <section class=\"vdG-sec\">\n        <div class=\"vdG-grid\" id=\"grid\">\n          <!-- FICHES — POIVRES & BAIES -->\n          <article class=\"sp-card reveal\" data-name=\"Poivre sauvage (Voatsiperifery)\" data-tags=\"Poivre\" data-letter=\"P\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\">\n              <h3 class=\"sp-name\">Poivre sauvage (Voatsiperifery)</h3>\n              <div class=\"sp-badges\"><span class=\"badge\">Poivre</span><span class=\"badge\">Malagasy</span></div>\n            </div>\n            <div class=\"sp-notes\">\n              <span class=\"sp-row\"><span class=\"dot\"></span><span>Boisé</span></span>\n              <span class=\"sp-row\"><span class=\"dot\"></span><span>Agrume vert</span></span>\n              <span class=\"sp-row\"><span class=\"dot\"></span><span>Résine</span></span>\n            </div>\n            <ul class=\"sp-ul\">\n              <li><b>Usages :</b> viandes blanches, sauces crème, chocolat.</li>\n              <li><b>Dosage :</b> 1–2 g/L en fin de cuisson (moudre au service).</li>\n              <li><b>Accords :</b> vanille, combava.</li>\n            </ul>\n            <div class=\"sp-cta\">\n              <a class=\"chip\" href=\"/pages/wiki-poivre-sauvage-voatsiperifery\">Wiki produit</a>\n              <a class=\"chip\" href=\"/collections/poivres-baies-de-madagascar\">Voir la collection</a>\n            </div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Poivre noir\" data-tags=\"Poivre\" data-letter=\"P\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Poivre noir</h3><div class=\"sp-badges\"><span class=\"badge\">Poivre</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Chaude</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Terreuse</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> marinades, viandes, légumes rôtis.</li><li><b>Dosage :</b> 3–6 g/L en cuisson, au goût au service.</li><li><b>Accords :</b> combava, gingembre.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-poivre-noir-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/poivres-baies-de-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Poivre blanc\" data-tags=\"Poivre\" data-letter=\"P\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Poivre blanc</h3><div class=\"sp-badges\"><span class=\"badge\">Poivre</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Animal léger</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Frais</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> poissons, veloutés, sauces blanches.</li><li><b>Dosage :</b> 1–2 g/L en fin de cuisson.</li><li><b>Accords :</b> vanille, baies roses.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-poivre-blanc-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/poivres-baies-de-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Baies roses\" data-tags=\"Poivre\" data-letter=\"B\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Baies roses</h3><div class=\"sp-badges\"><span class=\"badge\">Baie</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Floral</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Suave</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> fruits, poissons gras, fromages frais.</li><li><b>Dosage :</b> au goût au service (écraser grossièrement).</li><li><b>Accords :</b> chocolat, agrumes.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-baies-roses-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/poivres-baies-de-madagascar\">Collection</a></div>\n          </article>\n\n          <!-- ÉPICES & AGRUMES -->\n          <article class=\"sp-card reveal\" data-name=\"Cannelle\" data-tags=\"Épice\" data-letter=\"C\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Cannelle</h3><div class=\"sp-badges\"><span class=\"badge\">Épice</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Douce</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Boisée</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> pâtisserie, compotes, infusions.</li><li><b>Dosage :</b> 2–5 g/L en infusion/sirop.</li><li><b>Accords :</b> vanille, girofle.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-cannelle-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Curcuma\" data-tags=\"Épice\" data-letter=\"C\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Curcuma</h3><div class=\"sp-badges\"><span class=\"badge\">Épice</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Terre</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Poivré léger</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> currys, bouillons, riz parfumé.</li><li><b>Dosage :</b> 3–6 g/L (teinte vite).</li><li><b>Accords :</b> gingembre, poivre noir.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-curcuma-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Gingembre\" data-tags=\"Épice\" data-letter=\"G\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Gingembre</h3><div class=\"sp-badges\"><span class=\"badge\">Épice</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Citronné</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Piquant</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> woks, sirops, marinades.</li><li><b>Dosage :</b> 2–4 g/L (poudre) ou au goût (frais).</li><li><b>Accords :</b> combava, curcuma.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-gingembre-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Girofle\" data-tags=\"Épice\" data-letter=\"G\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Girofle</h3><div class=\"sp-badges\"><span class=\"badge\">Épice</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Épicé</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Balsamique</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> pickles, sirops, pâtisserie.</li><li><b>Dosage :</b> parcimonieux (puissant).</li><li><b>Accords :</b> cannelle, poivre noir.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-girofle-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Combava (zeste & feuilles)\" data-tags=\"Agrume\" data-letter=\"C\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Combava (zeste & feuilles)</h3><div class=\"sp-badges\"><span class=\"badge\">Agrume</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Citron vert</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Herbacé</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> currys lait de coco, sirops, desserts.</li><li><b>Dosage :</b> micro-dose (très puissant).</li><li><b>Accords :</b> vanille, poivre sauvage.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-combava-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Graines de sésame\" data-tags=\"Épice\" data-letter=\"G\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Graines de sésame</h3><div class=\"sp-badges\"><span class=\"badge\">Graine</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Grillé</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Noisette</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> pains, salades, toppings.</li><li><b>Dosage :</b> au goût (torréfier légèrement).</li><li><b>Accords :</b> piment, combava.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-sesame-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Curry (mélange)\" data-tags=\"Mélange\" data-letter=\"C\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Curry (mélange)</h3><div class=\"sp-badges\"><span class=\"badge\">Mélange</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Chaud</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Aromatique</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> sauces, légumes, volailles.</li><li><b>Dosage :</b> 3–6 g/L.</li><li><b>Accords :</b> lait de coco, combava.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-curry-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Fond d’épices (profil chaud)\" data-tags=\"Mélange\" data-letter=\"F\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Fond d’épices (profil chaud)</h3><div class=\"sp-badges\"><span class=\"badge\">Mélange</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Chaleur</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Rondeur</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> sauce, bouillon, base maison.</li><li><b>Dosage :</b> 3–6 g/L.</li><li><b>Accords :</b> poivre noir, gingembre.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-fond-epices-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/fond-epices\">Acheter</a></div>\n          </article>\n\n          <article class=\"sp-card reveal\" data-name=\"Piment pili-pili\" data-tags=\"Épice\" data-letter=\"P\" onmousemove=\"vdHalo(event,this)\">\n            <div class=\"halo\"></div>\n            <div class=\"sp-head\"><h3 class=\"sp-name\">Piment pili-pili</h3><div class=\"sp-badges\"><span class=\"badge\">Piment</span></div></div>\n            <div class=\"sp-notes\"><span class=\"sp-row\"><span class=\"dot\"></span><span>Piquant</span></span><span class=\"sp-row\"><span class=\"dot\"></span><span>Fruité</span></span></div>\n            <ul class=\"sp-ul\"><li><b>Usages :</b> condiments, huiles pimentées, grillades.</li><li><b>Dosage :</b> au goût (croissant).</li><li><b>Accords :</b> sésame, citron.</li></ul>\n            <div class=\"sp-cta\"><a class=\"chip\" href=\"/pages/wiki-piment-pili-pili-madagascar\">Wiki produit</a><a class=\"chip\" href=\"/collections/epices-madagascar\">Collection</a></div>\n          </article>\n        </div>\n      </section>\n    </main>\n  </div>\n\n  <!-- FOOTER court -->\n  <footer class=\"vdG-sec\" style=\"padding-top:0;border-top:1px solid var(--line);background:#fff\">\n    <div class=\"vdG-container\" style=\"display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--muted);padding-block:14px\">\n      <span>© Vanille Désiré — Glossaire des épices</span>\n      <span>Traçabilité • Arômes • Simplicité</span>\n    </div>\n  </footer>\n\n  <!-- JSON-LD : liste des épices (SEO) -->\n  <script type=\"application/ld+json\">\n  {\n    \"@context\":\"https://schema.org\",\n    \"@type\":\"ItemList\",\n    \"name\":\"Glossaire des épices de Madagascar — Vanille Désiré\",\n    \"itemListElement\":[\n      {\"@type\":\"ListItem\",\"position\":1,\"name\":\"Poivre sauvage (Voatsiperifery)\",\"url\":\"/pages/wiki-poivre-sauvage-voatsiperifery\"},\n      {\"@type\":\"ListItem\",\"position\":2,\"name\":\"Poivre noir de Madagascar\",\"url\":\"/pages/wiki-poivre-noir-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":3,\"name\":\"Poivre blanc de Madagascar\",\"url\":\"/pages/wiki-poivre-blanc-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":4,\"name\":\"Baies roses de Madagascar\",\"url\":\"/pages/wiki-baies-roses-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":5,\"name\":\"Cannelle de Madagascar\",\"url\":\"/pages/wiki-cannelle-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":6,\"name\":\"Curcuma de Madagascar\",\"url\":\"/pages/wiki-curcuma-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":7,\"name\":\"Gingembre de Madagascar\",\"url\":\"/pages/wiki-gingembre-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":8,\"name\":\"Girofle de Madagascar\",\"url\":\"/pages/wiki-girofle-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":9,\"name\":\"Combava (zeste & feuilles)\",\"url\":\"/pages/wiki-combava-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":10,\"name\":\"Graines de sésame de Madagascar\",\"url\":\"/pages/wiki-sesame-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":11,\"name\":\"Curry de Madagascar\",\"url\":\"/pages/wiki-curry-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":12,\"name\":\"Fond d'épices (profil chaud)\",\"url\":\"/pages/wiki-fond-epices-madagascar\"},\n      {\"@type\":\"ListItem\",\"position\":13,\"name\":\"Piment pili-pili de Madagascar\",\"url\":\"/pages/wiki-piment-pili-pili-madagascar\"}\n    ]\n  }\n  </script>\n\n  <!-- SCRIPTS : reveal + A–Z + recherche + tags + halo -->\n  <script>\n    // Reveal\n    (function(){const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.18});\n      document.querySelectorAll('.reveal').forEach(n=>io.observe(n));})();\n\n    // Build A–Z\n    (function(){\n      const letters='ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');\n      const box=document.querySelector('.vdG-index');\n      const btn=(ch)=>{const b=document.createElement('button');b.textContent=ch;b.setAttribute('data-letter',ch);b.setAttribute('aria-pressed','false');return b};\n      letters.forEach(l=>box.appendChild(btn(l)));\n    })();\n\n    // Search / filter\n    (function(){\n      const cards=[...document.querySelectorAll('.sp-card')];\n      const q=document.getElementById('q');\n      const letters=[...document.querySelectorAll('.vdG-index button')];\n      const tags=[...document.querySelectorAll('.tag')];\n      let activeLetter=''; let activeTag='all';\n\n      const apply=()=>{\n        const term=(q.value||'').trim().toLowerCase();\n        cards.forEach(c=>{\n          const name=c.dataset.name.toLowerCase();\n          const tags=c.dataset.tags||'';\n          const letter=c.dataset.letter||'';\n          const matchTerm=!term||name.includes(term);\n          const matchLetter=!activeLetter||letter===activeLetter;\n          const matchTag=activeTag==='all'||tags.includes(activeTag);\n          c.style.display=(matchTerm&&matchLetter&&matchTag)?'':'none';\n        });\n      };\n\n      q.addEventListener('input',apply);\n\n      letters.forEach(b=>b.addEventListener('click',()=>{\n        const on=b.getAttribute('aria-pressed')==='true';\n        letters.forEach(x=>x.setAttribute('aria-pressed','false'));\n        activeLetter= on ? '' : b.dataset.letter;\n        if(!on) b.setAttribute('aria-pressed','true');\n        apply();\n      }));\n\n      tags.forEach(t=>t.addEventListener('click',()=>{\n        const tag=t.dataset.tag;\n        tags.forEach(x=>x.setAttribute('aria-pressed', x===t ? 'true':'false'));\n        activeTag=tag; apply();\n      }));\n\n      apply();\n    })();\n\n    // Hover halo\n    window.vdHalo=function(e,el){\n      const r=el.getBoundingClientRect();\n      el.style.setProperty('--mx', ((e.clientX-r.left)/r.width*100).toFixed(1)+'%');\n      el.style.setProperty('--my', ((e.clientY-r.top)/r.height*100).toFixed(1)+'%');\n    }\n  </script>\n</section>",
            "width": "100%",
            "alignment": "center"
          }
        }
