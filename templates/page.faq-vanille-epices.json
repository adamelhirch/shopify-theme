        "liquid_BVbLEV": {
          "type": "liquid",
          "settings": {
            "code": "<!-- VANILLE DÉSIRÉ — WIKI : FAQ (v1 maxi) -->\n<section class=\"vdF-root\" aria-label=\"Wiki — Foire aux questions\">\n  <style>\n    .vdF-root{\n      --ink:#171511;--sub:#3d3a34;--muted:#6c695f;--line:rgba(0,0,0,.08);\n      --paper:#fff;--bg:#fbf6ee;--cream:#f6efe6;--accent:#FFB766;--accent2:#FFD09A;--leaf:#87a36a;\n      --shadow:rgba(13,10,8,.10);--r:24px;--w:clamp(980px,92vw,1280px);\n      --h1:clamp(44px,7vw,86px);--h2:clamp(26px,4.4vw,52px);--lead:clamp(18px,2.2vw,22px);\n      color:var(--ink);background:linear-gradient(180deg,var(--paper),var(--bg) 48%,var(--cream));\n      border-radius:34px;box-shadow:0 30px 80px var(--shadow);isolation:isolate;overflow:hidden}\n    .vdF-root *{box-sizing:border-box}\n    .vdF-container{max-width:var(--w);margin-inline:auto;padding-inline:clamp(16px,2.2vw,28px)}\n\n    /* NAV */\n    .vdF-nav{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.85);backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--line)}\n    .vdF-nav .vdF-container{display:flex;align-items:center;justify-content:space-between;padding-block:10px}\n    .vdF-brand{display:flex;align-items:center;gap:10px}\n    .vdF-logo{width:26px;height:26px;border-radius:8px;background:conic-gradient(from 12deg,#ffd7a3,#fff 40%,#ffc17a);box-shadow:inset 0 0 0 1px var(--line)}\n    .vdF-brand b{font-size:14px}\n    .vdF-nav a{color:var(--ink);text-decoration:none;font-size:14px;padding:.5rem .7rem;border-radius:10px}\n    .vdF-nav a:hover{background:rgba(0,0,0,.04)}\n\n    /* HERO */\n    .vdF-hero .vdF-container{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(16px,4vw,48px);align-items:end;padding-block:clamp(28px,7vw,88px)}\n    .vdF-kicker{letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600;font-size:12px}\n    .vdF-hero h1{font-size:var(--h1);line-height:1.06;letter-spacing:-.02em;margin:.2rem 0 1rem}\n    .vdF-hero h1 .hl{background:linear-gradient(90deg,var(--accent),var(--accent2));padding:.06em .20em;border-radius:.35em;box-decoration-break:clone}\n    .vdF-hero p{font-size:var(--lead);color:var(--sub);max-width:64ch}\n    .vdF-cta{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}\n    .chip{display:inline-flex;align-items:center;gap:6px;padding:.45rem .7rem;border:1px solid var(--line);border-radius:999px;background:#fff;font-size:12px;text-decoration:none;color:var(--ink)}\n    .chip:hover{background:linear-gradient(180deg,#fff,#ffe8c9)}\n    .chip .ext{font-size:10px;opacity:.7}\n\n    /* WRAP layout */\n    .vdF-wrap{display:grid;grid-template-columns:260px 1fr;gap:clamp(14px,2.4vw,22px);align-items:start}\n    .vdF-side{position:sticky;top:76px;align-self:start}\n    .vdF-search{border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 12px;display:flex;gap:8px;align-items:center}\n    .vdF-search input{border:none;outline:none;flex:1;min-width:0}\n    .vdF-filters{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}\n    .tag{border:1px solid var(--line);border-radius:999px;padding:.35rem .6rem;font-size:11px;background:#fff;cursor:pointer}\n    .tag[aria-pressed=\"true\"]{background:linear-gradient(180deg,#fff,#f7efe5)}\n    .vdF-tools{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}\n    .toolbtn{border:1px solid var(--line);border-radius:10px;background:#fff;padding:.45rem .6rem;font-size:12px;cursor:pointer}\n\n    /* FAQ groups */\n    .vdF-sec{padding-block:clamp(24px,5.6vw,70px)}\n    .vdF-sec h2{font-size:var(--h2);margin:0 0 10px}\n    .vdF-note{color:var(--muted);font-size:13px;margin-top:-4px;margin-bottom:10px}\n    .faq-grid{display:grid;grid-template-columns:1fr;gap:10px}\n    details.faq{position:relative;border:1px solid var(--line);border-radius:16px;background:#fff;box-shadow:0 12px 30px var(--shadow);overflow:hidden}\n    summary{list-style:none;cursor:pointer;padding:14px 46px 14px 14px;display:flex;gap:10px;align-items:center}\n    summary::-webkit-details-marker{display:none}\n    .q{font-weight:700}\n    .badge{font-size:11px;border:1px solid var(--line);border-radius:8px;padding:.18rem .45rem;background:linear-gradient(180deg,#fff,#f7efe5);color:var(--muted)}\n    .ans{padding:0 14px 14px;color:var(--sub);font-size:14px}\n    .copylink{position:absolute;right:8px;top:8px;border:1px solid var(--line);border-radius:10px;background:#fff;font-size:12px;padding:.25rem .45rem;cursor:pointer}\n    .bar{height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));opacity:.7}\n\n    /* highlight */\n    mark{background:#ffe2bf;padding:0 .15em;border-radius:4px}\n\n    /* Reveal */\n    .reveal{opacity:0;transform:translateY(22px);transition:opacity .55s cubic-bezier(.2,.8,.2,1), transform .55s cubic-bezier(.2,.8,.2,1)}\n    .reveal.in{opacity:1;transform:none}\n\n    @media (max-width:1080px){.vdF-wrap{grid-template-columns:1fr}}\n  </style>\n\n  <!-- NAV -->\n  <nav class=\"vdF-nav\" aria-label=\"Navigation FAQ\">\n    <div class=\"vdF-container\">\n      <div class=\"vdF-brand\"><span class=\"vdF-logo\" aria-hidden=\"true\"></span><b>FAQ — Vanille Désiré</b></div>\n      <div class=\"vdF-links\">\n        <a href=\"/pages/wiki-bienfaits-usages\">Bienfaits & Usages</a>\n        <a href=\"/pages/wiki-savoir-faire-producteurs\">Savoir-faire</a>\n        <a href=\"/collections/all\">Catalogue</a>\n        <a href=\"/blogs/recettes\">Nos recettes</a>\n      </div>\n    </div>\n  </nav>\n\n  <!-- HERO -->\n  <header class=\"vdF-hero\">\n    <div class=\"vdF-container\">\n      <div>\n        <div class=\"vdF-kicker\">Clair • Complet • Actionnable</div>\n        <h1>La <span class=\"hl\">FAQ</span> qui répond avant que vous ne posiez la question.</h1>\n        <p class=\"reveal\">Recherche instantanée, filtres par thèmes, liens directs vers les pages du wiki et les collections produits. Si vous ne trouvez pas, <a href=\"/pages/contact\">écrivez-nous</a> — on répond vite.</p>\n        <div class=\"vdF-cta\">\n          <a class=\"chip\" href=\"/collections/vanille-bourbon\">Acheter la vanille</a>\n          <a class=\"chip\" href=\"/collections/poivres-baies-de-madagascar\">Poivres & baies</a>\n          <a class=\"chip\" href=\"/collections/epices-madagascar\">Épices & combava</a>\n          <a class=\"chip\" href=\"/collections/huiles-essentielles\">Huiles essentielles</a>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <!-- WRAP -->\n  <div class=\"vdF-container vdF-wrap\">\n    <!-- Sidebar -->\n    <aside class=\"vdF-side\" aria-label=\"Filtres & outils FAQ\">\n      <div class=\"vdF-search\">\n        <span aria-hidden=\"true\">🔎</span>\n        <input id=\"faq-q\" type=\"search\" placeholder=\"Rechercher (ex : DLUO, livraison, vanille…)\" aria-label=\"Rechercher une question\">\n      </div>\n      <div class=\"vdF-filters\" role=\"tablist\" aria-label=\"Thèmes FAQ\">\n        <button class=\"tag\" data-cat=\"all\" aria-pressed=\"true\">Tout</button>\n        <button class=\"tag\" data-cat=\"produits\">Produits & qualité</button>\n        <button class=\"tag\" data-cat=\"usages\">Usages & conservation</button>\n        <button class=\"tag\" data-cat=\"commande\">Commande & livraison</button>\n        <button class=\"tag\" data-cat=\"pro\">Pro / B2B</button>\n        <button class=\"tag\" data-cat=\"ethique\">Traçabilité & éthique</button>\n        <button class=\"tag\" data-cat=\"sav\">SAV & retours</button>\n      </div>\n      <div class=\"vdF-tools\" aria-label=\"Outils\">\n        <button class=\"toolbtn\" id=\"openAll\">Tout ouvrir</button>\n        <button class=\"toolbtn\" id=\"closeAll\">Tout fermer</button>\n        <button class=\"toolbtn\" id=\"clearSearch\">Effacer recherche</button>\n      </div>\n      <p class=\"vdF-note\">Astuce : cliquez sur 🔗 pour copier un lien direct vers une question.</p>\n    </aside>\n\n    <!-- Main -->\n    <main>\n      <!-- GROUPE : Produits & qualité -->\n      <section class=\"vdF-sec reveal\" data-group=\"produits\">\n        <h2>Produits & qualité</h2>\n        <p class=\"vdF-note\">Origine, grades, lots, humidité, différences entre produits…</p>\n        <div class=\"faq-grid\">\n          <details class=\"faq\" id=\"q-origine\" data-cat=\"produits\">\n            <summary><span class=\"q\">D’où proviennent vos produits&nbsp;?</span> <span class=\"badge\">Origine</span> <button class=\"copylink\" data-anchor=\"#q-origine\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Nos épices, poivres et vanille proviennent <b>directement de Madagascar</b> via des producteurs familiaux avec lesquels nous travaillons sans intermédiaire. Pour comprendre notre chaîne courte et les contrôles qualité, voir <a href=\"/pages/wiki-savoir-faire-producteurs\">Savoir-faire & Producteurs</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-vanille-bourbon\" data-cat=\"produits\">\n            <summary><span class=\"q\">C’est quoi la “Vanille Bourbon”&nbsp;?</span> <span class=\"badge\">Vanille</span> <button class=\"copylink\" data-anchor=\"#q-vanille-bourbon\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">“Bourbon” désigne l’aire historique de l’océan Indien. Chez nous&nbsp;: Vanille <b>planifolia</b>, lots tracés, séchage soigné et affinage patient. Pour les usages et dosages, rendez-vous sur <a href=\"/pages/wiki-bienfaits-usages\">Bienfaits & Usages</a> et <a href=\"/pages/wiki-recettes\">Blueprints & Bases</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-grades-vanille\" data-cat=\"produits\">\n            <summary><span class=\"q\">Différence entre gousses “gourmet” et “extraction”&nbsp;?</span> <span class=\"badge\">Vanille</span> <button class=\"copylink\" data-anchor=\"#q-grades-vanille\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\"><b>Gourmet</b>: gousses souples, huileuses, souvent plus longues, idéales infusion/pâtisserie.<br><b>Extraction</b>: plus sèches/irrégulières, parfaites pour poudre, sirop et macérations. Nous indiquons <b>lot, calibre, humidité</b> sur l’étiquette.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-humidite\" data-cat=\"produits\">\n            <summary><span class=\"q\">Pourquoi parle-t-on du “taux d’humidité”&nbsp;?</span> <span class=\"badge\">Qualité</span> <button class=\"copylink\" data-anchor=\"#q-humidite\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">L’humidité influe sur la <b>texture</b>, la <b>stabilité</b> et la <b>concentration aromatique</b>. Un lot cohérent permet une reproductibilité en cuisine. Nous contrôlons chaque réception et traçons les résultats par lot.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-givre\" data-cat=\"produits\">\n            <summary><span class=\"q\">J’observe un “givre” blanc sur la vanille, normal&nbsp;?</span> <span class=\"badge\">Vanille</span> <button class=\"copylink\" data-anchor=\"#q-givre\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Oui — il s’agit souvent de <b>cristaux de vanilline</b> naturellement exsudés lors de l’affinage. C’est un bon signe, sans impact négatif. Essuyez délicatement et utilisez normalement.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-voatsi-vs-noir\" data-cat=\"produits\">\n            <summary><span class=\"q\">Poivre sauvage (voatsiperifery) vs poivre noir&nbsp;?</span> <span class=\"badge\">Poivres</span> <button class=\"copylink\" data-anchor=\"#q-voatsi-vs-noir\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\"><b>Voatsiperifery</b>: boisé, agrume vert, résine — superbe sur sauces crème et chocolat.<br><b>Noir</b>: structure et chaleur — marinades, viandes, légumes rôtis. Voir <a href=\"/pages/wiki-poivre-sauvage-voatsiperifery\">wiki voatsiperifery</a> et <a href=\"/pages/wiki-poivre-noir-madagascar\">wiki poivre noir</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-baies-roses\" data-cat=\"produits\">\n            <summary><span class=\"q\">Les baies roses, c’est un “poivre”&nbsp;?</span> <span class=\"badge\">Baies</span> <button class=\"copylink\" data-anchor=\"#q-baies-roses\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">On les classe parmi les “poivres & baies”, mais ce n’est pas du <i>Piper</i>. Profil <b>floral/suave</b>, top sur fruits, poissons gras, fromages frais. <a href=\"/pages/wiki-baies-roses-madagascar\">En savoir plus</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-combava-formes\" data-cat=\"produits\">\n            <summary><span class=\"q\">Combava : différence zeste, poudre et feuilles&nbsp;?</span> <span class=\"badge\">Agrume</span> <button class=\"copylink\" data-anchor=\"#q-combava-formes\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\"><b>Zeste/poudre</b>: très puissants, desserts & sirops (micro-dosage).<br><b>Feuilles</b>: plus herbacées, currys au lait de coco. Voir <a href=\"/pages/wiki-epice-combava-madagascar\">wiki combava</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-he-usage\" data-cat=\"produits\">\n            <summary><span class=\"q\">Vos huiles essentielles sont-elles alimentaires&nbsp;?</span> <span class=\"badge\">HE</span> <button class=\"copylink\" data-anchor=\"#q-he-usage\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\"><b>Non</b>. Nous communiquons des <b>usages aromatiques/cosmétiques externes</b> uniquement (diffusion légère, dilution dans huile végétale). Toujours diluer, test cutané, éviter zones sensibles. Voir <a href=\"/pages/wiki-bienfaits-sante\">section HE</a>.</div>\n          </details>\n        </div>\n      </section>\n\n      <!-- GROUPE : Usages & conservation -->\n      <section class=\"vdF-sec reveal\" data-group=\"usages\">\n        <h2>Usages & conservation</h2>\n        <p class=\"vdF-note\">Dosages repères, méthodes, stockage, DLUO…</p>\n        <div class=\"faq-grid\">\n          <details class=\"faq\" id=\"q-dosage-vanille\" data-cat=\"usages\">\n            <summary><span class=\"q\">Dosage vanille (gousse/poudre/extrait) — repères&nbsp;?</span> <span class=\"badge\">Dosage</span> <button class=\"copylink\" data-anchor=\"#q-dosage-vanille\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Repères usuels&nbsp;: <b>gousse</b> 1–2/L (crèmes & glaces), <b>poudre</b> 4–6 g/L (≈1 c.à c.), <b>extrait</b> 1–2 c.à c./L. Détails et variantes sur <a href=\"/pages/wiki-bienfaits-sante\">Repères de dosage</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-infusions\" data-cat=\"usages\">\n            <summary><span class=\"q\">Infuser correctement la vanille&nbsp;?</span> <span class=\"badge\">Technique</span> <button class=\"copylink\" data-anchor=\"#q-infusions\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Fendre la gousse, 80–85 °C, <b>30–45 min couvert</b>, filtrage fin. Pour sirop, base 1 L eau + 800 g sucre + 1–2 gousses (repos 24 h). Voir <a href=\"/pages/wiki-recettes#blueprints\">blueprints</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-dosage-poivres\" data-cat=\"usages\">\n            <summary><span class=\"q\">Dosage rapide poivres & baies&nbsp;?</span> <span class=\"badge\">Poivres</span> <button class=\"copylink\" data-anchor=\"#q-dosage-poivres\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\"><b>Voatsiperifery</b> 1–2 g/L (fin de cuisson) • <b>Noir</b> 3–6 g/L (cuisson) • <b>Baies roses</b> au goût (au service, écrasées). Plus d’idées dans <a href=\"/pages/wiki-bienfaits-sante\">Usages culinaires</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-conservation\" data-cat=\"usages\">\n            <summary><span class=\"q\">Comment conserver épices & vanille&nbsp;?</span> <span class=\"badge\">Conservation</span> <button class=\"copylink\" data-anchor=\"#q-conservation\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Pot <b>hermétique</b>, à l’abri de la lumière/chaleur (15–20 °C). Éviter frigo/congélation (condensation). Aérer brièvement les gousses de vanille si nécessaire (quelques minutes, 1×/mois).</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-duree\" data-cat=\"usages\">\n            <summary><span class=\"q\">DLUO/DLC : combien de temps ça se garde&nbsp;?</span> <span class=\"badge\">DLUO</span> <button class=\"copylink\" data-anchor=\"#q-duree\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Les épices sont à <b>DLUO</b> (qualité optimale). Utilisées après, elles ne sont pas “périmées” mais peuvent perdre en intensité. La vanille se garde longtemps si bien stockée. Référez-vous à l’étiquette (lot + DLUO).</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-maceration\" data-cat=\"usages\">\n            <summary><span class=\"q\">Macération alcoolique de vanille — bases&nbsp;?</span> <span class=\"badge\">Technique</span> <button class=\"copylink\" data-anchor=\"#q-maceration\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Repère&nbsp;: ~<b>30 g gousses/L</b> d’alcool 35–45°, <b>6–8 semaines</b> avec agitation 1–2×/semaine, puis filtrage fin. Détails sur <a href=\"/pages/wiki-bienfaits-sante\">Infusions & macérations</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-he-dilution\" data-cat=\"usages\">\n            <summary><span class=\"q\">Dilution huiles essentielles (usage externe)&nbsp;?</span> <span class=\"badge\">HE</span> <button class=\"copylink\" data-anchor=\"#q-he-dilution\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Diffusion&nbsp;: 5–8 gouttes/100 mL (20–30 min). Cosmétique&nbsp;: ≤ 1 % dans une <b>huile végétale</b>. Test cutané préalable. Voir <a href=\"/pages/wiki-bienfaits-sante\">guide HE</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-mouture\" data-cat=\"usages\">\n            <summary><span class=\"q\">Moudre ou concasser&nbsp;? Et quand assaisonner&nbsp;?</span> <span class=\"badge\">Technique</span> <button class=\"copylink\" data-anchor=\"#q-mouture\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">La mouture <b>au service</b> préserve les notes volatiles (voatsiperifery, baies roses). En cuisson longue, préférer des grains plus gros puis rectifier au service.</div>\n          </details>\n        </div>\n      </section>\n\n      <!-- GROUPE : Commande & livraison -->\n      <section class=\"vdF-sec reveal\" data-group=\"commande\">\n        <h2>Commande & livraison</h2>\n        <p class=\"vdF-note\">Zones desservies, délais, frais, suivi…</p>\n        <div class=\"faq-grid\">\n          <details class=\"faq\" id=\"q-zones\" data-cat=\"commande\">\n            <summary><span class=\"q\">Quelles zones de livraison&nbsp;?</span> <span class=\"badge\">Livraison</span> <button class=\"copylink\" data-anchor=\"#q-zones\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Nous expédions en <b>France métropolitaine</b> et, selon options affichées au checkout, vers certains pays de l’UE. Les modes/ tarifs disponibles s’affichent automatiquement selon votre adresse.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-delais\" data-cat=\"commande\">\n            <summary><span class=\"q\">Délais d’expédition et de livraison&nbsp;?</span> <span class=\"badge\">Délais</span> <button class=\"copylink\" data-anchor=\"#q-delais\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Préparation rapide (jours ouvrés). Les délais transporteur varient selon le mode choisi. Un e-mail de <b>suivi</b> est envoyé à l’expédition.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-frais\" data-cat=\"commande\">\n            <summary><span class=\"q\">Frais de port&nbsp;? Offres de franco&nbsp;?</span> <span class=\"badge\">Frais</span> <button class=\"copylink\" data-anchor=\"#q-frais\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Les frais sont calculés au panier selon poids, mode et destination. Les éventuels paliers de <b>franco</b> sont indiqués lors du checkout s’ils s’appliquent.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-suivi\" data-cat=\"commande\">\n            <summary><span class=\"q\">Comment suivre mon colis&nbsp;?</span> <span class=\"badge\">Suivi</span> <button class=\"copylink\" data-anchor=\"#q-suivi\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Dès l’expédition, vous recevez un lien de suivi. Problème de scan ou retard&nbsp;? Contactez-nous via <a href=\"/pages/contact\">le formulaire</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-cadeau\" data-cat=\"commande\">\n            <summary><span class=\"q\">Puis-je envoyer un cadeau ou un message personnalisé&nbsp;?</span> <span class=\"badge\">Cadeau</span> <button class=\"copylink\" data-anchor=\"#q-cadeau\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Oui, vous pouvez indiquer une adresse différente et ajouter un message (si l’option s’affiche à la caisse). Nous évitons d’inclure les prix dans les colis cadeau.</div>\n          </details>\n        </div>\n      </section>\n\n      <!-- GROUPE : Pro / B2B -->\n      <section class=\"vdF-sec reveal\" data-group=\"pro\">\n        <h2>Pro / B2B</h2>\n        <p class=\"vdF-note\">Devis, tarifs dégressifs, échantillons, traçabilité, MDD…</p>\n        <div class=\"faq-grid\">\n          <details class=\"faq\" id=\"q-pro-devis\" data-cat=\"pro\">\n            <summary><span class=\"q\">Comment obtenir un tarif pro ou un devis&nbsp;?</span> <span class=\"badge\">Pro</span> <button class=\"copylink\" data-anchor=\"#q-pro-devis\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Écrivez-nous via <a href=\"/pages/contact\">contact</a> en précisant volumes, références et fréquence. Nous revenons avec une proposition (<b>lots tracés</b>, prix nets, délais).</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-echantillons\" data-cat=\"pro\">\n            <summary><span class=\"q\">Proposez-vous des échantillons&nbsp;?</span> <span class=\"badge\">Pro</span> <button class=\"copylink\" data-anchor=\"#q-echantillons\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Oui, selon les références et disponibilités des lots. Frais symboliques/port possibles, déduits d’une commande pro validée.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-traca-docs\" data-cat=\"pro\">\n            <summary><span class=\"q\">Quelles pièces fournissez-vous aux pros&nbsp;?</span> <span class=\"badge\">Docs</span> <button class=\"copylink\" data-anchor=\"#q-traca-docs\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\"><b>Traçabilité lot</b>, étiquetage clair (origine, séchage, humidité), et sur demande&nbsp;: fiches techniques, attestations, MSDS pour HE.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-mdd\" data-cat=\"pro\">\n            <summary><span class=\"q\">Faites-vous de la marque blanche (MDD) ou des mélanges sur mesure&nbsp;?</span> <span class=\"badge\">MDD</span> <button class=\"copylink\" data-anchor=\"#q-mdd\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Oui, <b>au cas par cas</b> : cahier des charges simple, sélection de lots, tests d’assemblage, étiquettes. Parlons-en via <a href=\"/pages/contact\">contact</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-tva\" data-cat=\"pro\">\n            <summary><span class=\"q\">TVA intracommunautaire et facturation&nbsp;?</span> <span class=\"badge\">TVA</span> <button class=\"copylink\" data-anchor=\"#q-tva\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Nous émettons des <b>factures détaillées</b>. Pour les sociétés éligibles, la TVA intracom peut s’appliquer selon la réglementation en vigueur.</div>\n          </details>\n        </div>\n      </section>\n\n      <!-- GROUPE : Traçabilité & éthique -->\n      <section class=\"vdF-sec reveal\" data-group=\"ethique\">\n        <h2>Traçabilité & éthique</h2>\n        <p class=\"vdF-note\">Lots, prix justes, saisonnalité, transparence…</p>\n        <div class=\"faq-grid\">\n          <details class=\"faq\" id=\"q-tracabilite\" data-cat=\"ethique\">\n            <summary><span class=\"q\">Comment assurez-vous la traçabilité des lots&nbsp;?</span> <span class=\"badge\">Traçabilité</span> <button class=\"copylink\" data-anchor=\"#q-tracabilite\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Chaque lot a sa <b>carte d’identité</b> (origine, méthode, humidité). Nous gardons les infos de réception et contrôles pour un <b>suivi simple</b>. Voir <a href=\"/pages/wiki-savoir-faire-producteurs\">notre méthode</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-prix\" data-cat=\"ethique\">\n            <summary><span class=\"q\">Pourquoi vos prix sont-ils compétitifs&nbsp;?</span> <span class=\"badge\">Prix justes</span> <button class=\"copylink\" data-anchor=\"#q-prix\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Appro <b>direct Madagascar</b>, chaîne courte, peu d’intermédiaires, et logistique simple. Cela permet de rémunérer correctement les producteurs tout en gardant des prix nets.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-saisons\" data-cat=\"ethique\">\n            <summary><span class=\"q\">La saveur peut-elle varier d’un lot à l’autre&nbsp;?</span> <span class=\"badge\">Saisons</span> <button class=\"copylink\" data-anchor=\"#q-saisons\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Oui, comme pour le café ou le vin. Nous visons la <b>cohérence</b> par nos contrôles, mais assumons la part de <b>vintage</b> des produits vivants.</div>\n          </details>\n        </div>\n      </section>\n\n      <!-- GROUPE : SAV & retours -->\n      <section class=\"vdF-sec reveal\" data-group=\"sav\">\n        <h2>SAV & retours</h2>\n        <p class=\"vdF-note\">Rétractation, colis endommagé, erreur de référence…</p>\n        <div class=\"faq-grid\">\n          <details class=\"faq\" id=\"q-retractation\" data-cat=\"sav\">\n            <summary><span class=\"q\">Puis-je retourner ma commande&nbsp;?</span> <span class=\"badge\">Retours</span> <button class=\"copylink\" data-anchor=\"#q-retractation\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Vous disposez du <b>droit de rétractation</b> légal (produits non ouverts, dans leur état d’origine). Les modalités précises figurent dans nos CGV. Écrivez-nous via <a href=\"/pages/contact\">contact</a>.</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-casse\" data-cat=\"sav\">\n            <summary><span class=\"q\">Colis endommagé / produit manquant&nbsp;?</span> <span class=\"badge\">SAV</span> <button class=\"copylink\" data-anchor=\"#q-casse\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Prenez des <b>photos</b> du colis et des produits, gardez l’emballage et contactez-nous. On s’occupe de la suite (réexpédition, remboursement selon cas).</div>\n          </details>\n\n          <details class=\"faq\" id=\"q-erreur-ref\" data-cat=\"sav\">\n            <summary><span class=\"q\">Erreur de référence reçue, que faire&nbsp;?</span> <span class=\"badge\">SAV</span> <button class=\"copylink\" data-anchor=\"#q-erreur-ref\">🔗</button></summary>\n            <div class=\"bar\"></div>\n            <div class=\"ans\">Dites-nous le <b>numéro de commande</b> et la référence manquante/reçue via <a href=\"/pages/contact\">contact</a>. Nous corrigeons rapidement.</div>\n          </details>\n        </div>\n      </section>\n\n      <!-- GROUPE : Plus de questions rapides -->\n      <section class=\"vdF-sec reveal\" data-group=\"extra\">\n        <h2>Questions rapides (encore plus)</h2>\n        <p class=\"vdF-note\">Tout ce qu’on nous pose souvent, en vrac.</p>\n        <div class=\"faq-grid\">\n          <!-- 16+ quick Q/A -->\n          <details class=\"faq\" id=\"q-poudre-vanille\" data-cat=\"produits\"><summary><span class=\"q\">Votre poudre de vanille contient-elle du sucre&nbsp;?</span> <span class=\"badge\">Vanille</span> <button class=\"copylink\" data-anchor=\"#q-poudre-vanille\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Non si mention “pure”. Nous proposons aussi du <b>sucre vanillé</b> (mélange indiqué clairement).</div></details>\n          <details class=\"faq\" id=\"q-extrait-vanille\" data-cat=\"usages\"><summary><span class=\"q\">Extrait vs gousse : quand utiliser l’un ou l’autre&nbsp;?</span> <span class=\"badge\">Vanille</span> <button class=\"copylink\" data-anchor=\"#q-extrait-vanille\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\"><b>Gousse</b>: infusion longue, pâtisserie/glace. <b>Extrait</b>: ajout en fin (sirop, crème fouettée, renfort aromatique rapide).</div></details>\n          <details class=\"faq\" id=\"q-epices-bio\" data-cat=\"ethique\"><summary><span class=\"q\">Avez-vous du bio&nbsp;?</span> <span class=\"badge\">Labels</span> <button class=\"copylink\" data-anchor=\"#q-epices-bio\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Selon lots/références. Nous privilégions la <b>traçabilité réelle</b> et la qualité organoleptique. Les mentions figurent sur les fiches produit lorsqu’applicables.</div></details>\n          <details class=\"faq\" id=\"q-fds-he\" data-cat=\"pro\"><summary><span class=\"q\">Fournissez-vous des FDS (HE) et fiches techniques&nbsp;?</span> <span class=\"badge\">Docs</span> <button class=\"copylink\" data-anchor=\"#q-fds-he\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Oui sur demande pour nos <b>huiles essentielles</b> (Ylang Ylang, Ravintsara). Écrivez-nous.</div></details>\n          <details class=\"faq\" id=\"q-stock\" data-cat=\"commande\"><summary><span class=\"q\">Un produit est en rupture. Quand revient-il&nbsp;?</span> <span class=\"badge\">Stock</span> <button class=\"copylink\" data-anchor=\"#q-stock\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Saisonnalité oblige. Activez l’alerte quand elle est disponible ou contactez-nous pour un <b>lot alternatif</b>.</div></details>\n          <details class=\"faq\" id=\"q-cafe-chocolat\" data-cat=\"usages\"><summary><span class=\"q\">Accords café & chocolat : quelles épices&nbsp;?</span> <span class=\"badge\">Accords</span> <button class=\"copylink\" data-anchor=\"#q-cafe-chocolat\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Vanille, <b>voatsiperifery</b> moulu au service, baies roses (fruits/chocolats blancs). Voir <a href=\"/pages/wiki-bienfaits-sante\">exemples</a>.</div></details>\n          <details class=\"faq\" id=\"q-marinade\" data-cat=\"usages\"><summary><span class=\"q\">Une marinade simple pour volaille/poisson&nbsp;?</span> <span class=\"badge\">Astuce</span> <button class=\"copylink\" data-anchor=\"#q-marinade\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Au litre&nbsp;: 700 g eau + 300 g yaourt, 10 g sel, 6–8 g poivre noir, 2–3 g baies roses. 2–4 h. Détails dans <a href=\"/pages/wiki-recettes#blueprints\">blueprints</a>.</div></details>\n          <details class=\"faq\" id=\"q-piment\" data-cat=\"usages\"><summary><span class=\"q\">Piment pili-pili : à quel moment l’ajouter&nbsp;?</span> <span class=\"badge\">Piment</span> <button class=\"copylink\" data-anchor=\"#q-piment\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">En début : plus de chaleur diffuse. Au service : piquant plus vif. Testez progressivement.</div></details>\n          <details class=\"faq\" id=\"q-gluten\" data-cat=\"ethique\"><summary><span class=\"q\">Vos épices contiennent-elles du gluten&nbsp;?</span> <span class=\"badge\">Allergènes</span> <button class=\"copylink\" data-anchor=\"#q-gluten\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Les épices brutes n’en contiennent pas naturellement. Nous ne revendiquons toutefois pas de statut “sans allergène” strict : évitez si contrainte médicale stricte et contactez-nous pour en parler.</div></details>\n          <details class=\"faq\" id=\"q-sucre-vanille\" data-cat=\"usages\"><summary><span class=\"q\">Faire un sucre vanillé maison&nbsp;?</span> <span class=\"badge\">DIY</span> <button class=\"copylink\" data-anchor=\"#q-sucre-vanille\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Mélangez sucre blanc + <b>poudre de vanille</b> ou caviar. Repère 10–20 % de vanille, pot hermétique 1–2 semaines, secouez.</div></details>\n          <details class=\"faq\" id=\"q-stockage-pro\" data-cat=\"pro\"><summary><span class=\"q\">Stockage en labo/boutique : conseils&nbsp;?</span> <span class=\"badge\">Pro</span> <button class=\"copylink\" data-anchor=\"#q-stockage-pro\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Rotation par lot (FIFO), zones sèches/opaques, recharges en <b>petits contenants</b> pour limiter l’air. Étiquetage lot/DLUO visible.</div></details>\n          <details class=\"faq\" id=\"q-salons\" data-cat=\"commande\"><summary><span class=\"q\">Vous participez à des salons/foires&nbsp;?</span> <span class=\"badge\">Événements</span> <button class=\"copylink\" data-anchor=\"#q-salons\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Oui ponctuellement. Nous l’annonçons sur le site et nos réseaux. Vous pouvez acheter sur place selon le stock.</div></details>\n          <details class=\"faq\" id=\"q-contact\" data-cat=\"sav\"><summary><span class=\"q\">Comment vous contacter rapidement&nbsp;?</span> <span class=\"badge\">Contact</span> <button class=\"copylink\" data-anchor=\"#q-contact\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Le plus simple&nbsp;: <a href=\"/pages/contact\">formulaire de contact</a>. Donnez votre n° de commande pour un traitement express.</div></details>\n          <details class=\"faq\" id=\"q-courbes\" data-cat=\"usages\"><summary><span class=\"q\">Mes plats “verdisent” à la vanille, pourquoi&nbsp;?</span> <span class=\"badge\">Astuce</span> <button class=\"copylink\" data-anchor=\"#q-courbes\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Souvent <b>surdosage</b> de poudre ou infusion trop longue/chaude. Revenez aux repères et filtrez fin.</div></details>\n          <details class=\"faq\" id=\"q-packaging\" data-cat=\"produits\"><summary><span class=\"q\">Pourquoi certains pots sont-ils sous vide&nbsp;?</span> <span class=\"badge\">Emballage</span> <button class=\"copylink\" data-anchor=\"#q-packaging\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Pour stabiliser parfum et humidité sur certaines références. Ouvrez, aérer 1–2 min, refermez hermétiquement.</div></details>\n          <details class=\"faq\" id=\"q-cout\" data-cat=\"pro\"><summary><span class=\"q\">Dégressifs et remises volume&nbsp;?</span> <span class=\"badge\">Pro</span> <button class=\"copylink\" data-anchor=\"#q-cout\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Oui selon seuils/conditionnements. Dites-nous vos volumes et fréquences via <a href=\"/pages/contact\">contact</a>.</div></details>\n          <details class=\"faq\" id=\"q-atelier\" data-cat=\"commande\"><summary><span class=\"q\">Avez-vous une boutique physique&nbsp;?</span> <span class=\"badge\">Point de vente</span> <button class=\"copylink\" data-anchor=\"#q-atelier\">🔗</button></summary><div class=\"bar\"></div><div class=\"ans\">Nous concentrons l’activité sur la vente en ligne et les événements. Suivez nos annonces pour les ventes physiques ponctuelles.</div></details>\n        </div>\n      </section>\n    </main>\n  </div>\n\n  <!-- FOOTER court -->\n  <footer class=\"vdF-sec\" style=\"padding-top:0;border-top:1px solid var(--line);background:#fff\">\n    <div class=\"vdF-container\" style=\"display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--muted);padding-block:14px\">\n      <span>© Vanille Désiré — FAQ</span>\n      <span>Traçabilité • Simplicité • Réactivité</span>\n    </div>\n  </footer>\n\n  <!-- JSON-LD : SEO FAQ (sélection des Q clés) -->\n  <script type=\"application/ld+json\">\n  {\n    \"@context\":\"https://schema.org\",\n    \"@type\":\"FAQPage\",\n    \"mainEntity\":[\n      {\"@type\":\"Question\",\"name\":\"D’où proviennent vos produits ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Directement de Madagascar via des producteurs familiaux, sans intermédiaire. Lots tracés et contrôlés.\"}},\n      {\"@type\":\"Question\",\"name\":\"C’est quoi la “Vanille Bourbon” ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Appellation d’aire historique de l’océan Indien (planifolia). Lots tracés, séchage/affinage soignés.\"}},\n      {\"@type\":\"Question\",\"name\":\"Différence entre gousses gourmet et extraction ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Gourmet : souples/huileuses pour infusion. Extraction : plus sèches/irrégulières pour poudre, sirops, macérations.\"}},\n      {\"@type\":\"Question\",\"name\":\"Comment infuser correctement la vanille ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Fendre la gousse, 80–85 °C, 30–45 min couvert, filtrage fin.\"}},\n      {\"@type\":\"Question\",\"name\":\"Comment conserver épices & vanille ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pots hermétiques, à l’abri lumière/chaleur (15–20 °C). Éviter frigo/congélation.\"}},\n      {\"@type\":\"Question\",\"name\":\"Vos huiles essentielles sont-elles alimentaires ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Usages aromatiques/cosmétiques externes uniquement, toujours diluer et réaliser un test cutané.\"}},\n      {\"@type\":\"Question\",\"name\":\"Quelles zones de livraison ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"France métropolitaine et, selon options au checkout, certains pays de l’UE.\"}},\n      {\"@type\":\"Question\",\"name\":\"Proposez-vous des échantillons pro ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui, selon références et disponibilité. Frais symboliques/port possibles, déduits d’une commande validée.\"}},\n      {\"@type\":\"Question\",\"name\":\"Comment assurez-vous la traçabilité ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Chaque lot a sa carte d’identité (origine, méthode, humidité). Suivi simple et contrôles à chaque réception.\"}},\n      {\"@type\":\"Question\",\"name\":\"Puis-je retourner ma commande ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Droit de rétractation légal sur produits non ouverts. Modalités détaillées dans les CGV ; contactez-nous.\"}}\n    ]\n  }\n  </script>\n\n  <!-- SCRIPTS : reveal + filtre + recherche + ancre + open/close -->\n  <script>\n    // Reveal\n    (function(){const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.18});\n      document.querySelectorAll('.reveal').forEach(n=>io.observe(n));})();\n\n    // Helpers\n    const $$=(sel,ctx=document)=>[...ctx.querySelectorAll(sel)];\n\n    // Search + filter by category + highlight + hash open\n    (function(){\n      const q=document.getElementById('faq-q');\n      const tags=$$('.tag');\n      let activeCat='all';\n\n      const clearMarks=(el)=>{el.innerHTML=el.innerHTML.replace(/<mark>|<\\/mark>/g,'')};\n      const hilite=(node,term)=>{\n        if(!term) return;\n        const rx=new RegExp('('+term.replace(/[.*+?^${}()|[\\]\\\\]/g,'\\\\$&')+')','gi');\n        node.innerHTML=node.innerHTML.replace(rx,'<mark>$1</mark>');\n      };\n\n      function apply(){\n        const term=(q.value||'').trim().toLowerCase();\n        const faqs=$$('details.faq');\n        faqs.forEach(d=>{\n          const body=d.querySelector('.ans'); const sum=d.querySelector('summary');\n          clearMarks(sum); clearMarks(body);\n          const text=(d.innerText||'').toLowerCase();\n          const inCat=(activeCat==='all'||d.dataset.cat===activeCat);\n          const match=!term || text.includes(term);\n          d.style.display=(inCat && match)?'':'none';\n          if(term && match){ hilite(sum,term); hilite(body,term); d.open=true; }\n          if(!term && !d.dataset.pin){ d.open=false; }\n        });\n      }\n\n      q.addEventListener('input',apply);\n      tags.forEach(t=>t.addEventListener('click',()=>{\n        tags.forEach(x=>x.setAttribute('aria-pressed','false'));\n        t.setAttribute('aria-pressed','true'); activeCat=t.dataset.cat; apply();\n      }));\n      apply();\n\n      // anchor open on load & copylink\n      const hash=decodeURIComponent(location.hash||'');\n      if(hash){\n        const el=document.querySelector(hash);\n        if(el && el.tagName.toLowerCase()==='details'){ el.open=true; el.scrollIntoView({behavior:'smooth',block:'start'}); }\n      }\n      $$('.copylink').forEach(b=>b.addEventListener('click',()=>{\n        const a=b.dataset.anchor; const url=location.origin+location.pathname+a;\n        navigator.clipboard.writeText(url); b.textContent='✔'; setTimeout(()=>b.textContent='🔗',900);\n        history.replaceState(null,'',a);\n      }));\n    })();\n\n    // Open/close all + clear search\n    (function(){\n      const openAll=document.getElementById('openAll');\n      const closeAll=document.getElementById('closeAll');\n      const clearSearch=document.getElementById('clearSearch');\n      const q=document.getElementById('faq-q');\n\n      openAll.addEventListener('click',()=>$$('details.faq').forEach(d=>{ if(d.style.display!=='none') d.open=true; }));\n      closeAll.addEventListener('click',()=>$$('details.faq').forEach(d=>d.open=false));\n      clearSearch.addEventListener('click',()=>{ q.value=''; q.dispatchEvent(new Event('input')); });\n    })();\n  </script>\n</section>",
