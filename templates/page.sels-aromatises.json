        "liquid_tEhiTN": {
          "type": "liquid",
          "settings": {
            "code": "<!-- =========================\n  VANILLE DÉSIRÉ — WIKI : SELS AROMATISÉS (Camargue)\n  Une seule page avec volets dépliants par produit + TOC sticky + SEO JSON-LD\n  Coller dans /pages/wiki-sels-aromatises\n========================== -->\n\n<section class=\"vdw-salts\" aria-labelledby=\"vdw-salts-title\">\n  <style>\n    .vdw-salts{\n      /* Palette VD */\n      --ink:#2B1C10; --bg:#FAF5EE; --paper:#F6EFE6; --cream:#F2E9DD;\n      --accent:#D4A373; --olive:#6E7B59; --warn:#C77D47; --ring:rgba(0,0,0,.08);\n      --safe-top: clamp(64px, env(safe-area-inset-top) + 72px, 112px);\n      color:var(--ink); background:var(--bg);\n      border-radius:20px; padding:clamp(20px,3vw,44px)\n    }\n    .vdw-salts *{box-sizing:border-box}\n    .vdw-salts a{color:inherit;text-decoration:none}\n    .vdw-salts .wrap{max-width:1200px;margin:0 auto}\n\n    /* Hero */\n    .vdw-salts .kicker{letter-spacing:.12em;text-transform:uppercase;font-size:.78rem;opacity:.8;margin-bottom:.35rem}\n    .vdw-salts h1{font-size:clamp(1.9rem,4.2vw,3rem);line-height:1.08;margin:.1rem 0 .35rem}\n    .vdw-salts .lead{font-size:clamp(1rem,1.2vw,1.125rem);max-width:80ch;opacity:.95;margin:0}\n\n    /* Layout + TOC */\n    .vdw-salts .grid{display:grid;gap:20px}\n    @media(min-width:980px){.vdw-salts .grid.cols-2{grid-template-columns:280px 1fr}}\n    .vdw-salts .toc{position:sticky; top:var(--safe-top); align-self:flex-start;\n      background:#fff;border:1px solid var(--cream);border-radius:16px;padding:14px;box-shadow:0 6px 18px rgba(0,0,0,.04)}\n    .vdw-salts .toc h2{font-size:1rem;margin:.1rem 0 .4rem}\n    .vdw-salts .toc ul{list-style:none;margin:0;padding:0;display:grid;gap:.35rem}\n    .vdw-salts .toc a{display:flex;gap:.5rem;align-items:center;padding:.45rem .6rem;border-radius:10px}\n    .vdw-salts .toc a:hover{background:var(--paper)}\n    .vdw-salts .toc .dot{width:8px;height:8px;border-radius:999px;background:var(--accent);opacity:.8}\n\n    /* Blocks */\n    .vdw-salts section.block{background:#fff;border:1px solid var(--cream);border-radius:18px;padding:18px;box-shadow:0 8px 24px rgba(0,0,0,.04)}\n    .vdw-salts .block h2{font-size:clamp(1.25rem,2.3vw,1.6rem);margin:0 0 .5rem}\n    .vdw-salts .intro{opacity:.95;margin:.2rem 0 .8rem;max-width:85ch}\n\n    /* Accordions (volets produits) */\n    .vdw-salts details.prod{background:#fff;border:1px solid var(--cream);border-radius:14px;margin:12px 0;overflow:hidden}\n    .vdw-salts details[open]{border-color:var(--accent); box-shadow:0 8px 26px rgba(0,0,0,.06)}\n    .vdw-salts summary{cursor:pointer;list-style:none;padding:14px 16px;font-weight:700;display:flex;align-items:center;gap:.6rem}\n    .vdw-salts summary .tag{font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:linear-gradient(180deg,#fff7ee,#fff);\n      border:1px solid var(--cream);border-radius:999px;padding:.32rem .6rem}\n    .vdw-salts .pwrap{padding:0 16px 16px}\n    .vdw-salts .pgrid{display:grid;gap:14px}\n    @media(min-width:860px){.vdw-salts .pgrid{grid-template-columns:220px 1fr}}\n    .vdw-salts .pimg{aspect-ratio:1/1;background:#fff;border:1px solid var(--paper);border-radius:12px;display:flex;align-items:center;justify-content:center;padding:10px}\n    .vdw-salts .pimg img{max-width:100%;height:auto}\n    .vdw-salts .specs{display:grid;gap:10px}\n    .vdw-salts .panel{background:linear-gradient(180deg,#fff 0%,#fff7ee 100%);border:1px solid var(--cream);border-radius:12px;padding:12px}\n    .vdw-salts .panel h3{margin:.1rem 0 .4rem;font-size:1.02rem}\n    .vdw-salts .mini{font-size:.95rem;opacity:.98;margin:.2rem 0 0}\n    .vdw-salts ul.clean{margin:.2rem 0 .2rem;padding-left:1.1rem}\n\n    /* CTA */\n    .vdw-salts .cta-row{display:flex;flex-wrap:wrap;gap:.6rem}\n    .vdw-salts .btn{appearance:none;border:none;border-radius:999px;background:var(--accent);color:#20130C;\n      padding:.85rem 1.1rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:.45rem}\n    .vdw-salts .btn--ghost{background:#fff;border:1px solid var(--cream);font-weight:600}\n\n    /* Reveal */\n    .vdw-salts .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease, transform .6s ease}\n    .vdw-salts .reveal.on{opacity:1;transform:none}\n    @media(prefers-reduced-motion:reduce){\n      .vdw-salts .reveal{opacity:1;transform:none}\n    }\n  </style>\n\n  <div class=\"wrap\">\n    <!-- HERO -->\n    <p class=\"kicker\">Wiki — Sels aromatisés</p>\n    <h1 id=\"vdw-salts-title\">Sels de Camargue parfumés — Guide complet</h1>\n    <p class=\"lead\">\n      Base <strong>Sel de Camargue</strong> + aromates de <strong>Madagascar</strong>. Retrouvez ici le <strong>profil</strong>, les <strong>usages</strong>, les\n      <strong>dosages</strong> et des <strong>astuces</strong> pour chaque recette. Une seule page, tout en volets dépliants.\n    </p>\n\n    <!-- LAYOUT -->\n    <div class=\"grid cols-2\" style=\"margin-top:18px\">\n      <!-- TOC -->\n      <nav class=\"toc reveal\" aria-label=\"Sommaire\">\n        <h2>Sommaire</h2>\n        <ul>\n          <li><a href=\"#base\"><span class=\"dot\"></span> La base : Sel de Camargue + philosophie</a></li>\n          <li><a href=\"#vanille\"><span class=\"dot\"></span> Sel à la Vanille Bourbon</a></li>\n          <li><a href=\"#poivres-baies\"><span class=\"dot\"></span> Sel aux poivres & baies roses</a></li>\n          <li><a href=\"#combava\"><span class=\"dot\"></span> Sel au Combava</a></li>\n          <li><a href=\"#pilipili\"><span class=\"dot\"></span> Sel au Piment Pili-pili</a></li>\n          <li><a href=\"#faq\"><span class=\"dot\"></span> FAQ — Sels aromatisés</a></li>\n        </ul>\n      </nav>\n\n      <!-- CONTENT -->\n      <div class=\"content\">\n        <!-- BASE -->\n        <section id=\"base\" class=\"block reveal anchor\" aria-labelledby=\"base-title\">\n          <h2 id=\"base-title\">La base & l’esprit Vanille Désiré</h2>\n          <p class=\"intro\">\n            Nos sels parfumés partent d’un <strong>Sel de Camargue</strong> à la granulométrie idéale, travaillé en\n            <strong>petites séries</strong>, puis marié à des <strong>aromates de Madagascar</strong> soigneusement sélectionnés (traçabilité <em>familles productrices</em>).\n          </p>\n          <div class=\"panel\">\n            <h3>Pourquoi c’est différent</h3>\n            <ul class=\"clean\">\n              <li><strong>Vrai aromatage</strong> (matière noble : gousse, caviar, zestes, grains), pas “saveur”.</li>\n              <li><strong>Fraîcheur</strong> : broyage & mélange à la demande, préserve les huiles essentielles.</li>\n              <li><strong>Équilibre</strong> : salinité maîtrisée pour <em>relever</em> sans masquer.</li>\n            </ul>\n            <p class=\"mini\"> Tous les dosages sont donnés <em>à froid</em> (assaisonnement final) et <em>à chaud</em> (cuisson douce).</p>\n          </div>\n        </section>\n\n        <!-- PRODUITS (VOLETS) -->\n        <!-- 1. VANILLE -->\n        <section id=\"vanille\" class=\"reveal anchor\">\n          <details class=\"prod\" open>\n            <summary>\n              <span class=\"tag\">Signature</span> Sel de Camargue à la <strong>Vanille Bourbon</strong> de Madagascar\n            </summary>\n            <div class=\"pwrap\">\n              <div class=\"pgrid\">\n                <div class=\"pimg\" aria-hidden=\"true\">\n                  <!-- Remplace l'image si souhaité -->\n                  <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/sel_a_la_vanille_bourbon_de_Madagascar.png?v=1756746741\" alt=\"Sel de Camargue parfumé à la vanille Bourbon\">\n                </div>\n                <div class=\"specs\">\n                  <div class=\"panel\">\n                    <h3>Profil aromatique</h3>\n                    <p class=\"mini\">\n                      Rond, pâtissier, <strong>gourmand</strong>. Notes chaudes de <em>vanilline</em>, pointe caramélisée.\n                      Maillage recommandé : <a href=\"/pages/wiki-vanille\">Wiki Vanille</a>.\n                    </p>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Usages conseillés</h3>\n                    <ul class=\"clean\">\n                      <li><strong>Finition sucrée</strong> : fraises, salades de fruits, crumble, crêpes.</li>\n                      <li><strong>Accords salés</strong> (surprise maîtrisée) : purée de patate douce, carotte rôtie, Saint-Jacques snackées.</li>\n                      <li><strong>Boissons</strong> : chocolat chaud, cappuccino, latte vanillé (une pincée au dressage).</li>\n                    </ul>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Dosages</h3>\n                    <ul class=\"clean\">\n                      <li>Finition : <strong>1 à 2 pincées</strong> / portion.</li>\n                      <li>Pâte à crêpes/gaufres : <strong>4–6 g</strong> / 500 g de pâte.</li>\n                    </ul>\n                    <p class=\"mini\">Astuce : ajoute une <strong>micro-pincée</strong> sur fruits rôtis pour booster le sucre naturel.</p>\n                  </div>\n                  <div class=\"cta-row\">\n                    <a class=\"btn\" href=\"/collections/sels-aromatises\">Acheter le sel à la Vanille</a>\n                    <a class=\"btn btn--ghost\" href=\"/pages/wiki-vanille-conservation-preparation\">→ Tout sur la vanille</a>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </details>\n        </section>\n\n        <!-- 2. POIVRES & BAIES ROSES -->\n        <section id=\"poivres-baies\" class=\"reveal anchor\">\n          <details class=\"prod\">\n            <summary>\n              <span class=\"tag\">Épicerie fine</span> Sel de Camargue parfumé au <strong>mélange de poivres & baies roses</strong>\n            </summary>\n            <div class=\"pwrap\">\n              <div class=\"pgrid\">\n                <div class=\"pimg\" aria-hidden=\"true\">\n                  <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/sel-de-camargue-parfume-au-melange-de-poivres-et-baies-roses-de-madagascar.png?v=1757252302\" alt=\"Sel parfumé poivres et baies roses\">\n                </div>\n                <div class=\"specs\">\n                  <div class=\"panel\">\n                    <h3>Profil aromatique</h3>\n                    <p class=\"mini\">\n                      Poivre noir (charpente), <em>poivre sauvage</em> (boisé, floral), <em>baies roses</em> (fruité, suave).\n                      Maillage : <a href=\"/pages/wiki-baies-roses\">Wiki Baies roses</a> & <a href=\"/pages/wiki-vanille\">terroirs d’épices</a>.\n                    </p>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Usages conseillés</h3>\n                    <ul class=\"clean\">\n                      <li><strong>Viandes grillées</strong>, carpaccios, tartares.</li>\n                      <li><strong>Légumes</strong> rôtis, asperges, tomates anciennes.</li>\n                      <li><strong>Fromages</strong> frais (chèvre, faisselle) avec filet d’huile d’olive.</li>\n                    </ul>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Dosages</h3>\n                    <ul class=\"clean\">\n                      <li>Finition : <strong>1 pincée</strong> / assiette.</li>\n                      <li>Cuisson douce : <strong>2 g</strong> / 300 g d’aliment, à ajuster.</li>\n                    </ul>\n                    <p class=\"mini\">Astuce chef : saupoudrer <em>après</em> cuisson pour préserver le fruité des baies roses.</p>\n                  </div>\n                  <div class=\"cta-row\">\n                    <a class=\"btn\" href=\"/collections/sels-aromatises\">Acheter le sel Poivres & Baies</a>\n                    <a class=\"btn btn--ghost\" href=\"/pages/wiki-baies-roses\">→ Tout sur les baies roses</a>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </details>\n        </section>\n\n        <!-- 3. COMBAVA -->\n        <section id=\"combava\" class=\"reveal anchor\">\n          <details class=\"prod\">\n            <summary>\n              <span class=\"tag\">Agrume</span> Sel de Camargue parfumé au <strong>Combava</strong>\n            </summary>\n            <div class=\"pwrap\">\n              <div class=\"pgrid\">\n                <div class=\"pimg\" aria-hidden=\"true\">\n                  <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/sel-de-camargue-parfume-au-combava-de-madagascar.png?v=1757252344\" alt=\"Sel parfumé au combava\">\n                </div>\n                <div class=\"specs\">\n                  <div class=\"panel\">\n                    <h3>Profil aromatique</h3>\n                    <p class=\"mini\">\n                      Zeste <strong>vert</strong>, ultra-citronné, notes de feuille de kaffir, finale vive.\n                      Maillage : <a href=\"/pages/wiki-combava\">Wiki Combava</a>.\n                    </p>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Usages conseillés</h3>\n                    <ul class=\"clean\">\n                      <li><strong>Poissons</strong> (crus & cuissons douces), crevettes, Saint-Jacques.</li>\n                      <li><strong>Légumes</strong> vapeur, riz coco, woks minute.</li>\n                      <li><strong>Mocktails & cocktails</strong> (bord de verre, sirops maison).</li>\n                    </ul>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Dosages</h3>\n                    <ul class=\"clean\">\n                      <li>Finition : <strong>1 pincée</strong> / assiette (très puissant).</li>\n                      <li>Marinades courtes : <strong>2–3 g</strong> / 300 g de poisson, 15–20 min.</li>\n                    </ul>\n                    <p class=\"mini\">Astuce : évite les cuissons longues qui émoussent l’agrume — privilégie le dressage.</p>\n                  </div>\n                  <div class=\"cta-row\">\n                    <a class=\"btn\" href=\"/collections/sels-aromatises\">Acheter le sel au Combava</a>\n                    <a class=\"btn btn--ghost\" href=\"/pages/wiki-combava\">→ En savoir plus sur le combava</a>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </details>\n        </section>\n\n        <!-- 4. PILI-PILI -->\n        <section id=\"pilipili\" class=\"reveal anchor\">\n          <details class=\"prod\">\n            <summary>\n              <span class=\"tag\">Piquant</span> Sel de Camargue parfumé au <strong>Piment Pili-pili</strong>\n            </summary>\n            <div class=\"pwrap\">\n              <div class=\"pgrid\">\n                <div class=\"pimg\" aria-hidden=\"true\">\n                  <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/sel_camargue_piment_pili_pili_madagascar.png?v=1757252444\" alt=\"Sel parfumé au piment pili-pili\">\n                </div>\n                <div class=\"specs\">\n                  <div class=\"panel\">\n                    <h3>Profil aromatique</h3>\n                    <p class=\"mini\">\n                      Chaleur <strong>progressive</strong>, notes végétales et légèrement fumées.\n                      Maillage : <a href=\"/pages/wiki-pili-pili\">Wiki Pili-pili</a>.\n                    </p>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Usages conseillés</h3>\n                    <ul class=\"clean\">\n                      <li><strong>Grillades</strong>, brochettes, burgers.</li>\n                      <li><strong>Œufs</strong> (brouillés, shakshuka), avocats, maïs.</li>\n                      <li><strong>Frites / patates rôties</strong> (mélange à l’huile avant four).</li>\n                    </ul>\n                  </div>\n                  <div class=\"panel\">\n                    <h3>Dosages</h3>\n                    <ul class=\"clean\">\n                      <li>Finition : <strong>1/2 à 1 pincée</strong> / portion.</li>\n                      <li>Marinades : <strong>2 g</strong> / 300 g, 30–45 min.</li>\n                    </ul>\n                    <p class=\"mini\">Astuce douceur : marier au <em>miel</em> pour un glaçage “hot-sweet” irrésistible.</p>\n                  </div>\n                  <div class=\"cta-row\">\n                    <a class=\"btn\" href=\"/collections/sels-aromatises\">Acheter le sel au Pili-pili</a>\n                    <a class=\"btn btn--ghost\" href=\"/pages/wiki-pili-pili\">→ En savoir plus sur le pili-pili</a>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </details>\n        </section>\n\n        <!-- FAQ -->\n        <section id=\"faq\" class=\"block reveal anchor\" aria-labelledby=\"faq-title\">\n          <h2 id=\"faq-title\">FAQ — Sels aromatisés</h2>\n          <details>\n            <summary>Quelle est la différence entre “aromatisé” et “saveur” ?</summary>\n            <p>Nos sels sont <strong>aromatisés</strong> avec de la matière première réelle (gousses, zestes, grains, piments). Aucune “saveur” artificielle.</p>\n          </details>\n          <details>\n            <summary>Les sels se cuisent ou s’utilisent en finition ?</summary>\n            <p>Les deux, mais la <strong>finition</strong> préserve mieux les arômes volatils (vanille, agrumes, baies). Pour le pili-pili et les poivres, la cuisson douce fonctionne très bien.</p>\n          </details>\n          <details>\n            <summary>Comment conserver un sel aromatisé ?</summary>\n            <p>Pot <strong>hermétique</strong>, au sec, à l’abri de la lumière et de la chaleur. Bien refermer après usage. Durée optimale : 12–18 mois.</p>\n          </details>\n        </section>\n\n        <!-- CTA GLOBAL -->\n        <section class=\"block reveal anchor\" style=\"text-align:center\">\n          <h2>Prêt·e à assaisonner comme un·e chef&nbsp;?</h2>\n          <p class=\"intro\">Découvrez la collection complète de nos <strong>sels de Camargue parfumés</strong>, travaillés en petites séries à Lyon.</p>\n          <div class=\"cta-row\" style=\"justify-content:center\">\n            <a class=\"btn\" href=\"/collections/sels-aromatises\">Voir la collection</a>\n            <a class=\"btn btn--ghost\" href=\"/pages/wiki\">← Retour au Wiki</a>\n          </div>\n        </section>\n      </div>\n    </div>\n  </div>\n\n  <!-- Reveal on scroll -->\n  <script>\n    document.addEventListener('DOMContentLoaded',function(){\n      var els=document.querySelectorAll('.vdw-salts .reveal');\n      if('IntersectionObserver' in window){\n        var io=new IntersectionObserver(function(entries){\n          entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('on'); io.unobserve(e.target);} });\n        },{threshold:.12});\n        els.forEach(function(el){ io.observe(el); });\n      } else { els.forEach(function(el){ el.classList.add('on'); }); }\n    });\n  </script>\n\n  <!-- JSON-LD : ItemList + FAQ (SEO) -->\n  <script type=\"application/ld+json\">\n  {\n    \"@context\":\"https://schema.org\",\n    \"@type\":\"ItemList\",\n    \"name\":\"Sels de Camargue aromatisés Vanille Désiré\",\n    \"itemListElement\":[\n      {\"@type\":\"ListItem\",\"position\":1,\"name\":\"Sel de Camargue à la Vanille Bourbon\",\"url\":\"/collections/sels-aromatises\"},\n      {\"@type\":\"ListItem\",\"position\":2,\"name\":\"Sel au mélange de poivres & baies roses\",\"url\":\"/collections/sels-aromatises\"},\n      {\"@type\":\"ListItem\",\"position\":3,\"name\":\"Sel au Combava\",\"url\":\"/collections/sels-aromatises\"},\n      {\"@type\":\"ListItem\",\"position\":4,\"name\":\"Sel au Piment Pili-pili\",\"url\":\"/collections/sels-aromatises\"}\n    ]\n  }\n  </script>\n\n  <script type=\"application/ld+json\">\n  {\n    \"@context\":\"https://schema.org\",\n    \"@type\":\"FAQPage\",\n    \"mainEntity\":[\n      {\"@type\":\"Question\",\"name\":\"Quelle est la différence entre “aromatisé” et “saveur” ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nos sels sont aromatisés avec de la matière première réelle (gousses, zestes, grains, piments). Aucune saveur artificielle.\"}},\n      {\"@type\":\"Question\",\"name\":\"Les sels se cuisent ou s’utilisent en finition ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Les deux, mais la finition préserve mieux les arômes volatils (vanille, agrumes, baies). Pour le pili-pili et les poivres, la cuisson douce fonctionne très bien.\"}},\n      {\"@type\":\"Question\",\"name\":\"Comment conserver un sel aromatisé ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pot hermétique, au sec, à l’abri de la lumière et de la chaleur. Durée optimale 12–18 mois.\"}}\n    ]\n  }\n  </script>\n</section>",
