          "type": "liquid",
          "settings": {
            "code": "<section id=\"vd-recipe-beignets\" class=\"vd-recipe\" lang=\"fr\" data-base-serves=\"10\">\n  <style>\n    /* ===== Vanille Désiré — Recipe Block (clean, light theme) ===== */\n    #vd-recipe-beignets{\n      /* Palette claire + orange marque */\n      --vd-bg:#FAF9F6;          /* fond ivoire */\n      --vd-card:#FFFFFF;        /* cartes blanches */\n      --vd-text:#1F1F1F;        /* texte principal */\n      --vd-dim:#6E6E6E;         /* texte secondaire */\n      --vd-border:#E8E6E3;      /* bordures claires */\n      --vd-brand:#FF7A3D;       /* ORANGE marque (ajuste si besoin) */\n      --vd-accent:var(--vd-brand);\n      --vd-accent-2:var(--vd-brand);\n      --vd-danger:#C0392B;\n\n      --vd-radius:16px;--vd-gap:14px;\n      --vd-shadow:0 12px 30px rgba(0,0,0,.12);\n      color:var(--vd-text);\n      font:16px/1.55 system-ui,-apple-system,Segoe UI,Roboto,Inter,Arial,sans-serif;\n      background:var(--vd-bg)\n    }\n    #vd-recipe-beignets *{box-sizing:border-box}\n    #vd-recipe-beignets .visually-hidden{position:absolute!important;clip:rect(1px,1px,1px,1px);padding:0;border:0;height:1px;width:1px;overflow:hidden;white-space:nowrap}\n\n    #vd-recipe-beignets .wrap{max-width:980px;margin:auto;padding:28px}\n\n    /* Header sticky clair */\n    #vd-recipe-beignets .header{\n      position:sticky;top:0;\n      background:linear-gradient(180deg, rgba(250,249,246,.95), rgba(255,255,255,.92));\n      backdrop-filter:saturate(140%) blur(6px);\n      z-index:20;box-shadow:0 1px 0 var(--vd-border)\n    }\n    #vd-recipe-beignets .header .bar{display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:space-between;padding:14px 28px}\n    #vd-recipe-beignets h1{font-size:clamp(24px,4vw,34px);margin:0;font-weight:800;letter-spacing:.2px}\n    #vd-recipe-beignets .sub{color:var(--vd-dim);max-width:72ch;margin:8px 0 0;font-size:15px}\n\n    /* Controls */\n    #vd-recipe-beignets .controls{display:flex;flex-wrap:wrap;gap:10px}\n    #vd-recipe-beignets .btn{\n      appearance:none;border:1px solid var(--vd-border);background:var(--vd-card);color:var(--vd-text);\n      padding:10px 14px;border-radius:12px;cursor:pointer;\n      transition:transform .15s ease, border-color .2s ease, background .2s ease;\n      display:inline-flex;align-items:center;gap:8px\n    }\n    #vd-recipe-beignets .btn:hover{transform:translateY(-1px);border-color:var(--vd-accent)}\n    #vd-recipe-beignets .btn.primary{background:linear-gradient(180deg,var(--vd-accent),#e96d2e);color:#fff;border-color:transparent}\n    #vd-recipe-beignets .btn.ghost{background:transparent}\n    #vd-recipe-beignets .qty{display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid var(--vd-border);border-radius:12px;background:var(--vd-card)}\n    #vd-recipe-beignets .qty input{width:64px;background:transparent;border:none;color:var(--vd-text);font-weight:700;text-align:center}\n    #vd-recipe-beignets .qty button{all:unset;cursor:pointer;font-weight:900;padding:0 8px;border-radius:8px}\n    #vd-recipe-beignets .qty button:focus-visible{outline:2px solid var(--vd-accent)}\n\n    /* Grid */\n    #vd-recipe-beignets .grid{display:grid;grid-template-columns:1.1fr .9fr;gap:22px;margin:22px 28px}\n    @media (max-width:860px){#vd-recipe-beignets .grid{grid-template-columns:1fr;gap:16px;margin:18px 0}}\n    #vd-recipe-beignets .card{background:var(--vd-card);border:1px solid var(--vd-border);border-radius:var(--vd-radius);box-shadow:var(--vd-shadow);overflow:hidden}\n    #vd-recipe-beignets .card header{padding:16px 18px;border-bottom:1px solid var(--vd-border);display:flex;align-items:center;justify-content:space-between;gap:12px}\n    #vd-recipe-beignets .card header h2{margin:0;font-size:18px}\n    #vd-recipe-beignets .card .body{padding:16px 18px}\n\n    /* Checklist */\n    #vd-recipe-beignets .list{display:grid;gap:10px}\n    #vd-recipe-beignets .item{\n      display:grid;grid-template-columns:auto 1fr auto;align-items:start;gap:10px;\n      padding:10px;border:1px dashed var(--vd-border);border-radius:12px;\n      transition:background .2s ease, border-color .2s ease\n    }\n    #vd-recipe-beignets .item:hover{border-color:var(--vd-accent)}\n    #vd-recipe-beignets .item input[type=\"checkbox\"]{width:18px;height:18px;margin-top:2px}\n    #vd-recipe-beignets .qtyNote{color:var(--vd-dim);font-size:13px}\n    #vd-recipe-beignets .strike{opacity:.55;text-decoration:line-through}\n\n    /* Steps */\n    #vd-recipe-beignets .step{position:relative;padding:12px 12px 12px 44px;border:1px dashed var(--vd-border);border-radius:12px}\n    #vd-recipe-beignets .step:before{\n      content:attr(data-n);position:absolute;left:10px;top:10px;display:inline-grid;place-items:center;\n      width:24px;height:24px;border-radius:8px;background:var(--vd-accent);color:#fff;font-weight:800\n    }\n\n    /* Accordéons clairs */\n    #vd-recipe-beignets details{border:1px solid var(--vd-border);border-radius:12px;overflow:hidden;background:#fff}\n    #vd-recipe-beignets summary{\n      list-style:none;padding:12px 14px;cursor:pointer;background:linear-gradient(180deg,#ffffff,#F6F3ED);\n      font-weight:700;color:var(--vd-text)\n    }\n    #vd-recipe-beignets summary::-webkit-details-marker{display:none}\n    #vd-recipe-beignets details[open]{box-shadow:0 12px 24px rgba(0,0,0,.07)}\n    #vd-recipe-beignets .hint{font-size:14px;color:var(--vd-dim)}\n\n    /* Toast clair */\n    #vd-recipe-beignets .toast{\n      position:fixed;inset:auto 18px 18px auto;background:#fff;border:1px solid var(--vd-border);\n      padding:10px 14px;border-radius:10px;opacity:0;transform:translateY(8px);\n      transition:all .2s ease;z-index:50;box-shadow:0 8px 18px rgba(0,0,0,.08)\n    }\n    #vd-recipe-beignets .toast.show{opacity:1;transform:translateY(0)}\n\n    /* Reduced motion */\n    @media (prefers-reduced-motion:reduce){\n      #vd-recipe-beignets .btn,#vd-recipe-beignets .item,#vd-recipe-beignets details{transition:none}\n    }\n\n    /* Mode service : focus étapes, UI épurée */\n    #vd-recipe-beignets.service #vd-ingredients,\n    #vd-recipe-beignets.service #vd-tips,\n    #vd-recipe-beignets.service #vd-origin {display:none}\n    #vd-recipe-beignets.service #vd-steps .step{border-width:2px}\n  </style>\n\n  <div class=\"header\">\n    <div class=\"bar\">\n      <div>\n        <h1>Beignets de Banane à la Vanille — Recette Signature</h1>\n        <p class=\"sub\">Beignets dorés, moelleux à cœur, parfumés aux <strong>gousses de vanille Bourbon</strong> de Madagascar. Recette maison pour <span data-serves>10</span> personnes (scalable) — environ 25 à 30 beignets.</p>\n      </div>\n      <div class=\"controls\" aria-label=\"Actions de la recette\">\n        <div class=\"qty\" aria-live=\"polite\">\n          <button type=\"button\" data-action=\"minus\" aria-label=\"Diminuer les portions\">−</button>\n          <label for=\"vd-serves\" class=\"visually-hidden\">Portions</label>\n          <input id=\"vd-serves\" inputmode=\"numeric\" pattern=\"[0-9]*\" value=\"10\" aria-label=\"Portions\">\n          <button type=\"button\" data-action=\"plus\" aria-label=\"Augmenter les portions\">+</button>\n        </div>\n        <button class=\"btn ghost\" type=\"button\" data-action=\"toggle-check\">Tout cocher</button>\n        <button class=\"btn\" type=\"button\" data-action=\"copy\">Copier</button>\n        <button class=\"btn primary\" type=\"button\" data-action=\"service\">Mode service</button>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"wrap\">\n    <div class=\"grid\">\n      <!-- Ingrédients -->\n      <article class=\"card\" id=\"vd-ingredients\">\n        <header>\n          <h2>Ingrédients</h2>\n          <small class=\"hint\">Base pour <span data-serves>10</span> personnes — ajustez avec le sélecteur</small>\n        </header>\n        <div class=\"body\">\n          <div class=\"list\" role=\"list\">\n            <label class=\"item\" role=\"listitem\"><input type=\"checkbox\"><span><strong><span data-qty=\"3\" data-unit=\"œufs\">3</span> œufs</strong></span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><strong><span data-qty=\"400\" data-unit=\"g\">400</span> g</strong> de farine (T55)</span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><strong><span data-qty=\"100\" data-unit=\"g\">100</span> g</strong> de sucre</span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><strong><span data-qty=\"1\" data-unit=\"sachet\">1</span> sachet</strong> de levure chimique <span class=\"hint\">(≈11 g)</span></span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><strong><span data-qty=\"35\" data-unit=\"cl\">35</span> cl</strong> de lait</span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><strong><span data-qty=\"2\" data-unit=\"gousses\">2</span> gousses</strong> de vanille Bourbon <em>Vanille Désiré</em>, fendues et grattées</span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><strong><span data-qty=\"7\" data-unit=\"bananes\">7</span> bananes</strong> bien mûres <span class=\"hint\">(6–8 selon taille)</span></span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span>Huile pour friture <span class=\"hint\">(arachide ou tournesol raffinée)</span></span><span class=\"qtyNote\"></span></label>\n            <label class=\"item\"><input type=\"checkbox\"><span><em>Alternative si pas de gousse</em> : <strong><span data-qty=\"1\" data-unit=\"c. à café\">1</span> c. à café</strong> de sucre vanillé <em>Vanille Désiré</em></span><span class=\"qtyNote\"></span></label>\n          </div>\n        </div>\n      </article>\n\n      <!-- Étapes -->\n      <article class=\"card\" id=\"vd-steps\">\n        <header>\n          <h2>Préparation pas à pas</h2>\n          <small class=\"hint\">Cochez au fur et à mesure pour suivre l’avancement</small>\n        </header>\n        <div class=\"body list\">\n          <label class=\"step item\" data-n=\"1\"><input type=\"checkbox\"><span>Dans un grand bol, fouetter <strong>œufs</strong> et <strong>sucre</strong>. Fendre les <strong>gousses de vanille</strong>, gratter les graines et les incorporer (vous pouvez mettre les gousses à infuser quelques minutes dans le lait). Si vous n’avez pas de gousse, utilisez <strong>1 c. à café de sucre vanillé Vanille Désiré</strong>.</span></label>\n          <label class=\"step item\" data-n=\"2\"><input type=\"checkbox\"><span>Ajouter la <strong>farine</strong> et la <strong>levure chimique</strong>, puis verser le <strong>lait</strong> progressivement jusqu’à obtenir une pâte lisse, souple et nappante (<em>consistance ruban</em>). Laisser <strong>reposer 20–30 min</strong>.</span></label>\n          <label class=\"step item\" data-n=\"3\"><input type=\"checkbox\"><span>Éplucher les <strong>bananes</strong> et les couper en <strong>rondelles de 1,5–2&nbsp;cm</strong> (ou en bâtonnets). Chauffer l’<strong>huile</strong> dans une casserole profonde ou une friteuse.</span></label>\n          <label class=\"step item\" data-n=\"4\"><input type=\"checkbox\"><span>Amener l’huile à environ <strong>170–175&nbsp;°C</strong> (tester avec une goutte de pâte&nbsp;: elle doit frire de suite sans brunir trop vite). Travailler par petites fournées.</span></label>\n          <label class=\"step item\" data-n=\"5\"><input type=\"checkbox\"><span>Tremper les morceaux de banane dans la pâte, plonger dans l’huile et frire <strong>2–3&nbsp;min par face</strong> jusqu’à belle coloration dorée. Égoutter sur papier absorbant.</span></label>\n          <label class=\"step item\" data-n=\"6\"><input type=\"checkbox\"><span>Servir <strong>bien chaud</strong>. Option&nbsp;: saupoudrer d’un peu de sucre vanillé ou glace. Déguster nature ou avec un filet de miel.</span></label>\n        </div>\n      </article>\n\n      <!-- Présentation / astuces -->\n      <article class=\"card\" id=\"vd-tips\">\n        <header><h2>Présentation & astuces</h2></header>\n        <div class=\"body\">\n          <details open>\n            <summary>Pâte & texture</summary>\n            <div class=\"body\">La pâte doit napper la spatule (<em>ruban</em>). Si elle est trop épaisse, détendez avec 1–2 c. à soupe de lait ; trop fluide, ajoutez 1–2 c. à soupe de farine. Le repos aide la levure à agir et limite l’absorption d’huile.</div>\n          </details>\n          <div style=\"height:10px\"></div>\n          <details>\n            <summary>Température de friture</summary>\n            <div class=\"body\">Visez <strong>≈170&nbsp;°C</strong> (jusqu’à 180&nbsp;°C max). Sans thermomètre, testez avec une goutte de pâte&nbsp;: elle doit crépiter immédiatement et dorer doucement. Frire par petites quantités pour maintenir la température.</div>\n          </details>\n          <div style=\"height:10px\"></div>\n          <details>\n            <summary>Vanille & alternatives</summary>\n            <div class=\"body\">La gousse apporte un parfum incomparable. À défaut, utilisez <strong>1 c. à café de sucre vanillé Vanille Désiré</strong> pour parfumer la pâte et pour saupoudrer à la fin.</div>\n          </details>\n        </div>\n      </article>\n\n      <!-- Encadré SEO / origine produit -->\n      <aside class=\"card\" id=\"vd-origin\">\n        <header><h2>Vanille Bourbon — origine directe Madagascar</h2></header>\n        <div class=\"body\">\n          Recette élaborée avec des gousses de <strong>vanille Bourbon</strong> sourcées directement auprès de producteurs familiaux à Madagascar. Traçabilité, maturité optimale, calibre régulier et prix compétitifs.\n        </div>\n      </aside>\n    </div>\n  </div>\n\n  <div class=\"toast\" role=\"status\" aria-live=\"polite\"></div>\n\n  <script>\n    (()=> {\n      const root=document.getElementById('vd-recipe-beignets');\n      const baseServes=Number(root.dataset.baseServes||10);\n      const inputServes=root.querySelector('#vd-serves');\n      const servesSlots=root.querySelectorAll('[data-serves]');\n      const toast=msg=>{\n        const t=root.querySelector('.toast'); t.textContent=msg; t.classList.add('show');\n        setTimeout(()=>t.classList.remove('show'),1600);\n      };\n\n      function formatQty(val, unit){\n        const rounded = Math.round(val*100)/100;\n        const str = (Number.isInteger(rounded)? String(rounded) : rounded.toString().replace('.', ',')); \n        return unit ? `${str} ${unit}` : str;\n      }\n\n      function scale(){\n        let target = parseFloat(inputServes.value);\n        if(isNaN(target)||target<1){target=baseServes; inputServes.value=baseServes;}\n        const factor = target/baseServes;\n        servesSlots.forEach(el=> el.textContent=target);\n\n        // Ingrédients\n        root.querySelectorAll('[data-qty]').forEach(span=>{\n          const qty=parseFloat(span.dataset.qty);\n          const unit=span.dataset.unit||'';\n          if(!isNaN(qty)){\n            const scaled = qty*factor;\n            span.textContent = formatQty(scaled, unit.includes('citron')?'':unit);\n          }\n        });\n\n        // Notes compactes\n        root.querySelectorAll('#vd-ingredients .item').forEach(it=>{\n          const q=it.querySelector('[data-qty]');\n          const note=it.querySelector('.qtyNote');\n          if(q && note){\n            const val=q.textContent.trim();\n            note.textContent = `≈ ${val} / ${target} pers`;\n          }\n        });\n      }\n\n      // + / -\n      root.querySelector('[data-action=\"plus\"]').addEventListener('click',()=>{inputServes.value = Number(inputServes.value||baseServes)+2; scale();});\n      root.querySelector('[data-action=\"minus\"]').addEventListener('click',()=>{inputServes.value = Math.max(1, Number(inputServes.value||baseServes)-2); scale();});\n      inputServes.addEventListener('input', scale);\n\n      // Tout cocher / décocher\n      const toggleBtn = root.querySelector('[data-action=\"toggle-check\"]');\n      toggleBtn.addEventListener('click',()=>{\n        const boxes = root.querySelectorAll('.card input[type=\"checkbox\"]');\n        const allChecked = [...boxes].every(b=>b.checked);\n        boxes.forEach(b=>b.checked=!allChecked);\n        root.querySelectorAll('.item').forEach(it=>{\n          const cb=it.querySelector('input[type=\"checkbox\"]');\n          it.classList.toggle('strike', cb.checked);\n        });\n        toggleBtn.textContent = allChecked? 'Tout cocher' : 'Tout décocher';\n      });\n\n      // Ligne barrée au clic\n      root.querySelectorAll('.item input[type=\"checkbox\"]').forEach(cb=>{\n        cb.addEventListener('change', e=>{\n          const it=e.target.closest('.item');\n          it.classList.toggle('strike', e.target.checked);\n        });\n      });\n\n      // Copier\n      root.querySelector('[data-action=\"copy\"]').addEventListener('click',()=>{\n        const h1 = root.querySelector('h1').textContent.trim();\n        const intro = root.querySelector('.sub').textContent.trim();\n        const ings = [...root.querySelectorAll('#vd-ingredients .item')].map(l=>{\n          const txt = l.innerText.replace(/≈.*$/,'').trim();\n          return `- ${txt}`;\n        }).join('\\n');\n        const steps = [...root.querySelectorAll('#vd-steps .step')].map((s,i)=> `${i+1}. ${s.innerText.trim()}`).join('\\n');\n        const txt = `${h1}\\n\\n${intro}\\n\\nIngrédients (pour ${inputServes.value} personnes)\\n${ings}\\n\\nPréparation\\n${steps}\\n`;\n        navigator.clipboard.writeText(txt).then(()=>toast('Recette copiée')).catch(()=>toast('Impossible de copier'));\n      });\n\n      // Mode service\n      let serviceOn=false;\n      const serviceBtn=root.querySelector('[data-action=\"service\"]');\n      serviceBtn.addEventListener('click',()=>{\n        serviceOn = !serviceOn;\n        root.classList.toggle('service', serviceOn);\n        serviceBtn.textContent = serviceOn? 'Quitter service' : 'Mode service';\n        toast(serviceOn?'Mode service activé':'Mode service désactivé');\n      });\n\n      // Init\n      scale();\n    })();\n  </script>\n\n  <!-- JSON-LD Recipe retiré temporairement pour éviter toute alerte (pas d'image, pas d'aggregateRating/video/nutrition à ce stade). -->\n</section>",
            "width": "100%",
            "alignment": "center"
          }
        }
