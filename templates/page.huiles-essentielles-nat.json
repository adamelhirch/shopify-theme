:700;margin-right:.45rem}\n\n    /* Accordions & tables */\n    .vdw-oe details{background:#fff;border:1px solid var(--cream);border-radius:12px;padding:12px 14px;margin:10px 0}\n    .vdw-oe summary{cursor:pointer;font-weight:600;list-style:none}\n    .vdw-oe summary::-webkit-details-marker{display:none}\n    .vdw-oe details[open]{border-color:var(--accent)}\n    .vdw-oe table{width:100%;border-collapse:separate;border-spacing:0;margin:.4rem 0;border:1px solid var(--cream);border-radius:12px;overflow:hidden}\n    .vdw-oe th,.vdw-oe td{padding:.6rem .7rem;border-bottom:1px solid var(--cream);text-align:left}\n    .vdw-oe thead th{background:#fff7ee;font-weight:700}\n    .vdw-oe tbody tr:last-child td{border-bottom:none}\n\n    /* Buttons */\n    .vdw-oe .cta-row{display:flex;flex-wrap:wrap;gap:.6rem}\n    .vdw-oe .btn{appearance:none;border:none;border-radius:999px;background:var(--accent);color:#20130C;\n      padding:.85rem 1.1rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:.45rem}\n    .vdw-oe .btn--ghost{background:#fff;border:1px solid var(--cream);font-weight:600}\n\n    /* Reveal on scroll */\n    .vdw-oe .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease, transform .6s ease}\n    .vdw-oe .reveal.on{opacity:1;transform:none}\n\n    @media(prefers-reduced-motion:reduce){\n      .vdw-oe .reveal{opacity:1;transform:none}\n      .vdw-oe .card{transition:none}\n      .vdw-oe .card:hover{transform:none}\n    }\n  </style>\n\n  <div class=\"wrap\">\n    <!-- HERO -->\n    <p class=\"kicker\">Wiki — Huiles essentielles</p>\n    <h1 id=\"vdw-oe-title\">Huiles essentielles & huiles naturelles de Madagascar</h1>\n    <p class=\"lead\">\n      Guide clair et pratique pour <strong>choisir</strong>, <strong>utiliser</strong> et <strong>conserver</strong> nos huiles\n      (Ylang Ylang, Ravintsara, Girofle, Eucalyptus citronné, Cannelle, Ricin). Sourcing <strong>direct producteurs</strong>, traçabilité et qualité artisanale.\n    </p>\n\n    <!-- LAYOUT -->\n    <div class=\"grid cols-2\" style=\"margin-top:18px\">\n      <!-- TOC -->\n      <nav class=\"toc reveal\" aria-label=\"Sommaire\">\n        <h2>Sommaire</h2>\n        <ul>\n          <li><a href=\"#choisir\"><span class=\"dot\"></span> Bien choisir son huile</a></li>\n          <li><a href=\"#fiches\"><span class=\"dot\"></span> Fiches par huile (notes & usages)</a></li>\n          <li><a href=\"#utiliser\"><span class=\"dot\"></span> Utilisation : diffusion & peau</a></li>\n          <li><a href=\"#dilution\"><span class=\"dot\"></span> Tableau de dilution (gouttes/ml)</a></li>\n          <li><a href=\"#conserver\"><span class=\"dot\"></span> Conservation & stabilité</a></li>\n          <li><a href=\"#faq\"><span class=\"dot\"></span> FAQ & précautions</a></li>\n        </ul>\n      </nav>\n\n      <!-- CONTENT -->\n      <div class=\"content\">\n\n        <!-- 1. CHOISIR -->\n        <section id=\"choisir\" class=\"block reveal anchor\" aria-labelledby=\"choisir-title\">\n          <h2 id=\"choisir-title\">Bien choisir son huile</h2>\n          <p class=\"intro\">Trois repères simples pour une huile de qualité, utile en cuisine aromatique, diffusion ambiante ou cosmétique.</p>\n\n          <div class=\"cards\">\n            <article class=\"card\">\n              <h3>Origine & traçabilité</h3>\n              <p class=\"mini\">Production familiale à Madagascar, circuits <strong>sans intermédiaire</strong>, lots courts, étiquetage clair (espèce botanique, partie distillée).</p>\n              <span class=\"badge badge--direct\" title=\"Approvisionnement direct\">Direct producteurs</span>\n            </article>\n            <article class=\"card\">\n              <h3>Fraîcheur & profil olfactif</h3>\n              <p class=\"mini\">Parfum net, sans « note lourde » rance. Couleur et viscosité conformes à l’espèce. Bouchon compte-gouttes <em>propre</em>.</p>\n            </article>\n            <article class=\"card\">\n              <h3>Usage attendu</h3>\n              <p class=\"mini\">Diffusion, cosmétique diluée, cuisine aromatique : adaptez la <strong>dilution</strong> et choisissez des espèces <strong>douces</strong> pour débuter (Ylang Ylang, Ravintsara).</p>\n            </article>\n          </div>\n        </section>\n\n        <!-- 2. FICHES HUILES -->\n        <section id=\"fiches\" class=\"block reveal anchor\" aria-labelledby=\"fiches-title\">\n          <h2 id=\"fiches-title\">Fiches par huile — notes, idées d’usage & précautions</h2>\n          <p class=\"intro\">Chaque fiche propose des repères olfactifs, des pistes d’usage simples et des précautions essentielles. <strong>Ingestion déconseillée</strong> sans avis d’un pro qualifié.</p>\n\n          <!-- YLANG YLANG -->\n          <details open>\n            <summary><strong>Ylang Ylang (Cananga odorata) — HE 5 mL</strong></summary>\n            <div class=\"cards\" style=\"margin-top:.4rem\">\n              <div class=\"card\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile-essentielle-ylang-ylang-5ml.png?v=1757254085\" alt=\"Huile essentielle Ylang Ylang\" style=\"width:100%;border-radius:12px;margin-bottom:.6rem\" loading=\"lazy\">\n                <h3>Profil olfactif</h3>\n                <p class=\"mini\">Floral, solaire, crémeux. Super en accords « gourmands » vanillés.</p>\n              </div>\n              <div class=\"card\">\n                <h3>Idées d’usage</h3>\n                <ul class=\"mini\">\n                  <li>Diffusion du soir : 2 g Ylang + 3 g Orange douce (10 min/heure).</li>\n                  <li>Cosmétique (≤1%) : 1 goutte/5 mL d’huile végétale sur les pointes de cheveux.</li>\n                  <li>Cuisine aromatique : 1 goutte pour 300–500 g de préparation (pâtisseries exotiques). </li>\n                </ul>\n              </div>\n              <div class=\"card\">\n                <h3>Précautions</h3>\n                <ul class=\"mini\">\n                  <li>Puissante : toujours <strong>diluer</strong>. Éviter sur peaux très réactives.</li>\n                  <li>Déconseillée 1er trimestre de grossesse. Tenir hors de portée des enfants.</li>\n                </ul>\n              </div>\n            </div>\n            <div class=\"cta-row\" style=\"margin-top:.6rem\">\n              <a class=\"btn\" href=\"/products/huile-essentielle-ylang-ylang-5ml\">Voir le produit</a>\n              <a class=\"btn btn--ghost\" href=\"/collections/huiles-essentielles\">Toute la collection</a>\n            </div>\n          </details>\n\n          <!-- RAVINTSARA -->\n          <details>\n            <summary><strong>Ravintsara (Cinnamomum camphora CT 1,8-cinéole) — HE 5 mL</strong></summary>\n            <div class=\"cards\" style=\"margin-top:.4rem\">\n              <div class=\"card\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile_essentielle_ravintsara_madagascar.png?v=1757254488\" alt=\"Huile essentielle Ravintsara\" style=\"width:100%;border-radius:12px;margin-bottom:.6rem\" loading=\"lazy\">\n                <h3>Profil olfactif</h3>\n                <p class=\"mini\">Frais, eucalypté, propre. Idéal pour assainir l’air en douceur.</p>\n              </div>\n              <div class=\"card\">\n                <h3>Idées d’usage</h3>\n                <ul class=\"mini\">\n                  <li>Diffusion « air clair » : 3 g Ravintsara + 2 g Citron (10–15 min/heure).</li>\n                  <li>Baume poitrine doux (≤1%) : 2 g/10 mL d’huile végétale, appliquer localement.</li>\n                </ul>\n              </div>\n              <div class=\"card\">\n                <h3>Précautions</h3>\n                <ul class=\"mini\">\n                  <li>Contient 1,8-cinéole : éviter contact yeux. Usage cutané <strong>dilué</strong>.</li>\n                  <li>Chez l’enfant &lt;6 ans, privilégier diffusion douce courte. </li>\n                </ul>\n              </div>\n            </div>\n            <div class=\"cta-row\" style=\"margin-top:.6rem\">\n              <a class=\"btn\" href=\"/products/huile-essentielle-ravintsara-5ml\">Voir le produit</a>\n            </div>\n          </details>\n\n          <!-- GIROFLE -->\n          <details>\n            <summary><strong>Girofle (Syzygium aromaticum, clou) — HE 5 mL</strong></summary>\n            <div class=\"cards\" style=\"margin-top:.4rem\">\n              <div class=\"card\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile-essentielle-girofle-5ml.jpg?v=1744385167\" alt=\"Huile essentielle Girofle\" style=\"width:100%;border-radius:12px;margin-bottom:.6rem\" loading=\"lazy\">\n                <h3>Profil olfactif</h3>\n                <p class=\"mini\">Épicé, chaud, boisé. Très concentré en eugénol.</p>\n              </div>\n              <div class=\"card\">\n                <h3>Idées d’usage</h3>\n                <ul class=\"mini\">\n                  <li>Parfum d’ambiance d’automne : 1 g Girofle + 3 g Orange + 1 g Cannelle (diffusion courte).</li>\n                  <li>Cuisine aromatique (<em>micro-dose</em>) : piquer un clou entier dans un sirop, plutôt que l’HE si novice.</li>\n                </ul>\n              </div>\n              <div class=\"card\">\n                <h3>Précautions</h3>\n                <ul class=\"mini\">\n                  <li>Dermocaustique : ne pas dépasser ~<strong>0,5 %</strong> sur la peau, réaliser un test au pli du coude.</li>\n                  <li>Éviter muqueuses, femmes enceintes/allaitantes, enfants.</li>\n                </ul>\n              </div>\n            </div>\n          </details>\n\n          <!-- EUCALYPTUS CITRONNÉ -->\n          <details>\n            <summary><strong>Eucalyptus citronné (Eucalyptus citriodora) — HE 5 mL</strong></summary>\n            <div class=\"cards\" style=\"margin-top:.4rem\">\n              <div class=\"card\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile-essentielle-eucalyptus-citronne-5ml.jpg?v=1757257266\" alt=\"Huile essentielle Eucalyptus citronné\" style=\"width:100%;border-radius:12px;margin-bottom:.6rem\" loading=\"lazy\">\n                <h3>Profil olfactif</h3>\n                <p class=\"mini\">Citronné, vert, propre (citronellal).</p>\n              </div>\n              <div class=\"card\">\n                <h3>Idées d’usage</h3>\n                <ul class=\"mini\">\n                  <li>Spray textile maison : 10 g HE/L d’eau + 10 mL alcool (agiter, tester sur zone cachée).</li>\n                  <li>Huile de massage local (≤2 %) en mélange avec Ravintsara.</li>\n                </ul>\n              </div>\n              <div class=\"card\">\n                <h3>Précautions</h3>\n                <ul class=\"mini\">\n                  <li>Peaux réactives : commencer à <strong>1 %</strong>. Éviter yeux/muqueuses.</li>\n                </ul>\n              </div>\n            </div>\n          </details>\n\n          <!-- CANNELLE (feuille, Madagascar) -->\n          <details>\n            <summary><strong>Cannelle (Cinnamomum verum — feuille) — HE 5 mL</strong></summary>\n            <div class=\"cards\" style=\"margin-top:.4rem\">\n              <div class=\"card\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile-essentielle-cannelle-5-ml.jpg?v=1744385169\" alt=\"Huile essentielle Cannelle\" style=\"width:100%;border-radius:12px;margin-bottom:.6rem\" loading=\"lazy\">\n                <h3>Profil olfactif</h3>\n                <p class=\"mini\">Épicé, chaud, « biscuit ». La feuille est plus « ronde » que l’écorce mais reste puissante.</p>\n              </div>\n              <div class=\"card\">\n                <h3>Idées d’usage</h3>\n                <ul class=\"mini\">\n                  <li>Diffusion d’ambiance en fêtes : <em>très</em> parcimonieuse, toujours en mélange.</li>\n                  <li>Cuisine aromatique : privilégier la <strong>poudre</strong> ou le bâton si vous débutez.</li>\n                </ul>\n              </div>\n              <div class=\"card\">\n                <h3>Précautions</h3>\n                <ul class=\"mini\">\n                  <li>Dermocaustique : peau ≤<strong>0,5 %</strong>, test cutané obligatoire.</li>\n                  <li>Éviter femmes enceintes/allaitantes, enfants, peaux lésées.</li>\n                </ul>\n              </div>\n            </div>\n          </details>\n\n          <!-- RICIN (huile végétale) -->\n          <details>\n            <summary><strong>Ricin — huile végétale (100 mL) & Ricin infusé Ylang (100 mL)</strong></summary>\n            <div class=\"cards\" style=\"margin-top:.4rem\">\n              <div class=\"card\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0927/2911/4891/files/huile-de-ricin-flacon-100ml.jpg?v=1757257356\" alt=\"Huile de ricin 100mL\" style=\"width:100%;border-radius:12px;margin-bottom:.6rem\" loading=\"lazy\">\n                <h3>Qu’est-ce que c’est ?</h3>\n                <p class=\"mini\">Une <strong>huile naturelle</strong>, non une HE. Émolliente, idéale pour <strong>diluer</strong> les HE et les soins cheveux/cils/sourcils.</p>\n              </div>\n              <div class=\"card\">\n                <h3>Usages clés</h3>\n                <ul class=\"mini\">\n                  <li>Support de <strong>dilution</strong> des HE (voir tableau ci-dessous).</li>\n                  <li>Bain d’huile pointes (pur ou coupé avec coco/joba pour fluidifier).</li>\n                </ul>\n              </div>\n              <div class=\"card\">\n                <h3>Précautions</h3>\n                <ul class=\"mini\">\n                  <li>Usage externe. Éviter le contact oculaire direct.</li>\n                  <li>Conserver fermé, à l’abri de la lumière/ chaleur.</li>\n                </ul>\n              </div>\n            </div>\n            <div class=\"cta-row\" style=\"margin-top:.6rem\">\n              <a class=\"btn\" href=\"/products/huile-de-ricin-100ml\">Voir le ricin</a>\n              <a class=\"btn\" href=\"/products/huile-ricin-ylang-ylang-100ml\">Voir ricin × Ylang</a>\n            </div>\n          </details>\n        </section>\n\n        <!-- 3. UTILISER -->\n        <section id=\"utiliser\" class=\"block reveal anchor\" aria-labelledby=\"utiliser-title\">\n          <h2 id=\"utiliser-title\">Bien utiliser : diffusion & application cutanée</h2>\n          <div class=\"cards\">\n            <div class=\"panel good\">\n              <h3>À faire ✅</h3>\n              <ul>\n                <li>Diffuser <strong>10–15 min/heure</strong> dans une pièce ventilée.</li>\n                <li>Sur la peau : dilution <strong>1–3 %</strong> adulte (peaux sensibles : 0,5–1 %).</li>\n                <li>Test cutané 24 h au pli du coude avant première utilisation.</li>\n                <li>Utiliser une <strong>huile végétale</strong> (ricin, coco, jojoba) comme support.</li>\n              </ul>\n            </div>\n            <div class=\"panel warn\">\n              <h3>À éviter ❌</h3>\n              <ul>\n                <li>Ingestion sans avis d’un professionnel qualifié.</li>\n                <li>Contact avec yeux/muqueuses, application pure (sauf HE très douces et cas spécifiques).</li>\n                <li>Usage chez femme enceinte/allaitante et enfant sans conseil adapté.</li>\n                <li>Exposition solaire immédiate après HE photosensibilisantes (pas le cas des huiles listées ici, mais prudence générale).</li>\n              </ul>\n            </div>\n          </div>\n\n          <!-- HowTo exemples (SEO) -->\n          <div class=\"steps\" itemscope itemtype=\"https://schema.org/HowTo\" style=\"margin-top:12px\">\n            <meta itemprop=\"name\" content=\"Mélange de diffusion relaxant Ylang Ylang\">\n            <article class=\"step\" itemprop=\"step\" itemscope itemtype=\"https://schema.org/HowToStep\">\n              <h3><span class=\"n\">1</span> Préparer</h3>\n              <p class=\"mini\" itemprop=\"text\">Ajouter 2 g Ylang Ylang + 3 g Orange douce dans un diffuseur à eau.</p>\n            </article>\n            <article class=\"step\" itemprop=\"step\" itemscope itemtype=\"https://schema.org/HowToStep\">\n              <h3><span class=\"n\">2</span> Diffuser</h3>\n              <p class=\"mini\" itemprop=\"text\">Lancer 10–15 min. Aérer légèrement la pièce.</p>\n            </article>\n            <article class=\"step\" itemprop=\"step\" itemscope itemtype=\"https://schema.org/HowToStep\">\n              <h3><span class=\"n\">3</span> Pause</h3>\n              <p class=\"mini\" itemprop=\"text\">Faire une pause d’au moins 45 min avant de relancer.</p>\n            </article>\n            <article class=\"step\" itemprop=\"step\" itemscope itemtype=\"https://schema.org/HowToStep\">\n              <h3><span class=\"n\">4</span> Ajuster</h3>\n              <p class=\"mini\" itemprop=\"text\">Adapter le nombre de gouttes à la taille de la pièce.</p>\n            </article>\n          </div>\n        </section>\n\n        <!-- 4. DILUTION -->\n        <section id=\"dilution\" class=\"block reveal anchor\" aria-labelledby=\"dilution-title\">\n          <h2 id=\"dilution-title\">Tableau de dilution — repères rapides</h2>\n          <p class=\"intro\">Repères indicatifs pour un <strong>usage cosmétique externe</strong>. 1 mL ≈ 20 gouttes (bouchon standard).</p>\n          <table aria-label=\"Tableau de dilution des huiles essentielles\">\n            <thead>\n              <tr>\n                <th>Volume d’huile végétale</th>\n                <th>0,5 %</th>\n                <th>1 %</th>\n                <th>2 %</th>\n                <th>3 %</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr>\n                <td>10 mL</td>\n                <td>1 goutte</td><td>2 gouttes</td><td>4 gouttes</td><td>6 gouttes</td>\n              </tr>\n              <tr>\n                <td>30 mL</td>\n                <td>3 g</td><td>6 g</td><td>12 g</td><td>18 g</td>\n              </tr>\n              <tr>\n                <td>50 mL</td>\n                <td>5 g</td><td>10 g</td><td>20 g</td><td>30 g</td>\n              </tr>\n              <tr>\n                <td>100 mL</td>\n                <td>10 g</td><td>20 g</td><td>40 g</td><td>60 g</td>\n              </tr>\n            </tbody>\n          </table>\n          <p class=\"mini\">HE « chaudes » (Girofle, Cannelle) : rester ≤0,5 % sur la peau et privilégier la diffusion brève.</p>\n        </section>\n\n        <!-- 5. CONSERVATION -->\n        <section id=\"conserver\" class=\"block reveal anchor\" aria-labelledby=\"conserver-title\">\n          <h2 id=\"conserver-title\">Conservation & stabilité</h2>\n          <div class=\"cards\">\n            <article class=\"card\">\n              <h3>Flacon ambré & bouchon propre</h3>\n              <p class=\"mini\">Toujours refermer après usage. Essuyer le compte-gouttes. Éviter la lumière directe et la chaleur.</p>\n            </article>\n            <article class=\"card\">\n              <h3>Durée indicatives</h3>\n              <p class=\"mini\">HE : 3–5 ans (selon espèce & stockage). Huiles végétales : 6–18 mois après ouverture (risque d’oxydation).</p>\n            </article>\n            <article class=\"card\">\n              <h3>Stock malin</h3>\n              <p class=\"mini\">Privilégier des <strong>petits volumes</strong> si usage ponctuel. Étiqueter la date d’ouverture.</p>\n            </article>\n          </div>\n        </section>\n\n        <!-- 6. FAQ -->\n        <section id=\"faq\" class=\"block reveal anchor\" aria-labelledby=\"faq-title\">\n          <h2 id=\"faq-title\">FAQ — Huiles essentielles & huiles naturelles</h2>\n          <details>\n            <summary>Peut-on ingérer une huile essentielle ?</summary>\n            <p>Nous ne recommandons pas l’ingestion <strong>sans avis</strong> d’un professionnel de santé formé en aromathérapie.</p>\n          </details>\n          <details>\n            <summary>Quelle différence entre huile essentielle et huile végétale ?</summary>\n            <p>Une <strong>HE</strong> est un extrait aromatique concentré (distillation). Une <strong>huile végétale</strong> (ricin, coco…) est un corps gras qui nourrit la peau et <strong>dilue</strong> les HE.</p>\n          </details>\n          <details>\n            <summary>Les huiles sont-elles adaptées aux enfants ?</summary>\n            <p>Privilégier la <strong>diffusion courte</strong> et éviter l’application cutanée d’HE avant 6 ans sans conseil adapté. Tenir hors de portée.</p>\n          </details>\n          <details>\n            <summary>Vos huiles viennent d’où ?</summary>\n            <p>De <strong>Madagascar</strong>, via des <strong>producteurs familiaux</strong> avec qui nous travaillons en direct pour garantir fraîcheur, qualité et prix justes.</p>\n          </details>\n        </section>\n\n        <!-- CTA -->\n        <section class=\"block reveal anchor\" style=\"text-align:center\">\n          <h2>Découvrir nos huiles de Madagascar</h2>\n          <p class=\"intro\">Sélection courte, traçable, issue de producteurs familiaux. Livraison France & Europe.</p>\n          <div class=\"cta-row\" style=\"justify-content:center\">\n            <a class=\"btn\" href=\"/collections/huiles-essentielles\">Voir la collection</a>\n            <a class=\"btn btn--ghost\" href=\"/pages/wiki\">← Retour au Wiki</a>\n          </div>\n        </section>\n\n        <!-- Disclaimer -->\n        <p class=\"mini\" style=\"opacity:.8;margin-top:10px\">\n          Les informations ci-dessus sont données à titre éducatif pour un usage familial responsable.\n          Elles ne remplacent pas un avis médical. En cas de doute, demandez conseil à un professionnel.\n        </p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Reveal on scroll (léger, vanilla JS) -->\n  <script>\n    document.addEventListener('DOMContentLoaded',function(){\n      var els=document.querySelectorAll('.vdw-oe .reveal');\n      if('IntersectionObserver' in window){\n        var io=new IntersectionObserver(function(entries){\n          entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('on'); io.unobserve(e.target);} });\n        },{threshold:.12});\n        els.forEach(function(el){ io.observe(el); });\n      } else { els.forEach(function(el){ el.classList.add('on'); }); }\n    });\n  </script>\n\n  <!-- JSON-LD : FAQ + HowTo (SEO) -->\n  <script type=\"application/ld+json\">\n  {\n    \"@context\":\"https://schema.org\",\n    \"@type\":\"FAQPage\",\n    \"mainEntity\":[\n      {\"@type\":\"Question\",\"name\":\"Peut-on ingérer une huile essentielle ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nous ne recommandons pas l’ingestion sans avis d’un professionnel de santé formé en aromathérapie.\"}},\n      {\"@type\":\"Question\",\"name\":\"Quelle différence entre huile essentielle et huile végétale ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Une HE est un extrait aromatique concentré. Une huile végétale (ricin, coco…) est un corps gras qui nourrit la peau et dilue les HE.\"}},\n      {\"@type\":\"Question\",\"name\":\"Les huiles essentielles sont-elles adaptées aux enfants ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Privilégier la diffusion courte et éviter l’application cutanée d’HE avant 6 ans sans conseil adapté. Tenir hors de portée.\"}},\n      {\"@type\":\"Question\",\"name\":\"D’où viennent vos huiles ?\",\n       \"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"De Madagascar, via des producteurs familiaux en circuit direct pour une qualité fraîche et traçable.\"}}\n    ]\n  }\n  </script>\n\n  <script type=\"application/ld+json\">\n  {\n    \"@context\":\"https://schema.org\",\n    \"@type\":\"HowTo\",\n    \"name\":\"Mélange de diffusion relaxant Ylang Ylang\",\n    \"totalTime\":\"PT15M\",\n    \"supply\":[\n      {\"@type\":\"HowToSupply\",\"name\":\"2 gouttes d’huile essentielle d’Ylang Ylang\"},\n      {\"@type\":\"HowToSupply\",\"name\":\"3 gouttes d’Orange douce\"},\n      {\"@type\":\"HowToSupply\",\"name\":\"Diffuseur à eau\"}\n    ],\n    \"step\":[\n      {\"@type\":\"HowToStep\",\"name\":\"Préparer\",\"text\":\"Ajouter 2 gouttes d’Ylang Ylang et 3 gouttes d’Orange douce dans le diffuseur.\"},\n      {\"@type\":\"HowToStep\",\"name\":\"Diffuser\",\"text\":\"Lancer 10 à 15 minutes dans une pièce ventilée.\"},\n      {\"@type\":\"HowToStep\",\"name\":\"Pause\",\"text\":\"Faire une pause d’au moins 45 minutes avant une nouvelle diffusion.\"}\n    ]\n  }\n  </script>\n</section>",
