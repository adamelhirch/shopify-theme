            "code": "<!-- =========================\n  VANILLE DÉSIRÉ — WIKI : HUILES ESSENTIELLES & HUILES NATURELLES\n  Page longue, TOC sticky, volets par huile, guides, sécurité, SEO JSON-LD\n  Coller dans /pages/wiki-huiles-essentielles\n========================== -->\n\n<section class=\"vdw-oe\" aria-labelledby=\"vdw-oe-title\">\n  <style>\n    .vdw-oe{\n      /* Palette VD */\n      --ink:#2B1C10; --bg:#FAF5EE; --paper:#F6EFE6; --cream:#F2E9DD;\n      --accent:#D4A373; --olive:#6E7B59; --warn:#C77D47; --ring:rgba(0,0,0,.08);\n      /* Sécurité header/bandeau sticky */\n      --safe-top: clamp(64px, env(safe-area-inset-top) + 72px, 112px);\n      color:var(--ink); background:var(--bg);\n      border-radius:20px; padding:clamp(20px,3vw,44px)\n    }\n    .vdw-oe *{box-sizing:border-box}\n    .vdw-oe a{color:inherit;text-decoration:none}\n    .vdw-oe .wrap{max-width:1200px;margin:0 auto}\n\n    /* Hero */\n    .vdw-oe .kicker{letter-spacing:.12em;text-transform:uppercase;font-size:.78rem;opacity:.8;margin-bottom:.35rem}\n    .vdw-oe h1{font-size:clamp(1.9rem,4.2vw,3rem);line-height:1.08;margin:.1rem 0 .35rem}\n    .vdw-oe .lead{font-size:clamp(1rem,1.2vw,1.125rem);max-width:80ch;opacity:.95;margin:0}\n\n    /* Layout + TOC */\n    .vdw-oe .grid{display:grid;gap:20px}\n    @media(min-width:980px){.vdw-oe .grid.cols-2{grid-template-columns:280px 1fr}}\n    .vdw-oe .toc{position:sticky; top:var(--safe-top); align-self:flex-start;\n      background:#fff;border:1px solid var(--cream);border-radius:16px;padding:14px;box-shadow:0 6px 18px rgba(0,0,0,.04)}\n    .vdw-oe .toc h2{font-size:1rem;margin:.1rem 0 .4rem}\n    .vdw-oe .toc ul{list-style:none;margin:0;padding:0;display:grid;gap:.35rem}\n    .vdw-oe .toc a{display:flex;gap:.5rem;align-items:center;padding:.45rem .6rem;border-radius:10px}\n    .vdw-oe .toc a:hover{background:var(--paper)}\n    .vdw-oe .toc .dot{width:8px;height:8px;border-radius:999px;background:var(--accent);opacity:.8}\n\n    /* Anchors */\n    .v