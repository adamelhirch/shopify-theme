/* Geometria — licensed font for Vanille Désiré.
   Loaded from layout/theme.liquid via the standard
   asset_url | stylesheet_tag pattern. */

@font-face {
  font-family: 'Geometria';
  src: url('{{ 'Geometria-Light.woff2' | asset_url }}') format('woff2');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Geometria';
  src: url('{{ 'Geometria-LightItalic.woff2' | asset_url }}') format('woff2');
  font-weight: 300;
  font-style: italic;
  font-display: swap;
}

