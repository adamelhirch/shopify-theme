# Copier ce fichier vers apps/recipes-service/.env puis adapter si besoin.

VD_RECIPES_PORT=4567
VD_RECIPES_ADMIN_TOKEN=change-me
VD_RECIPES_STORE=json

# Publication Shopify
VD_RECIPES_SHOPIFY_STORE=4bru0c-p4.myshopify.com
VD_RECIPES_SHOPIFY_ADMIN_TOKEN=shpat_xxx
VD_RECIPES_SHOPIFY_API_VERSION=2025-10

# Resolution auto de la preview QA la plus recente
VD_RECIPES_PREVIEW_THEME_PREFIX=QA Shared v
VD_RECIPES_PREVIEW_EXCLUDE=QA Shared v1
VD_RECIPES_PREVIEW_ROLES=unpublished,development
VD_RECIPES_PREVIEW_SYNC_ARGS=--nodelete
